@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 68 - Credit Overload Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int currentClientId ? currentClientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

<style>
    .R68-results-wrap { display:grid; gap:24px; }
    .R68-table-wrap { overflow-x:auto; border:1px solid var(--rule15-table-border); border-radius:14px; background:var(--rule15-card-alt); }
    .R68-grid { width:100%; min-width:700px; border-collapse:collapse; table-layout:fixed; }
    .R68-grid th, .R68-grid td { border:1px solid var(--rule15-table-border); padding:8px 10px; text-align:left; white-space:normal; word-break:normal; overflow-wrap:anywhere; vertical-align:top; font-family:Consolas,"Courier New",monospace; font-size:12px; color:var(--text); }
    .R68-grid .group-key   { background:var(--rule15-group-bridge); }
    .R68-grid .group-cred  { background:var(--rule15-group-stud); }
    .R68-grid .group-final { background:var(--rule15-group-final); }
    .R68-grid .is-pass { color:var(--rule15-pass); font-weight:800; }
    .R68-grid .is-fail { color:var(--rule15-fail); font-weight:800; }
    .R68-summary-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); }
    .R68-cat-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:4px; }
    .R68-cat-tab { padding:7px 14px; border-radius:20px; border:2px solid var(--border,#ddd); background:var(--card-bg,#fff); color:var(--text,#333); font-size:12px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; transition:background .15s,border-color .15s; }
    .R68-cat-tab:hover { border-color:var(--primary,#1a237e); color:var(--primary,#1a237e); }
    .R68-cat-tab.active { background:var(--primary,#1a237e); border-color:var(--primary,#1a237e); color:#fff; }
    .R68-cat-tab[data-cat="PASS"].active    { background:#1b5e20; border-color:#1b5e20; }
    .R68-cat-tab[data-cat="FAIL"].active    { background:#b71c1c; border-color:#b71c1c; }
    .R68-cat-tab[data-cat="CONFIRMED"].active   { background:#2e7d32; border-color:#2e7d32; }
    .R68-cat-tab[data-cat="NOT_CONFIRMED"].active { background:#f57f17; border-color:#f57f17; }
    .R68-cat-tab[data-cat="RULE32_ONLY"].active   { background:#880e4f; border-color:#880e4f; }
    .R68-cat-count { background:rgba(255,255,255,.25); border-radius:10px; padding:1px 7px; font-size:11px; font-weight:700; }
    .R68-cat-tab:not(.active) .R68-cat-count { background:var(--border,#e5e7eb); color:var(--text-muted,#666); }
    .R68-recon { display:inline-block; border-radius:10px; padding:2px 8px; font-size:11px; font-weight:700; white-space:nowrap; }
    .R68-recon--confirmed    { background:#e8f5e9; color:#2e7d32; border:1px solid #a5d6a7; }
    .R68-recon--notconfirmed { background:#fff8e1; color:#e65100; border:1px solid #ffcc80; }
    .R68-recon--only         { background:#fce4ec; color:#880e4f; border:1px solid #f48fb1; }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>Rule 68 checks that the sum of <code>CRED._036</code> (credits) per student-qualification pair stays within a configurable threshold. Exception code <strong>03603</strong> applies when the total exceeds the configured value.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R68</div>
        <div>
            <h1 class="rule-header__title">HEMIS Rule 68: Credit Overload Validation</h1>
            <p class="rule-header__sub">Groups each student-qualification pair from <code>CREG</code> and sums <code>CRED._036</code> (credits) across all registered courses. If the total exceeds the configured threshold, the pair fails with exception code <strong>03603</strong>. Confirms findings against <code>dbo_STUD_VALIDATION_DETAIL</code> using the Rule 32 reconciliation pattern.</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                    <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-connection">
                    <div class="form-grid">
                        <div class="field-group"><label for="server">Server Name</label><input id="server" type="text" placeholder="e.g. MYSERVER\INSTANCE" /></div>
                        <div class="field-group">
                            <label for="driver">Driver</label>
                            <select id="driver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group"><label for="database">Database</label><select id="database"></select></div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    </div>
                    <div id="connectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                    <span class="acc-icon">CF</span><span>Rule Configuration</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-config" style="display:none">
                    <div class="info-box info-box--red">
                        <strong>Rule 68 Logic:</strong><br />
                        From <strong>CREG</strong>, join <strong>QUAL</strong> (for qualification name), <strong>CRED</strong> (for credit values), and <strong>CRSE</strong> (for course names).<br />
                        Group by (Student Number + Qualification Code) and compute <code>SUM(CRED._036)</code>.<br />
                        <strong>PASS</strong> when total credits &le; the configured value. &nbsp; <strong>FAIL (03603)</strong> when total credits &gt; the configured value.
                    </div>
                    <div class="form-grid" style="margin-top:14px">
                        <div class="field-group"><label for="cregTable">CREG Table (registrations)</label><select id="cregTable"></select></div>
                        <div class="field-group"><label for="studTable">STUD Table <small>(optional — used for counts)</small></label><select id="studTable"></select></div>
                        <div class="field-group"><label for="qualTable">QUAL Table (qualification names)</label><select id="qualTable"></select></div>
                        <div class="field-group"><label for="credTable">CRED Table (credit values)</label><select id="credTable"></select></div>
                        <div class="field-group"><label for="crseTable">CRSE Table (course names)</label><select id="crseTable"></select></div>
                    </div>
                    <div class="form-grid" style="margin-top:14px">
                        <div class="field-group"><label>CREG Student No Column <small>(_007)</small></label><select id="cregStudNoCol"><option value="_007">_007</option></select></div>
                        <div class="field-group"><label>CREG Qualification Column <small>(_001)</small></label><select id="cregQualCol"><option value="_001">_001</option></select></div>
                        <div class="field-group"><label>CREG Course Code Column <small>(_030)</small></label><select id="cregCourseCol"><option value="_030">_030</option></select></div>
                        <div class="field-group"><label>QUAL Qualification Column <small>(_001)</small></label><select id="qualQualCol"><option value="_001">_001</option></select></div>
                        <div class="field-group"><label>QUAL Name Column <small>(_003)</small></label><select id="qualNameCol"><option value="_003">_003</option></select></div>
                        <div class="field-group"><label>CRED Qualification Column <small>(_001)</small></label><select id="credQualCol"><option value="_001">_001</option></select></div>
                        <div class="field-group"><label>CRED Course Column <small>(_030)</small></label><select id="credCourseCol"><option value="_030">_030</option></select></div>
                        <div class="field-group"><label>CRED Credits Column <small>(_036)</small></label><select id="credCreditsCol"><option value="_036">_036</option></select></div>
                        <div class="field-group"><label for="maxTotalCredits">Maximum Total Credits <small>e.g. 1.0, 1.5, 2.15</small></label><input id="maxTotalCredits" type="number" step="0.01" min="0" value="1.0" /></div>
                        <div class="field-group"><label>CRSE Course Column <small>(_030)</small></label><select id="crseCourseCol"><option value="_030">_030</option></select></div>
                        <div class="field-group"><label>CRSE Name Column <small>(_058)</small></label><select id="crseNameCol"><option value="_058">_058</option></select></div>
                    </div>
                    <div class="form-grid" style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border,#ddd)">
                        <div class="field-group"><label for="detailTable">Validation Detail Table <small>(for Rule 32 reconciliation)</small></label><select id="detailTable"><option value="">(none — skip reconciliation)</option></select></div>
                        <div class="field-group"><label for="detailErrorTypeCol">Error Type Column <small>(optional filter column)</small></label><select id="detailErrorTypeCol"><option value="">(none)</option></select></div>
                        <div class="field-group"><label for="detailErrorTypeValue">Error Type Filter Value <small>(e.g. Fatal)</small></label><input id="detailErrorTypeValue" type="text" value="Fatal" /></div>
                        <div class="field-group"><label for="detailErrorCol">Error Code Column</label><select id="detailErrorCol"><option value="Error">Error</option></select></div>
                        <div class="field-group"><label for="detailExclusionCodes">Exclusion Codes <small>(comma separated, e.g. 02202,02301,02302,00708,07201,01501)</small></label><input id="detailExclusionCodes" type="text" value="02202,02301,02302,00708,07201,01501" /></div>
                        <div class="field-group"><label for="detailElementInfoCol">Element Info Column <small>(holds E007:/E001:/Sum E036: text)</small></label><select id="detailElementInfoCol"><option value="Element_Information">Element_Information</option></select></div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:10px 0 0">
                        <button type="button" class="btn btn-secondary" onclick="autoDetectColumns()">Auto-Detect Columns</button>
                    </div>
                    <div id="configOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                    <span class="acc-icon">DL</span><span>Export Options</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-downloads" style="display:none">
                    <div class="checkbox-row">
                        <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The latest Rule 68 connection, results, and signoffs reload automatically for this engagement.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 68 workspace.</div>
        <div class="workspace-signoff-grid">
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div><div id="workspaceRunLabel">No saved run yet</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div id="workspaceStatusLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div><div id="workspaceEditedLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div><div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div></div>
            <div class="field-group" style="grid-column:1 / -1"><label for="workspaceSignoffComment">Signoff Comment</label><textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea></div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
                <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            }
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove Signoff</button>
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="runBtn">Run Rule 68</button>
            <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
            <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="analysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="resultsPane"></div>
        <div class="tab-pane" data-tab-panel="sql"><textarea id="sqlText" rows="18" readonly></textarea></div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">Excel includes Summary, PASS, FAIL, and Rule 32 reconciliation sheets. SQL shows the full credit aggregation query.</div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn">Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn">CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn">SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box"><div class="spinner-ring"></div><p id="spinnerMsg">Processing...</p></div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = function (section) {
    const body = document.getElementById(`body-${section}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

(() => {
    const apiBase = '/Rule68';
    const currentSystemRole = '@currentSystemRole';
    const isResultsOnlyRole = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';

    const state = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        currentRunId: null, summary: null, sql: '',
        resultsVisible: false, hasPendingValidation: false,
        currentUserEngagementRole: '', currentUserHasSignedOff: false,
        isWorkspaceSaved: false, hasDataAnalystSignoff: false,
        currentStatus: '', categoryTab: 'ALL'
    };

    const els = {
        clientId:             document.getElementById('clientId'),
        server:               document.getElementById('server'),
        driver:               document.getElementById('driver'),
        database:             document.getElementById('database'),
        cregTable:            document.getElementById('cregTable'),
        studTable:            document.getElementById('studTable'),
        qualTable:            document.getElementById('qualTable'),
        credTable:            document.getElementById('credTable'),
        crseTable:            document.getElementById('crseTable'),
        cregStudNoCol:        document.getElementById('cregStudNoCol'),
        cregQualCol:          document.getElementById('cregQualCol'),
        cregCourseCol:        document.getElementById('cregCourseCol'),
        qualQualCol:          document.getElementById('qualQualCol'),
        qualNameCol:          document.getElementById('qualNameCol'),
        credQualCol:          document.getElementById('credQualCol'),
        credCourseCol:        document.getElementById('credCourseCol'),
        credCreditsCol:       document.getElementById('credCreditsCol'),
        maxTotalCredits:      document.getElementById('maxTotalCredits'),
        crseCourseCol:        document.getElementById('crseCourseCol'),
        crseNameCol:          document.getElementById('crseNameCol'),
        detailTable:          document.getElementById('detailTable'),
        detailErrorTypeCol:   document.getElementById('detailErrorTypeCol'),
        detailErrorTypeValue: document.getElementById('detailErrorTypeValue'),
        detailErrorCol:       document.getElementById('detailErrorCol'),
        detailExclusionCodes: document.getElementById('detailExclusionCodes'),
        detailElementInfoCol: document.getElementById('detailElementInfoCol'),
        connectionOutput: document.getElementById('connectionOutput'),
        configOutput:     document.getElementById('configOutput'),
        analysisPane:     document.getElementById('analysisPane'),
        resultsPane:      document.getElementById('resultsPane'),
        sqlText:          document.getElementById('sqlText'),
        downloadAllBtn:   document.getElementById('downloadAllBtn'),
        workspaceInfo:         document.getElementById('workspaceInfo'),
        workspaceRunState:     document.getElementById('workspaceRunState'),
        workspaceRunLabel:     document.getElementById('workspaceRunLabel'),
        workspaceStatusLabel:  document.getElementById('workspaceStatusLabel'),
        workspaceEditedLabel:  document.getElementById('workspaceEditedLabel'),
        workspaceRoleLabel:    document.getElementById('workspaceRoleLabel'),
        workspaceSignoffComment: document.getElementById('workspaceSignoffComment'),
        beginEditBtn:    document.getElementById('beginEditBtn'),
        saveWorkspaceBtn:document.getElementById('saveWorkspaceBtn'),
        signoffBtn:      document.getElementById('signoffBtn'),
        removeSignoffBtn:document.getElementById('removeSignoffBtn'),
        statusBadge:     document.getElementById('statusBadge')
    };

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    tabButtons.forEach(btn => btn.addEventListener('click', () => setActiveTab(btn.dataset.tab)));

    function showSpinner(msg) { document.getElementById('spinnerMsg').textContent = msg || 'Processing...'; document.getElementById('spinner').style.display = 'flex'; }
    function hideSpinner() { document.getElementById('spinner').style.display = 'none'; }
    function escapeHtml(v) { return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#39;'); }
    function formatNumber(v) { return Number(v || 0).toLocaleString('en-US'); }
    function normalizeRole(v) { return String(v || '').replace(/[^a-z0-9]+/gi,'').toLowerCase(); }
    function normalizeThreshold(v) {
        const raw = String(v ?? '').trim();
        if (!raw) return 1.0;
        const parsed = Number.parseFloat(raw);
        return Number.isFinite(parsed) && parsed >= 0 ? parsed : 1.0;
    }
    function setAlert(target, type, message) { if (target) target.innerHTML = `<div class="alert alert--${type}">${message}</div>`; }
    function setWorkspaceState(message, type) { els.workspaceInfo.className = `alert alert--${type}`; els.workspaceInfo.textContent = message || ''; }
    function setStatusBadge(text, type) {
        if (!text) { els.statusBadge.style.display='none'; return; }
        els.statusBadge.style.display='inline-block';
        els.statusBadge.className=`rule-header__badge ${type==='fail'?'badge--fail':'badge--pass'}`;
        els.statusBadge.textContent=text;
    }
    function setActiveTab(tab) {
        tabButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.toggle('active', pane.dataset.tabPanel === tab));
        if (tab === 'results') setTimeout(() => renderResults(true), 0);
    }
    function getActiveTab() { return document.querySelector('.tab-btn.active')?.dataset.tab || 'analysis'; }

    async function postJson(url, data) {
        return await window.fetchJsonWithProgress(url, { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(data) });
    }
    async function downloadBlob(url, payload, defaultName) {
        await window.downloadFileWithProgress({ url, method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(payload), defaultFileName:defaultName, label:'Downloading' });
    }

    function populateSelect(sel, values, selected) {
        if (!sel) return;
        sel.innerHTML = '<option value="">Select table</option>';
        values.forEach(v => { const o = document.createElement('option'); o.value = o.textContent = v; sel.appendChild(o); });
        if (selected) { if (![...sel.options].some(o => o.value === selected)) { const o = document.createElement('option'); o.value = o.textContent = selected; sel.appendChild(o); } sel.value = selected; }
    }
    function fillColSel(selEl, cols, preferred) {
        if (!selEl) return;
        const cur = selEl.value; selEl.innerHTML = '';
        (cols || []).forEach(c => { const o = document.createElement('option'); o.value = o.textContent = c; if (c === (preferred || cur)) o.selected = true; selEl.appendChild(o); });
        if (!selEl.value && cols.length) selEl.value = cols[0];
    }
    function setColSel(selEl, value) {
        if (!selEl || !value) return;
        if (![...selEl.options].some(o => o.value === value)) { const o = document.createElement('option'); o.value = o.textContent = value; selEl.appendChild(o); }
        selEl.value = value;
    }

    function getRequest() {
        return {
            clientId:             parseInt(els.clientId.value||'0',10)||0,
            runId:                state.currentRunId,
            server:               els.server?.value.trim()||'',
            database:             els.database?.value||'',
            driver:               els.driver?.value||'ODBC Driver 17 for SQL Server',
            cregTable:            els.cregTable?.value||'',
            studTable:            els.studTable?.value||'dbo_STUD',
            qualTable:            els.qualTable?.value||'dbo_QUAL',
            credTable:            els.credTable?.value||'dbo_CRED',
            crseTable:            els.crseTable?.value||'dbo_CRSE',
            detailTable:          els.detailTable?.value||'',
            cregStudNoCol:        els.cregStudNoCol?.value||'_007',
            cregQualCol:          els.cregQualCol?.value||'_001',
            cregCourseCol:        els.cregCourseCol?.value||'_030',
            qualQualCol:          els.qualQualCol?.value||'_001',
            qualNameCol:          els.qualNameCol?.value||'_003',
            credQualCol:          els.credQualCol?.value||'_001',
            credCourseCol:        els.credCourseCol?.value||'_030',
            credCreditsCol:       els.credCreditsCol?.value||'_036',
            maxTotalCredits:      normalizeThreshold(els.maxTotalCredits?.value),
            crseCourseCol:        els.crseCourseCol?.value||'_030',
            crseNameCol:          els.crseNameCol?.value||'_058',
            detailErrorTypeCol:   els.detailErrorTypeCol?.value||'',
            detailErrorTypeValue: els.detailErrorTypeValue?.value?.trim()||'Fatal',
            detailErrorCol:       els.detailErrorCol?.value||'Error',
            detailExclusionCodes: els.detailExclusionCodes?.value?.trim()||'02202,02301,02302,00708,07201,01501',
            detailElementInfoCol: els.detailElementInfoCol?.value||'Element_Information'
        };
    }

    function getVerifyRequest() {
        return { server:els.server?.value.trim()||'', database:els.database?.value||'', driver:els.driver?.value||'ODBC Driver 17 for SQL Server',
            studTable:els.studTable?.value||'', cregTable:els.cregTable?.value||'',
            qualTable:els.qualTable?.value||'', credTable:els.credTable?.value||'', crseTable:els.crseTable?.value||'',
            detailTable:els.detailTable?.value||'' };
    }

    async function loadCols(role, tableName) {
        const server = els.server?.value?.trim(); const db = els.database?.value;
        if (!server || !db || !tableName) return;
        const endpoints = { creg:'GetCregColumns', stud:'GetStudColumns', qual:'GetQualColumns', cred:'GetCredColumns', crse:'GetCrseColumns', detail:'GetDetailColumns' };
        const endpoint = endpoints[role] || 'GetCregColumns';
        const vr = getVerifyRequest(); vr.cregTable=tableName; vr.studTable=tableName; vr.qualTable=tableName; vr.credTable=tableName; vr.crseTable=tableName; vr.detailTable=tableName;
        try {
            const data = await postJson(`${apiBase}/${endpoint}`, vr);
            if (!data.success || !data.columns) return;
            const cols = data.columns || [];
            if (role === 'creg') { fillColSel(els.cregStudNoCol, cols, '_007'); fillColSel(els.cregQualCol, cols, '_001'); fillColSel(els.cregCourseCol, cols, '_030'); }
            else if (role === 'qual') { fillColSel(els.qualQualCol, cols, '_001'); fillColSel(els.qualNameCol, cols, '_003'); }
            else if (role === 'cred') { fillColSel(els.credQualCol, cols, '_001'); fillColSel(els.credCourseCol, cols, '_030'); fillColSel(els.credCreditsCol, cols, '_036'); }
            else if (role === 'crse') { fillColSel(els.crseCourseCol, cols, '_030'); fillColSel(els.crseNameCol, cols, '_058'); }
            else if (role === 'detail') {
                fillColSel(els.detailErrorTypeCol, ['', ...cols], cols.find(c=>/type/i.test(c))||'');
                fillColSel(els.detailErrorCol,     cols, cols.find(c=>/^error$/i.test(c))||cols.find(c=>/error/i.test(c))||'Error');
                fillColSel(els.detailElementInfoCol, cols, cols.find(c=>/element/i.test(c))||'Element_Information');
            }
            setAlert(els.configOutput, 'success', `Columns loaded for ${tableName}.`);
        } catch { /* silent */ }
    }

    window.autoDetectColumns = async function() {
        await Promise.all([
            loadCols('creg',   els.cregTable?.value),
            loadCols('qual',   els.qualTable?.value),
            loadCols('cred',   els.credTable?.value),
            loadCols('crse',   els.crseTable?.value),
            loadCols('detail', els.detailTable?.value)
        ]);
    };

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role); const normalizedSystemRole = normalizeRole(currentSystemRole);
        const hasUnsaved = !!state.summary && (!!state.hasPendingValidation || (!state.currentRunId && !state.isWorkspaceSaved));
        const canEdit = !isResultsOnlyRole && (normalizedSystemRole==='dataanalyst'||normalizedRole==='dataanalyst'||hasUnsaved);
        const canSign = !state.hasPendingValidation && !!state.currentRunId && !!state.isWorkspaceSaved &&
            (normalizedRole==='dataanalyst' || (state.resultsVisible && (normalizedRole==='manager'||normalizedRole==='director')));
        const signoffLocked = !!state.currentUserHasSignedOff;
        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.applyStates([
            {target:'connectBtn',disabled:!canEdit||signoffLocked},{target:'verifyBtn',disabled:!canEdit||signoffLocked},
            {target:'runBtn',disabled:!canEdit||signoffLocked},{target:'sqlBtn',disabled:!canEdit||signoffLocked},
            {target:els.beginEditBtn,disabled:signoffLocked||!canEdit||!state.currentRunId||state.hasPendingValidation},
            {target:els.saveWorkspaceBtn,disabled:signoffLocked||!canEdit||!hasUnsaved},
            {target:els.signoffBtn,disabled:signoffLocked||!canSign,text:state.currentUserHasSignedOff?`Signed Off as ${role||currentSystemRole}`:'Save Signoff'},
            {target:els.removeSignoffBtn,show:state.currentUserHasSignedOff,display:'',disabled:!state.currentUserHasSignedOff},
            {target:els.workspaceSignoffComment,disabled:signoffLocked||!canSign},
            {target:els.downloadAllBtn,disabled:!state.summary}
        ]);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions','.action-bar'],signoffLocked,{allow:['#downloadAllBtn','#downloadExcelBtn','#downloadCsvBtn','#downloadSqlBtn','#removeSignoffBtn']});
        applyWorkspaceAccessMode(canEdit);
    }

    function applyWorkspaceAccessMode(canEditWorkspace) {
        ['body-connection', 'body-config'].forEach(function(id) {
            var body = document.getElementById(id);
            if (!body) return;
            body.style.opacity = canEditWorkspace ? '' : '0.45';
            body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
            body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
                el.disabled = !canEditWorkspace;
            });
        });
    }

    function applySummary(summary, options = {}) {
        state.summary = summary;
        if (!options.fromWorkspace) state.currentRunId = summary?.savedRunId||state.currentRunId;
        state.currentStatus = summary?.status||state.currentStatus;
        state.resultsVisible = !!summary||state.resultsVisible;
        if (!summary) { els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 68 results loaded.</p></div>'; els.resultsPane.innerHTML='<div class="empty-card"><p>No Rule 68 results loaded.</p></div>'; setStatusBadge('','pass'); updateWorkspaceButtons(); return; }
        if (state.hasPendingValidation) { els.workspaceRunState.textContent=`Pending save | ${summary.status||'Completed'}`; els.workspaceRunLabel.textContent='Unsaved Rule 68 validation'; els.workspaceStatusLabel.textContent='Pending Save'; }
        else { els.workspaceRunState.textContent=state.currentRunId?`Run #${state.currentRunId} | ${state.currentStatus||'Completed'}`:'No saved run loaded'; els.workspaceRunLabel.textContent=state.currentRunId?`Run #${state.currentRunId}`:'No saved run yet'; els.workspaceStatusLabel.textContent=state.currentStatus||'-'; }
        setStatusBadge(summary.status, summary.failCount>0?'fail':'pass');
        renderAnalysis(summary); renderResults(); updateWorkspaceButtons();
    }

    function applyWorkspace(workspace, resultsVisible, preserveExistingSummary = false) {
        if (!workspace) {
            state.currentRunId=null;state.currentStatus='';state.currentUserEngagementRole='';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=false;state.hasPendingValidation=false;
            els.workspaceRunState.textContent='No saved run loaded';els.workspaceRunLabel.textContent='No saved run yet';els.workspaceStatusLabel.textContent='-';els.workspaceEditedLabel.textContent='-';
            setWorkspaceState('No saved Rule 68 workspace exists for this engagement yet.','info');
            if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
            return;
        }
        state.clientId=workspace.clientId||state.clientId;state.currentRunId=workspace.runId||null;state.currentStatus=workspace.currentStatus||'';
        state.currentUserEngagementRole=workspace.currentUserEngagementRole||currentSystemRole||'';state.currentUserHasSignedOff=!!workspace.currentUserHasSignedOff;
        state.isWorkspaceSaved=!!workspace.isWorkspaceSaved;state.hasDataAnalystSignoff=!!workspace.hasDataAnalystSignoff;state.resultsVisible=!!resultsVisible;state.hasPendingValidation=false;
        if (els.server) els.server.value=workspace.server||'';
        if (els.driver) els.driver.value=workspace.driver||'ODBC Driver 17 for SQL Server';
        populateSelect(els.database, workspace.database?[workspace.database]:[], workspace.database);
        populateSelect(els.cregTable, workspace.cregTable?[workspace.cregTable]:[], workspace.cregTable||'');
        populateSelect(els.studTable, workspace.studTable?[workspace.studTable]:[], workspace.studTable||'dbo_STUD');
        populateSelect(els.qualTable, workspace.qualTable?[workspace.qualTable]:[], workspace.qualTable||'dbo_QUAL');
        populateSelect(els.credTable, workspace.credTable?[workspace.credTable]:[], workspace.credTable||'dbo_CRED');
        populateSelect(els.crseTable, workspace.crseTable?[workspace.crseTable]:[], workspace.crseTable||'dbo_CRSE');
        if (els.detailTable) {
            const savedDt = workspace.detailTable||'';
            els.detailTable.innerHTML = '<option value="">(none — skip reconciliation)</option>';
            if (savedDt) { const o=document.createElement('option'); o.value=o.textContent=savedDt; els.detailTable.appendChild(o); els.detailTable.value=savedDt; }
        }
        if (workspace.cregStudNoCol)  setColSel(els.cregStudNoCol,  workspace.cregStudNoCol);
        if (workspace.cregQualCol)    setColSel(els.cregQualCol,    workspace.cregQualCol);
        if (workspace.cregCourseCol)  setColSel(els.cregCourseCol,  workspace.cregCourseCol);
        if (workspace.qualQualCol)    setColSel(els.qualQualCol,    workspace.qualQualCol);
        if (workspace.qualNameCol)    setColSel(els.qualNameCol,    workspace.qualNameCol);
        if (workspace.credQualCol)    setColSel(els.credQualCol,    workspace.credQualCol);
        if (workspace.credCourseCol)  setColSel(els.credCourseCol,  workspace.credCourseCol);
        if (workspace.credCreditsCol) setColSel(els.credCreditsCol, workspace.credCreditsCol);
        if (els.maxTotalCredits) els.maxTotalCredits.value = workspace.maxTotalCredits != null ? String(workspace.maxTotalCredits) : '1.0';
        if (workspace.crseCourseCol)  setColSel(els.crseCourseCol,  workspace.crseCourseCol);
        if (workspace.crseNameCol)    setColSel(els.crseNameCol,    workspace.crseNameCol);
        if (workspace.detailErrorTypeCol)   setColSel(els.detailErrorTypeCol,   workspace.detailErrorTypeCol);
        if (els.detailErrorTypeValue) els.detailErrorTypeValue.value = workspace.detailErrorTypeValue || 'Fatal';
        if (workspace.detailErrorCol)       setColSel(els.detailErrorCol,       workspace.detailErrorCol);
        if (els.detailExclusionCodes) els.detailExclusionCodes.value = workspace.detailExclusionCodes || '02202,02301,02302,00708,07201,01501';
        if (workspace.detailElementInfoCol) setColSel(els.detailElementInfoCol, workspace.detailElementInfoCol);
        els.workspaceRunState.textContent=workspace.runId?`Run #${workspace.runId}`:'No saved run loaded';
        els.workspaceRunLabel.textContent=workspace.runId?`Rule 68 Run #${workspace.runId}`:'No saved run yet';
        els.workspaceStatusLabel.textContent=workspace.currentStatus||'-';
        els.workspaceEditedLabel.textContent=workspace.lastEditedAt?new Date(workspace.lastEditedAt).toLocaleString():'-';
        els.workspaceRoleLabel.textContent=workspace.currentUserEngagementRole||currentSystemRole||'-';
        els.workspaceSignoffComment.value=workspace.currentUserSignoffComment||'';
        if (!resultsVisible) { setWorkspaceState('Saved Rule 68 results are not available for your engagement role.','info'); if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons(); return; }
        setWorkspaceState(workspace.summary?'Saved workspace loaded.':'Rule 68 workspace loaded. Run validation to generate results.','success');
        if (workspace.summary) applySummary(workspace.summary,{fromWorkspace:true}); else if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
    }

    async function loadWorkspace() {
        state.clientId=Number(els.clientId?.value||0);
        if (!state.clientId) { applyWorkspace(null,false); return; }
        const data = await window.fetchJsonWithProgress(`${apiBase}/GetWorkspaceState?clientId=${state.clientId}`,{method:'GET'});
        if (!data.success) throw new Error(data.error||'Failed to load workspace.');
        applyWorkspace(data.workspace, data.resultsVisible);
    }

    async function connect() {
        const server = els.server?.value?.trim();
        if (!server) throw new Error('Enter the SQL Server name first.');
        showSpinner('Loading databases...');
        try {
            const data = await postJson(`${apiBase}/GetDatabases`, {server, driver:els.driver.value});
            if (!data.success) throw new Error(data.error||'Connection failed.');
            els.database.innerHTML='<option value="">Select database</option>';
            (data.databases||[]).forEach(db => { const o=document.createElement('option');o.value=o.textContent=db;els.database.appendChild(o); });
            if (data.databases.length === 1) els.database.value = data.databases[0];
            setAlert(els.connectionOutput,'success',`Connected. Found ${data.databases.length} database(s).`);
            if (els.database.value) await loadTables();
        } finally { hideSpinner(); }
    }

    async function loadTables() {
        if (!els.database.value) return;
        const data = await postJson(`${apiBase}/GetTables`, {server:els.server.value.trim(), database:els.database.value, driver:els.driver.value});
        if (!data.success) throw new Error(data.error||'Could not load tables.');
        const tables = data.tables||[];
        populateSelect(els.cregTable,  tables, data.autoCregTable);
        populateSelect(els.studTable,  tables, data.autoStudTable);
        populateSelect(els.qualTable,  tables, data.autoQualTable);
        populateSelect(els.credTable,  tables, data.autoCredTable);
        populateSelect(els.crseTable,  tables, data.autoCrseTable);
        if (els.detailTable) {
            const autoDetail = data.autoDetailTable || '';
            els.detailTable.innerHTML = '<option value="">(none — skip reconciliation)</option>';
            tables.forEach(v => { const o=document.createElement('option'); o.value=o.textContent=v; els.detailTable.appendChild(o); });
            if (autoDetail) els.detailTable.value = autoDetail;
        }
        setAlert(els.configOutput,'success',`Loaded ${tables.length} table(s). Auto-detecting columns...`);
        await window.autoDetectColumns();
    }

    async function verifyTables() {
        showSpinner('Verifying Rule 68 tables...');
        try {
            const data = await postJson(`${apiBase}/VerifyTables`, getVerifyRequest());
            if (!data.success) throw new Error(data.error||'Verification failed.');
            els.configOutput.innerHTML=`<div class="alert alert--success">CREG: <strong>${formatNumber(data.cregRecordCount)}</strong> | STUD: <strong>${formatNumber(data.studRecordCount)}</strong> | QUAL: <strong>${formatNumber(data.qualRecordCount)}</strong> | CRED: <strong>${formatNumber(data.credRecordCount)}</strong> | CRSE: <strong>${formatNumber(data.crseRecordCount)}</strong></div>`;
        } finally { hideSpinner(); }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) { setWorkspaceState('Select the approved engagement assigned to you before running this rule.','warning'); return; }
        if (!request.cregTable) { setAlert(els.configOutput,'warning','Select the CREG table in Rule Configuration before running.'); return; }
        try {
            showSpinner('Running Rule 68: aggregating CRED._036 per student-qualification pair...');
            const data = await postJson(`${apiBase}/RunValidation`, request);
            if (!data.success) throw new Error(data.error||'Rule 68 failed.');
            state.hasPendingValidation=true;state.currentRunId=null;state.currentStatus=data.status||'';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=true;state.currentUserEngagementRole=state.currentUserEngagementRole||currentSystemRole||'DataAnalyst';
            applySummary(data);
            setWorkspaceState(`Rule 68 completed. Pairs checked: ${formatNumber(data.totalValidated)} | PASS: ${formatNumber(data.passCount)} | FAIL (03603): ${formatNumber(data.failCount)}. Click Save Workspace before signoff.`,'success');
        } finally { hideSpinner(); }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try { const data=await postJson(`${apiBase}/GenerateSql`,getRequest()); if(!data.success) throw new Error(data.error||'SQL generation failed.'); state.sql=data.sql||''; els.sqlText.value=state.sql; setActiveTab('sql'); } finally { hideSpinner(); }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try { const data=await postJson(`${apiBase}/BeginWorkspaceEdit`,getRequest()); if(!data.success) throw new Error(data.error||'Could not begin editing.'); applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace ready for editing.','warning'); } finally { hideSpinner(); }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try { const data=await postJson(`${apiBase}/SaveWorkspace`,getRequest()); if(!data.success) throw new Error(data.error||'Could not save workspace.'); state.hasPendingValidation=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace saved.',data.signoffsCleared?'warning':'success'); } finally { hideSpinner(); }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try { const data=await postJson(`${apiBase}/SignOffWorkspace`,{clientId:state.clientId,runId:state.currentRunId,comment:els.workspaceSignoffComment.value.trim()}); if(!data.success) throw new Error(data.error||'Signoff failed.'); state.currentUserHasSignedOff=true; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Signoff saved.','success'); } finally { hideSpinner(); }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try { const prevRunId=state.currentRunId; const data=await postJson(`${apiBase}/RemoveWorkspaceSignoff`,{clientId:state.clientId,runId:state.currentRunId,comment:''}); if(!data.success) throw new Error(data.error||'Could not remove signoff.'); state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,!!(data.workspace&&prevRunId&&data.workspace.runId===prevRunId)); setWorkspaceState(data.message||'Signoff removed.','warning'); } finally { hideSpinner(); }
    }

    function renderAnalysis(summary) {
        if (!summary) { els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 68 results loaded.</p></div>'; return; }
        const creditsCol = summary.credCreditsCol||'_036';
        const thresholdValue = Number(summary.maxTotalCredits ?? 1.0);
        const thresholdLabel = Number.isFinite(thresholdValue) ? thresholdValue.toLocaleString('en-US', { maximumFractionDigits: 2 }) : '1.0';
        const hasDetail  = !!(summary.detailTable);
        const allRows    = summary.reviewRows||[];
        const failRows   = allRows.filter(r=>String(r.validationResult||'').toUpperCase()==='FAIL');
        const passRows   = allRows.filter(r=>String(r.validationResult||'').toUpperCase()==='PASS');
        const rule32Only = summary.rule32OnlyRows||[];

        const buildPreviewTable = (rowList, rowBg, textColor) => rowList.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            return `<tr style="background:${rowBg}">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:${textColor}">${escapeHtml(v.STUDENT_NO||'')}</td>
                <td>${escapeHtml(v.QUAL_CODE||'')}</td>
                <td>${escapeHtml(v.QUAL_NAME||'')}</td>
                <td>${escapeHtml(v.COURSE_COUNT||'')}</td>
                <td style="font-weight:700;color:${textColor}">${escapeHtml(v.TOTAL_CREDITS||'')}</td>
                <td style="font-weight:700;color:${textColor}">${escapeHtml(String(row.validationResult||''))} ${row.errorCode?`(${escapeHtml(row.errorCode)})`:''}</td>
            </tr>`;
        }).join('');

        els.analysisPane.innerHTML = `
            ${summary.isPreviewOnly?`<div class="alert alert--warning" style="margin-bottom:16px">Browser preview shows ${formatNumber(summary.previewLimit)} rows. Download Excel for complete results.</div>`:''}
            <div class="R68-summary-grid">
                <div class="stat-card"><div class="stat-card__label">CREG Records</div><div class="stat-card__value">${formatNumber(summary.cregRecordCount)}</div></div>
                <div class="stat-card"><div class="stat-card__label">CRED Records</div><div class="stat-card__value">${formatNumber(summary.credRecordCount)}</div></div>
                <div class="stat-card"><div class="stat-card__label">Student-Qual Pairs Checked</div><div class="stat-card__value">${formatNumber(summary.totalValidated)}</div></div>
                <div class="stat-card stat-card--pass" style="cursor:pointer" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='PASS';renderResults(true);">
                    <div class="stat-card__label">PASS (&le; ${escapeHtml(thresholdLabel)})</div><div class="stat-card__value">${formatNumber(summary.passCount)}</div>
                    <div style="font-size:11px;margin-top:4px;opacity:.75">Click to view &rarr;</div>
                </div>
                <div class="stat-card stat-card--fail" style="cursor:pointer" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='FAIL';renderResults(true);">
                    <div class="stat-card__label">FAIL (03603) &mdash; &gt; ${escapeHtml(thresholdLabel)}</div><div class="stat-card__value">${formatNumber(summary.failCount)}</div>
                    <div style="font-size:11px;margin-top:4px;opacity:.75">Rate: ${Number(summary.exceptionRate||0).toFixed(2)}% &nbsp;|&nbsp; Click &rarr;</div>
                </div>
                ${hasDetail?`
                <div class="stat-card" style="border-left:4px solid #2e7d32;cursor:pointer" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='CONFIRMED';renderResults(true);">
                    <div class="stat-card__label">Confirmed by Rule 32</div><div class="stat-card__value" style="color:#2e7d32">${formatNumber(summary.confirmedByRule32Count)}</div>
                    <div style="font-size:11px;margin-top:4px;opacity:.75">Click to view &rarr;</div>
                </div>
                <div class="stat-card" style="border-left:4px solid #f57f17;cursor:pointer" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='NOT_CONFIRMED';renderResults(true);">
                    <div class="stat-card__label">Not Confirmed (Rule 68 only)</div><div class="stat-card__value" style="color:#f57f17">${formatNumber(summary.notInRule32Count)}</div>
                    <div style="font-size:11px;margin-top:4px;opacity:.75">Click to view &rarr;</div>
                </div>
                <div class="stat-card" style="border-left:4px solid #880e4f;cursor:pointer" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='RULE32_ONLY';renderResults(true);">
                    <div class="stat-card__label">Rule 32 Detail (03603)</div><div class="stat-card__value" style="color:#880e4f">${formatNumber(summary.rule32OnlyCount)}</div>
                    <div style="font-size:11px;margin-top:4px;opacity:.75">Click to view &rarr;</div>
                </div>`:''
                }
            </div>

            ${failRows.length > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #b71c1c">
                <h3 class="section-title" style="margin-top:0;color:#b71c1c">FAIL (03603) — ${formatNumber(summary.failCount)} pair(s) &nbsp;<span style="font-size:13px;font-weight:400;color:var(--text-muted)">${summary.isPreviewOnly&&failRows.length<summary.failCount?`(showing ${failRows.length} in preview)`:''}</span></h3>
                <p style="font-size:13px;color:var(--text-muted);margin:0 0 12px">Student-qualification pairs where SUM(CRED.[${escapeHtml(creditsCol)}]) &gt; ${escapeHtml(thresholdLabel)}.</p>
                <div class="table-wrapper" style="overflow-x:auto"><table class="data-table" style="min-width:600px;font-size:12px;font-family:Consolas,monospace">
                    <thead><tr><th>#</th><th>Student No</th><th>Qual Code</th><th>Qual Name</th><th>Courses</th><th>Total ${escapeHtml(creditsCol)}</th><th>Result</th></tr></thead>
                    <tbody>${buildPreviewTable(failRows,'#FFF3F3','#b71c1c')}</tbody>
                </table></div>
                <div style="margin-top:12px"><button type="button" class="btn btn-info" onclick="document.querySelector('[data-tab=\\'results\\']')?.click();state.categoryTab='FAIL';renderResults(true);">View in Results tab &rarr;</button></div>
            </div>` : `<div class="alert alert--success" style="margin-top:16px">All ${formatNumber(summary.totalValidated)} student-qualification pairs have total credits &le; ${escapeHtml(thresholdLabel)}. No exceptions.</div>`}

            ${hasDetail&&rule32Only.length > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #880e4f">
                <h3 class="section-title" style="margin-top:0;color:#880e4f">Rule 32 Detail (03603) — ${formatNumber(rule32Only.length)} records in preview</h3>
                <p style="font-size:13px;color:var(--text-muted);margin:0 0 8px">Records from <strong>${escapeHtml(summary.detailTable||'')}</strong> with error 03603. <span style="color:#2e7d32;font-weight:700">Green</span> = confirmed by Rule 68 FAIL.</p>
                <div class="table-wrapper" style="overflow-x:auto"><table class="data-table" style="min-width:500px;font-size:12px;font-family:Consolas,monospace">
                    <thead><tr><th>#</th><th>Student No (Rule 32)</th><th>Qual Code (Rule 32)</th><th>Sum Credits</th><th>Confirmed by Rule 68?</th></tr></thead>
                    <tbody>${rule32Only.map((row,i)=>{const conf=row.confirmedByR68==='Yes';return `<tr style="background:${conf?'#E8F5E9':'#FCE4EC'}"><td>${i+1}</td><td style="font-weight:700;color:${conf?'#2e7d32':'#880e4f'}">${escapeHtml(String(row.studentNo||''))}</td><td>${escapeHtml(String(row.qualCode||''))}</td><td>${escapeHtml(String(row.sumCredits||''))}</td><td style="font-weight:700;color:${conf?'#2e7d32':'#880e4f'}">${conf?'Yes':'No'}</td></tr>`;}).join('')}</tbody>
                </table></div>
            </div>` : ''}

            <div class="card" style="padding:20px;margin-top:20px">
                <h3 class="section-title" style="margin-top:0">Run Summary</h3>
                <div class="form-grid">
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>${escapeHtml(summary.database)}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">CREG Table</div><div>${escapeHtml(summary.cregTable||'')}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">CRED Table</div><div>${escapeHtml(summary.credTable||'')}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Credits Column</div><div><code>CRED.[${escapeHtml(creditsCol)}]</code></div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Threshold</div><div>SUM &gt; ${escapeHtml(thresholdLabel)} = FAIL (03603)</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Exception Rate</div><div>${Number(summary.exceptionRate||0).toFixed(2)}%</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div>${escapeHtml(summary.status)}</div></div>
                    ${summary.timestamp?`<div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Timestamp</div><div>${escapeHtml(summary.timestamp)}</div></div>`:''}
                </div>
            </div>`;
    }

    function renderResults(force = false) {
        if (!state.summary) { els.resultsPane.innerHTML='<div class="empty-card"><p>No Rule 68 results loaded.</p></div>'; return; }
        if (!force && getActiveTab()!=='results') { els.resultsPane.innerHTML='<div class="empty-card"><p>Open the Results tab to load the browser preview.</p></div>'; return; }
        const summary  = state.summary;
        const allRows  = summary.reviewRows||[];
        const hasDetail= !!(summary.detailTable);
        const failRows = allRows.filter(r=>String(r.validationResult||'').toUpperCase()==='FAIL');
        const passRows = allRows.filter(r=>String(r.validationResult||'').toUpperCase()==='PASS');
        const getRecon = r => String((r.displayValues||{}).Reconciliation_Status||(r.displayValues||{}).RECONCILIATION_STATUS||'');
        const confirmedRows   = hasDetail ? allRows.filter(r=>getRecon(r)==='Confirmed by Rule 32') : [];
        const notConfirmedRows= hasDetail ? allRows.filter(r=>getRecon(r)==='Not in Rule 32') : [];
        const rule32OnlyRows  = hasDetail ? (summary.rule32OnlyRows||[]) : [];

        const creditsCol = summary.credCreditsCol||'_036';
        const catMap = {
            ALL:           { rows: allRows,         label: 'All Results',              count: summary.totalValidated||allRows.length },
            PASS:          { rows: passRows,         label: 'PASS',                     count: summary.passCount||passRows.length },
            FAIL:          { rows: failRows,         label: 'FAIL (03603)',              count: summary.failCount||failRows.length },
            ...(hasDetail ? {
                CONFIRMED:     { rows: confirmedRows,    label: 'Confirmed by Rule 32',   count: summary.confirmedByRule32Count||confirmedRows.length, isR32: false },
                NOT_CONFIRMED: { rows: notConfirmedRows, label: 'Not Confirmed (R68 Only)',count: summary.notInRule32Count||notConfirmedRows.length, isR32: false },
                RULE32_ONLY:   { rows: rule32OnlyRows,   label: 'Rule 32 Detail (03603)', count: summary.rule32OnlyCount||rule32OnlyRows.length, isR32: true }
            } : {})
        };
        if (!catMap[state.categoryTab]) state.categoryTab = 'ALL';
        const isR32Tab = catMap[state.categoryTab]?.isR32 === true;
        const rows = catMap[state.categoryTab]?.rows || allRows;

        const reconBadge = r => {
            if (!hasDetail || !r) return '';
            if (r === 'Confirmed by Rule 32') return `<span class="R68-recon R68-recon--confirmed">&#10003; Rule 32</span>`;
            if (r === 'Not in Rule 32')       return `<span class="R68-recon R68-recon--notconfirmed">&#9888; Not in Rule 32</span>`;
            return '';
        };

        const buildRowHtml = rows => rows.map(row => {
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const isFail=String(row.validationResult||'').toUpperCase()==='FAIL';
            const recon=hasDetail?v.RECONCILIATION_STATUS||'':'';
            return `<tr style="background:${isFail?'#FFF3F3':'#F3FFF3'}">
                <td>${row.validationNumber}</td>
                <td class="group-key" style="${isFail?'color:#b71c1c;font-weight:700':''}">${escapeHtml(v.STUDENT_NO||'')}</td>
                <td class="group-key">${escapeHtml(v.QUAL_CODE||'')}</td>
                <td>${escapeHtml(v.QUAL_NAME||'')}</td>
                <td>${escapeHtml(v.COURSE_COUNT||'')}</td>
                <td class="group-cred" style="${isFail?'color:#b71c1c;font-weight:800':'color:#2e7d32;font-weight:800'}">${escapeHtml(v.TOTAL_CREDITS||'')}</td>
                <td class="group-final ${isFail?'is-fail':'is-pass'}">${escapeHtml(row.validationResult||'')} ${row.errorCode?`<small>(${escapeHtml(row.errorCode)})</small>`:''}</td>
                ${hasDetail?`<td>${reconBadge(recon)}</td>`:''}
            </tr>`;
        }).join('');

        const buildR32Html = rows => rows.map((row,i) => {
            const conf=row.confirmedByR68==='Yes';
            return `<tr style="background:${conf?'#E8F5E9':'#FCE4EC'}">
                <td>${i+1}</td>
                <td style="font-weight:700;color:${conf?'#2e7d32':'#880e4f'}">${escapeHtml(String(row.studentNo||''))}</td>
                <td>${escapeHtml(String(row.qualCode||''))}</td>
                <td>${escapeHtml(String(row.sumCredits||''))}</td>
                <td style="font-weight:700;color:${conf?'#2e7d32':'#880e4f'}">${conf?'Yes':'No'}</td>
            </tr>`;
        }).join('');

        const colSpan = hasDetail ? 8 : 7;
        const catTabsHtml = Object.entries(catMap).map(([key,cfg])=>
            `<button type="button" class="R68-cat-tab${state.categoryTab===key?' active':''}" data-cat="${key}">
                ${escapeHtml(cfg.label)} <span class="R68-cat-count">${cfg.count.toLocaleString()}</span>
            </button>`).join('');

        const tableHeader = isR32Tab
            ? `<tr><th>#</th><th>Student No (Rule 32)</th><th>Qual Code (Rule 32)</th><th>Sum Credits</th><th>Confirmed by R68?</th></tr>`
            : `<tr><th>#</th><th class="group-key">Student No</th><th class="group-key">Qual Code</th><th>Qual Name</th><th>Courses</th><th class="group-cred">Total ${escapeHtml(creditsCol)}</th><th class="group-final">Result</th>${hasDetail?'<th>Reconciliation</th>':''}</tr>`;
        const activeCat = catMap[state.categoryTab];
        const activeCatTotal = activeCat?.count || 0;
        const noPreviewMsg = activeCatTotal > 0 && rows.length === 0 ? `<tr><td colspan="${colSpan}" style="text-align:center;padding:20px"><div class="alert alert--info" style="display:inline-block;text-align:left;max-width:500px"><strong>${formatNumber(activeCatTotal)} records</strong> in this category — browser preview does not include rows for this tab. Download Excel for full data.</div></td></tr>` : '';
        const bodyHtml = isR32Tab
            ? (buildR32Html(rows)||noPreviewMsg||`<tr><td colspan="${colSpan}" style="text-align:center;color:var(--text-muted);padding:16px">No Rule 32 records in this category.</td></tr>`)
            : (buildRowHtml(rows)||noPreviewMsg||`<tr><td colspan="${colSpan}" style="text-align:center;color:var(--text-muted);padding:16px">No rows in this category.</td></tr>`);

        els.resultsPane.innerHTML=`
            <div class="R68-cat-tabs">${catTabsHtml}</div>
            <div style="font-size:12px;color:var(--text-muted);padding:6px 0 8px">
                Showing ${formatNumber(rows.length)} of ${formatNumber(activeCatTotal)} rows
                ${summary.isPreviewOnly||rows.length<activeCatTotal?`<em style="margin-left:4px">(browser preview — download Excel for complete data)</em>`:''}
            </div>
            <div class="R68-table-wrap">
                <table class="R68-grid"><thead>${tableHeader}</thead><tbody>${bodyHtml}</tbody></table>
            </div>`;

        els.resultsPane.querySelectorAll('.R68-cat-tab').forEach(btn => {
            btn.addEventListener('click', () => { state.categoryTab = btn.dataset.cat; renderResults(true); });
        });
    }

    // ─── Wire up buttons ─────────────────────────────────────────────────────

    els.clientId?.addEventListener('change', async () => {
        showSpinner('Loading workspace...'); try { await loadWorkspace(); } catch(e) { setWorkspaceState(e.message,'error'); } finally { hideSpinner(); }
    });
    els.database?.addEventListener('change', async () => {
        try { showSpinner('Loading tables...'); await loadTables(); } catch(e) { setAlert(els.configOutput,'error',e.message); } finally { hideSpinner(); }
    });
    els.cregTable?.addEventListener('change',  async () => { await loadCols('creg',   els.cregTable.value).catch(()=>{}); });
    els.qualTable?.addEventListener('change',  async () => { await loadCols('qual',   els.qualTable.value).catch(()=>{}); });
    els.credTable?.addEventListener('change',  async () => { await loadCols('cred',   els.credTable.value).catch(()=>{}); });
    els.crseTable?.addEventListener('change',  async () => { await loadCols('crse',   els.crseTable.value).catch(()=>{}); });
    els.detailTable?.addEventListener('change',async () => { await loadCols('detail', els.detailTable.value).catch(()=>{}); });

    document.getElementById('connectBtn')?.addEventListener('click', async () => { try { await connect(); } catch(e) { setAlert(els.connectionOutput,'error',e.message); } });
    document.getElementById('verifyBtn')?.addEventListener('click',  async () => { try { await verifyTables(); } catch(e) { setAlert(els.configOutput,'error',e.message); } });
    document.getElementById('runBtn')?.addEventListener('click',     async () => { try { await runValidation(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });
    document.getElementById('sqlBtn')?.addEventListener('click',     async () => { try { await generateSql(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });
    els.beginEditBtn?.addEventListener('click',    async () => { try { await beginEdit(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });
    els.saveWorkspaceBtn?.addEventListener('click',async () => { try { await saveWorkspace(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });
    els.signoffBtn?.addEventListener('click',      async () => { try { await signoffWorkspace(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });
    els.removeSignoffBtn?.addEventListener('click',async () => { try { await removeWorkspaceSignoff(); } catch(e) { setWorkspaceState(e.message,'error'); hideSpinner(); } });

    document.getElementById('downloadAllBtn')?.addEventListener('click', async () => {
        if (!state.summary) return;
        const chkExcel = document.getElementById('chkExcel')?.checked ?? true;
        const chkCsv   = document.getElementById('chkCsv')?.checked ?? true;
        const chkSql   = document.getElementById('chkSql')?.checked ?? true;
        if (chkExcel) await downloadBlob(`${apiBase}/DownloadExcel`, state.summary, 'Rule68_CreditOverload.xlsx').catch(e=>setWorkspaceState(e.message,'error'));
        if (chkCsv)   await downloadBlob(`${apiBase}/DownloadCsv`,   state.summary, 'Rule68_CreditOverload.csv').catch(e=>setWorkspaceState(e.message,'error'));
        if (chkSql)   await downloadBlob(`${apiBase}/DownloadSql`,   getRequest(),  'Rule68_CreditOverload.sql').catch(e=>setWorkspaceState(e.message,'error'));
    });
    document.getElementById('downloadExcelBtn')?.addEventListener('click', () => downloadBlob(`${apiBase}/DownloadExcel`, state.summary, 'Rule68_CreditOverload.xlsx').catch(e=>setWorkspaceState(e.message,'error')));
    document.getElementById('downloadCsvBtn')?.addEventListener('click',   () => downloadBlob(`${apiBase}/DownloadCsv`,   state.summary, 'Rule68_CreditOverload.csv').catch(e=>setWorkspaceState(e.message,'error')));
    document.getElementById('downloadSqlBtn')?.addEventListener('click',   () => downloadBlob(`${apiBase}/DownloadSql`,   getRequest(),  'Rule68_CreditOverload.sql').catch(e=>setWorkspaceState(e.message,'error')));

    // ─── Init ─────────────────────────────────────────────────────────────────
    if (state.clientId > 0) {
        (async () => { showSpinner('Loading workspace...'); try { await loadWorkspace(); } catch(e) { setWorkspaceState(e.message,'error'); } finally { hideSpinner(); } })();
    } else {
        applySummary(null);
        updateWorkspaceButtons();
    }
})();
</script>
