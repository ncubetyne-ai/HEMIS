async function generateSql() {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can generate SQL.', 'error');
        return;
    }
    if (isArchivedWorkspace()) {
        setWorkspaceInfo('Archived engagements are read-only. SQL generation is disabled.', 'error');
        return;
    }
    if (!validateConfig()) return;

    showSpinner('Generating SQL...');
    try {
        const result = await post('/Rule34/GenerateSql', buildRequest());
        if (!result.success) {
            setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to generate SQL.')}`, 'error');
            return;
        }

        const content = document.getElementById('sqlContent');
        content.classList.remove('empty-state');
        content.innerHTML = `
            <div class="sql-toolbar">
                <button class="btn btn-sm btn-primary" onclick="copyToClipboard('sqlCode')">Copy</button>
                <button class="btn btn-sm btn-info" onclick="downloadSql()">Download SQL</button>
            </div>
            <div class="sql-panel"><pre id="sqlCode" class="sql-block">${escapeHtml(result.sql)}</pre></div>`;
        switchTab('sql');
    } finally {
        hideSpinner();
    }
}
async function generateRScript() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can generate the R script.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. R script generation is disabled.', 'error'); return; }
    syncStateFromSelects();
    if (!validateConfig()) return;
    showSpinner('Generating R script...');
    try {
        const result = await post('/Rule34/GenerateRScript', buildRequest());
        if (!result.success) return;
        const el = document.getElementById('rContent');
        el.classList.remove('empty-state');
        el.innerHTML = `
            <div class="sql-toolbar">
                <button class="btn btn-sm btn-primary" onclick="copyToClipboard('rCode')">Copy</button>
            </div>
            <div class="sql-panel"><pre id="rCode" class="sql-block">`+escapeHtml(result.sql)+`</pre></div>`;
        switchTab('rscript');
    } finally {
        hideSpinner();
    }
}


async function saveWorkspace() {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can save this workspace.', 'error');
        return;
    }
    if (isArchivedWorkspace()) {
        setWorkspaceInfo('Archived engagements are read-only. Saving is disabled.', 'error');
        return;
    }
    if (!state.currentRunId) {
        setWorkspaceInfo('Run validation first so the workspace can be saved.', 'error');
        return;
    }

    showSpinner('Saving workspace...');
    try {
        const result = await post('/Rule34/SaveWorkspace', buildRequest());
        if (!result.success) {
            setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save workspace.')}`, 'error');
            return;
        }

        state.editWarningAccepted = true;
        state.isDirty = false;
        const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible')
            ? !!result.resultsVisible
            : !!result.workspace?.resultsVisible;
        if (result.workspace) applyWorkspace(result.workspace, workspaceResultsVisible);
        setWorkspaceInfo(result.message || 'Workspace saved.', result.signoffsCleared ? 'warning' : 'success');
    } finally {
        hideSpinner();
    }
}

async function signOffWorkspace() {
    const currentRole = state.currentUserEngagementRole || currentSystemRole;
    const canSign = state.currentRunId && !isArchivedWorkspace() &&
        (currentSystemRole === 'DataAnalyst' || ((currentRole === 'Manager' || currentRole === 'Director') && state.resultsVisible));

    if (!canSign) {
        setWorkspaceInfo('This workspace can only be signed off by the assigned analyst, manager, or director after the analyst review is available.', 'error');
        return;
    }
    if (!state.isWorkspaceSaved) {
        setWorkspaceInfo('Save the workspace first before signing off.', 'warning');
        return;
    }
    if (state.isDirty) {
        setWorkspaceInfo('Save the workspace first. Editing removes signoffs and requires a fresh review.', 'warning');
        return;
    }

    showSpinner('Saving signoff...');
    try {
        const result = await post('/Rule34/SignOffWorkspace', {
            clientId: state.clientId,
            runId: state.currentRunId,
            comment: document.getElementById('signoffComment').value.trim()
        });

        if (!result.success) {
            setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save signoff.')}`, 'error');
            return;
        }

        const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible')
            ? !!result.resultsVisible
            : !!result.workspace?.resultsVisible;
        if (result.workspace) applyWorkspace(result.workspace, workspaceResultsVisible);
        state.isDirty = false;
        setWorkspaceInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
        switchTab('downloads');
    } finally {
        hideSpinner();
    }
}

async function removeWorkspaceSignoff() {
    if (!state.currentRunId || !state.currentUserHasSignedOff) {
        setWorkspaceInfo('There is no signoff for your assigned engagement role to remove.', 'error');
        return;
    }

    showSpinner('Removing signoff...');
    try {
        const result = await post('/Rule34/RemoveWorkspaceSignoff', {
            clientId: state.clientId,
            runId: state.currentRunId,
            comment: ''
        });

        if (!result.success) {
            setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to remove signoff.')}`, 'error');
            return;
        }

        if (result.workspace) applyWorkspace(result.workspace, true);
        setWorkspaceInfo('Signoff removed.', 'warning');
    } finally {
        hideSpinner();
    }
}

function fileStamp() {
    return new Date().toISOString().replace(/[:.]/g, '-').replace('T', '_').replace('Z', '');
}

async function downloadExcel() {
    if (!state.validationResult) return alert('Run validation first.');
    await downloadPost('/Rule34/DownloadExcel', state.validationResult, `Rule34_Census_Date_Validation_${fileStamp()}.xlsx`);
}

async function downloadCsv() {
    if (!state.validationResult) return alert('Run validation first.');
    await downloadPost('/Rule34/DownloadCsv', state.validationResult, `Rule34_Validation_Results_${fileStamp()}.csv`);
}

async function downloadExceptionsCsv() {
    if (!state.validationResult) return alert('Run validation first.');
    await downloadPost('/Rule34/DownloadExceptionsCsv', state.validationResult, `Rule34_Census_Date_Exceptions_${fileStamp()}.csv`);
}

async function downloadSql() {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can download the SQL script.', 'error');
        return;
    }
    if (!validateConfig()) return;
    await downloadPost('/Rule34/DownloadSql', buildRequest(), `Rule34_Census_Date_Validation_${fileStamp()}.sql`);
}

async function downloadAll() {
    if (!state.validationResult) return alert('Run validation first.');

    const tasks = [];
    if (document.getElementById('chkExcel').checked) tasks.push(() => downloadExcel());
    if (document.getElementById('chkCsv').checked) tasks.push(() => downloadCsv());
    if (document.getElementById('chkExceptionsCsv').checked) tasks.push(() => downloadExceptionsCsv());
    if (currentSystemRole === 'DataAnalyst' && document.getElementById('chkSql').checked) tasks.push(() => downloadSql());

    if (!tasks.length) {
        alert('Select at least one download format.');
        return;
    }

    for (const task of tasks) await task();
}

function copyToClipboard(id) {
    const text = document.getElementById(id).textContent;
    navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

function escapeHtml(value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

