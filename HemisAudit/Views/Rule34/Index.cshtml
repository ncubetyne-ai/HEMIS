async function loadWorkspaceState() {
    if (!state.clientId) return;
    showSpinner('Loading saved workspace...');
    try {
        const result = await getJson(`/Rule34/GetWorkspaceState?clientId=${state.clientId}`);
        if (!result.success) {
            setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to load workspace.')}`, 'error');
            return;
        }

        if (!result.hasWorkspace) {
            setWorkspaceInfo(
                currentSystemRole === 'DataAnalyst'
                    ? 'No saved Rule 34 workspace exists for this engagement yet. Connect, configure, run validation, then save and sign off.'
                    : 'No saved Rule 34 workspace exists for this engagement yet. This module is read-only for your role.',
                'info');
            renderWorkspaceState();
            return;
        }

        applyWorkspace(result.workspace, false);
    } finally {
        hideSpinner();
    }
}

async function loadHolidays() {
    state.startYear = parseInt(document.getElementById('startYearInput').value || '0') || 0;
    state.endYear = parseInt(document.getElementById('endYearInput').value || '0') || 0;
    if (state.startYear > state.endYear) {
        setStatus('holidayStatus', 'Start year must be less than or equal to end year.', 'error');
        return;
    }

    showSpinner('Loading South African public holidays...');
    try {
        const result = await post('/Rule34/LoadHolidays', { startYear: state.startYear, endYear: state.endYear });
        if (!result.success) {
            setStatus('holidayStatus', escapeHtml(result.error || 'Failed to load holidays.'), 'error');
            return;
        }

        const preview = (result.holidays || []).slice(0, 8).map(h => `${escapeHtml(h.date)} - ${escapeHtml(h.name)}`).join('<br>');
        setStatus('holidayStatus', `Loaded <strong>${result.totalCount}</strong> holidays for ${result.startYear}-${result.endYear}.${preview ? `<br><br>${preview}` : ''}`, 'success');
        await markWorkspaceDirty();
    } finally {
        hideSpinner();
    }
}

async function connectServer() {
    state.server = document.getElementById('serverInput').value.trim();
    state.driver = document.getElementById('driverSelect').value;
    if (!state.server) {
        setStatus('connectionStatus', 'Enter a server name first.', 'warning');
        return;
    }

    const cacheKey = `${state.server}|${state.driver}`;
    if (state.cache.databases[cacheKey]) {
        document.getElementById('dbFieldGroup').style.display = 'block';
        const select = document.getElementById('databaseSelect');
        select.innerHTML = '<option value="">Select database</option>' +
            state.cache.databases[cacheKey].map(db => `<option value="${escapeHtml(db)}">${escapeHtml(db)}</option>`).join('');
        setStatus('connectionStatus', `Loaded ${state.cache.databases[cacheKey].length} cached databases. Select one to continue.`, 'success');
        await markWorkspaceDirty();
        return;
    }

    showSpinner('Connecting to SQL Server...');
    try {
        const result = await post('/Rule34/GetDatabases', { server: state.server, driver: state.driver });
        if (!result.success) {
            setStatus('connectionStatus', escapeHtml(result.error || 'Connection failed.'), 'error');
            return;
        }

        state.cache.databases[cacheKey] = result.databases || [];
        document.getElementById('dbFieldGroup').style.display = 'block';
        const select = document.getElementById('databaseSelect');
        select.innerHTML = '<option value="">Select database</option>' +
            (result.databases || []).map(db => `<option value="${escapeHtml(db)}">${escapeHtml(db)}</option>`).join('');
        setStatus('connectionStatus', `Found ${result.databases.length} databases. Select one to continue.`, 'success');
        await markWorkspaceDirty();
    } finally {
        hideSpinner();
    }
}

async function loadTables() {
    if (!state.server || !state.database) return;
    const cacheKey = `${state.server}|${state.driver}|${state.database}`;
    if (state.cache.tables[cacheKey]) {
        const cached = state.cache.tables[cacheKey];
        populateRule34TableSelects(cached.tables || [], cached.autoStudTable || '');
        if (state.tableName) await loadColumns();
        if (state.clientTableName) await loadClientColumns();
        return;
    }

    showSpinner('Loading tables...');
    try {
        const result = await post('/Rule34/GetTables', { server: state.server, database: state.database, driver: state.driver });
        if (!result.success) {
            setStatus('configStatus', escapeHtml(result.error || 'Failed to load tables.'), 'error');
            return;
        }

        state.cache.tables[cacheKey] = {
            tables: result.tables || [],
            autoStudTable: result.autoStudTable || ''
        };
        populateRule34TableSelects(result.tables || [], result.autoStudTable || '');
        if (state.tableName) await loadColumns();
        if (state.clientTableName) await loadClientColumns();
    } finally {
        hideSpinner();
    }
}

function populateRule34TableSelects(tables, autoSourceTable) {
    const options = '<option value="">Select table</option>' +
        (tables || []).map(t => `<option value="${escapeHtml(t)}">${escapeHtml(t)}</option>`).join('');
    const sourceSelect = document.getElementById('tableSelect');
    const clientSelect = document.getElementById('clientTableSelect');
    sourceSelect.innerHTML = options;
    clientSelect.innerHTML = options;

    const preferredSource = state.tableName || autoSourceTable || '';
    const preferredClient = state.clientTableName || findPreferredRule34Table(tables, ['CENSUS_LIST_CLIENT']) || '';

    if (preferredSource && [...sourceSelect.options].some(o => o.value === preferredSource)) {
        sourceSelect.value = preferredSource;
        state.tableName = preferredSource;
    } else {
        state.tableName = '';
    }

    if (preferredClient && [...clientSelect.options].some(o => o.value === preferredClient)) {
        clientSelect.value = preferredClient;
        state.clientTableName = preferredClient;
    } else {
        state.clientTableName = '';
    }
}

async function loadColumns() {
    if (!state.tableName) return;
    const cacheKey = `${state.server}|${state.driver}|${state.database}|${state.tableName}`;
    if (state.cache.columns[cacheKey]) {
        populateRule34SourceColumnSelects(state.cache.columns[cacheKey]);
        return;
    }

    showSpinner('Loading columns...');
    try {
        const result = await post('/Rule34/GetColumns', {
            server: state.server,
            database: state.database,
            driver: state.driver,
            tableName: state.tableName
        });

        if (!result.success) {
            setStatus('configStatus', escapeHtml(result.error || 'Failed to load columns.'), 'error');
            return;
        }

        state.cache.columns[cacheKey] = result;
        populateRule34SourceColumnSelects(result);
        setStatus('configStatus', 'Source columns loaded. Review the auto-selected date fields before running validation.', 'success');
    } finally {
        hideSpinner();
    }
}

async function loadClientColumns() {
    if (!state.clientTableName) return;
    const cacheKey = `${state.server}|${state.driver}|${state.database}|${state.clientTableName}`;
    if (state.cache.columns[cacheKey]) {
        populateRule34ClientColumnSelects(state.cache.columns[cacheKey]);
        return;
    }

    showSpinner('Loading client census columns...');
    try {
        const result = await post('/Rule34/GetColumns', {
            server: state.server,
            database: state.database,
            driver: state.driver,
            tableName: state.clientTableName
        });

        if (!result.success) {
            setStatus('configStatus', escapeHtml(result.error || 'Failed to load client table columns.'), 'error');
            return;
        }

        state.cache.columns[cacheKey] = result;
        populateRule34ClientColumnSelects(result);
        setStatus('configStatus', 'Client census columns loaded. Review the join and census-date fields before running validation.', 'success');
    } finally {
        hideSpinner();
    }
}

function populateRule34SourceColumnSelects(result) {
    const options = '<option value="">Select column</option>' +
        (result.columns || []).map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
    const firstDaySelect = document.getElementById('firstDaySelect');
    const lastDaySelect = document.getElementById('lastDaySelect');
    const blockSelect = document.getElementById('blockColumnSelect');
    firstDaySelect.innerHTML = options;
    lastDaySelect.innerHTML = options;
    blockSelect.innerHTML = options;

    if (state.firstDayColumn && [...firstDaySelect.options].some(o => o.value === state.firstDayColumn)) {
        firstDaySelect.value = state.firstDayColumn;
    } else if (result.autoFirstDayColumn) {
        firstDaySelect.value = result.autoFirstDayColumn;
        state.firstDayColumn = result.autoFirstDayColumn;
    } else {
        state.firstDayColumn = '';
    }

    if (state.lastDayColumn && [...lastDaySelect.options].some(o => o.value === state.lastDayColumn)) {
        lastDaySelect.value = state.lastDayColumn;
    } else if (result.autoLastDayColumn) {
        lastDaySelect.value = result.autoLastDayColumn;
        state.lastDayColumn = result.autoLastDayColumn;
    } else {
        state.lastDayColumn = '';
    }

    if (state.blockColumn && [...blockSelect.options].some(o => o.value === state.blockColumn)) {
        blockSelect.value = state.blockColumn;
    } else if (result.autoBlockColumn) {
        blockSelect.value = result.autoBlockColumn;
        state.blockColumn = result.autoBlockColumn;
    } else {
        state.blockColumn = '';
    }
}

function populateRule34ClientColumnSelects(result) {
    const options = '<option value="">Select column</option>' +
        (result.columns || []).map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
    const censusSelect = document.getElementById('censusDateSelect');
    const clientJoinSelect = document.getElementById('clientJoinColumnSelect');
    censusSelect.innerHTML = options;
    clientJoinSelect.innerHTML = options;

    if (state.censusDateColumn && [...censusSelect.options].some(o => o.value === state.censusDateColumn)) {
        censusSelect.value = state.censusDateColumn;
    } else if (result.autoCensusDateColumn) {
        censusSelect.value = result.autoCensusDateColumn;
        state.censusDateColumn = result.autoCensusDateColumn;
    } else {
        state.censusDateColumn = '';
    }

    if (state.clientJoinColumn && [...clientJoinSelect.options].some(o => o.value === state.clientJoinColumn)) {
        clientJoinSelect.value = state.clientJoinColumn;
    } else if (result.autoBlockColumn) {
        clientJoinSelect.value = result.autoBlockColumn;
        state.clientJoinColumn = result.autoBlockColumn;
    } else {
        state.clientJoinColumn = '';
    }
