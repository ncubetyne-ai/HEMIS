    }
    if (state.database) {
        document.getElementById('dbFieldGroup').style.display = 'block';
        document.getElementById('databaseSelect').innerHTML = `<option value="${escapeHtml(state.database)}">${escapeHtml(state.database)}</option>`;
        document.getElementById('databaseSelect').value = state.database;
    }
    if (state.tableName) {
        document.getElementById('tableSelect').innerHTML = `<option value="${escapeHtml(state.tableName)}">${escapeHtml(state.tableName)}</option>`;
        document.getElementById('tableSelect').value = state.tableName;
    }
    if (state.clientTableName) {
        document.getElementById('clientTableSelect').innerHTML = `<option value="${escapeHtml(state.clientTableName)}">${escapeHtml(state.clientTableName)}</option>`;
        document.getElementById('clientTableSelect').value = state.clientTableName;
    }
    if (state.firstDayColumn) {
        document.getElementById('firstDaySelect').innerHTML = `<option value="${escapeHtml(state.firstDayColumn)}">${escapeHtml(state.firstDayColumn)}</option>`;
        document.getElementById('firstDaySelect').value = state.firstDayColumn;
    }
    if (state.lastDayColumn) {
        document.getElementById('lastDaySelect').innerHTML = `<option value="${escapeHtml(state.lastDayColumn)}">${escapeHtml(state.lastDayColumn)}</option>`;
        document.getElementById('lastDaySelect').value = state.lastDayColumn;
    }
    if (state.censusDateColumn) {
        document.getElementById('censusDateSelect').innerHTML = `<option value="${escapeHtml(state.censusDateColumn)}">${escapeHtml(state.censusDateColumn)}</option>`;
        document.getElementById('censusDateSelect').value = state.censusDateColumn;
    }
    if (state.clientJoinColumn) {
        document.getElementById('clientJoinColumnSelect').innerHTML = `<option value="${escapeHtml(state.clientJoinColumn)}">${escapeHtml(state.clientJoinColumn)}</option>`;
        document.getElementById('clientJoinColumnSelect').value = state.clientJoinColumn;
    }

    if (workspace.summary) {
        applyValidationResult(workspace.summary, false, { fromWorkspace: true });
    }

    state.isHydrating = false;
    renderWorkspaceState();

    if (!preserveMessage) {
        setWorkspaceInfo(
            workspace.summary
                ? 'Loaded the saved Rule 34 workspace for this engagement.'
                : 'Saved configuration loaded. Run validation to refresh the results.',
            'success');
    }
}

