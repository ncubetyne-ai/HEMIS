async function verifyTable() {
    if (!state.server || !state.database || !state.tableName || !state.clientTableName || !state.firstDayColumn || !state.lastDayColumn || !state.censusDateColumn || !state.blockColumn || !state.clientJoinColumn) {
        setStatus('configStatus', 'Select the server, database, source table, client table, date columns, and join columns first.', 'warning');
        return;
    }

    showSpinner('Verifying table...');
    try {
        const result = await post('/Rule34/VerifyTable', {
            server: state.server,
            database: state.database,
            driver: state.driver,
            tableName: state.tableName,
            clientTableName: state.clientTableName,
            firstDayColumn: state.firstDayColumn,
            lastDayColumn: state.lastDayColumn,
            censusDateColumn: state.censusDateColumn,
            clientJoinColumn: state.clientJoinColumn,
            blockColumn: state.blockColumn || ''
        });

        if (!result.success) {
            setStatus('configStatus', escapeHtml(result.error || 'Verification failed.'), 'error');
            return;
        }

        const blockColActive = state.blockColumn || '';
        const colCount = blockColActive ? 4 : 3;
        const rows = (result.sampleRows || []).map(r => {
            const values = r.values || {};
            return `<tr>
                <td>${escapeHtml(values[state.firstDayColumn] || '')}</td>
                <td>${escapeHtml(values[state.lastDayColumn] || '')}</td>
                <td>${escapeHtml(values[state.censusDateColumn] || '')}</td>
                ${blockColActive ? `<td>${escapeHtml(values[blockColActive] || '')}</td>` : ''}
            </tr>`;
        }).join('');

        const preview = document.getElementById('verifyPreview');
        preview.style.display = 'block';
        preview.innerHTML = `
            <div class="alert alert--success">Total records: <strong>${result.totalRecords.toLocaleString()}</strong>${blockColActive ? ` &nbsp;|&nbsp; Block filter column: <strong>${escapeHtml(blockColActive)}</strong>` : ''}</div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>${escapeHtml(state.firstDayColumn)}</th>
                            <th>${escapeHtml(state.lastDayColumn)}</th>
                            <th>${escapeHtml(getRule34CensusValueLabel(state))} (${escapeHtml(state.censusDateColumn)})</th>
                            ${blockColActive ? `<th>${escapeHtml(blockColActive)} (block)</th>` : ''}
                        </tr>
                    </thead>
                    <tbody>${rows || `<tr><td colspan="${colCount}">No sample rows returned.</td></tr>`}</tbody>
                </table>
            </div>`;
    } finally {
        hideSpinner();
    }
}

function validateConfig() {
    const missing = [];
    if (!state.clientId) missing.push('engagement');
    if (!state.server) missing.push('server');
    if (!state.database) missing.push('database');
    if (!state.tableName) missing.push('source table');
    if (!state.clientTableName) missing.push('client census table');
    if (!state.firstDayColumn) missing.push('first day column');
    if (!state.lastDayColumn) missing.push('last day column');
    if (!state.censusDateColumn) missing.push('client census date column');
    if (!state.blockColumn) missing.push('source block / join column');
    if (!state.clientJoinColumn) missing.push('client join column');
    if (!state.startYear || !state.endYear) missing.push('holiday year range');

    if (missing.length) {
        if (!state.clientId) {
            setWorkspaceInfo('Select the approved engagement assigned to you before running this rule.', 'warning');
        }
        setStatus('validationContent', `Please select ${missing.join(', ')} first.`, 'warning');
        switchTab('validation');
        return false;
    }

    return true;
}

function buildRequest() {
    return {
        clientId: state.clientId,
        runId: state.currentRunId,
        server: state.server,
        database: state.database,
        driver: state.driver,
        tableName: state.tableName,
        clientTableName: state.clientTableName,
        firstDayColumn: state.firstDayColumn,
        lastDayColumn: state.lastDayColumn,
        censusDateColumn: state.censusDateColumn,
        clientJoinColumn: state.clientJoinColumn,
        startYear: state.startYear,
        endYear: state.endYear,
        blockColumn: state.blockColumn || '',
        blockExcludeValues: state.blockExcludeValues || ''
    };
}

async function runValidation() {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can run Rule 34.', 'error');
        return;
    }
    if (isArchivedWorkspace()) {
        setWorkspaceInfo('Archived engagements are read-only. Validation is disabled.', 'error');
        return;
    }
    if (!validateConfig()) return;

    showSpinner('Running Rule 34 validation...');
    try {
        const result = await post('/Rule34/RunValidation', buildRequest());
        if (!result.success) {
            setStatus('validationContent', escapeHtml(result.error || 'Validation failed.'), 'error');
            switchTab('validation');
            return;
        }

        applyValidationResult(result, true);
        state.currentRunId = result.savedRunId || state.currentRunId;
        state.currentStatus = result.status || '';
        state.isDirty = false;
        setWorkspaceInfo('Validation completed. Save the workspace to confirm the current configuration, then sign off when the review is complete.', 'success');
        renderWorkspaceState();
    } finally {
        hideSpinner();
    }
}

function applyValidationResult(result, switchToValidationTab, options = {}) {
    state.validationResult = result;
    if (!options.fromWorkspace && result.savedRunId) state.currentRunId = result.savedRunId;
    if (result.status) state.currentStatus = result.status;
    updateHeaderBadge(result.status);
    document.getElementById('downloadAllBtn').disabled = false;
    renderValidationResults(result);
    renderExceptions(result);
    renderCharts(result);
    renderDownloads(result);
    if (switchToValidationTab) switchTab('validation');
}

function renderValidationResults(r) {
    const blockCol = r.blockColumn || '';
    const excludedVals = r.blockExcludeValues || '';
    const censusValueLabel = getRule34CensusValueLabel(r);
    const rows = (r.validationRows || []).slice(0, 10).map(row => {
        const isExcludedBlock = blockCol && excludedVals.split(',').map(v => v.trim().toUpperCase()).includes((row.blockValue||'').trim().toUpperCase());
        const badgeClass = row.dateMatch ? (row.withinTolerance ? 'badge--warning' : 'badge--pass') : 'badge--fail';
        return `
        <tr>
            <td>${row.validationNumber}</td>
            ${blockCol ? `<td style="font-weight:700;color:${isExcludedBlock?'var(--rule15-fail)':'inherit'}">${escapeHtml(row.blockValue||'')}</td>` : ''}
            <td>${escapeHtml(row.firstDayValue)}</td>
            <td>${escapeHtml(row.lastDayValue)}</td>
            <td>${row.currentDays ?? ''}</td>
            <td>${row.currentDaysHalf ?? ''}</td>
            <td>${escapeHtml(row.computedCensusDate)}</td>
            <td>${escapeHtml(row.actualCensusDate)}</td>
            <td>${escapeHtml(row.censusDateValue)}</td>
            <td>${escapeHtml(row.dayStatus)}</td>
            <td><span class="badge ${badgeClass}">${escapeHtml(row.validationStatus)}</span></td>
            <td style="font-size:11px;color:#b45309;max-width:280px">${escapeHtml(row.toleranceNote||'')}</td>
        </tr>`;
    }).join('');

    const content = document.getElementById('validationContent');
    content.classList.remove('empty-state');
    content.innerHTML = `
        <div class="stats-grid" style="margin-bottom:18px">
            <div class="stat-card"><div class="stat-card__label">Validated</div><div class="stat-card__value">${r.totalValidated.toLocaleString()}</div></div>
            <div class="stat-card stat-card--pass"><div class="stat-card__label">Pass</div><div class="stat-card__value">${r.passCount.toLocaleString()}</div></div>
            <div class="stat-card stat-card--fail"><div class="stat-card__label">Fail</div><div class="stat-card__value">${r.failCount.toLocaleString()}</div></div>
            ${(r.tolerancePassCount||0)>0?`<div class="stat-card" style="border-color:#d97706"><div class="stat-card__label" style="color:#b45309">Pass (Tolerance)</div><div class="stat-card__value" style="color:#b45309">${(r.tolerancePassCount||0).toLocaleString()}</div></div>`:''}
            <div class="stat-card"><div class="stat-card__label">Mismatch Rate</div><div class="stat-card__value">${parseFloat(r.exceptionRate).toFixed(2)}%</div></div>
            ${(r.excludedRowCount > 0 || r.blockColumn) ? `<div class="stat-card"><div class="stat-card__label">Excluded (Block Filter)</div><div class="stat-card__value">${(r.excludedRowCount||0).toLocaleString()}</div></div>` : ''}
        </div>
        <div class="card" style="padding:18px;margin-bottom:18px">
            <strong>Holiday Years:</strong> ${escapeHtml(r.holidayYearRange)}<br>
            <strong>Computed Holidays:</strong> ${r.holidayCount.toLocaleString()}<br>
            <strong>Computed Weekends:</strong> ${r.weekendCount.toLocaleString()}
