@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 34 - Census Date Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
    var selectedClientId = (int)(ViewBag.ClientId ?? 0);
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #app > .accordion-stack > .accordion-item:nth-child(-n+2),
        #app > .action-bar {
            display: none !important;
        }
    </style>
}

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label>Engagement</label>
        <select id="clientIdSelect" onchange="handleClientChange(this.value)">
            <option value="0">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name - @c.FiscalYear</option>
            }
        </select>
        <small id="workspaceSavedHint">Saved runs reload the last analyst configuration for this engagement.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R34</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 34: Census Date Validation</h1>
            <p class="rule-header__sub">Prepared midpoint from source census dates vs client census table | Dynamic South African holidays</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    <div class="accordion-stack">
        <div class="accordion-item" id="acc-holidays">
            <button class="accordion-toggle" onclick="toggleAccordion('holidays')">
                <span class="acc-icon">HL</span>
                <span>Holiday Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-holidays">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Start Year</label>
                        <input type="number" id="startYearInput" value="@DateTime.Now.Year" min="2000" max="2100" />
                    </div>
                    <div class="field-group">
                        <label>End Year</label>
                        <input type="number" id="endYearInput" value="@DateTime.Now.Year" min="2000" max="2100" />
                    </div>
                </div>
                <button class="btn btn-primary" onclick="loadHolidays()">Load Holidays</button>
                <div class="status-output" id="holidayStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="acc-connection">
            <button class="accordion-toggle" onclick="toggleAccordion('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-connection" style="display:none">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Server Name</label>
                        <input type="text" id="serverInput" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label>Driver</label>
                        <select id="driverSelect">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group" id="dbFieldGroup" style="display:none">
                        <label>Database</label>
                        <select id="databaseSelect">
                            <option value="">Select database</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="connectServer()">Connect</button>
                <div class="status-output" id="connectionStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="acc-config">
            <button class="accordion-toggle" onclick="toggleAccordion('config')">
                <span class="acc-icon">CF</span>
                <span>Rule Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-config" style="display:none">
                <div class="info-box info-box--red">
                    <strong>Rule 34 Requirement:</strong> Calculate c_Days, c_Days_2, c_Census_Date_Prep, then shift to c_ACTUAL_CENSUS_DATE when the prepared date falls on a weekend or public holiday before testing pass or fail.
                    <br />
                    FALSE (dates match) = PASS. TRUE (dates do not match) = FAIL.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>Source Table</label>
                        <select id="tableSelect">
                            <option value="">Select table</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Client Census Table</label>
                        <select id="clientTableSelect">
                            <option value="">Select table</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>First Day Column</label>
                        <select id="firstDaySelect">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Last Day Column</label>
                        <select id="lastDaySelect">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Client Census Date Column</label>
                        <select id="censusDateSelect">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Source Block / Join Column <small style="font-weight:normal">(used for join and excluded values)</small></label>
                        <select id="blockColumnSelect">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Client Join Column</label>
                        <select id="clientJoinColumnSelect">
                            <option value="">Select column</option>
                        </select>
                    </div>
                </div>
                <div class="field-group" id="blockExcludeGroup" style="margin-top:12px">
                    <label for="blockExcludeInput">Block Values to Exclude <small style="font-weight:normal">(comma-separated, case-insensitive)</small></label>
                    <input type="text" id="blockExcludeInput" value="5, 5F, 8F, 8G, R0, R1, R2" placeholder="e.g. 5, 5F, 8F, 8G, R0, R1, R2" />
                    <small style="color:var(--text-muted)">Rows where the Block column contains any of these values will be excluded from the validation.</small>
                </div>
                <div class="status-output" id="configStatus"></div>
                <div id="verifyPreview" class="validation-preview" style="display:none"></div>
            </div>
        </div>

        <div class="accordion-item" id="acc-downloads">
            <button class="accordion-toggle" onclick="toggleAccordion('downloads')">
                <span class="acc-icon">DL</span>
                <span>Download Formats</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-downloads" style="display:none">
                <div class="checkbox-row">
                    <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV (full results)</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkExceptionsCsv" checked /> CSV (exceptions only)</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL script</label>
                </div>
            </div>
        </div>
    </div>

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 34 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">
            Select an engagement to load the last saved Rule 34 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div class="field-group">
                <label>Signoff Comment</label>
                <textarea id="signoffComment" placeholder="Add the final review note that confirms this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button class="btn btn-success" id="saveWorkspaceBtn" onclick="saveWorkspace()">Save Workspace</button>
            <button class="btn btn-primary" id="signOffBtn" onclick="signOffWorkspace()">Sign Off</button>
            <button class="btn btn-warning" id="removeWorkspaceSignoffBtn" onclick="removeWorkspaceSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-info" onclick="verifyTable()">Verify Table</button>
        <button class="btn btn-success" id="runValidationBtn" onclick="runValidation()">Run Validation</button>
        <button class="btn btn-primary" id="generateSqlBtn" onclick="generateSql()">Generate SQL</button>
<button class="btn btn-primary" id="generateRScriptBtn" onclick="generateRScript()">Generate R Script</button>
        <button class="btn btn-warning" id="downloadAllBtn" onclick="downloadAll()" disabled>Download All</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="validation" onclick="switchTab('validation')">Validation Results</button>
            <button class="tab-btn" type="button" data-tab="exceptions" onclick="switchTab('exceptions')">Exceptions List</button>
            <button class="tab-btn" type="button" data-tab="charts" onclick="switchTab('charts')">Charts</button>
            <button class="tab-btn" type="button" data-tab="sql" onclick="switchTab('sql')">SQL Code</button>
<button class="tab-btn" type="button" data-tab="rscript" onclick="switchTab('rscript')">R Code</button>
            <button class="tab-btn" type="button" data-tab="downloads" onclick="switchTab('downloads')">Downloads</button>
        </div>

        <div class="tab-pane active" id="tab-validation" data-tab-panel="validation">
            <div id="validationContent" class="empty-state"><p>Run validation to see results here.</p></div>
        </div>
        <div class="tab-pane" id="tab-exceptions" data-tab-panel="exceptions">
            <div id="exceptionsContent" class="empty-state"><p>No exceptions data yet. Run validation first.</p></div>
        </div>
        <div class="tab-pane" id="tab-charts" data-tab-panel="charts">
            <div id="chartsContent" class="empty-state"><p>Charts will appear after running validation.</p></div>
        </div>
        <div class="tab-pane" id="tab-sql" data-tab-panel="sql">
            <div id="sqlContent" class="empty-state"><p>Click "Generate SQL" or run validation to generate the SQL script.</p></div>
        </div>
        <div class="tab-pane" id="tab-rscript" data-tab-panel="rscript">
            <div id="rContent" class="empty-state"><p>Click "Generate R Script" to generate the R script.</p></div>
        </div>
        <div class="tab-pane" id="tab-downloads" data-tab-panel="downloads">
            <div id="downloadsContent" class="empty-state"><p>Run validation first, then use "Download All" or the individual download buttons.</p></div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="spinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const currentSystemRole = '@(ViewBag.CurrentSystemRole ?? "")';
let spinnerDelayHandle = null;
const state = {
    clientId: parseInt(document.getElementById('clientIdSelect')?.value || '0') || 0,
    server: '',
    database: '',
    driver: 'ODBC Driver 17 for SQL Server',
    tableName: '',
    clientTableName: '',
    firstDayColumn: '',
    lastDayColumn: '',
    censusDateColumn: '',
    clientJoinColumn: '',
    startYear: parseInt(document.getElementById('startYearInput').value || '0') || new Date().getFullYear(),
    endYear: parseInt(document.getElementById('endYearInput').value || '0') || new Date().getFullYear(),
    blockColumn: '',
    blockExcludeValues: '5, 5F, 8F, 8G, R0, R1, R2',
    currentRunId: null,
    validationResult: null,
    currentUserEngagementRole: '',
    currentStatus: '',
    currentUserHasSignedOff: false,
    isWorkspaceSaved: false,
    hasDataAnalystSignoff: false,
    resultsVisible: false,
    editWarningAccepted: false,
    isBeginningWorkspaceEdit: false,
    isHydrating: false,
    isDirty: false,
    chartInstances: {},
    cache: {
        databases: {},
        tables: {},
        columns: {}
    }
};

function usesClientComparison(data) {
    return !!(data?.clientTableName && data?.clientJoinColumn);
}

function getRule34CensusValueLabel(data) {
    return usesClientComparison(data) ? 'Client Census Date' : 'Stored Census Date';
}

function getRule34CensusColumnLabel(data) {
    return usesClientComparison(data) ? 'Client Census Date Column' : 'Census Date Column';
}

function findPreferredRule34Table(tables, preferredNames) {
    const normalizedPreferred = (preferredNames || []).map(name => String(name || '').trim().toUpperCase());
    return (tables || []).find(table => normalizedPreferred.includes(String(table || '').trim().toUpperCase())) || '';
}

function toggleAccordion(name) {
    const body = document.getElementById(`body-${name}`);
    const chevron = document.querySelector(`#acc-${name} .acc-chevron`);
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (chevron) chevron.textContent = open ? '^' : 'v';
}

function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelector(`.tab-btn[data-tab="${name}"]`)?.classList.add('active');
    document.querySelector(`[data-tab-panel="${name}"]`)?.classList.add('active');
}

function showSpinner(msg) {
    document.getElementById('spinnerMsg').textContent = msg || 'Processing...';
    if (spinnerDelayHandle) window.clearTimeout(spinnerDelayHandle);
    spinnerDelayHandle = window.setTimeout(() => {
        document.getElementById('spinner').style.display = 'flex';
        spinnerDelayHandle = null;
    }, 150);
}

function hideSpinner() {
    if (spinnerDelayHandle) {
        window.clearTimeout(spinnerDelayHandle);
        spinnerDelayHandle = null;
    }
    document.getElementById('spinner').style.display = 'none';
}

function setStatus(elId, msg, type) {
    const el = document.getElementById(elId);
    if (!el) return;
    el.innerHTML = `<div class="alert alert--${type || 'info'}">${msg}</div>`;
}

function setWorkspaceInfo(msg, type) {
    const el = document.getElementById('workspaceInfo');
    el.className = `alert alert--${type || 'info'}`;
    el.innerHTML = msg;
    window.showWorkspaceActionToast?.(msg, type || 'info');
}

function setWorkspaceRunState(text, type) {
    const el = document.getElementById('workspaceRunState');
    el.className = `badge badge--${type || 'neutral'} badge--sm`;
    el.textContent = text;
}

function updateHeaderBadge(status) {
    const badge = document.getElementById('statusBadge');
    if (!status) {
        badge.style.display = 'none';
        badge.textContent = '';
        return;
    }

    badge.style.display = 'inline-block';
    badge.className = `rule-header__badge ${String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    badge.textContent = String(status).toUpperCase();
}

function isArchivedWorkspace() {
    return String(state.currentStatus || '').toLowerCase() === 'archived';
}

async function post(url, data) {
    return await window.fetchJsonWithProgress(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
}

async function getJson(url) {
    return await window.fetchJsonWithProgress(url, { method: 'GET' });
}

async function downloadPost(url, data, filename) {
    await window.downloadFileWithProgress({
        url,
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        defaultFileName: filename,
        label: 'Downloading result'
    });
}

function resetWorkspaceState(clearClient) {
    state.server = '';
    state.database = '';
    state.driver = 'ODBC Driver 17 for SQL Server';
    state.tableName = '';
    state.clientTableName = '';
    state.firstDayColumn = '';
    state.lastDayColumn = '';
    state.censusDateColumn = '';
    state.clientJoinColumn = '';
    state.currentRunId = null;
    state.validationResult = null;
    state.currentUserEngagementRole = '';
    state.currentStatus = '';
    state.currentUserHasSignedOff = false;
    state.isWorkspaceSaved = false;
    state.hasDataAnalystSignoff = false;
    state.resultsVisible = false;
    state.editWarningAccepted = false;
    state.isDirty = false;
    if (clearClient) state.clientId = 0;

    document.getElementById('serverInput').value = '';
    document.getElementById('driverSelect').value = 'ODBC Driver 17 for SQL Server';
    document.getElementById('databaseSelect').innerHTML = '<option value="">Select database</option>';
    document.getElementById('tableSelect').innerHTML = '<option value="">Select table</option>';
    document.getElementById('clientTableSelect').innerHTML = '<option value="">Select table</option>';
    document.getElementById('firstDaySelect').innerHTML = '<option value="">Select column</option>';
    document.getElementById('lastDaySelect').innerHTML = '<option value="">Select column</option>';
    document.getElementById('censusDateSelect').innerHTML = '<option value="">Select column</option>';
    document.getElementById('blockColumnSelect').innerHTML = '<option value="">Select column</option>';
    document.getElementById('clientJoinColumnSelect').innerHTML = '<option value="">Select column</option>';
    document.getElementById('blockExcludeInput').value = '5, 5F, 8F, 8G, R0, R1, R2';
    document.getElementById('dbFieldGroup').style.display = 'none';
    document.getElementById('signoffComment').value = '';
    document.getElementById('verifyPreview').style.display = 'none';
    document.getElementById('downloadAllBtn').disabled = true;
    document.getElementById('connectionStatus').innerHTML = '';
    document.getElementById('configStatus').innerHTML = '';
    document.getElementById('validationContent').className = 'empty-state';
    document.getElementById('validationContent').innerHTML = '<p>Run validation to see results here.</p>';
    document.getElementById('exceptionsContent').className = 'empty-state';
    document.getElementById('exceptionsContent').innerHTML = '<p>No exceptions data yet. Run validation first.</p>';
    document.getElementById('chartsContent').className = 'empty-state';
    document.getElementById('chartsContent').innerHTML = '<p>Charts will appear after running validation.</p>';
    document.getElementById('sqlContent').className = 'empty-state';
    document.getElementById('sqlContent').innerHTML = '<p>Click "Generate SQL" or run validation to generate the SQL script.</p>';
    document.getElementById('downloadsContent').className = 'empty-state';
    document.getElementById('downloadsContent').innerHTML = '<p>Run validation first, then use "Download All" or the individual download buttons.</p>';
    updateHeaderBadge('');
    renderWorkspaceState();
}

function renderWorkspaceState() {
    const currentRole = state.currentUserEngagementRole || currentSystemRole;
    const canEdit = currentSystemRole === 'DataAnalyst' && !isArchivedWorkspace();
    const canSign = state.currentRunId && !isArchivedWorkspace() && (
        currentSystemRole === 'DataAnalyst' ||
        ((currentRole === 'Manager' || currentRole === 'Director') && state.resultsVisible)
    );
    const canActivateSignoff = !!canSign && !!state.isWorkspaceSaved;
    const signedOffLock = !!state.currentUserHasSignedOff;
    window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit || signedOffLock);
    window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit || signedOffLock);
    const signoffButtonText = state.currentUserHasSignedOff
        ? `Signed Off as ${currentRole || currentSystemRole || 'Reviewer'}`
        : `Sign Off as ${currentRole || currentSystemRole || 'Reviewer'}`;
    window.ruleWorkspaceUi.applyStates([
        { target: 'saveWorkspaceBtn', show: canEdit, disabled: !canEdit || !state.currentRunId || signedOffLock },
        { target: 'signOffBtn', show: canSign, disabled: !canActivateSignoff || signedOffLock, text: signoffButtonText },
        { target: 'removeWorkspaceSignoffBtn', show: canSign && state.currentUserHasSignedOff, disabled: !canSign || !state.currentUserHasSignedOff },
        { target: 'runValidationBtn', disabled: !canEdit || signedOffLock },
        { target: 'generateSqlBtn', disabled: !canEdit || signedOffLock },
        { target: 'signoffComment', disabled: !canActivateSignoff || signedOffLock }
    ]);
    window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions', '.action-bar'], signedOffLock, {
        allow: ['#downloadAllBtn', '#removeWorkspaceSignoffBtn']
    });
    applyWorkspaceAccessMode(canEdit);

    if (!state.currentRunId) {
        setWorkspaceRunState('No saved run loaded', 'neutral');
        return;
    }

    const badgeType = String(state.currentStatus || '').toUpperCase() === 'PASS' ? 'pass' :
        String(state.currentStatus || '').toLowerCase().includes('review') ? 'warning' :
        String(state.currentStatus || '').toUpperCase() === 'FAIL' ? 'fail' : 'neutral';
    setWorkspaceRunState(`Run #${state.currentRunId} | ${state.currentStatus || 'Saved'}`, badgeType);
}

function applyWorkspaceAccessMode(canEditWorkspace) {
    ['body-connection', 'body-config'].forEach(function(id) {
        var body = document.getElementById(id);
        if (!body) return;
        body.style.opacity = canEditWorkspace ? '' : '0.45';
        body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
        body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
            el.disabled = !canEditWorkspace;
        });
    });
}

async function markWorkspaceDirty() {
    if (state.isHydrating || currentSystemRole === 'Admin' || isArchivedWorkspace()) return;

    if (state.clientId && state.currentRunId && !state.editWarningAccepted) {
        if (state.isBeginningWorkspaceEdit) {
            state.isDirty = true;
            renderWorkspaceState();
            return;
        }

        const confirmed = window.confirm('Are you sure you want to edit this saved workspace? Existing signoffs will be removed and the run will need to be reviewed again.');
        if (!confirmed) {
            await loadWorkspaceState();
            return;
        }

        state.isBeginningWorkspaceEdit = true;
        state.editWarningAccepted = true;
        showSpinner('Clearing signoffs for the edited workspace...');
        try {
            const result = await post('/Rule34/BeginWorkspaceEdit', buildRequest());
            if (!result.success) {
                state.editWarningAccepted = false;
                setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to begin editing.')}`, 'error');
                await loadWorkspaceState();
                return;
            }

            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;
            if (result.workspace) applyWorkspaceReviewState(result.workspace);
            setWorkspaceInfo(result.message || 'Editing has begun. Existing signoffs were removed.', 'warning');
        } catch (error) {
            state.editWarningAccepted = false;
            setWorkspaceInfo(`Error: ${escapeHtml(error?.message || 'Failed to begin editing.')}`, 'error');
            await loadWorkspaceState();
        } finally {
            state.isBeginningWorkspaceEdit = false;
            hideSpinner();
        }
    }

    state.isDirty = true;
    renderWorkspaceState();
}

async function handleClientChange(value) {
    state.clientId = parseInt(value || '0') || 0;
    resetWorkspaceState(false);

    if (!state.clientId) {
        setWorkspaceInfo('Select an engagement to load the last saved Rule 34 workspace.', 'info');
        return;
    }

    await loadWorkspaceState();
}

function applyWorkspace(workspace, preserveMessage) {
    state.isHydrating = true;
    state.currentRunId = workspace.runId || null;
    state.server = workspace.server || '';
    state.database = workspace.database || '';
    state.driver = workspace.driver || 'ODBC Driver 17 for SQL Server';
    state.tableName = workspace.tableName || '';
    state.clientTableName = workspace.clientTableName || '';
    state.firstDayColumn = workspace.firstDayColumn || '';
    state.lastDayColumn = workspace.lastDayColumn || '';
    state.censusDateColumn = workspace.censusDateColumn || '';
    state.clientJoinColumn = workspace.clientJoinColumn || '';
    state.startYear = workspace.startYear || state.startYear;
    state.endYear = workspace.endYear || state.endYear;
    state.blockColumn = workspace.blockColumn || '';
    state.blockExcludeValues = workspace.blockExcludeValues || '5, 5F, 8F, 8G, R0, R1, R2';
    state.currentUserEngagementRole = workspace.currentUserEngagementRole || '';
    state.currentUserHasSignedOff = !!workspace.currentUserHasSignedOff;
    state.isWorkspaceSaved = !!workspace.isWorkspaceSaved;
    state.hasDataAnalystSignoff = !!workspace.hasDataAnalystSignoff;
    state.currentStatus = workspace.currentStatus || '';
    state.resultsVisible = !!workspace.resultsVisible;
    state.editWarningAccepted = false;
    state.isDirty = false;

    document.getElementById('serverInput').value = state.server;
    document.getElementById('driverSelect').value = state.driver;
    document.getElementById('startYearInput').value = state.startYear;
