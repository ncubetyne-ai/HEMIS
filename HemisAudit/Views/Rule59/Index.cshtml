@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 59 - SFTE VALPAC Data in STAFF PRODUCTION";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int cid ? cid : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

<style>
    .R59-table-wrap { overflow-x:auto; border:1px solid var(--rule15-table-border,#ddd); border-radius:14px; }
    .R59-grid { width:100%; border-collapse:collapse; font-family:Consolas,"Courier New",monospace; font-size:12px; }
    .R59-grid th, .R59-grid td { border:1px solid var(--rule15-table-border,#ddd); padding:8px 10px; text-align:left; vertical-align:top; }
    .R59-grid .group-valpac { background:#FFF3E0; }
    .R59-grid .group-prod   { background:#E8F5E9; }
    .R59-grid .group-final  { background:#F3E5F5; }
    .R59-grid .is-pass { color:#2e7d32; font-weight:800; }
    .R59-grid .is-fail { color:#c62828; font-weight:800; }
    .R59-summary-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name (@c.FiscalYear)</option>
            }
        </select>
        <small>Rule 59 checks that every record in <code>SFTE VALPAC</code> exists in <code>STAFF PRODUCTION</code> using <code>_037 &lt;&gt; PERSONEL_NUMBER</code>.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R59</div>
        <div>
            <h1 class="rule-header__title">HEMIS Rule 59: SFTE VALPAC Data in STAFF PRODUCTION</h1>
            <p class="rule-header__sub">Every <code>SFTE VALPAC._037</code> must exist in <code>STAFF PRODUCTION.PERSONEL_NUMBER</code>. PASS when found; FAIL when missing.</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                    <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-connection">
                    <div class="form-grid">
                        <div class="field-group"><label for="server">Server Name</label><input id="server" type="text" placeholder="e.g. MYSERVER\INSTANCE" /></div>
                        <div class="field-group">
                            <label for="driver">Driver</label>
                            <select id="driver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group"><label for="database">Database</label><select id="database"></select></div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    </div>
                    <div id="connectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                    <span class="acc-icon">CF</span><span>Rule Configuration</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-config" style="display:none">
                    <div class="info-box info-box--red">
                        <strong>Rule 59 Logic:</strong> Select all records from <strong>SFTE VALPAC</strong> where <code>_037</code> is not null/empty. For each record, find a matching row in <strong>STAFF PRODUCTION</strong> where <code>PERSONEL_NUMBER = _037</code>. PASS when found; FAIL when missing.
                    </div>
                    <div class="form-grid">
                        <div class="field-group"><label for="valpacTable">SFTE VALPAC Table</label><select id="valpacTable"></select></div>
                        <div class="field-group"><label for="prodTable">STAFF PRODUCTION Table</label><select id="prodTable"></select></div>
                        <div class="field-group"><label for="valpacCol037">VALPAC Column <small>(_037)</small></label><select id="valpacCol037"></select></div>
                        <div class="field-group"><label for="prodColPersonel">PRODUCTION Column <small>(PERSONEL_NUMBER)</small></label><select id="prodColPersonel"></select></div>
                    </div>
                    <div id="configOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                    <span class="acc-icon">DL</span><span>Export Options</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-downloads" style="display:none">
                    <div class="checkbox-row">
                        <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The latest Rule 59 connection, results, and signoffs reload automatically for this engagement.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 59 workspace.</div>
        <div class="workspace-signoff-grid">
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div><div id="workspaceRunLabel">No saved run yet</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div id="workspaceStatusLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div><div id="workspaceEditedLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div><div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div></div>
            <div class="field-group" style="grid-column:1 / -1"><label for="workspaceSignoffComment">Signoff Comment</label><textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea></div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
                <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            }
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove Signoff</button>
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="runBtn">Run Rule 59</button>
            <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
            <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="analysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="resultsPane"></div>
        <div class="tab-pane" data-tab-panel="sql"><textarea id="sqlText" rows="18" readonly></textarea></div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">Excel includes all results and a summary sheet. CSV exports the full result set. SQL shows the matching query. Save the workspace before downloading.</div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn" disabled>Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn" disabled>CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn" disabled>SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box"><div class="spinner-ring"></div><p id="spinnerMsg">Processing...</p></div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = function (section) {
    const body = document.getElementById(`body-${section}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

(() => {
    const apiBase = '/Rule59';
    const currentSystemRole = '@currentSystemRole';
    const isResultsOnlyRole = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';

    const state = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        currentRunId: null, summary: null, sql: '',
        resultsVisible: false, hasPendingValidation: false,
        currentUserEngagementRole: '', currentUserHasSignedOff: false,
        isWorkspaceSaved: false, hasDataAnalystSignoff: false,
        currentStatus: '', resultFilter: 'ALL'
    };

    const els = {
        clientId: document.getElementById('clientId'),
        server: document.getElementById('server'), driver: document.getElementById('driver'), database: document.getElementById('database'),
        valpacTable: document.getElementById('valpacTable'), prodTable: document.getElementById('prodTable'),
        valpacCol037: document.getElementById('valpacCol037'), prodColPersonel: document.getElementById('prodColPersonel'),
        connectionOutput: document.getElementById('connectionOutput'), configOutput: document.getElementById('configOutput'),
        analysisPane: document.getElementById('analysisPane'), resultsPane: document.getElementById('resultsPane'),
        sqlText: document.getElementById('sqlText'), downloadAllBtn: document.getElementById('downloadAllBtn'),
        workspaceInfo: document.getElementById('workspaceInfo'), workspaceRunState: document.getElementById('workspaceRunState'),
        workspaceRunLabel: document.getElementById('workspaceRunLabel'), workspaceStatusLabel: document.getElementById('workspaceStatusLabel'),
        workspaceEditedLabel: document.getElementById('workspaceEditedLabel'), workspaceRoleLabel: document.getElementById('workspaceRoleLabel'),
        workspaceSignoffComment: document.getElementById('workspaceSignoffComment'),
        beginEditBtn: document.getElementById('beginEditBtn'), saveWorkspaceBtn: document.getElementById('saveWorkspaceBtn'),
        signoffBtn: document.getElementById('signoffBtn'), removeSignoffBtn: document.getElementById('removeSignoffBtn'),
        downloadExcelBtn: document.getElementById('downloadExcelBtn'),
        downloadCsvBtn: document.getElementById('downloadCsvBtn'),
        downloadSqlBtn: document.getElementById('downloadSqlBtn'),
        statusBadge: document.getElementById('statusBadge')
    };

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    tabButtons.forEach(btn => btn.addEventListener('click', () => setActiveTab(btn.dataset.tab)));

    function showSpinner(msg) { document.getElementById('spinnerMsg').textContent = msg || 'Processing...'; document.getElementById('spinner').style.display = 'flex'; }
    function hideSpinner() { document.getElementById('spinner').style.display = 'none'; }
    function escapeHtml(v) { return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#39;'); }
    function formatNumber(v) { return Number(v || 0).toLocaleString(); }
    function normalizeRole(v) { return String(v || '').replace(/[^a-z0-9]+/gi,'').toLowerCase(); }
    function setAlert(target, type, message) { if (target) target.innerHTML = `<div class="alert alert--${type}">${message}</div>`; }
    function setWorkspaceState(message, type) { els.workspaceInfo.className = `alert alert--${type}`; els.workspaceInfo.textContent = message || ''; }
    function setStatusBadge(text, type) {
        if (!text) { els.statusBadge.style.display='none'; return; }
        els.statusBadge.style.display='inline-block';
        els.statusBadge.className=`rule-header__badge ${type==='fail'?'badge--fail':'badge--pass'}`;
        els.statusBadge.textContent=text;
    }
    function setActiveTab(tab) {
        tabButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.toggle('active', pane.dataset.tabPanel === tab));
        if (tab === 'results') setTimeout(() => renderResults(true), 0);
    }

    async function postJson(url, data) {
        return await window.fetchJsonWithProgress(url, { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(data) });
    }
    async function downloadBlob(url, payload, defaultName) {
        await window.downloadFileWithProgress({ url, method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(payload), defaultFileName:defaultName, label:'Downloading' });
    }
    function openSavedDownload(kind) {
        if (!state.currentRunId) {
            setWorkspaceState('Save or load a Rule 59 run before downloading results.','warning');
            setActiveTab('downloads');
            return;
        }

        const routes = {
            excel: `${apiBase}/DownloadSavedExcel?runId=${state.currentRunId}`,
            csv: `${apiBase}/DownloadSavedCsv?runId=${state.currentRunId}`,
            sql: `${apiBase}/DownloadSavedSql?runId=${state.currentRunId}`
        };

        const url = routes[kind];
        if (!url) return;
        window.open(url, '_blank');
    }

    function populateSelect(sel, values, selected) {
        if (!sel) return;
        sel.innerHTML = '<option value="">Select table</option>';
        values.forEach(v => { const o = document.createElement('option'); o.value = o.textContent = v; sel.appendChild(o); });
        if (selected) sel.value = selected;
    }
    function fillColSel(sel, cols, preferred) {
        if (!sel) return;
        sel.innerHTML = '';
        (cols || []).forEach(c => { const o = document.createElement('option'); o.value = o.textContent = c; if (c === preferred) o.selected = true; sel.appendChild(o); });
        if (!sel.value && cols.length) sel.value = cols[0];
    }

    function getRequest() {
        return {
            clientId: parseInt(els.clientId?.value||'0',10)||0,
            runId: state.currentRunId,
            server: els.server?.value?.trim()||'',
            database: els.database?.value||'',
            driver: els.driver?.value||'ODBC Driver 17 for SQL Server',
            valpacTable: els.valpacTable?.value||'dbo_SFTE_VALPAC',
            prodTable:   els.prodTable?.value||'dbo_STAFF_PRODUCTION',
            valpacCol037: els.valpacCol037?.value||'_037',
            prodColPersonelNumber: els.prodColPersonel?.value||'PERSONEL_NUMBER'
        };
    }

    async function loadColsForTable(sel, tableName, preferred) {
        const server = els.server?.value?.trim(); const db = els.database?.value;
        if (!server || !db || !tableName || !sel) return;
        try {
            const data = await postJson(`${apiBase}/GetColumns`, { server, database: db, driver: els.driver?.value||'ODBC Driver 17 for SQL Server', valpacTable: tableName });
            if (data.success && data.columns) fillColSel(sel, data.columns, preferred);
        } catch (e) { /* silently ignore */ }
    }

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role);
        const hasUnsaved = !!state.summary && (!!state.hasPendingValidation || (!state.currentRunId && !state.isWorkspaceSaved));
        const canEdit = !isResultsOnlyRole && (normalizeRole(currentSystemRole)==='dataanalyst'||normalizedRole==='dataanalyst'||hasUnsaved);
        const canSign = !state.hasPendingValidation && !!state.currentRunId && !!state.isWorkspaceSaved &&
            (normalizedRole==='dataanalyst' || (state.resultsVisible && (normalizedRole==='manager'||normalizedRole==='director')));
        const signoffLocked = !!state.currentUserHasSignedOff;
        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.applyStates([
            {target:'connectBtn',disabled:!canEdit||signoffLocked},
            {target:'verifyBtn',disabled:!canEdit||signoffLocked},
            {target:'runBtn',disabled:!canEdit||signoffLocked},
            {target:'sqlBtn',disabled:!canEdit||signoffLocked},
            {target:els.beginEditBtn,disabled:signoffLocked||!canEdit||!state.currentRunId||state.hasPendingValidation},
            {target:els.saveWorkspaceBtn,disabled:signoffLocked||!canEdit||!hasUnsaved},
            {target:els.signoffBtn,disabled:signoffLocked||!canSign,text:state.currentUserHasSignedOff?`Signed Off as ${role||currentSystemRole}`:'Save Signoff'},
            {target:els.removeSignoffBtn,show:state.currentUserHasSignedOff,display:'',disabled:!state.currentUserHasSignedOff},
            {target:els.workspaceSignoffComment,disabled:signoffLocked||!canSign},
            {target:els.downloadAllBtn,disabled:!state.summary},
            {target:els.downloadExcelBtn,disabled:!state.currentRunId},
            {target:els.downloadCsvBtn,disabled:!state.currentRunId},
            {target:els.downloadSqlBtn,disabled:!state.currentRunId}
        ]);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions','.action-bar'],signoffLocked,{allow:['#downloadAllBtn','#downloadExcelBtn','#downloadCsvBtn','#downloadSqlBtn','#removeSignoffBtn']});
        applyWorkspaceAccessMode(canEdit);
    }

    function applyWorkspaceAccessMode(canEditWorkspace) {
        ['body-connection', 'body-config'].forEach(function(id) {
            var body = document.getElementById(id);
            if (!body) return;
            body.style.opacity = canEditWorkspace ? '' : '0.45';
            body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
            body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
                el.disabled = !canEditWorkspace;
            });
        });
    }

    function applySummary(summary, options = {}) {
        state.summary = summary;
        if (!options.fromWorkspace) state.currentRunId = summary?.savedRunId||state.currentRunId;
        state.currentStatus = summary?.status||state.currentStatus;
        state.resultsVisible = !!summary||state.resultsVisible;
        if (!summary) { if(els.analysisPane) els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 59 results loaded.</p></div>'; if(els.resultsPane) els.resultsPane.innerHTML=''; setStatusBadge('','pass'); updateWorkspaceButtons(); return; }
        setStatusBadge(summary.status, summary.failCount>0?'fail':'pass');
        renderAnalysis(summary); renderResults(); updateWorkspaceButtons();
    }

    function applyWorkspace(workspace, resultsVisible, preserveExistingSummary = false) {
        if (!workspace) {
            state.currentRunId=null;state.currentStatus='';state.currentUserEngagementRole='';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=false;state.hasPendingValidation=false;
            els.workspaceRunState.textContent='No saved run loaded';els.workspaceRunLabel.textContent='No saved run yet';els.workspaceStatusLabel.textContent='-';els.workspaceEditedLabel.textContent='-';
            setWorkspaceState('No saved Rule 59 workspace exists for this engagement yet.','info');
            if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
            return;
        }
        state.clientId=workspace.clientId||state.clientId;state.currentRunId=workspace.runId||null;state.currentStatus=workspace.currentStatus||'';
        state.currentUserEngagementRole=workspace.currentUserEngagementRole||currentSystemRole||'';state.currentUserHasSignedOff=!!workspace.currentUserHasSignedOff;
        state.isWorkspaceSaved=!!workspace.isWorkspaceSaved;state.hasDataAnalystSignoff=!!workspace.hasDataAnalystSignoff;state.resultsVisible=!!resultsVisible;state.hasPendingValidation=false;
        if(els.server) els.server.value=workspace.server||'';
        if(els.driver) els.driver.value=workspace.driver||'ODBC Driver 17 for SQL Server';
        populateSelect(els.database, workspace.database?[workspace.database]:[], workspace.database);
        populateSelect(els.valpacTable, workspace.valpacTable?[workspace.valpacTable]:[], workspace.valpacTable);
        populateSelect(els.prodTable, [workspace.prodTable||'dbo_STAFF_PRODUCTION'], workspace.prodTable||'dbo_STAFF_PRODUCTION');
        if(els.valpacCol037) { els.valpacCol037.innerHTML=`<option value="${escapeHtml(workspace.valpacCol037||'_037')}">${escapeHtml(workspace.valpacCol037||'_037')}</option>`; els.valpacCol037.value=workspace.valpacCol037||'_037'; }
        if(els.prodColPersonel) { els.prodColPersonel.innerHTML=`<option value="${escapeHtml(workspace.prodColPersonelNumber||'PERSONEL_NUMBER')}">${escapeHtml(workspace.prodColPersonelNumber||'PERSONEL_NUMBER')}</option>`; els.prodColPersonel.value=workspace.prodColPersonelNumber||'PERSONEL_NUMBER'; }
        els.workspaceRunState.textContent=workspace.runId?`Run #${workspace.runId}`:'No saved run loaded';
        els.workspaceRunLabel.textContent=workspace.runId?`Rule 59 Run #${workspace.runId}`:'No saved run yet';
        els.workspaceStatusLabel.textContent=workspace.currentStatus||'-';
        els.workspaceEditedLabel.textContent=workspace.lastEditedAt?new Date(workspace.lastEditedAt).toLocaleString():'-';
        els.workspaceRoleLabel.textContent=workspace.currentUserEngagementRole||currentSystemRole||'-';
        els.workspaceSignoffComment.value=workspace.currentUserSignoffComment||'';
        if (!resultsVisible) { setWorkspaceState('Saved Rule 59 results are not available for your engagement role.','info'); if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons(); return; }
        setWorkspaceState(workspace.summary?'Saved workspace loaded.':'Rule 59 workspace loaded. Run validation to generate results.','success');
        if (workspace.summary) applySummary(workspace.summary,{fromWorkspace:true}); else if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
    }

    async function loadWorkspace() {
        state.clientId=Number(els.clientId?.value||0);
        if (!state.clientId) { applyWorkspace(null,false); return; }
        const data = await window.fetchJsonWithProgress(`${apiBase}/GetWorkspaceState?clientId=${state.clientId}`,{method:'GET'});
        if (!data.success) throw new Error(data.error||'Failed to load workspace.');
        applyWorkspace(data.workspace, data.resultsVisible);
    }

    async function connect() {
        const server = els.server?.value?.trim();
        if (!server) throw new Error('Enter the SQL Server name first.');
        showSpinner('Loading databases...');
        try {
            const data = await postJson(`${apiBase}/GetDatabases`, {server, driver:els.driver.value});
            if (!data.success) throw new Error(data.error||'Connection failed.');
            els.database.innerHTML='<option value="">Select database</option>';
            data.databases.forEach(db => { const o=document.createElement('option');o.value=o.textContent=db;els.database.appendChild(o); });
            setAlert(els.connectionOutput,'success',`Connected. Found ${data.databases.length} database(s).`);
            if (data.databases.length) await loadTables();
        } finally { hideSpinner(); }
    }

    async function loadTables() {
        if (!els.database.value) return;
        const data = await postJson(`${apiBase}/GetTables`, {server:els.server.value.trim(), database:els.database.value, driver:els.driver.value});
        if (!data.success) throw new Error(data.error||'Could not load tables.');
        populateSelect(els.valpacTable, data.tables||[], data.autoValpacTable);
        populateSelect(els.prodTable, data.tables||[], data.autoProdTable);
        if (els.valpacTable.value) await loadColsForTable(els.valpacCol037, els.valpacTable.value, '_037');
        if (els.prodTable.value)   await loadColsForTable(els.prodColPersonel, els.prodTable.value, 'PERSONEL_NUMBER');
        setAlert(els.configOutput,'success',`Loaded ${data.tables.length} table(s).`);
    }

    async function verifyTables() {
        showSpinner('Verifying Rule 59 tables...');
        try {
            const data = await postJson(`${apiBase}/VerifyTables`, getRequest());
            if (!data.success) throw new Error(data.error||'Verification failed.');
            setAlert(els.configOutput,'success',`VALPAC rows: <strong>${formatNumber(data.valpacRecordCount)}</strong> | PRODUCTION rows: <strong>${formatNumber(data.prodRecordCount)}</strong> | Total tested: <strong>${formatNumber(data.totalTested)}</strong> | Matched: <strong>${formatNumber(data.matchedCount)}</strong> | Missing: <strong>${formatNumber(data.missingCount)}</strong>`);
        } finally { hideSpinner(); }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) { setWorkspaceState('Select the approved engagement assigned to you before running this rule.','warning'); return; }
        showSpinner('Running Rule 59 SFTE VALPAC in STAFF PRODUCTION validation...');
        try {
            const data = await postJson(`${apiBase}/RunValidation`, request);
            if (!data.success) throw new Error(data.error||'Rule 59 failed.');
            state.hasPendingValidation=true;state.currentRunId=data.savedRunId||null;state.currentStatus=data.status||'';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=true;
            state.currentUserEngagementRole=state.currentUserEngagementRole||currentSystemRole||'DataAnalyst';
            applySummary(data);
            setWorkspaceState(`Rule 59 completed. Total tested: ${formatNumber(data.totalValidated)} | Matched: ${formatNumber(data.passCount)} | Missing: ${formatNumber(data.failCount)}. Click Save Workspace before signoff.`,'success');
        } finally { hideSpinner(); }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try { const data=await postJson(`${apiBase}/GenerateSql`,getRequest()); if(!data.success) throw new Error(data.error||'SQL generation failed.'); state.sql=data.sql||''; els.sqlText.value=state.sql; setActiveTab('sql'); } finally { hideSpinner(); }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try { const data=await postJson(`${apiBase}/BeginWorkspaceEdit`,getRequest()); if(!data.success) throw new Error(data.error||'Could not begin editing.'); applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace ready for editing.','warning'); } finally { hideSpinner(); }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try { const data=await postJson(`${apiBase}/SaveWorkspace`,getRequest()); if(!data.success) throw new Error(data.error||'Could not save workspace.'); state.hasPendingValidation=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace saved.',data.signoffsCleared?'warning':'success'); } finally { hideSpinner(); }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try { const data=await postJson(`${apiBase}/SignOffWorkspace`,{clientId:state.clientId,runId:state.currentRunId,comment:els.workspaceSignoffComment.value.trim()}); if(!data.success) throw new Error(data.error||'Signoff failed.'); state.currentUserHasSignedOff=true; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Signoff saved.','success'); } finally { hideSpinner(); }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try { const prevRunId=state.currentRunId; const data=await postJson(`${apiBase}/RemoveWorkspaceSignoff`,{clientId:state.clientId,runId:state.currentRunId,comment:''}); if(!data.success) throw new Error(data.error||'Could not remove signoff.'); state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,!!(data.workspace&&prevRunId&&data.workspace.runId===prevRunId)); setWorkspaceState(data.message||'Signoff removed.','warning'); } finally { hideSpinner(); }
    }

    function renderAnalysis(summary) {
        if (!summary || !els.analysisPane) { if(els.analysisPane) els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 59 results loaded.</p></div>'; return; }
        const failRows = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='FAIL');
        const passRows = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='PASS');
        const v037=summary.valpacCol037||'_037'; const pPersonel=summary.prodColPersonelNumber||'PERSONEL_NUMBER';

        const failRowHtml = failRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            return `<tr style="background:#FFF3F3"><td>${row.validationNumber}</td><td style="font-weight:700;color:#c62828">${escapeHtml(v.VALPAC__037||'')}</td><td style="color:#c62828;font-style:italic">Not found in PRODUCTION</td></tr>`;
        }).join('');

        const passRowHtml = passRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            return `<tr style="background:#F3FFF3"><td>${row.validationNumber}</td><td style="font-weight:700;color:#2e7d32">${escapeHtml(v.VALPAC__037||'')}</td><td>${escapeHtml(v.PROD_PERSONEL_NUMBER||'')}</td></tr>`;
        }).join('');

        els.analysisPane.innerHTML=`
            ${summary.isPreviewOnly?`<div class="alert alert--warning" style="margin-bottom:16px">Browser shows a preview of ${summary.previewLimit.toLocaleString()} rows prioritising FAIL records. Download Excel/CSV for the complete result set.</div>`:''}
            <div class="R59-summary-grid">
                <div class="stat-card"><div class="stat-card__label">VALPAC Records</div><div class="stat-card__value">${formatNumber(summary.valpacRecordCount)}</div></div>
                <div class="stat-card"><div class="stat-card__label">PRODUCTION Records</div><div class="stat-card__value">${formatNumber(summary.prodRecordCount)}</div></div>
                <div class="stat-card"><div class="stat-card__label">Total Tested</div><div class="stat-card__value">${formatNumber(summary.totalValidated)}</div></div>
                <div class="stat-card stat-card--pass"><div class="stat-card__label">Found in PRODUCTION</div><div class="stat-card__value">${formatNumber(summary.passCount)}</div></div>
                <div class="stat-card stat-card--fail"><div class="stat-card__label">Missing from PRODUCTION</div><div class="stat-card__value">${formatNumber(summary.failCount)}</div></div>
            </div>
            ${summary.failCount>0?`<div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #c62828"><h3 class="section-title" style="margin-top:0;color:#c62828">Missing from PRODUCTION (FAIL) — ${formatNumber(summary.failCount)} record(s)</h3>${failRows.length===0?`<div class="alert alert--info">No FAIL rows in this preview. Download for the full list.</div>`:`<div class="R59-table-wrap"><table class="R59-grid"><thead><tr><th>#</th><th class="group-valpac">${escapeHtml(v037)} (VALPAC)</th><th class="group-prod">PRODUCTION match</th></tr></thead><tbody>${failRowHtml}</tbody></table></div>`}</div>`:`<div class="alert alert--success" style="margin-top:16px">All ${formatNumber(summary.totalValidated)} SFTE VALPAC records found in STAFF PRODUCTION.</div>`}
            ${summary.passCount>0?`<div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #2e7d32"><h3 class="section-title" style="margin-top:0;color:#2e7d32">Found in PRODUCTION (PASS) — ${formatNumber(summary.passCount)} record(s)</h3>${passRows.length===0?`<div class="alert alert--info">No PASS rows in this preview (FAIL-prioritised). Download for all matched records.</div>`:`<div class="R59-table-wrap"><table class="R59-grid"><thead><tr><th>#</th><th class="group-valpac">${escapeHtml(v037)} (VALPAC)</th><th class="group-prod">${escapeHtml(pPersonel)} (PRODUCTION)</th></tr></thead><tbody>${passRowHtml}</tbody></table></div>`}</div>`:''
            }
            <div class="card" style="padding:20px;margin-top:20px"><h3 class="section-title" style="margin-top:0">Run Summary</h3><div class="form-grid"><div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>${escapeHtml(summary.database)}</div></div><div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">VALPAC Table</div><div>${escapeHtml(summary.valpacTable||'')}</div></div><div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">PRODUCTION Table</div><div>${escapeHtml(summary.prodTable||'')}</div></div><div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><span class="badge ${summary.failCount===0?'badge--pass':'badge--fail'}">${escapeHtml(summary.status)}</span></div></div></div></div>`;
    }

    function renderResults(force = false) {
        if (!state.summary || !els.resultsPane) { if(els.resultsPane) els.resultsPane.innerHTML='<div class="empty-card"><p>No Rule 59 results loaded.</p></div>'; return; }
        if (!force && document.querySelector('.tab-btn.active')?.dataset.tab!=='results') { els.resultsPane.innerHTML='<div class="empty-card"><p>Open the Results tab to load the browser preview.</p></div>'; return; }
        const summary=state.summary;
        const v037=summary.valpacCol037||'_037'; const pPersonel=summary.prodColPersonelNumber||'PERSONEL_NUMBER';
        const rows=(summary.reviewRows||[]).filter(r=>state.resultFilter==='ALL'||String(r.validationResult||'').toUpperCase()===state.resultFilter);

        const rowHtml=rows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const isFail=String(row.validationResult||'').toUpperCase()==='FAIL';
            return `<tr><td class="group-valpac ${isFail?'is-fail':''}">${escapeHtml(v.VALPAC__037||'')}</td><td class="group-prod ${isFail?'is-fail':''}">${escapeHtml(v.PROD_PERSONEL_NUMBER||'')}</td><td class="group-final ${isFail?'is-fail':'is-pass'}">${escapeHtml(isFail?'FAIL':'PASS')}: ${escapeHtml(v.FINAL_RESULT_MESSAGE||'')}</td></tr>`;
        }).join('');

        els.resultsPane.innerHTML=`<div style="display:flex;gap:12px;align-items:flex-end;margin-bottom:16px"><div class="field-group" style="margin:0;min-width:180px"><label style="font-size:12px;font-weight:700;text-transform:uppercase;color:var(--text-muted)">Result Filter</label><select id="liveResultFilter"><option value="ALL">All results</option><option value="FAIL">FAIL — Missing</option><option value="PASS">PASS — Found</option></select></div></div>${summary.isPreviewOnly?`<div class="alert alert--warning" style="margin-bottom:12px">Only browser preview shown.</div>`:''}<div class="R59-table-wrap"><table class="R59-grid"><thead><tr><th class="group-valpac">${escapeHtml(summary.valpacTable||'SFTE VALPAC')}</th><th class="group-prod">${escapeHtml(summary.prodTable||'STAFF PRODUCTION')}</th><th class="group-final">Final Result</th></tr><tr><th class="group-valpac">${escapeHtml(v037)}</th><th class="group-prod">${escapeHtml(pPersonel)}</th><th class="group-final">pass/fail</th></tr></thead><tbody>${rowHtml}</tbody></table></div>`;
        const liveFilter=document.getElementById('liveResultFilter');
        if(liveFilter){liveFilter.value=state.resultFilter;liveFilter.addEventListener('change',()=>{state.resultFilter=liveFilter.value;renderResults(true);});}
    }

    if (!isResultsOnlyRole) {
        els.database?.addEventListener('change', () => loadTables().catch(err=>setAlert(els.configOutput,'error',escapeHtml(err.message))));
        els.valpacTable?.addEventListener('change', () => loadColsForTable(els.valpacCol037, els.valpacTable.value, '_037'));
        els.prodTable?.addEventListener('change', () => loadColsForTable(els.prodColPersonel, els.prodTable.value, 'PERSONEL_NUMBER'));
        document.getElementById('connectBtn')?.addEventListener('click', () => connect().catch(err=>{hideSpinner();setAlert(els.connectionOutput,'error',escapeHtml(err.message));}));
        document.getElementById('verifyBtn')?.addEventListener('click', () => verifyTables().catch(err=>{hideSpinner();setAlert(els.configOutput,'error',escapeHtml(err.message));}));
        document.getElementById('runBtn')?.addEventListener('click', () => runValidation().catch(err=>{hideSpinner();setWorkspaceState(err.message,'error');}));
        document.getElementById('sqlBtn')?.addEventListener('click', () => generateSql().catch(err=>{hideSpinner();if(els.sqlText)els.sqlText.value=err.message;}));
        els.beginEditBtn?.addEventListener('click', () => beginEdit().catch(err=>{hideSpinner();setWorkspaceState(err.message,'error');}));
        els.saveWorkspaceBtn?.addEventListener('click', () => saveWorkspace().catch(err=>{hideSpinner();setWorkspaceState(err.message,'error');}));
        els.downloadAllBtn?.addEventListener('click', () => {
            if (!state.currentRunId) { setWorkspaceState('Save the workspace before downloading.','warning'); return; }
            const id = state.currentRunId;
            if (document.getElementById('chkExcel')?.checked) window.open(`/Rule59/DownloadSavedExcel?runId=${id}`, '_blank');
            if (document.getElementById('chkCsv')?.checked)   window.open(`/Rule59/DownloadSavedCsv?runId=${id}`, '_blank');
            if (document.getElementById('chkSql')?.checked)   window.open(`/Rule59/DownloadSavedSql?runId=${id}`, '_blank');
        });
    }

    els.downloadExcelBtn?.addEventListener('click', () => openSavedDownload('excel'));
    els.downloadCsvBtn?.addEventListener('click', () => openSavedDownload('csv'));
    els.downloadSqlBtn?.addEventListener('click', () => openSavedDownload('sql'));
    els.signoffBtn?.addEventListener('click', () => signoffWorkspace().catch(err=>{hideSpinner();setWorkspaceState(err.message,'error');}));
    els.removeSignoffBtn?.addEventListener('click', () => removeWorkspaceSignoff().catch(err=>{hideSpinner();setWorkspaceState(err.message,'error');}));
    els.clientId?.addEventListener('change', () => loadWorkspace().catch(err=>setWorkspaceState(err.message,'error')));

    renderAnalysis(null); renderResults(); updateWorkspaceButtons();
    if (state.clientId) loadWorkspace().catch(err=>setWorkspaceState(err.message,'error'));
    else if (isResultsOnlyRole) setWorkspaceState('Select an engagement to load the saved Rule 59 results.','info');
})();
</script>