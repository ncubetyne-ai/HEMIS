@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 51 - VALPAC Data in Production";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int currentClientId ? currentClientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

<style>
    .R51-results-wrap { display:grid; gap:24px; }
    .R51-table-wrap { overflow-x:auto; border:1px solid var(--rule15-table-border); border-radius:14px; background:var(--rule15-card-alt); }
    .R51-grid { width:100%; min-width:960px; border-collapse:collapse; table-layout:fixed; }
    .R51-grid th, .R51-grid td { border:1px solid var(--rule15-table-border); padding:8px 10px; text-align:left; white-space:normal; word-break:normal; overflow-wrap:anywhere; vertical-align:top; font-family:Consolas,"Courier New",monospace; font-size:12px; color:var(--text); }
    .R51-grid .group-valpac { background:var(--rule15-group-stud); }
    .R51-grid .group-prod   { background:var(--rule15-group-bridge); }
    .R51-grid .group-final  { background:var(--rule15-group-final); }
    .R51-grid .is-pass { color:var(--rule15-pass); font-weight:800; }
    .R51-grid .is-fail { color:var(--rule15-fail); font-weight:800; }
    .R51-grid .result-text  { font-weight:800; margin-bottom:4px; display:block; }
    .R51-grid .message-text { display:block; }
    .R51-filterbar { display:flex; gap:12px; flex-wrap:wrap; align-items:end; margin-bottom:18px; }
    .R51-filterbar label { font-size:12px; font-weight:700; text-transform:uppercase; color:var(--text-muted); display:block; margin-bottom:6px; }
    .R51-summary-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>Rule 51 checks that all data from <code>STUD VALPAC</code> exists in <code>STUD PRODUCTION</code> using 4 mapped columns.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R51</div>
        <div>
            <h1 class="rule-header__title">HEMIS Rule 51: VALPAC Data in Production</h1>
            <p class="rule-header__sub">Every record in <code>STUD VALPAC</code> must be present in <code>STUD PRODUCTION</code> on all 4 mapped columns. PASS when found; FAIL when missing.</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                    <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-connection">
                    <div class="form-grid">
                        <div class="field-group"><label for="server">Server Name</label><input id="server" type="text" placeholder="e.g. MYSERVER\INSTANCE" /></div>
                        <div class="field-group">
                            <label for="driver">Driver</label>
                            <select id="driver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group"><label for="database">Database</label><select id="database"></select></div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    </div>
                    <div id="connectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                    <span class="acc-icon">CF</span><span>Rule Configuration</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-config" style="display:none">
                    <div class="info-box info-box--red">
                        <strong>Rule 51 Logic:</strong><br />
                        Select all records from <strong>STUD VALPAC</strong> and attempt to find a matching row in <strong>STUD PRODUCTION</strong> using all 4 mapped columns simultaneously.<br />
                        Mapped columns: <code>_007 &lt;&gt; IAGSTNO</code> | <code>_008 &lt;&gt; IADIDNO</code> | <code>_001 &lt;&gt; IAGQUAL</code> | <code>ColYear &lt;&gt; IAGCYR</code>
                    </div>
                    <div class="form-grid">
                        <div class="field-group"><label for="valpacTable">STUD VALPAC Table</label><select id="valpacTable" onchange="loadCols('valpac', this.value)"></select></div>
                        <div class="field-group"><label for="prodTable">STUD PRODUCTION Table</label><select id="prodTable" onchange="loadCols('prod', this.value)"></select></div>
                    </div>
                    <div class="form-grid" style="margin-top:12px">
                        <div class="field-group"><label>VALPAC Student No. <small>(_007)</small></label><select id="valpacCol007"><option value="_007">_007</option></select></div>
                        <div class="field-group"><label>VALPAC ID No. <small>(_008)</small></label><select id="valpacCol008"><option value="_008">_008</option></select></div>
                        <div class="field-group"><label>VALPAC Qual Code <small>(_001)</small></label><select id="valpacCol001"><option value="_001">_001</option></select></div>
                        <div class="field-group"><label>VALPAC Year <small>(ColYear)</small></label><select id="valpacColYear"><option value="ColYear">ColYear</option></select></div>
                        <div class="field-group"><label>PROD Student No. <small>(IAGSTNO)</small></label><select id="prodColStNo"><option value="IAGSTNO">IAGSTNO</option></select></div>
                        <div class="field-group"><label>PROD ID No. <small>(IADIDNO)</small></label><select id="prodColIdNo"><option value="IADIDNO">IADIDNO</option></select></div>
                        <div class="field-group"><label>PROD Qual Code <small>(IAGQUAL)</small></label><select id="prodColQual"><option value="IAGQUAL">IAGQUAL</option></select></div>
                        <div class="field-group"><label>PROD Year <small>(IAGCYR)</small></label><select id="prodColYear"><option value="IAGCYR">IAGCYR</option></select></div>
                    </div>
                    <div class="form-grid" style="margin-top:12px;border-top:1px solid var(--rule15-table-border);padding-top:12px">
                        <div class="field-group"><label>VALPAC Citizen/Resident Status <small>(_049)</small></label><select id="valpacCol049"><option value="_049">_049</option></select></div>
                        <div class="field-group"><label>SA/PR National Values <small>(comma-separated, e.g. SA,PR)</small></label><input id="saNationalValues" type="text" value="SA,PR" placeholder="e.g. SA,PR" style="font-family:Consolas,monospace" /></div>
                        <div class="field-group"><label>_008 ID Placeholder Values <small>(all-Z values, comma-separated)</small></label><input id="valpacCol008ZPlaceholders" type="text" value="ZZZZZZZZZZZZZ" placeholder="e.g. ZZZZZZZZZZZZZ" style="font-family:Consolas,monospace" /></div>
                    </div>
                    <div class="alert alert--info" style="margin-top:10px;font-size:12px">
                        <strong>Foreign National Exemption (_049 + _008):</strong> If a student's citizen/resident status (_049) is <strong>not</strong> in the SA/PR values list, their ID (_008) matches one of the Z-placeholder values, and PROD has no IADIDNO — the record is <strong>PASS (Foreign National Exempt)</strong>. If _049 <em>is</em> in the list (e.g. SA or PR), a matching IADIDNO <strong>must</strong> exist in PRODUCTION or the record FAILs.
                    </div>
                    <div class="form-grid" style="margin-top:12px;border-top:1px solid var(--rule15-table-border);padding-top:12px">
                        <div class="field-group">
                            <label>CREG Table <small>(optional — for NOT IN CREG check)</small></label>
                            <select id="cregTable"><option value="">— Not configured (skip CREG check) —</option></select>
                        </div>
                        <div class="field-group">
                            <label>CREG Student No. Column <small>(student number col in CREG)</small></label>
                            <select id="cregIdCol"><option value="_007">_007</option></select>
                        </div>
                    </div>
                    <div class="alert alert--info" style="margin-top:10px;font-size:12px">
                        <strong>CREG Not-In-Service Check (optional):</strong> If a VALPAC student is not found in PRODUCTION, the system will also check CREG.
                        If the student does <strong>not</strong> exist in CREG either, this is <strong>not an exception</strong> — the university never provided a service for that student.
                        Leave CREG Table blank to skip this check.
                    </div>
                    <div class="form-grid" style="margin-top:12px;border-top:1px solid var(--rule15-table-border);padding-top:12px">
                        <div class="field-group">
                            <label>CREG Completion Status Column <small>(_032 — Course completion status)</small></label>
                            <select id="cregCompletionStatusCol"><option value="_032">_032</option></select>
                        </div>
                        <div class="field-group">
                            <label>CREG Completion Status Filter <small>(comma separated, e.g. W,F)</small></label>
                            <input id="cregCompletionStatusValues" type="text" value="W" placeholder="e.g. W" style="font-family:Consolas,monospace" />
                        </div>
                    </div>
                    <div class="alert alert--info" style="margin-top:10px;font-size:12px">
                        <strong>CREG Withdrawn/Completion Status Check (optional):</strong> HEMIS element <code>032</code> (Course completion status) on CREG records: <code>C</code> = completed requirements, <code>S</code> = still in progress, <code>W</code> = withdrew after being registered, <code>F</code> = failed/refused admission/absent.
                        If a VALPAC student is not found in PRODUCTION but <strong>is</strong> in CREG with completion status matching this filter (default <code>W</code> — withdrew), this is <strong>not an exception</strong> — the student withdrew from the course registration, so absence from PRODUCTION is expected.
                        Requires CREG Table to be configured above. Leave the filter blank to disable this check.
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:10px 0 0">
                        <button type="button" class="btn btn-secondary" onclick="autoDetectColumns()">Auto-Detect Columns</button>
                    </div>
                    <div class="alert alert--info" style="margin-top:16px">
                        <strong>Control 1:</strong> All <code>[VALPAC]</code> records exist in <code>[PRODUCTION]</code> using all 4 mapped column pairs.<br />
                        Use Auto-Detect after connecting to populate column dropdowns.
                    </div>
                    <div id="configOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                    <span class="acc-icon">DL</span><span>Export Options</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-downloads" style="display:none">
                    <div class="checkbox-row">
                        <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The latest Rule 51 connection, results, and signoffs reload automatically for this engagement.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 51 workspace.</div>
        <div class="workspace-signoff-grid">
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div><div id="workspaceRunLabel">No saved run yet</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div id="workspaceStatusLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div><div id="workspaceEditedLabel">-</div></div>
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div><div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div></div>
            <div class="field-group" style="grid-column:1 / -1"><label for="workspaceSignoffComment">Signoff Comment</label><textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea></div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
                <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            }
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove Signoff</button>
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="runBtn">Run Rule 51</button>
            <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
            <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="analysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="resultsPane"></div>
        <div class="tab-pane" data-tab-panel="sql"><textarea id="sqlText" rows="18" readonly></textarea></div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">Excel includes all results and a summary sheet. CSV exports the full result set. SQL includes the 4-column join query.</div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn">Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn">CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn">SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box"><div class="spinner-ring"></div><p id="spinnerMsg">Processing...</p></div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = function (section) {
    const body = document.getElementById(`body-${section}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

(() => {
    const apiBase = '/Rule51';
    const currentSystemRole = '@currentSystemRole';
    const isResultsOnlyRole = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';

    const state = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        currentRunId: null, summary: null, sql: '',
        resultsVisible: false, hasPendingValidation: false,
        currentUserEngagementRole: '', currentUserHasSignedOff: false,
        isWorkspaceSaved: false, hasDataAnalystSignoff: false,
        currentStatus: '', resultFilter: 'ALL'
    };

    const els = {
        clientId: document.getElementById('clientId'),
        server: document.getElementById('server'), driver: document.getElementById('driver'), database: document.getElementById('database'),
        valpacTable: document.getElementById('valpacTable'), prodTable: document.getElementById('prodTable'),
        valpacCol007: document.getElementById('valpacCol007'), valpacCol008: document.getElementById('valpacCol008'),
        valpacCol001: document.getElementById('valpacCol001'), valpacColYear: document.getElementById('valpacColYear'),
        prodColStNo: document.getElementById('prodColStNo'), prodColIdNo: document.getElementById('prodColIdNo'),
        prodColQual: document.getElementById('prodColQual'), prodColYear: document.getElementById('prodColYear'),
        valpacCol049: document.getElementById('valpacCol049'), saNationalValues: document.getElementById('saNationalValues'),
        valpacCol008ZPlaceholders: document.getElementById('valpacCol008ZPlaceholders'),
        cregTable: document.getElementById('cregTable'), cregIdCol: document.getElementById('cregIdCol'),
        cregCompletionStatusCol: document.getElementById('cregCompletionStatusCol'), cregCompletionStatusValues: document.getElementById('cregCompletionStatusValues'),
        connectionOutput: document.getElementById('connectionOutput'), configOutput: document.getElementById('configOutput'),
        analysisPane: document.getElementById('analysisPane'), resultsPane: document.getElementById('resultsPane'),
        sqlText: document.getElementById('sqlText'), downloadAllBtn: document.getElementById('downloadAllBtn'),
        workspaceInfo: document.getElementById('workspaceInfo'), workspaceRunState: document.getElementById('workspaceRunState'),
        workspaceRunLabel: document.getElementById('workspaceRunLabel'), workspaceStatusLabel: document.getElementById('workspaceStatusLabel'),
        workspaceEditedLabel: document.getElementById('workspaceEditedLabel'), workspaceRoleLabel: document.getElementById('workspaceRoleLabel'),
        workspaceSignoffComment: document.getElementById('workspaceSignoffComment'),
        beginEditBtn: document.getElementById('beginEditBtn'), saveWorkspaceBtn: document.getElementById('saveWorkspaceBtn'),
        signoffBtn: document.getElementById('signoffBtn'), removeSignoffBtn: document.getElementById('removeSignoffBtn'),
        statusBadge: document.getElementById('statusBadge')
    };

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    tabButtons.forEach(btn => btn.addEventListener('click', () => setActiveTab(btn.dataset.tab)));

    function showSpinner(msg) { document.getElementById('spinnerMsg').textContent = msg || 'Processing...'; document.getElementById('spinner').style.display = 'flex'; }
    function hideSpinner() { document.getElementById('spinner').style.display = 'none'; }
    function escapeHtml(v) { return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#39;'); }
    function formatNumber(v) { return Number(v || 0).toLocaleString(); }
    function normalizeRole(v) { return String(v || '').replace(/[^a-z0-9]+/gi,'').toLowerCase(); }
    function setAlert(target, type, message) { if (target) target.innerHTML = `<div class="alert alert--${type}">${message}</div>`; }
    function setWorkspaceState(message, type) { els.workspaceInfo.className = `alert alert--${type}`; els.workspaceInfo.textContent = message || ''; }
    function setStatusBadge(text, type) {
        if (!text) { els.statusBadge.style.display='none'; return; }
        els.statusBadge.style.display='inline-block';
        els.statusBadge.className=`rule-header__badge ${type==='fail'?'badge--fail':'badge--pass'}`;
        els.statusBadge.textContent=text;
    }
    function setActiveTab(tab) {
        tabButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.toggle('active', pane.dataset.tabPanel === tab));
        if (tab === 'results') setTimeout(() => renderResults(true), 0);
    }
    function getActiveTab() { return document.querySelector('.tab-btn.active')?.dataset.tab || 'analysis'; }

    async function postJson(url, data) {
        return await window.fetchJsonWithProgress(url, { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(data) });
    }
    async function downloadBlob(url, payload, defaultName) {
        await window.downloadFileWithProgress({ url, method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':token}, body:JSON.stringify(payload), defaultFileName:defaultName, label:'Downloading' });
    }

    function populateSelect(sel, values, selected) {
        if (!sel) return;
        sel.innerHTML = '<option value="">Select table</option>';
        values.forEach(v => { const o = document.createElement('option'); o.value = o.textContent = v; sel.appendChild(o); });
        if (selected) { if (![...sel.options].some(o => o.value === selected)) { const o = document.createElement('option'); o.value = o.textContent = selected; sel.appendChild(o); } sel.value = selected; }
    }
    function fillColSel(selEl, cols, preferred) {
        if (!selEl) return;
        const cur = selEl.value; selEl.innerHTML = '';
        (cols || []).forEach(c => { const o = document.createElement('option'); o.value = o.textContent = c; if (c === (preferred || cur)) o.selected = true; selEl.appendChild(o); });
        if (!selEl.value && cols.length) selEl.value = cols[0];
    }

    function getRequest() {
        return {
            clientId: parseInt(els.clientId.value||'0',10)||0,
            runId: state.currentRunId,
            server: els.server?.value.trim()||'',
            database: els.database?.value||'',
            driver: els.driver?.value||'ODBC Driver 17 for SQL Server',
            valpacTable: els.valpacTable?.value||'dbo_STUD_VALPAC',
            prodTable:   els.prodTable?.value||'dbo_STUD_PRODUCTION',
            valpacCol007: els.valpacCol007?.value||'_007',
            valpacCol008: els.valpacCol008?.value||'_008',
            valpacCol001: els.valpacCol001?.value||'_001',
            valpacColYear:els.valpacColYear?.value||'ColYear',
            prodColStNo:  els.prodColStNo?.value||'IAGSTNO',
            prodColIdNo:  els.prodColIdNo?.value||'IADIDNO',
            prodColQual:  els.prodColQual?.value||'IAGQUAL',
            prodColYear:  els.prodColYear?.value||'IAGCYR',
            valpacCol049: els.valpacCol049?.value||'_049',
            saNationalValues: els.saNationalValues?.value||'SA,PR',
            valpacCol008ZPlaceholders: els.valpacCol008ZPlaceholders?.value||'ZZZZZZZZZZZZZ',
            cregTable: els.cregTable?.value||'',
            cregIdCol: els.cregIdCol?.value||'_007',
            cregCompletionStatusCol: els.cregCompletionStatusCol?.value||'_032',
            cregCompletionStatusValues: els.cregCompletionStatusValues?.value?.trim()||'W'
        };
    }

    async function loadCols(role, tableName) {
        const server = els.server?.value?.trim(); const db = els.database?.value;
        if (!server || !db || !tableName) return;
        try {
            const data = await postJson(`${apiBase}/GetColumns`, { server, database: db, driver: els.driver?.value||'ODBC Driver 17 for SQL Server', valpacTable: tableName });
            if (!data.success || !data.columns) return;
            const cols = data.columns || [];
            if (role === 'valpac') {
                fillColSel(els.valpacCol007, cols, '_007'); fillColSel(els.valpacCol008, cols, '_008');
                fillColSel(els.valpacCol001, cols, '_001'); fillColSel(els.valpacColYear, cols, 'ColYear');
                fillColSel(els.valpacCol049, cols, '_049');
            } else if (role === 'creg') {
                fillColSel(els.cregIdCol, cols, '_007');
                fillColSel(els.cregCompletionStatusCol, cols, '_032');
            } else {
                fillColSel(els.prodColStNo, cols, 'IAGSTNO'); fillColSel(els.prodColIdNo, cols, 'IADIDNO');
                fillColSel(els.prodColQual, cols, 'IAGQUAL'); fillColSel(els.prodColYear, cols, 'IAGCYR');
            }
            setAlert(els.configOutput, 'success', `Columns loaded for ${tableName}.`);
        } catch (e) { /* silently ignore */ }
    }

    window.autoDetectColumns = async function() {
        await Promise.all([loadCols('valpac', els.valpacTable?.value), loadCols('prod', els.prodTable?.value)]);
    };

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role); const normalizedSystemRole = normalizeRole(currentSystemRole);
        const hasUnsaved = !!state.summary && (!!state.hasPendingValidation || (!state.currentRunId && !state.isWorkspaceSaved));
        const canEdit = !isResultsOnlyRole && (normalizedSystemRole==='dataanalyst'||normalizedRole==='dataanalyst'||hasUnsaved);
        const canSign = !state.hasPendingValidation && !!state.currentRunId && !!state.isWorkspaceSaved &&
            (normalizedRole==='dataanalyst' || (state.resultsVisible && (normalizedRole==='manager'||normalizedRole==='director')));
        const signoffLocked = !!state.currentUserHasSignedOff;
        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit||signoffLocked);
        window.ruleWorkspaceUi.applyStates([
            {target:'connectBtn',disabled:!canEdit||signoffLocked},{target:'verifyBtn',disabled:!canEdit||signoffLocked},
            {target:'runBtn',disabled:!canEdit||signoffLocked},{target:'sqlBtn',disabled:!canEdit||signoffLocked},
            {target:els.beginEditBtn,disabled:signoffLocked||!canEdit||!state.currentRunId||state.hasPendingValidation},
            {target:els.saveWorkspaceBtn,disabled:signoffLocked||!canEdit||!hasUnsaved},
            {target:els.signoffBtn,disabled:signoffLocked||!canSign,text:state.currentUserHasSignedOff?`Signed Off as ${role||currentSystemRole}`:'Save Signoff'},
            {target:els.removeSignoffBtn,show:state.currentUserHasSignedOff,display:'',disabled:!state.currentUserHasSignedOff},
            {target:els.workspaceSignoffComment,disabled:signoffLocked||!canSign},
            {target:els.downloadAllBtn,disabled:!state.summary}
        ]);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions','.action-bar'],signoffLocked,{allow:['#downloadAllBtn','#downloadExcelBtn','#downloadCsvBtn','#downloadSqlBtn','#removeSignoffBtn']});
        applyWorkspaceAccessMode(canEdit);
    }

    function applyWorkspaceAccessMode(canEditWorkspace) {
        ['body-connection', 'body-config'].forEach(function(id) {
            var body = document.getElementById(id);
            if (!body) return;
            body.style.opacity = canEditWorkspace ? '' : '0.45';
            body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
            body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
                el.disabled = !canEditWorkspace;
            });
        });
    }

    function applySummary(summary, options = {}) {
        state.summary = summary;
        if (!options.fromWorkspace) state.currentRunId = summary?.savedRunId||state.currentRunId;
        state.currentStatus = summary?.status||state.currentStatus;
        state.resultsVisible = !!summary||state.resultsVisible;
        if (!summary) { els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 51 results loaded.</p></div>'; els.resultsPane.innerHTML='<div class="empty-card"><p>No Rule 51 results loaded.</p></div>'; setStatusBadge('','pass'); updateWorkspaceButtons(); return; }
        if (state.hasPendingValidation) { els.workspaceRunState.textContent=`Pending save | ${summary.status||'Completed'}`; els.workspaceRunLabel.textContent='Unsaved Rule 51 validation'; els.workspaceStatusLabel.textContent='Pending Save'; }
        else { els.workspaceRunState.textContent=state.currentRunId?`Run #${state.currentRunId} | ${state.currentStatus||'Completed'}`:'No saved run loaded'; els.workspaceRunLabel.textContent=state.currentRunId?`Run #${state.currentRunId}`:'No saved run yet'; els.workspaceStatusLabel.textContent=state.currentStatus||'-'; }
        setStatusBadge(summary.status, summary.failCount>0?'fail':'pass');
        renderAnalysis(summary); renderResults(); updateWorkspaceButtons();
    }

    function applyWorkspace(workspace, resultsVisible, preserveExistingSummary = false) {
        if (!workspace) {
            state.currentRunId=null;state.currentStatus='';state.currentUserEngagementRole='';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=false;state.hasPendingValidation=false;
            els.workspaceRunState.textContent='No saved run loaded';els.workspaceRunLabel.textContent='No saved run yet';els.workspaceStatusLabel.textContent='-';els.workspaceEditedLabel.textContent='-';
            setWorkspaceState('No saved Rule 51 workspace exists for this engagement yet.','info');
            if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
            return;
        }
        state.clientId=workspace.clientId||state.clientId;state.currentRunId=workspace.runId||null;state.currentStatus=workspace.currentStatus||'';
        state.currentUserEngagementRole=workspace.currentUserEngagementRole||currentSystemRole||'';state.currentUserHasSignedOff=!!workspace.currentUserHasSignedOff;
        state.isWorkspaceSaved=!!workspace.isWorkspaceSaved;state.hasDataAnalystSignoff=!!workspace.hasDataAnalystSignoff;state.resultsVisible=!!resultsVisible;state.hasPendingValidation=false;
        if (els.server) els.server.value=workspace.server||'';
        if (els.driver) els.driver.value=workspace.driver||'ODBC Driver 17 for SQL Server';
        populateSelect(els.database, workspace.database?[workspace.database]:[], workspace.database);
        populateSelect(els.valpacTable, workspace.valpacTable?[workspace.valpacTable]:[], workspace.valpacTable);
        populateSelect(els.prodTable, [workspace.prodTable||'dbo_STUD_PRODUCTION'], workspace.prodTable||'dbo_STUD_PRODUCTION');
        if (els.valpacCol049) {
            const col049Val = workspace.valpacCol049 || workspace.summary?.valpacCol049 || '_049';
            if (![...els.valpacCol049.options].some(o => o.value === col049Val)) {
                const o = document.createElement('option'); o.value = o.textContent = col049Val; els.valpacCol049.appendChild(o);
            }
            els.valpacCol049.value = col049Val;
        }
        if (els.saNationalValues) els.saNationalValues.value = workspace.saNationalValues || workspace.summary?.saNationalValues || 'SA,PR';
        if (els.valpacCol008ZPlaceholders) els.valpacCol008ZPlaceholders.value = workspace.valpacCol008ZPlaceholders || workspace.summary?.valpacCol008ZPlaceholders || 'ZZZZZZZZZZZZZ';
        if (els.cregTable) {
            const savedCregTable = workspace.cregTable || workspace.summary?.cregTable || '';
            if (savedCregTable && ![...els.cregTable.options].some(o => o.value === savedCregTable)) {
                const o = document.createElement('option'); o.value = o.textContent = savedCregTable; els.cregTable.appendChild(o);
            }
            els.cregTable.value = savedCregTable;
        }
        if (els.cregIdCol) {
            const savedCregIdCol = workspace.cregIdCol || workspace.summary?.cregIdCol || '_007';
            if (![...els.cregIdCol.options].some(o => o.value === savedCregIdCol)) {
                const o = document.createElement('option'); o.value = o.textContent = savedCregIdCol; els.cregIdCol.appendChild(o);
            }
            els.cregIdCol.value = savedCregIdCol;
        }
        if (els.cregCompletionStatusCol) {
            const savedCregCompletionCol = workspace.cregCompletionStatusCol || workspace.summary?.cregCompletionStatusCol || '_032';
            if (![...els.cregCompletionStatusCol.options].some(o => o.value === savedCregCompletionCol)) {
                const o = document.createElement('option'); o.value = o.textContent = savedCregCompletionCol; els.cregCompletionStatusCol.appendChild(o);
            }
            els.cregCompletionStatusCol.value = savedCregCompletionCol;
        }
        if (els.cregCompletionStatusValues) els.cregCompletionStatusValues.value = workspace.cregCompletionStatusValues || workspace.summary?.cregCompletionStatusValues || 'W';
        els.workspaceRunState.textContent=workspace.runId?`Run #${workspace.runId}`:'No saved run loaded';
        els.workspaceRunLabel.textContent=workspace.runId?`Rule 51 Run #${workspace.runId}`:'No saved run yet';
        els.workspaceStatusLabel.textContent=workspace.currentStatus||'-';
        els.workspaceEditedLabel.textContent=workspace.lastEditedAt?new Date(workspace.lastEditedAt).toLocaleString():'-';
        els.workspaceRoleLabel.textContent=workspace.currentUserEngagementRole||currentSystemRole||'-';
        els.workspaceSignoffComment.value=workspace.currentUserSignoffComment||'';
        if (!resultsVisible) { setWorkspaceState('Saved Rule 51 results are not available for your engagement role.','info'); if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons(); return; }
        setWorkspaceState(workspace.summary?'Saved workspace loaded.':'Rule 51 workspace loaded. Run validation to generate results.','success');
        if (workspace.summary) applySummary(workspace.summary,{fromWorkspace:true}); else if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
    }

    async function loadWorkspace() {
        state.clientId=Number(els.clientId?.value||0);
        if (!state.clientId) { applyWorkspace(null,false); return; }
        const data = await window.fetchJsonWithProgress(`${apiBase}/GetWorkspaceState?clientId=${state.clientId}`,{method:'GET'});
        if (!data.success) throw new Error(data.error||'Failed to load workspace.');
        applyWorkspace(data.workspace, data.resultsVisible);
    }

    async function connect() {
        const server = els.server?.value?.trim();
        if (!server) throw new Error('Enter the SQL Server name first.');
        showSpinner('Loading databases...');
        try {
            const data = await postJson(`${apiBase}/GetDatabases`, {server, driver:els.driver.value});
            if (!data.success) throw new Error(data.error||'Connection failed.');
            els.database.innerHTML='<option value="">Select database</option>';
            data.databases.forEach(db => { const o=document.createElement('option');o.value=o.textContent=db;els.database.appendChild(o); });
            setAlert(els.connectionOutput,'success',`Connected. Found ${data.databases.length} database(s).`);
            if ((data.databases||[]).length) await loadTables();
        } finally { hideSpinner(); }
    }

    async function loadTables() {
        if (!els.database.value) return;
        const data = await postJson(`${apiBase}/GetTables`, {server:els.server.value.trim(), database:els.database.value, driver:els.driver.value});
        if (!data.success) throw new Error(data.error||'Could not load tables.');
        populateSelect(els.valpacTable, data.tables||[], data.autoValpacTable);
        populateSelect(els.prodTable, data.tables||[], data.autoProdTable);
        // CREG: populate with blank option + all tables; auto-select dbo_CREG if present
        if (els.cregTable) {
            const cregCur = els.cregTable.value;
            els.cregTable.innerHTML = '<option value="">— Not configured (skip CREG check) —</option>';
            (data.tables||[]).forEach(t => { const o = document.createElement('option'); o.value = o.textContent = t; els.cregTable.appendChild(o); });
            const autoCreg = (data.tables||[]).find(t => /creg/i.test(t)) || '';
            els.cregTable.value = cregCur || autoCreg;
            // Also populate cregIdCol with CREG columns if available
            if (els.cregIdCol && els.cregTable.value) loadCols('creg', els.cregTable.value).catch(()=>{});
        }
        setAlert(els.configOutput,'success',`Loaded ${data.tables.length} table(s).`);
    }

    async function verifyTables() {
        showSpinner('Verifying Rule 51 tables...');
        try {
            const data = await postJson(`${apiBase}/VerifyTables`, getRequest());
            if (!data.success) throw new Error(data.error||'Verification failed.');
            els.configOutput.innerHTML=`<div class="alert alert--success">VALPAC rows: <strong>${formatNumber(data.valpacRecordCount)}</strong> | PRODUCTION rows: <strong>${formatNumber(data.prodRecordCount)}</strong> | Total tested: <strong>${formatNumber(data.totalTested)}</strong> | Matched: <strong>${formatNumber(data.matchedCount)}</strong> | Missing: <strong>${formatNumber(data.missingCount)}</strong></div>`;
        } finally { hideSpinner(); }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) { setWorkspaceState('Select the approved engagement assigned to you before running this rule.','warning'); return; }
        try {
            showSpinner('Running Rule 51 VALPAC in Production validation...');
            const data = await postJson(`${apiBase}/RunValidation`, request);
            if (!data.success) throw new Error(data.error||'Rule 51 failed.');
            state.hasPendingValidation=true;state.currentRunId=null;state.currentStatus=data.status||'';state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false;state.hasDataAnalystSignoff=false;state.resultsVisible=true;state.currentUserEngagementRole=state.currentUserEngagementRole||currentSystemRole||'DataAnalyst';
            applySummary(data);
            setWorkspaceState(`Rule 51 completed. Total tested: ${formatNumber(data.totalValidated)} | Matched in PRODUCTION: ${formatNumber(data.passCount)} | Missing: ${formatNumber(data.failCount)}. Click Save Workspace before signoff.`,'success');
        } finally { hideSpinner(); }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try { const data=await postJson(`${apiBase}/GenerateSql`,getRequest()); if(!data.success) throw new Error(data.error||'SQL generation failed.'); state.sql=data.sql||''; els.sqlText.value=state.sql; setActiveTab('sql'); } finally { hideSpinner(); }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try { const data=await postJson(`${apiBase}/BeginWorkspaceEdit`,getRequest()); if(!data.success) throw new Error(data.error||'Could not begin editing.'); applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace ready for editing.','warning'); } finally { hideSpinner(); }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try { const data=await postJson(`${apiBase}/SaveWorkspace`,getRequest()); if(!data.success) throw new Error(data.error||'Could not save workspace.'); state.hasPendingValidation=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Workspace saved.',data.signoffsCleared?'warning':'success'); } finally { hideSpinner(); }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try { const data=await postJson(`${apiBase}/SignOffWorkspace`,{clientId:state.clientId,runId:state.currentRunId,comment:els.workspaceSignoffComment.value.trim()}); if(!data.success) throw new Error(data.error||'Signoff failed.'); state.currentUserHasSignedOff=true; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,true); setWorkspaceState(data.message||'Signoff saved.','success'); } finally { hideSpinner(); }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try { const prevRunId=state.currentRunId; const data=await postJson(`${apiBase}/RemoveWorkspaceSignoff`,{clientId:state.clientId,runId:state.currentRunId,comment:''}); if(!data.success) throw new Error(data.error||'Could not remove signoff.'); state.currentUserHasSignedOff=false;state.isWorkspaceSaved=false; applyWorkspace(data.workspace,!!data.workspace?.resultsVisible,!!(data.workspace&&prevRunId&&data.workspace.runId===prevRunId)); setWorkspaceState(data.message||'Signoff removed.','warning'); } finally { hideSpinner(); }
    }

    function renderAnalysis(summary) {
        if (!summary) { els.analysisPane.innerHTML='<div class="empty-card"><p>No Rule 51 results loaded.</p></div>'; return; }
        const ctrl = (summary.controlSummaries||[]).find(i=>i.controlType==='Control_1');
        const controlRows = (summary.controlSummaries||[]).map(i=>`<tr><td>${escapeHtml(i.controlLabel)}</td><td>${escapeHtml(i.criteriaText)}</td><td>${i.totalCount.toLocaleString()}</td><td>${i.passCount.toLocaleString()}</td><td>${i.failCount.toLocaleString()}</td><td>${escapeHtml(i.status)}</td></tr>`).join('');

        const failRows       = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='FAIL');
        const passRows       = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='PASS');
        const passReviewRows = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='PASS_REVIEW');
        const notInCregRows  = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='NOT_IN_CREG');
        const cregWithdrawnRows = (summary.reviewRows||[]).filter(r=>String(r.validationResult||'').toUpperCase()==='CREG_WITHDRAWN');
        const purePassCount  = (summary.passCount||0) - (summary.passWithReviewCount||0) - (summary.notInCregCount||0) - (summary.cregWithdrawnCount||0);
        const v007=summary.valpacCol007||'_007';const v008=summary.valpacCol008||'_008';
        const v001=summary.valpacCol001||'_001';const vYear=summary.valpacColYear||'ColYear';
        const pSt=summary.prodColStNo||'IAGSTNO';const pId=summary.prodColIdNo||'IADIDNO';
        const pQual=summary.prodColQual||'IAGQUAL';const pYear=summary.prodColYear||'IAGCYR';
        const v049=summary.valpacCol049||'_049';

        const failRowHtml = failRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const reason = row.validationExplanation || v.EXCEPTION_REASON || 'No matching record found in PRODUCTION.';
            const partialFound = v.PARTIAL_MATCH_FOUND === '1';
            // Show PROD values from partial match; highlight differing cells in orange
            const prodCell = (idx, valpacVal) => {
                const pk = `PROD_COL_${idx+1}`;
                const pv = v[pk] ?? '';
                if (!partialFound || !pv) return `<td style="color:#999;font-style:italic">—</td>`;
                const differs = (valpacVal||'').trim().toUpperCase() !== pv.trim().toUpperCase();
                return `<td style="${differs?'background:#FFE0B2;color:#BF360C;font-weight:700':''}"> ${escapeHtml(pv)}</td>`;
            };
            const vv=[v.VALPAC_COL_1||'',v.VALPAC_COL_2||'',v.VALPAC_COL_3||'',v.VALPAC_COL_4||''];
            const v049val = v.VALPAC_049_DISP||'';
            return `<tr style="background:#FFF3F3">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:var(--rule15-fail)">${escapeHtml(vv[0])}</td>
                <td>${escapeHtml(vv[1])}</td>
                <td>${escapeHtml(vv[2])}</td>
                <td>${escapeHtml(vv[3])}</td>
                <td style="font-style:italic;color:#6A1B9A">${escapeHtml(v049val)}</td>
                ${prodCell(0,vv[0])}${prodCell(1,vv[1])}${prodCell(2,vv[2])}${prodCell(3,vv[3])}
                <td style="font-size:11px;color:#5D4037;max-width:260px;white-space:normal;line-height:1.4">${escapeHtml(reason)}</td>
            </tr>`;
        }).join('');

        const passRowHtml = passRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            return `<tr style="background:#F3FFF3">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:var(--rule15-pass,#2e7d32)">${escapeHtml(v.VALPAC_COL_1||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_2||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_3||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_4||'')}</td>
                <td>${escapeHtml(v.PROD_COL_1||'')}</td>
                <td>${escapeHtml(v.PROD_COL_2||'')}</td>
                <td>${escapeHtml(v.PROD_COL_3||'')}</td>
                <td>${escapeHtml(v.PROD_COL_4||'')}</td>
            </tr>`;
        }).join('');

        const passReviewRowHtml = passReviewRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const note = row.validationExplanation || v.EXCEPTION_REASON || '';
            const v049val = v.VALPAC_049_DISP||'';
            return `<tr style="background:#FFF8E1">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:#E65100">${escapeHtml(v.VALPAC_COL_1||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_2||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_3||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_4||'')}</td>
                <td style="font-style:italic;color:#6A1B9A">${escapeHtml(v049val)}</td>
                <td>${escapeHtml(v.PROD_COL_1||'')}</td>
                <td style="background:#FFF3E0;font-weight:700;color:#E65100">${escapeHtml(v.PROD_COL_2||'')}</td>
                <td>${escapeHtml(v.PROD_COL_3||'')}</td>
                <td>${escapeHtml(v.PROD_COL_4||'')}</td>
                <td style="font-size:11px;color:#5D4037;max-width:280px;white-space:normal;line-height:1.4">${escapeHtml(note)}</td>
            </tr>`;
        }).join('');

        const notInCregRowHtml = notInCregRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const note = row.validationExplanation || v.EXCEPTION_REASON || '';
            return `<tr style="background:#E1F5FE">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:#01579B">${escapeHtml(v.VALPAC_COL_1||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_2||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_3||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_4||'')}</td>
                <td style="font-style:italic;color:#6A1B9A">${escapeHtml(v.VALPAC_049_DISP||'')}</td>
                <td colspan="4" style="color:#0277BD;font-style:italic;font-size:12px">— Student not found in CREG —</td>
                <td style="font-size:11px;color:#01579B;max-width:280px;white-space:normal;line-height:1.4">${escapeHtml(note)}</td>
            </tr>`;
        }).join('');

        const cregWithdrawnRowHtml = cregWithdrawnRows.map(row=>{
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const note = row.validationExplanation || v.EXCEPTION_REASON || '';
            return `<tr style="background:#EDE7F6">
                <td>${row.validationNumber}</td>
                <td style="font-weight:700;color:#4527A0">${escapeHtml(v.VALPAC_COL_1||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_2||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_3||'')}</td>
                <td>${escapeHtml(v.VALPAC_COL_4||'')}</td>
                <td style="font-style:italic;color:#6A1B9A">${escapeHtml(v.VALPAC_049_DISP||'')}</td>
                <td colspan="4" style="color:#4527A0;font-style:italic;font-size:12px">— CREG completion status (${escapeHtml(summary.cregCompletionStatusCol||'_032')}): <strong>${escapeHtml(v.CREG_COMPLETION_STATUS_DISP||'')}</strong> — withdrew —</td>
                <td style="font-size:11px;color:#4527A0;max-width:280px;white-space:normal;line-height:1.4">${escapeHtml(note)}</td>
            </tr>`;
        }).join('');

        els.analysisPane.innerHTML = `
            ${summary.isPreviewOnly?`<div class="alert alert--warning" style="margin-bottom:16px">Browser shows a preview of ${summary.previewLimit.toLocaleString()} rows prioritising FAIL records. Download Excel/CSV for the complete result set.</div>`:''}
            <div class="R51-summary-grid">
                <div class="stat-card"><div class="stat-card__label">VALPAC Records</div><div class="stat-card__value">${(summary.valpacRecordCount||0).toLocaleString()}</div></div>
                <div class="stat-card"><div class="stat-card__label">PRODUCTION Records</div><div class="stat-card__value">${(summary.prodRecordCount||0).toLocaleString()}</div></div>
                <div class="stat-card"><div class="stat-card__label">Total Tested</div><div class="stat-card__value">${summary.totalValidated.toLocaleString()}</div></div>
                <div class="stat-card stat-card--pass"><div class="stat-card__label">Found in PRODUCTION</div><div class="stat-card__value">${purePassCount.toLocaleString()}</div></div>
                <div class="stat-card stat-card--fail"><div class="stat-card__label">Missing from PRODUCTION</div><div class="stat-card__value">${summary.failCount.toLocaleString()}</div></div>
                ${(summary.passWithReviewCount||0)>0?`<div class="stat-card" style="border-left:4px solid #F57C00;background:#FFF3E0"><div class="stat-card__label" style="color:#E65100">Pass with Review Note</div><div class="stat-card__value" style="color:#E65100">${(summary.passWithReviewCount||0).toLocaleString()}</div></div>`:''}
                ${(summary.notInCregCount||0)>0?`<div class="stat-card" style="border-left:4px solid #0288D1;background:#E1F5FE"><div class="stat-card__label" style="color:#01579B">Not in CREG (No Service)</div><div class="stat-card__value" style="color:#01579B">${(summary.notInCregCount||0).toLocaleString()}</div></div>`:''}
                ${(summary.cregWithdrawnCount||0)>0?`<div class="stat-card" style="border-left:4px solid #5E35B1;background:#EDE7F6"><div class="stat-card__label" style="color:#4527A0">Withdrew (CREG ${escapeHtml(summary.cregCompletionStatusCol||'_032')})</div><div class="stat-card__value" style="color:#4527A0">${(summary.cregWithdrawnCount||0).toLocaleString()}</div></div>`:''}
                ${(summary.foreignNationalExemptCount||0)>0?`<div class="stat-card" style="border-left:4px solid #AB47BC;background:#F3E5F5"><div class="stat-card__label" style="color:#6A1B9A">Foreign National Exempt</div><div class="stat-card__value" style="color:#6A1B9A">${(summary.foreignNationalExemptCount||0).toLocaleString()}</div></div>`:''}
            </div>

            ${(summary.exceptionCategories||[]).length > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #F57C00">
                <h3 class="section-title" style="margin-top:0;color:#E65100">Exception Category Breakdown</h3>
                <table class="data-table" style="min-width:500px">
                    <thead><tr>
                        <th style="background:#F57C00;color:#fff">Category</th>
                        <th style="background:#F57C00;color:#fff">Description</th>
                        <th style="background:#F57C00;color:#fff;text-align:right">Count</th>
                    </tr></thead>
                    <tbody>
                        ${(summary.exceptionCategories||[]).map(cat=>`<tr style="background:#FFF8E1">
                            <td style="font-family:Consolas,monospace;font-size:12px;font-weight:700;color:#BF360C">${escapeHtml(cat.category||'')}</td>
                            <td style="font-size:13px">${escapeHtml(cat.description||'')}</td>
                            <td style="text-align:right;font-weight:700;font-size:14px;color:#BF360C">${(cat.count||0).toLocaleString()}</td>
                        </tr>`).join('')}
                    </tbody>
                </table>
            </div>` : ''}

            ${summary.failCount > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid var(--rule15-fail,#c62828)">
                <h3 class="section-title" style="margin-top:0;color:var(--rule15-fail,#c62828)">
                    Missing from PRODUCTION (FAIL) — ${formatNumber(summary.failCount)} record(s) not found
                    ${summary.isPreviewOnly ? `<small style="font-weight:normal;font-size:13px"> (showing ${failRows.length} in preview)</small>` : ''}
                </h3>
                ${failRows.length === 0
                    ? `<div class="alert alert--info">No FAIL rows in this browser preview. Download Excel or CSV to see the full list of ${formatNumber(summary.failCount)} missing record(s).</div>`
                    : `<div class="table-wrapper" style="overflow-x:auto">
                        <table class="data-table" style="min-width:700px;font-size:12px;font-family:Consolas,monospace">
                            <thead><tr>
                                <th rowspan="2">#</th>
                                <th colspan="5" style="background:#c62828;color:#fff;text-align:center">VALPAC</th>
                                <th colspan="4" style="background:#1565C0;color:#fff;text-align:center">PRODUCTION (found via student no.)</th>
                                <th rowspan="2">Exception Reason</th>
                            </tr><tr>
                                <th style="background:#c62828;color:#fff">${escapeHtml(v007)}</th>
                                <th>${escapeHtml(v008)}</th>
                                <th>${escapeHtml(v001)}</th>
                                <th>${escapeHtml(vYear)}</th>
                                <th style="background:#6A1B9A;color:#fff">${escapeHtml(v049)} (Citizen/Res.)</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pSt)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pId)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pQual)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pYear)}</th>
                            </tr></thead>
                            <tbody>${failRowHtml}</tbody>
                        </table>
                    </div>`
                }
                <div style="margin-top:12px">
                    <button type="button" class="btn btn-info" onclick="document.querySelector('[data-tab=\\'results\\']')?.click()">
                        View in Results tab &rarr;
                    </button>
                    <button type="button" class="btn btn-info" id="dlFailBtn" style="margin-left:8px">Download FAIL rows (CSV)</button>
                </div>
            </div>` : `
            <div class="alert alert--success" style="margin-top:16px">
                All ${formatNumber(summary.totalValidated)} VALPAC records were found in PRODUCTION. No missing records.
            </div>`}

            ${(summary.passWithReviewCount||0) > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #F57C00">
                <h3 class="section-title" style="margin-top:0;color:#E65100">
                    Pass with Review Note (PASS_REVIEW) — ${formatNumber(summary.passWithReviewCount)} record(s): student matched on primary qualification
                    ${summary.isPreviewOnly ? `<small style="font-weight:normal;font-size:13px"> (showing ${passReviewRows.length} in preview)</small>` : ''}
                </h3>
                <div class="alert" style="background:#FFF8E1;border-left:4px solid #F9A825;color:#5D4037;margin-bottom:12px;padding:10px 14px;font-size:13px">
                    These VALPAC records belong to students who were matched on their <strong>primary qualification</strong> in PRODUCTION.
                    PRODUCTION stores only the primary qualification; additional VALPAC qualification rows are not exceptions.
                    They are counted as <strong>PASS</strong> for compliance purposes.
                </div>
                ${passReviewRows.length === 0
                    ? `<div class="alert alert--info">No PASS_REVIEW rows in this browser preview. Download Excel/CSV to see all ${formatNumber(summary.passWithReviewCount)} review record(s).</div>`
                    : `<div class="table-wrapper" style="overflow-x:auto">
                        <table class="data-table" style="min-width:900px;font-size:12px;font-family:Consolas,monospace">
                            <thead><tr>
                                <th rowspan="2">#</th>
                                <th colspan="4" style="background:#E65100;color:#fff;text-align:center">VALPAC</th>
                                <th rowspan="2" style="background:#6A1B9A;color:#fff">${escapeHtml(v049)} (Citizen/Res.)</th>
                                <th colspan="4" style="background:#1565C0;color:#fff;text-align:center">PRODUCTION (primary qual found)</th>
                                <th rowspan="2">Review Note</th>
                            </tr><tr>
                                <th style="background:#E65100;color:#fff">${escapeHtml(v007)}</th>
                                <th>${escapeHtml(v008)}</th>
                                <th>${escapeHtml(v001)}</th>
                                <th>${escapeHtml(vYear)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pSt)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pId)}</th>
                                <th style="background:#F57C00;color:#fff">${escapeHtml(pQual)}</th>
                                <th style="background:#1565C0;color:#fff">${escapeHtml(pYear)}</th>
                            </tr></thead>
                            <tbody>${passReviewRowHtml}</tbody>
                        </table>
                    </div>`
                }
            </div>` : ''}

            ${(summary.notInCregCount||0) > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #0288D1">
                <h3 class="section-title" style="margin-top:0;color:#01579B">
                    Not in CREG — No University Service (NOT_IN_CREG) — ${formatNumber(summary.notInCregCount)} record(s): student absent from CREG, not expected in PRODUCTION
                    ${summary.isPreviewOnly ? `<small style="font-weight:normal;font-size:13px"> (showing ${notInCregRows.length} in preview)</small>` : ''}
                </h3>
                <div class="alert" style="background:#E1F5FE;border-left:4px solid #0288D1;color:#01579B;margin-bottom:12px;padding:10px 14px;font-size:13px">
                    These VALPAC records belong to students who do <strong>not appear in the CREG table</strong>.
                    The university never provided a service for these students, so their absence from PRODUCTION is <strong>expected — not an exception</strong>.
                </div>
                ${notInCregRows.length === 0
                    ? `<div class="alert alert--info">No NOT_IN_CREG rows in this browser preview. Download Excel/CSV to see all ${formatNumber(summary.notInCregCount)} record(s).</div>`
                    : `<div class="table-wrapper" style="overflow-x:auto">
                        <table class="data-table" style="min-width:900px;font-size:12px;font-family:Consolas,monospace">
                            <thead><tr>
                                <th rowspan="2">#</th>
                                <th colspan="4" style="background:#0288D1;color:#fff;text-align:center">VALPAC</th>
                                <th rowspan="2" style="background:#6A1B9A;color:#fff">${escapeHtml(v049)}</th>
                                <th colspan="4" style="background:#546E7A;color:#fff;text-align:center">PRODUCTION (no match)</th>
                                <th rowspan="2">Note</th>
                            </tr><tr>
                                <th style="background:#0288D1;color:#fff">${escapeHtml(v007)}</th>
                                <th>${escapeHtml(v008)}</th><th>${escapeHtml(v001)}</th><th>${escapeHtml(vYear)}</th>
                                <th style="background:#546E7A;color:#fff">${escapeHtml(pSt)}</th>
                                <th style="background:#546E7A;color:#fff">${escapeHtml(pId)}</th>
                                <th style="background:#546E7A;color:#fff">${escapeHtml(pQual)}</th>
                                <th style="background:#546E7A;color:#fff">${escapeHtml(pYear)}</th>
                            </tr></thead>
                            <tbody>${notInCregRowHtml}</tbody>
                        </table>
                    </div>`
                }
            </div>` : ''}

            ${(summary.cregWithdrawnCount||0) > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid #5E35B1">
                <h3 class="section-title" style="margin-top:0;color:#4527A0">
                    Withdrew — CREG Completion Status (CREG_WITHDRAWN) — ${formatNumber(summary.cregWithdrawnCount)} record(s): student withdrew from course registration, not expected in PRODUCTION
                    ${summary.isPreviewOnly ? `<small style="font-weight:normal;font-size:13px"> (showing ${cregWithdrawnRows.length} in preview)</small>` : ''}
                </h3>
                <div class="alert" style="background:#EDE7F6;border-left:4px solid #5E35B1;color:#4527A0;margin-bottom:12px;padding:10px 14px;font-size:13px">
                    These VALPAC records belong to students who are <strong>not found in PRODUCTION</strong>, but <strong>are</strong> in CREG with completion status
                    (<code>${escapeHtml(summary.cregCompletionStatusCol||'_032')}</code>) matching the configured filter (<code>${escapeHtml(summary.cregCompletionStatusValues||'W')}</code>).
                    The student withdrew from the course registration, so their absence from PRODUCTION is <strong>expected — not an exception</strong>.
                </div>
                ${cregWithdrawnRows.length === 0
                    ? `<div class="alert alert--info">No CREG_WITHDRAWN rows in this browser preview. Download Excel/CSV to see all ${formatNumber(summary.cregWithdrawnCount)} record(s).</div>`
                    : `<div class="table-wrapper" style="overflow-x:auto">
                        <table class="data-table" style="min-width:900px;font-size:12px;font-family:Consolas,monospace">
                            <thead><tr>
                                <th rowspan="2">#</th>
                                <th colspan="4" style="background:#5E35B1;color:#fff;text-align:center">VALPAC</th>
                                <th rowspan="2" style="background:#6A1B9A;color:#fff">${escapeHtml(v049)}</th>
                                <th colspan="4" style="background:#4527A0;color:#fff;text-align:center">CREG (withdrawn)</th>
                                <th rowspan="2">Note</th>
                            </tr><tr>
                                <th style="background:#5E35B1;color:#fff">${escapeHtml(v007)}</th>
                                <th>${escapeHtml(v008)}</th><th>${escapeHtml(v001)}</th><th>${escapeHtml(vYear)}</th>
                                <th colspan="4" style="background:#4527A0;color:#fff">${escapeHtml(summary.cregCompletionStatusCol||'_032')}</th>
                            </tr></thead>
                            <tbody>${cregWithdrawnRowHtml}</tbody>
                        </table>
                    </div>`
                }
            </div>` : ''}

            ${purePassCount > 0 ? `
            <div class="card" style="padding:20px;margin-top:20px;border-left:4px solid var(--rule15-pass,#2e7d32)">
                <h3 class="section-title" style="margin-top:0;color:var(--rule15-pass,#2e7d32)">
                    Found in PRODUCTION (PASS) — ${formatNumber(purePassCount)} record(s) matched
                    ${summary.isPreviewOnly ? `<small style="font-weight:normal;font-size:13px"> (showing ${passRows.length} in preview)</small>` : ''}
                </h3>
                ${passRows.length === 0
                    ? `<div class="alert alert--info">No PASS rows in this browser preview (preview prioritises FAIL records). Download Excel or CSV to see all ${formatNumber(purePassCount)} matched record(s).</div>`
                    : `<div class="table-wrapper" style="overflow-x:auto">
                        <table class="data-table" style="min-width:900px;font-size:12px;font-family:Consolas,monospace">
                            <thead><tr>
                                <th>#</th>
                                <th style="background:#2e7d32;color:#fff">${escapeHtml(v007)} (Student No.)</th>
                                <th>${escapeHtml(v008)} (ID No.)</th>
                                <th>${escapeHtml(v001)} (Qual)</th>
                                <th>${escapeHtml(vYear)} (Year)</th>
                                <th>${escapeHtml(pSt)} (PROD St.No.)</th>
                                <th>${escapeHtml(pId)} (PROD ID No.)</th>
                                <th>${escapeHtml(pQual)} (PROD Qual)</th>
                                <th>${escapeHtml(pYear)} (PROD Year)</th>
                            </tr></thead>
                            <tbody>${passRowHtml}</tbody>
                        </table>
                    </div>`
                }
            </div>` : ''}

            <div class="card" style="padding:20px;margin-top:20px">
                <h3 class="section-title" style="margin-top:0">Run Summary</h3>
                <div class="form-grid">
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>${escapeHtml(summary.database)}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">VALPAC Table</div><div>${escapeHtml(summary.valpacTable||'')}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">PRODUCTION Table</div><div>${escapeHtml(summary.prodTable||'')}</div></div>
                    <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div>${escapeHtml(summary.status)}</div></div>
                </div>
                <div style="margin-top:18px"><table class="data-table"><thead><tr><th>Control</th><th>Criteria</th><th>Rows Tested</th><th>PASS</th><th>FAIL</th><th>Status</th></tr></thead><tbody>${controlRows}</tbody></table></div>
            </div>`;

        document.getElementById('dlFailBtn')?.addEventListener('click', () => {
            if (state.summary) downloadBlob(`${apiBase}/DownloadCsv`, state.summary, 'Rule51_Missing_from_PRODUCTION.csv').catch(err=>setWorkspaceState(err.message,'error'));
        });
    }

    function renderResults(force = false) {
        if (!state.summary) { els.resultsPane.innerHTML='<div class="empty-card"><p>No Rule 51 results loaded.</p></div>'; return; }
        if (!force && getActiveTab()!=='results') { els.resultsPane.innerHTML='<div class="empty-card"><p>Open the Results tab to load the browser preview.</p></div>'; return; }
        const summary = state.summary;
        const purePassCount = (summary.passCount||0) - (summary.passWithReviewCount||0) - (summary.notInCregCount||0) - (summary.cregWithdrawnCount||0);
        const rows = (summary.reviewRows||[]).filter(r => state.resultFilter==='ALL'||String(r.validationResult||'').toUpperCase()===state.resultFilter);
        const valpacTable = summary.valpacTable||'STUD VALPAC';
        const prodTable   = summary.prodTable||'STUD PRODUCTION';
        const v007=summary.valpacCol007||'_007';const v008=summary.valpacCol008||'_008';
        const v001=summary.valpacCol001||'_001';const vYear=summary.valpacColYear||'ColYear';
        const pSt=summary.prodColStNo||'IAGSTNO';const pId=summary.prodColIdNo||'IADIDNO';
        const pQual=summary.prodColQual||'IAGQUAL';const pYear=summary.prodColYear||'IAGCYR';
        const v049r=summary.valpacCol049||'_049';

        const rowHtml = rows.map(row => {
            const v=Object.fromEntries(Object.entries(row.displayValues||{}).map(([k,val])=>[k.toUpperCase(),val]));
            const resultUc=String(row.validationResult||'').toUpperCase();
            const isFail=resultUc==='FAIL';
            const isPassReview=resultUc==='PASS_REVIEW';
            const isNotInCreg=resultUc==='NOT_IN_CREG';
            const isCregWithdrawn=resultUc==='CREG_WITHDRAWN';
            const partialFound = v.PARTIAL_MATCH_FOUND === '1';
            const prodTd = (idx, valpacVal) => {
                const pk = `PROD_COL_${idx+1}`;
                const pv = v[pk] ?? '';
                if (!pv) return `<td class="group-prod" style="color:#bbb;font-style:italic">—</td>`;
                const differs = isFail && (valpacVal||'').trim().toUpperCase() !== pv.trim().toUpperCase();
                const reviewDiffers = isPassReview && idx===1 && (valpacVal||'').trim().toUpperCase() !== pv.trim().toUpperCase();
                return `<td class="group-prod${isFail&&!partialFound?' is-fail':''}" style="${differs?'background:#FFE0B2;color:#BF360C;font-weight:700':reviewDiffers?'background:#FFF3E0;color:#E65100;font-weight:700':''}">${escapeHtml(pv)}</td>`;
            };
            const vv=[v.VALPAC_COL_1||'',v.VALPAC_COL_2||'',v.VALPAC_COL_3||'',v.VALPAC_COL_4||''];
            const v049cell = v.VALPAC_049_DISP||'';
            const reason = row.validationExplanation || v.EXCEPTION_REASON || '';
            const trStyle = isPassReview ? ' style="background:#FFF8E1"' : isNotInCreg ? ' style="background:#E1F5FE"' : isCregWithdrawn ? ' style="background:#EDE7F6"' : '';
            const resultLabel = isFail ? 'FAIL' : isPassReview ? 'PASS (Review)' : isNotInCreg ? 'PASS (Not in CREG)' : isCregWithdrawn ? 'PASS (Withdrew)' : 'PASS';
            const resultCls = isFail ? 'is-fail' : isPassReview || isNotInCreg || isCregWithdrawn ? '' : 'is-pass';
            const resultColor = isPassReview ? 'color:#E65100;font-weight:700' : isNotInCreg ? 'color:#01579B;font-weight:700' : isCregWithdrawn ? 'color:#4527A0;font-weight:700' : '';
            return `<tr${trStyle}>
                <td class="group-valpac">${escapeHtml(vv[0])}</td>
                <td class="group-valpac">${escapeHtml(vv[1])}</td>
                <td class="group-valpac">${escapeHtml(vv[2])}</td>
                <td class="group-valpac">${escapeHtml(vv[3])}</td>
                <td class="group-valpac" style="color:#6A1B9A;font-style:italic">${escapeHtml(v049cell)}</td>
                ${prodTd(0,vv[0])}${prodTd(1,vv[1])}${prodTd(2,vv[2])}${prodTd(3,vv[3])}
                <td class="group-final ${resultCls}" style="${resultColor}">
                    <span class="result-text">${escapeHtml(resultLabel)}</span>
                    ${reason?`<span class="message-text" style="display:block;font-size:11px;white-space:normal;line-height:1.4">${escapeHtml(reason)}</span>`:''}
                </td>
            </tr>`;
        }).join('');

        els.resultsPane.innerHTML=`
            <div class="R51-filterbar">
                <div class="field-group" style="margin:0;min-width:180px">
                    <label>Result Filter</label>
                    <select id="liveResultFilter">
                        <option value="ALL">All results (PASS, FAIL, Review, Not in CREG &amp; Withdrew)</option>
                        <option value="FAIL">FAIL — Missing from PRODUCTION</option>
                        <option value="NOT_IN_CREG">PASS (Not in CREG) — No university service</option>
                        <option value="CREG_WITHDRAWN">PASS (Withdrew) — CREG completion status</option>
                        <option value="PASS_REVIEW">PASS (Review) — Primary qual matched</option>
                        <option value="PASS">PASS — Found in PRODUCTION</option>
                    </select>
                </div>
            </div>
            <div class="alert alert--${rows.length === 0 && state.resultFilter === 'FAIL' ? 'success' : 'info'}" style="margin-bottom:16px">
                ${state.resultFilter === 'FAIL'
                    ? `Showing <strong>${formatNumber(rows.length)}</strong> record(s) missing from PRODUCTION (FAIL).${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                    : state.resultFilter === 'NOT_IN_CREG'
                        ? `Showing <strong>${formatNumber(rows.length)}</strong> record(s) where student was not found in CREG — no university service, not an exception.${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                        : state.resultFilter === 'CREG_WITHDRAWN'
                            ? `Showing <strong>${formatNumber(rows.length)}</strong> record(s) where student withdrew from the course registration (CREG completion status) — not an exception.${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                            : state.resultFilter === 'PASS_REVIEW'
                                ? `Showing <strong>${formatNumber(rows.length)}</strong> record(s) with review note — student passed on primary qualification.${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                                : state.resultFilter === 'PASS'
                                    ? `Showing <strong>${formatNumber(rows.length)}</strong> record(s) found in PRODUCTION (PASS).${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                                    : `Showing <strong>${formatNumber(rows.length)}</strong> result row(s) — <span style="color:var(--rule15-pass,#2e7d32);font-weight:700">${formatNumber(purePassCount||0)} PASS</span>${(summary.passWithReviewCount||0)>0?` / <span style="color:#E65100;font-weight:700">${formatNumber(summary.passWithReviewCount||0)} PASS (Review)</span>`:''}${(summary.notInCregCount||0)>0?` / <span style="color:#01579B;font-weight:700">${formatNumber(summary.notInCregCount||0)} Not in CREG</span>`:''}${(summary.cregWithdrawnCount||0)>0?` / <span style="color:#4527A0;font-weight:700">${formatNumber(summary.cregWithdrawnCount||0)} Withdrew</span>`:''} / <span style="color:var(--rule15-fail,#c62828);font-weight:700">${formatNumber(summary.failCount||0)} FAIL</span>.${summary.isPreviewOnly ? ' <em>Browser preview — download for full list.</em>' : ''}`
                }
            </div>
            ${summary.isPreviewOnly?`<div class="alert alert--warning" style="margin-bottom:12px">Only the browser preview is shown here. Downloads keep the full result set.</div>`:''}
            <div class="R51-results-wrap">
                <div class="R51-table-wrap">
                    <table class="R51-grid">
                        <thead>
                            <tr>
                                <th class="group-valpac" colspan="5">${escapeHtml(valpacTable)}</th>
                                <th class="group-prod" colspan="4">${escapeHtml(prodTable)}</th>
                                <th class="group-final">Final Results</th>
                            </tr>
                            <tr>
                                <th class="group-valpac">${escapeHtml(v007)}</th><th class="group-valpac">${escapeHtml(v008)}</th>
                                <th class="group-valpac">${escapeHtml(v001)}</th><th class="group-valpac">${escapeHtml(vYear)}</th>
                                <th class="group-valpac" style="background:#6A1B9A;color:#fff">${escapeHtml(v049r)}</th>
                                <th class="group-prod">${escapeHtml(pSt)}</th><th class="group-prod">${escapeHtml(pId)}</th>
                                <th class="group-prod">${escapeHtml(pQual)}</th><th class="group-prod">${escapeHtml(pYear)}</th>
                                <th class="group-final" style="width:200px">pass/fail</th>
                            </tr>
                        </thead>
                        <tbody>${rowHtml}</tbody>
                    </table>
                </div>
            </div>`;

        const liveFilter = document.getElementById('liveResultFilter');
        if (liveFilter) { liveFilter.value=state.resultFilter; liveFilter.addEventListener('change',()=>{state.resultFilter=liveFilter.value;renderResults(true);}); }
    }

    if (!isResultsOnlyRole) {
        els.database?.addEventListener('change', () => loadTables().catch(err => { els.configOutput.innerHTML=`<div class="alert alert--error">${escapeHtml(err.message)}</div>`; }));
        document.getElementById('connectBtn')?.addEventListener('click', () => connect().catch(err => { hideSpinner(); els.connectionOutput.innerHTML=`<div class="alert alert--error">${escapeHtml(err.message)}</div>`; }));
        document.getElementById('verifyBtn')?.addEventListener('click', () => verifyTables().catch(err => { hideSpinner(); els.configOutput.innerHTML=`<div class="alert alert--error">${escapeHtml(err.message)}</div>`; }));
        document.getElementById('runBtn')?.addEventListener('click', () => runValidation().catch(err => { hideSpinner(); setWorkspaceState(err.message,'error'); }));
        document.getElementById('sqlBtn')?.addEventListener('click', () => generateSql().catch(err => { hideSpinner(); els.sqlText.value=err.message; }));
        els.beginEditBtn?.addEventListener('click', () => beginEdit().catch(err => { hideSpinner(); setWorkspaceState(err.message,'error'); }));
        els.saveWorkspaceBtn?.addEventListener('click', () => saveWorkspace().catch(err => { hideSpinner(); setWorkspaceState(err.message,'error'); }));
        els.downloadAllBtn?.addEventListener('click', async () => {
            try {
                if (!state.summary) throw new Error('Run Rule 51 first.');
                if (document.getElementById('chkExcel')?.checked) await downloadBlob(`${apiBase}/DownloadExcel`,state.summary,'Rule51_VALPAC_Production.xlsx');
                if (document.getElementById('chkCsv')?.checked)   await downloadBlob(`${apiBase}/DownloadCsv`,state.summary,'Rule51_VALPAC_Production.csv');
                if (document.getElementById('chkSql')?.checked)   await downloadBlob(`${apiBase}/DownloadSql`,getRequest(),'Rule51_VALPAC_Production.sql');
            } catch (err) { setWorkspaceState(err.message||'Download failed.','error'); }
        });
    }

    els.signoffBtn?.addEventListener('click', () => signoffWorkspace().catch(err => { hideSpinner(); setWorkspaceState(err.message,'error'); }));
    els.removeSignoffBtn?.addEventListener('click', () => removeWorkspaceSignoff().catch(err => { hideSpinner(); setWorkspaceState(err.message,'error'); }));
    document.getElementById('downloadExcelBtn')?.addEventListener('click', () => state.summary&&downloadBlob(`${apiBase}/DownloadExcel`,state.summary,'Rule51_VALPAC_Production.xlsx').catch(err=>setWorkspaceState(err.message,'error')));
    document.getElementById('downloadCsvBtn')?.addEventListener('click', () => state.summary&&downloadBlob(`${apiBase}/DownloadCsv`,state.summary,'Rule51_VALPAC_Production.csv').catch(err=>setWorkspaceState(err.message,'error')));
    document.getElementById('downloadSqlBtn')?.addEventListener('click', () => downloadBlob(`${apiBase}/DownloadSql`,getRequest(),'Rule51_VALPAC_Production.sql').catch(err=>setWorkspaceState(err.message,'error')));
    els.clientId?.addEventListener('change', () => loadWorkspace().catch(err => setWorkspaceState(err.message,'error')));

    renderAnalysis(null); renderResults(); updateWorkspaceButtons();
    if (state.clientId) loadWorkspace().catch(err => setWorkspaceState(err.message,'error'));
    else if (isResultsOnlyRole) setWorkspaceState('Select an engagement to load the saved Rule 51 results.','info');
})();
</script>