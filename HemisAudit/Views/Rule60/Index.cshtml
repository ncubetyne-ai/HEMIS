@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 60 – CRSE vs H16CRSE Agreement";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int cid ? cid : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager",  StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee",  StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

<style>
.r60-pair-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:6px; background:#f9f9f9; padding:6px 8px; border-radius:6px; border:1px solid #e8e8e8; }
.r60-pair-row select,.r60-pair-row input[type=text] { font-size:.82rem; border:1px solid #ccc; border-radius:4px; padding:3px 7px; min-width:100px; max-width:170px; }
.r60-pair-del { background:#C0392B; color:#fff; border:none; border-radius:4px; padding:2px 8px; cursor:pointer; font-size:.8rem; flex-shrink:0; }
.r60-tbl { border-collapse:collapse; width:100%; font-size:.81rem; }
.r60-tbl th { background:#1565A6; color:#fff; padding:5px 7px; text-align:center; border:1px solid #bbb; white-space:nowrap; }
.r60-tbl td { padding:4px 6px; border:1px solid #ddd; text-align:center; vertical-align:middle; }
.r60-tbl tr.agree    { background:#F1F8E9; }
.r60-tbl tr.disagree { background:#FFEBEE; }
.r60-tbl tr.missing  { background:#FFF3E0; }
.r60-tbl td.oc { background:#DDEEFF; }
.r60-agree { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#E8F5E9; color:#1E8449; }
.r60-exc   { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#FFEBEE; color:#C0392B; }
.r60-miss  { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#FFF3E0; color:#E67E22; }
.workspace-signoff-actions { display:flex; gap:10px; flex-wrap:wrap; padding-top:4px; }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="r60ClientId">Engagement</label>
        <select id="r60ClientId" onchange="r60OnClientChange(this.value)">
            <option value="">Select engagement</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R60</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 60: CRSE vs H16CRSE Agreement</h1>
            <p class="rule-header__sub">
                Full outer reconciliation — <code>dbo_CRSE</code> vs <code>H16CRSE</code>.
                Join key: <code>_030</code> (CRSE) &harr; <code>_030</code> (H16CRSE).
            </p>
        </div>
        <div class="rule-header__badge" id="r60StatusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
    <div class="accordion-stack">
        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r60-conn')">
                <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r60-conn">
                <div class="form-grid">
                    <div class="field-group">
                        <label for="r60Server">Server Name</label>
                        <input id="r60Server" type="text" placeholder="SERVER\INSTANCE or (localdb)\MSSQLLocalDB" />
                    </div>
                    <div class="field-group">
                        <label for="r60Driver">Driver</label>
                        <select id="r60Driver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="r60Db">Database</label>
                        <select id="r60Db" onchange="r60LoadTables()"></select>
                    </div>
                </div>
                <div class="action-bar" style="justify-content:flex-start;margin:10px 0 0">
                    <button type="button" class="btn btn-primary" onclick="r60Connect()">Connect</button>
                </div>
                <div id="r60ConnOut" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r60-tables')">
                <span class="acc-icon">TB</span><span>Table Configuration &amp; Join Keys</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r60-tables" style="display:none">
                <div class="info-box info-box--red" style="margin-bottom:12px">
                    Tables auto-detected on connect. CRSE uses <code>_030</code> and H16CRSE uses <code>_030</code> as the join key.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>CRSE Table (HEMIS ASCII)</label>
                        <select id="r60StudTable" onchange="r60LoadCols('stud',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label>H16CRSE Table</label>
                        <select id="r60AuditTable" onchange="r60LoadCols('audit',this.value)"></select>
                    </div>
                    <div class="field-group">
                        <label>CRSE join key</label>
                        <select id="r60StudKey"></select>
                    </div>
                    <div class="field-group">
                        <label>H16CRSE join key</label>
                        <select id="r60AuditKey"></select>
                    </div>
                </div>
                <div id="r60TableOut" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r60-colmap')">
                <span class="acc-icon">CM</span><span>Column Mapping</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r60-colmap" style="display:none">
                <div class="alert alert--info" style="margin-bottom:12px">
                    Map CRSE columns to H16CRSE columns for field-by-field comparison. Defaults match the standard HEMIS layout.
                    Connect and select a database to auto-populate.
                </div>
                <div id="r60ColPairs"></div>
                <button type="button" class="btn btn-secondary" style="margin-top:8px;font-size:.82rem" onclick="r60AddPair()">&#65291; Add pair</button>
            </div>
        </div>
    </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 60 configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="r60RunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 60 workspace.</div>
        <div class="workspace-signoff-grid">
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div>
                <div id="r60RunLabel">No saved run yet</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                <div id="r60StatusLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div>
                <div id="r60EditedLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div>
                <div id="r60RoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div>
            </div>
            <div class="field-group" style="grid-column:1/-1">
                <label for="r60SignoffComment">Signoff Comment</label>
                <textarea id="r60SignoffComment" rows="2" placeholder="Add the final review note confirming this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button class="btn btn-success" id="r60SaveBtn" onclick="r60SaveWorkspace()">Save Workspace</button>
            }
            <button class="btn btn-primary" id="r60SignoffBtn" onclick="r60SignOff()">Sign Off</button>
            <button class="btn btn-warning" id="r60RemoveSignoffBtn" onclick="r60RemoveSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        @if (!isResultsOnlyRole)
        {
            <button class="btn btn-info"    onclick="r60Verify()">Verify Tables</button>
            <button class="btn btn-success" onclick="r60Run()">&#9654; Run Rule 60</button>
            <button class="btn btn-primary" onclick="r60Sql()">Generate SQL</button>
        }
        <button class="btn btn-warning" id="r60DlAllBtn" onclick="r60DlAll()" disabled>Download All</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="r60-analysis"  onclick="r60Tab('r60-analysis')">Analysis Results</button>
            <button class="tab-btn"        type="button" data-tab="r60-details"   onclick="r60Tab('r60-details')">Data Details</button>
            <button class="tab-btn"        type="button" data-tab="r60-charts"    onclick="r60Tab('r60-charts')">Charts</button>
            <button class="tab-btn"        type="button" data-tab="r60-sql"       onclick="r60Tab('r60-sql')">SQL Code</button>
            <button class="tab-btn"        type="button" data-tab="r60-downloads" onclick="r60Tab('r60-downloads')">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="r60-analysis">
            <div id="r60AnalysisPane"><div class="empty-state"><p>Run Rule 60 validation to see results here.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r60-details">
            <div id="r60FlaggedPane"><div class="empty-state"><p>No flagged rows yet — run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r60-charts">
            <div id="r60ClearPane"><div class="empty-state"><p>No clear rows yet — run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r60-sql">
            <textarea id="r60SqlText" rows="20" readonly style="width:100%;font-family:monospace;font-size:12px"></textarea>
        </div>
        <div class="tab-pane" data-tab-panel="r60-downloads">
            <div class="alert alert--info" style="margin-bottom:12px">Download the full Rule 60 result set after running validation.</div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info"      id="r60DlExcel">Excel</button>
                <button type="button" class="btn btn-info"      id="r60DlCsv">CSV (All)</button>
                <button type="button" class="btn btn-secondary" id="r60DlExcCsv">CSV (Exceptions)</button>
                <button type="button" class="btn btn-secondary" id="r60DlSql">SQL</button>
            </div>
        </div>
    </div>

    <div id="r60Spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="r60SpinMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="r60AntiForgery" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = window.toggleAccordion || function(s) {
    var b = document.getElementById('body-' + s);
    if (b) b.style.display = b.style.display === 'none' ? '' : 'none';
};

window.r60Tab = function(tab) {
    document.querySelectorAll('#app .results-panel .tab-btn').forEach(function(b) { b.classList.toggle('active', b.dataset.tab === tab); });
    document.querySelectorAll('#app .results-panel .tab-pane').forEach(function(p) { p.classList.toggle('active', p.dataset.tabPanel === tab); });
};

(function () {
    var API = '/Rule60';
    var ROLE = '@currentSystemRole';
    var IS_RESULTS_ONLY = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    var TOKEN = (document.querySelector('#r60AntiForgery input[name="__RequestVerificationToken"]') || {}).value || '';

    var DEF_PAIRS = [
        { studCol: '_030', auditCol: '_030', label: 'Subject Code (_030)' },
        { studCol: '_065', auditCol: '_065', label: '_065' },
        { studCol: '_031', auditCol: '_031', label: '_031' },
        { studCol: '_033', auditCol: '_033', label: '_033' },
        { studCol: '_034', auditCol: '_034', label: '_034' },
        { studCol: '_059', auditCol: '_059', label: '_059' },
        { studCol: '_060', auditCol: '_060', label: '_060' },
        { studCol: '_061', auditCol: '_061', label: '_061' },
        { studCol: '_062', auditCol: '_062', label: '_062' },
        { studCol: '_058', auditCol: '_058', label: '_058' },
        { studCol: '_091', auditCol: '_091', label: '_091' },
        { studCol: '_092', auditCol: '_092', label: '_092' },
        { studCol: '_093', auditCol: '_093', label: '_093' }
    ];

    var st = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        runId: null, summary: null,
        studCols: [], auditCols: [],
        pairs: [],
        isWorkspaceSaved: false, currentUserHasSignedOff: false, resultsVisible: false,
        currentUserEngagementRole: ''
    };

    function g(id)             { return document.getElementById(id); }
    function gv(id)            { var e = g(id); return e ? e.value : ''; }
    function esc(v)            { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function fmt(n)            { return Number(n || 0).toLocaleString(); }
    function show(id, v)       { var e = g(id); if (e) e.style.display = v ? '' : 'none'; }
    function setHtml(id, html) { var e = g(id); if (e) e.innerHTML = html; }
    function spin(msg)         { var e = g('r60SpinMsg'); if (e) e.textContent = msg || 'Processing...'; show('r60Spinner', true); }
    function unspin()          { show('r60Spinner', false); }
    function setWs(msg, type)  { var e = g('workspaceInfo'); if (e) { e.className = 'alert alert--' + (type || 'info'); e.textContent = msg; } }
    function setStatus(id, msg, type) { var e = g(id); if (e) { e.className = 'alert alert--' + (type || 'info'); e.textContent = msg; } }

    function fillSel(id, items, selected) {
        var sel = typeof id === 'string' ? g(id) : id; if (!sel) return;
        sel.innerHTML = '';
        (items || []).forEach(function(item) {
            var o = document.createElement('option');
            o.value = o.textContent = item;
            if (selected && selected === item) o.selected = true;
            sel.appendChild(o);
        });
    }

    function post(url, body) {
        return fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(body)
        }).then(function(r) { return r.json(); });
    }

    function setStatusBadge(status) {
        var b = g('r60StatusBadge'); if (!b) return;
        if (!status) { b.style.display = 'none'; return; }
        b.style.display = ''; b.textContent = status;
        b.className = 'rule-header__badge ' + (String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail');
    }

    /* ── Pair Management ── */
    function renderPairs() {
        var box = g('r60ColPairs'); if (!box) return;
        box.innerHTML = '';
        if (!st.pairs || !st.pairs.length) st.pairs = DEF_PAIRS.slice();
        st.pairs.forEach(function(p, i) {
            var row = document.createElement('div'); row.className = 'r60-pair-row';
            row.innerHTML = '<span style="color:#888;font-size:.8rem">#' + (i + 1) + '</span>' +
                '<input type="text" placeholder="CRSE col" value="' + esc(p.studCol) + '" oninput="r60PairSet(' + i + ',\'studCol\',this.value)">' +
                '<span style="color:#999">&harr;</span>' +
                '<input type="text" placeholder="H16CRSE col" value="' + esc(p.auditCol) + '" oninput="r60PairSet(' + i + ',\'auditCol\',this.value)">' +
                '<input type="text" placeholder="Label" value="' + esc(p.label) + '" oninput="r60PairSet(' + i + ',\'label\',this.value)" style="max-width:130px">' +
                '<button class="r60-pair-del" onclick="r60RemovePair(' + i + ')">&#x2715;</button>';
            box.appendChild(row);
        });
    }

    window.r60PairSet = function(i, key, val) { if (st.pairs[i]) st.pairs[i][key] = val; };
    window.r60RemovePair = function(i) { st.pairs.splice(i, 1); renderPairs(); };
    window.r60AddPair = function() { st.pairs.push({ studCol: '', auditCol: '', label: '' }); renderPairs(); };

    /* ── Connection ── */
    window.r60Connect = function() {
        var server = gv('r60Server').trim();
        if (!server) { setWs('Enter a server name first.', 'warning'); return; }
        spin('Connecting to server...');
        post(API + '/GetDatabases', { server: server, driver: gv('r60Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setStatus('r60ConnOut', d.error || 'Connection failed.', 'error'); return; }
            fillSel('r60Db', d.databases || []);
            setStatus('r60ConnOut', 'Connected — ' + (d.databases || []).length + ' database(s) found.', 'success');
            if ((d.databases || []).length) r60LoadTables();
        }).catch(function(e) { unspin(); setStatus('r60ConnOut', e.message, 'error'); });
    };

    window.r60LoadTables = function() {
        var db = gv('r60Db'); if (!db) return;
        spin('Loading tables...');
        post(API + '/GetTables', { server: gv('r60Server').trim(), database: db, driver: gv('r60Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setStatus('r60TableOut', d.error || 'Failed to load tables.', 'error'); return; }
            var tables = d.tables || [];
            fillSel('r60StudTable',  tables, d.autoStudTable  || 'dbo_CRSE');
            fillSel('r60AuditTable', tables, d.autoAuditTable || 'H16CRSE');
            show('body-r60-tables', true); show('body-r60-colmap', true);
            setStatus('r60TableOut', 'Loaded ' + tables.length + ' tables — CRSE and H16CRSE auto-detected.', 'success');
            st.pairs = DEF_PAIRS.slice();
            return Promise.all([
                r60LoadColsInner('stud',  gv('r60StudTable')),
                r60LoadColsInner('audit', gv('r60AuditTable'))
            ]);
        }).then(function() { renderPairs(); })
        .catch(function(e) { unspin(); setStatus('r60TableOut', e.message, 'error'); });
    };

    function r60LoadColsInner(role, tableName) {
        if (!tableName || !gv('r60Server') || !gv('r60Db')) return Promise.resolve();
        return post(API + '/GetColumns', { server: gv('r60Server').trim(), database: gv('r60Db'), driver: gv('r60Driver'), tableName: tableName })
        .then(function(d) {
            if (!d.success) return;
            var cols = d.columns || [];
            if (role === 'stud')  { st.studCols  = cols; fillSel('r60StudKey',  cols, d.autoKey || '_030'); }
            if (role === 'audit') { st.auditCols = cols; fillSel('r60AuditKey', cols, d.autoKey || '_030'); }
        });
    }

    window.r60LoadCols = function(role, tbl) { r60LoadColsInner(role, tbl); };

    window.r60Verify = function() {
        spin('Verifying tables...');
        post(API + '/VerifyTables', {
            server: gv('r60Server').trim(), database: gv('r60Db'), driver: gv('r60Driver'),
            studTable: gv('r60StudTable'), auditTable: gv('r60AuditTable'),
            studKey: gv('r60StudKey') || '_030', auditKey: gv('r60AuditKey') || '_030'
        }).then(function(d) {
            unspin();
            if (!d.success) { setStatus('r60TableOut', d.error || 'Verification failed.', 'error'); return; }
            setStatus('r60TableOut', 'dbo_CRSE: ' + fmt(d.studCount) + ' rows | H16CRSE: ' + fmt(d.auditCount) + ' rows', 'success');
        }).catch(function(e) { unspin(); setStatus('r60TableOut', e.message, 'error'); });
    };

    function buildReq() {
        return {
            clientId: st.clientId, runId: st.runId,
            server: gv('r60Server').trim(), database: gv('r60Db'), driver: gv('r60Driver') || 'ODBC Driver 17 for SQL Server',
            studTable:  gv('r60StudTable')  || 'dbo_CRSE',
            auditTable: gv('r60AuditTable') || 'H16CRSE',
            studKey:    gv('r60StudKey')    || '_030',
            auditKey:   gv('r60AuditKey')   || '_030',
            pairs: st.pairs.filter(function(p) { return p.studCol && p.auditCol; })
        };
    }

    window.r60Run = function() {
        if (!st.clientId) { setWs('Select an engagement before running.', 'warning'); return; }
        spin('Running Rule 60 validation...');
        post(API + '/RunValidation', buildReq())
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Validation failed.', 'error'); return; }
            st.runId = d.savedRunId || st.runId;
            st.currentUserHasSignedOff = false; st.isWorkspaceSaved = false; st.resultsVisible = true;
            applySummary(d, false);
            setWs('Rule 60 complete. Total: ' + fmt(d.totalCount) + ' | Agree: ' + fmt(d.agreeCount) + ' | Exceptions: ' + fmt((d.disagreeCount || 0) + (d.missingCount || 0)) + '. Overall: ' + d.status, d.status === 'PASS' ? 'success' : 'warning');
            var dlBtn = g('r60DlAllBtn'); if (dlBtn) dlBtn.disabled = false;
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r60Sql = function() {
        spin('Generating SQL...');
        post(API + '/GenerateSql', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { alert('Error: ' + (d.error || 'Failed.')); return; }
            var t = g('r60SqlText'); if (t) t.value = d.sql || '';
            r60Tab('r60-sql');
        }).catch(function(e) { unspin(); alert(e.message); });
    };

    window.r60DlAll = function() { if (st.runId) window.open(API + '/DownloadSavedExcel?runId=' + st.runId, '_blank'); };

    /* ── Workspace ── */
    window.r60SaveWorkspace = function() {
        spin('Saving workspace...');
        post(API + '/SaveWorkspace', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Save failed.', 'error'); return; }
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Workspace saved.', d.signoffsCleared ? 'warning' : 'success');
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r60SignOff = function() {
        spin('Saving signoff...');
        post(API + '/SignOffWorkspace', { clientId: st.clientId, runId: st.runId, comment: gv('r60SignoffComment') })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Signoff failed.', 'error'); return; }
            st.currentUserHasSignedOff = true;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff saved.', 'success'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r60RemoveSignoff = function() {
        spin('Removing signoff...');
        post(API + '/RemoveWorkspaceSignoff', { clientId: st.clientId, runId: st.runId, comment: '' })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Failed.', 'error'); return; }
            st.currentUserHasSignedOff = false;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff removed.', 'warning'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    function applyWsMeta(ws) {
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        if (ws.currentUserEngagementRole) st.currentUserEngagementRole = ws.currentUserEngagementRole;
        var b   = g('r60RunState');    if (b)   b.textContent   = ws.runId ? 'Run #' + ws.runId : 'No saved run loaded';
        var rl  = g('r60RunLabel');    if (rl)  rl.textContent  = ws.runId ? 'Rule 60 Run #' + ws.runId : 'No saved run yet';
        var sl  = g('r60StatusLabel'); if (sl)  sl.textContent  = ws.currentStatus || ws.status || '-';
        var el  = g('r60EditedLabel'); if (el)  el.textContent  = ws.lastEditedAt ? new Date(ws.lastEditedAt).toLocaleString() : '-';
        var rl2 = g('r60RoleLabel');   if (rl2) rl2.textContent = ws.currentUserEngagementRole || ROLE || '-';
        var sc  = g('r60SignoffComment'); if (sc && ws.currentUserSignoffComment) sc.value = ws.currentUserSignoffComment;
        updateButtons();
    }

    function updateButtons() {
        var engRole = (st.currentUserEngagementRole || ROLE || '').toLowerCase();
        var nSys    = (ROLE || '').toLowerCase();
        var canEdit = !IS_RESULTS_ONLY && (nSys === 'dataanalyst' || engRole === 'dataanalyst');
        var canSign = !!st.runId && !!st.isWorkspaceSaved &&
            (engRole === 'dataanalyst' || (st.resultsVisible && (engRole === 'manager' || engRole === 'director')));
        var signed  = st.currentUserHasSignedOff;
        var sw = g('r60SaveBtn');   if (sw) sw.disabled = signed || !canEdit || !st.runId;
        var so = g('r60SignoffBtn');if (so) { so.disabled = signed || !canSign; so.textContent = signed ? 'Signed Off' : 'Sign Off'; }
        show('r60RemoveSignoffBtn', signed);
    }

    window.r60OnClientChange = function(val) {
        st.clientId = parseInt(val) || 0;
        if (!st.clientId) { setWs('Select an engagement to load the saved Rule 60 workspace.', 'info'); return; }
        loadWorkspace();
    };

    function loadWorkspace() {
        if (!st.clientId) return;
        setWs('Loading saved workspace...', 'info');
        (window.fetchJsonWithProgress || function(url, opts) { return fetch(url, opts).then(function(r) { return r.json(); }); })(API + '/GetWorkspaceState?clientId=' + st.clientId, { method: 'GET' })
        .then(function(d) {
            if (!d.success) { setWs(d.error || 'Failed to load workspace.', 'error'); return; }
            applyWorkspace(d.workspace, d.resultsVisible);
        }).catch(function(e) { setWs(e.message, 'error'); });
    }

    function applyWorkspace(ws, resultsVisible) {
        if (!ws) {
            st.runId = null; st.summary = null; st.isWorkspaceSaved = false;
            st.currentUserHasSignedOff = false; st.resultsVisible = false; st.currentUserEngagementRole = '';
            setWs('No saved Rule 60 workspace for this engagement yet.', 'info');
            var b   = g('r60RunState');    if (b)   b.textContent   = 'No saved run loaded';
            var rl  = g('r60RunLabel');    if (rl)  rl.textContent  = 'No saved run yet';
            var sl  = g('r60StatusLabel'); if (sl)  sl.textContent  = '-';
            var el  = g('r60EditedLabel'); if (el)  el.textContent  = '-';
            st.pairs = DEF_PAIRS.slice(); renderPairs();
            applySummary(null, false); updateButtons(); return;
        }
        st.runId = ws.runId || null;
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        st.resultsVisible = !!resultsVisible;
        st.currentUserEngagementRole = ws.currentUserEngagementRole || '';

        if (!IS_RESULTS_ONLY) {
            var sv = g('r60Server'); if (sv && ws.server) sv.value = ws.server;
            var dv = g('r60Driver'); if (dv && ws.driver) dv.value = ws.driver;
            if (ws.database)   fillSel('r60Db',         [ws.database],    ws.database);
            if (ws.studTable)  fillSel('r60StudTable',  [ws.studTable],   ws.studTable);
            if (ws.auditTable) fillSel('r60AuditTable', [ws.auditTable],  ws.auditTable);
            if (ws.studKey)    fillSel('r60StudKey',    [ws.studKey],     ws.studKey);
            if (ws.auditKey)   fillSel('r60AuditKey',   [ws.auditKey],    ws.auditKey);
        }

        applyWsMeta(ws);
        var sc = g('r60SignoffComment'); if (sc && ws.currentUserSignoffComment) sc.value = ws.currentUserSignoffComment;

        st.pairs = (ws.summary && ws.summary.reconc && ws.summary.reconc.pairs && ws.summary.reconc.pairs.length) ? ws.summary.reconc.pairs.slice() : DEF_PAIRS.slice();
        if (!IS_RESULTS_ONLY) renderPairs();

        if (!resultsVisible) { setWs('Saved Rule 60 results are not available for your role.', 'info'); applySummary(null, false); updateButtons(); return; }
        setWs(ws.summary ? 'Saved Rule 60 workspace loaded.' : 'Rule 60 workspace loaded. Run validation to generate results.', 'success');
        if (ws.summary) applySummary(ws.summary, true);
        else { applySummary(null, false); updateButtons(); }
        var dlBtn = g('r60DlAllBtn'); if (dlBtn) dlBtn.disabled = !ws.runId;
    }

    /* ── Rendering ── */
    function applySummary(summary, fromWs) {
        st.summary = summary;
        if (summary && !fromWs) st.runId = summary.savedRunId || st.runId;
        setStatusBadge(summary ? summary.status : '');
        renderAnalysis(summary);
        renderDetails(summary, summary ? summary.reconc : null);
        renderCharts(summary, summary ? summary.reconc : null);
        if (summary && st.runId) {
            var dlE = g('r60DlExcel');  if (dlE) dlE.onclick = function() { window.open(API + '/DownloadSavedExcel?runId=' + st.runId, '_blank'); };
            var dlC = g('r60DlCsv');    if (dlC) dlC.onclick = function() { window.open(API + '/DownloadSavedCsv?runId=' + st.runId, '_blank'); };
            var dlX = g('r60DlExcCsv');if (dlX) dlX.onclick = function() { window.open(API + '/DownloadSavedExceptionsCsv?runId=' + st.runId, '_blank'); };
            var dlS = g('r60DlSql');    if (dlS) dlS.onclick = function() { window.open(API + '/DownloadSavedSql?runId=' + st.runId, '_blank'); };
        }
        updateButtons();
    }

    function renderAnalysis(s) {
        var pane = g('r60AnalysisPane'); if (!pane) return;
        if (!s) { pane.innerHTML = '<div class="empty-state"><p>Run Rule 60 validation to see results here.</p></div>'; return; }
        var sc = String(s.status || '').toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail';
        pane.innerHTML =
            '<div class="stats-grid" style="margin-bottom:20px">' +
            statCard('Total', fmt(s.totalCount || 0), '') +
            statCard('Agree', fmt(s.agreeCount || 0), 'pass') +
            statCard('Disagree', fmt(s.disagreeCount || 0), s.disagreeCount > 0 ? 'fail' : '') +
            statCard('Missing', fmt(s.missingCount || 0), s.missingCount > 0 ? 'fail' : '') +
            statCard('Exception Rate', Number(s.exceptionRate || 0).toFixed(2) + '%', s.exceptionRate > 0 ? 'fail' : 'pass') +
            statCard('Overall', '<span class="badge ' + sc + '">' + esc(s.status) + '</span>', '') +
            '</div>' +
            '<div class="card" style="padding:16px"><div class="form-grid">' +
            '<div><div class="stat-label">Database</div><div>' + esc(s.database || '') + '</div></div>' +
            '<div><div class="stat-label">CRSE Table</div><div>' + esc(s.studTable || '') + '</div></div>' +
            '<div><div class="stat-label">H16CRSE Table</div><div>' + esc(s.auditTable || '') + '</div></div>' +
            '<div><div class="stat-label">Timestamp</div><div>' + esc(s.timestamp || '') + '</div></div>' +
            '<div style="grid-column:1 / -1"><div class="stat-label">Comparison Rule</div><div>Numeric-like values are treated as equal, so <code>05</code> matches <code>5</code> and <code>01</code> matches <code>1</code>.</div></div>' +
            '</div></div>';
    }

    function statCard(label, value, mod) {
        var cls = mod === 'pass' ? ' stat-card--pass' : mod === 'fail' ? ' stat-card--fail' : '';
        return '<div class="stat-card' + cls + '"><div class="stat-card__label">' + label + '</div><div class="stat-card__value">' + value + '</div></div>';
    }

    function renderDetails(summary, reconc) {
        if (!reconc) {
            setHtml('r60FlaggedPane', '<div class="empty-state"><p>Run validation first.</p></div>');
            return;
        }
        var pairs   = reconc.pairs || [];
        var excRows = reconc.exceptionRows || [];
        var agrRows = reconc.rows || [];

        setHtml('r60FlaggedPane',
            '<div class="card" style="padding:12px;margin-bottom:16px">' +
            '<div class="form-grid">' +
            '<div><div class="stat-label">Exception Rows</div><div>' + fmt((reconc.disagreeCount || 0) + (reconc.missingCount || 0)) + '</div></div>' +
            '<div><div class="stat-label">Agree Rows</div><div>' + fmt(reconc.agreeCount || 0) + '</div></div>' +
            '<div><div class="stat-label">Browser Preview</div><div>Showing ' + fmt(excRows.length) + ' exception row(s) and ' + fmt(agrRows.length) + ' agree row(s) on screen.</div></div>' +
            '</div>' +
            '</div>' +
            '<div class="card" style="padding:12px;margin-bottom:12px;border-left:4px solid #C0392B">' +
            '<strong>Exception Rows</strong>: ' + fmt(reconc.disagreeCount || 0) + ' DISAGREE + ' + fmt(reconc.missingCount || 0) + ' MISSING rows.' +
            '</div>' + buildTable(excRows, pairs, 'No exceptions â€” all subjects agree.') +
            '<div class="card" style="padding:12px;margin:20px 0 12px;border-left:4px solid #1E8449">' +
            '<strong>Agree Sample</strong>: ' + fmt(reconc.agreeCount || 0) + ' subject row(s) agree' +
            (agrRows.length < (reconc.agreeCount || 0) ? ' (sample of ' + fmt(agrRows.length) + ' shown)' : '') + '.' +
            '</div>' + buildTable(agrRows, pairs, 'No agree rows in this run.'));
    }

    function renderCharts(summary, reconc) {
        if (!reconc) {
            setHtml('r60ClearPane', '<div class="empty-state"><p>Run validation first.</p></div>');
            return;
        }

        setHtml('r60ClearPane',
            '<div class="stats-grid" style="margin-bottom:16px">' +
                statCard('Total Tested', fmt(summary ? (summary.totalCount || 0) : 0), '') +
                statCard('Exception Rate', Number(summary ? (summary.exceptionRate || 0) : 0).toFixed(2) + '%', summary && summary.exceptionRate > 0 ? 'fail' : 'pass') +
                statCard('Overall Status', '<span class="badge ' + ((summary && String(summary.status || '').toUpperCase() === 'PASS') ? 'badge--pass' : 'badge--fail') + '">' + esc(summary ? (summary.status || '') : '') + '</span>', '') +
            '</div>' +
            buildChartCards(summary));
    }

    function buildChartCards(summary) {
        if (!summary) return '<div class="empty-state"><p>No chart data yet.</p></div>';
        var total = Number(summary.totalCount || 0);
        var safeTotal = total > 0 ? total : 1;
        var metrics = [
            { label: 'Agree', count: Number(summary.agreeCount || 0), color: '#1E8449', bg: '#E8F5E9' },
            { label: 'Disagree', count: Number(summary.disagreeCount || 0), color: '#C0392B', bg: '#FDECEC' },
            { label: 'Missing', count: Number(summary.missingCount || 0), color: '#E67E22', bg: '#FFF4E5' }
        ];

        return '<div class="stats-grid">' + metrics.map(function(metric) {
            var percent = ((metric.count / safeTotal) * 100).toFixed(2);
            return '<div class="card" style="padding:16px">' +
                '<div style="display:flex;justify-content:space-between;gap:12px;margin-bottom:10px"><strong>' + metric.label + '</strong><span>' + fmt(metric.count) + ' (' + percent + '%)</span></div>' +
                '<div style="height:12px;border-radius:999px;background:' + metric.bg + ';overflow:hidden">' +
                '<div style="height:100%;width:' + percent + '%;background:' + metric.color + ';border-radius:999px"></div>' +
                '</div>' +
            '</div>';
        }).join('') + '</div>';
    }

    function renderReconc(reconc) {
        if (!reconc) {
            setHtml('r60FlaggedPane', '<div class="empty-state"><p>Run validation first.</p></div>');
            setHtml('r60ClearPane',   '<div class="empty-state"><p>Run validation first.</p></div>');
            return;
        }
        var pairs   = reconc.pairs || [];
        var excRows = reconc.exceptionRows || [];
        var agrRows = reconc.rows || [];

        setHtml('r60FlaggedPane',
            '<div class="card" style="padding:12px;margin-bottom:10px;border-left:4px solid #C0392B">' +
            '<strong>FLAGGED</strong>: ' + fmt(reconc.disagreeCount || 0) + ' DISAGREE + ' + fmt(reconc.missingCount || 0) + ' MISSING rows.' +
            '</div>' + buildTable(excRows, pairs, 'No exceptions — all students agree.'));

        setHtml('r60ClearPane',
            '<div class="card" style="padding:12px;margin-bottom:10px;border-left:4px solid #1E8449">' +
            '<strong>CLEAR</strong>: ' + fmt(reconc.agreeCount || 0) + ' students agree' +
            (agrRows.length < (reconc.agreeCount || 0) ? ' (sample of ' + fmt(agrRows.length) + ' shown)' : '') + '.' +
            '</div>' + buildTable(agrRows, pairs, 'No clear rows in this run.'));
    }

    function buildTable(rows, pairs, emptyMsg) {
        if (!rows || !rows.length) return '<div class="empty-state"><p>' + emptyMsg + '</p></div>';
        var hdrs = pairs.map(function(p) {
            return '<th style="background:#1565A6">CRSE ' + esc(p.studCol || p.StudCol || '') + '</th>' +
                   '<th style="background:#0D6E2E">H16CRSE ' + esc(p.auditCol || p.AuditCol || '') + '</th>' +
                   '<th>Match</th>';
        }).join('');
        var body = rows.map(function(r) {
            var ov = r.overallResult || r.OverallResult || '';
            var cls = ov === 'AGREE' ? 'agree' : ov === 'DISAGREE' ? 'disagree' : 'missing';
            var badge = ov === 'AGREE' ? '<span class="r60-agree">&#10003; AGREE</span>' : ov === 'DISAGREE' ? '<span class="r60-exc">&#x2717; DISAGREE</span>' : '<span class="r60-miss">? MISSING</span>';
            var cells = pairs.map(function(p) {
                var lbl = p.label || p.Label || p.studCol || '';
                var fMap = r.fields || {};
                var f = fMap[lbl] || fMap[lbl.charAt(0).toLowerCase() + lbl.slice(1)];
                if (!f) {
                    var lbl_lc = lbl.toLowerCase();
                    var fKeys = Object.keys(fMap);
                    for (var ki = 0; ki < fKeys.length; ki++) {
                        if (fKeys[ki].toLowerCase() === lbl_lc) { f = fMap[fKeys[ki]]; break; }
                    }
                }
                f = f || {};
                var sv = f.studValue != null ? f.studValue : (f.StudValue != null ? f.StudValue : '—');
                var av = f.auditValue != null ? f.auditValue : (f.AuditValue != null ? f.AuditValue : '—');
                var matchVal = f.match || f.Match || 'MISSING';
                var mi = matchVal === 'AGREE' ? '<span style="color:#1E8449">&#10003;</span>' : matchVal === 'DISAGREE' ? '<span style="color:#C0392B">&#x2717;</span>' : '<span style="color:#E67E22">?</span>';
                return '<td>' + esc(sv) + '</td><td class="oc">' + esc(av) + '</td><td>' + mi + '</td>';
            }).join('');
            return '<tr class="' + cls + '"><td style="font-size:.73rem;color:#777">' + (r.rowNumber || r.RowNumber || '') + '</td><td style="font-weight:600;font-family:monospace">' + esc(r.studentRef || r.StudentRef || r.staffRef || '') + '</td>' + cells + '<td>' + badge + '</td><td style="font-size:.71rem;text-align:left;max-width:230px">' + esc(r.disagreeDetail || r.DisagreeDetail || '') + '</td></tr>';
        }).join('');
        return '<div style="overflow-x:auto"><table class="r60-tbl"><thead><tr><th>#</th><th>Subject Ref</th>' + hdrs + '<th>Result</th><th>Detail</th></tr></thead><tbody>' + body + '</tbody></table></div>';
    }

    /* ── Init ── */
    st.pairs = DEF_PAIRS.slice();
    renderPairs();
    applySummary(null, false);
    updateButtons();
    if (st.clientId) loadWorkspace();
})();
</script>

