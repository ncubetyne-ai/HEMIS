@using HemisAudit.Helpers
@model HemisAudit.ViewModels.ClientDetailViewModel
@{
    ViewData["Title"] = Model.EngagementName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canOpenModule = ViewBag.CanOpenModule is bool allowed && allowed;
    var canRunModules = ViewBag.CanRunModules is bool runModules && runModules;
    var canManageAssignments = ViewBag.CanManageAssignments is bool manageAssignments && manageAssignments;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isArchived = Model.IsArchived;
    var showModulesWorkspaceUi = ViewBag.ShowModulesWorkspaceUi is bool showModules && showModules;
    var currentValidationRuns = Model.ValidationRuns
        .Where(run => run.IsCurrent && run.HasDataAnalystSignoff)
        .OrderBy(run => run.RuleNumber)
        .ThenByDescending(run => run.RunAt)
        .ToList();
    var pendingAnalystSignoffRuns = Model.ValidationRuns
        .Where(run => run.IsCurrent && !run.HasDataAnalystSignoff)
        .OrderBy(run => run.RuleNumber)
        .ThenByDescending(run => run.RunAt)
        .ToList();
    var historicalValidationRuns = Model.ValidationRuns
        .Where(run => !run.IsCurrent)
        .OrderByDescending(run => run.RunAt)
        .ThenByDescending(run => run.Id)
        .ToList();
    Func<ValidationRunRow, bool> isPassedInsightRun = run =>
        string.Equals(run.Status, "PASS", StringComparison.OrdinalIgnoreCase) ||
        (!string.Equals(run.Status, "FAIL", StringComparison.OrdinalIgnoreCase) && run.TotalValidated > 0 && run.FailCount <= 0);
    Func<ValidationRunRow, bool> isFailedInsightRun = run =>
        string.Equals(run.Status, "FAIL", StringComparison.OrdinalIgnoreCase) ||
        (!string.Equals(run.Status, "PASS", StringComparison.OrdinalIgnoreCase) && run.FailCount > 0);
    var engagementInsightCurrentRuns = Model.ValidationRuns
        .Where(run => run.IsCurrent)
        .OrderByDescending(run => run.RunAt)
        .ThenByDescending(run => run.Id)
        .ToList();
    var engagementInsightLatestRuleRuns = engagementInsightCurrentRuns
        .GroupBy(run => run.RuleNumber)
        .Select(group => group
            .OrderByDescending(run => run.RunAt)
            .ThenByDescending(run => run.Id)
            .First())
        .OrderBy(run => run.RuleNumber)
        .ToList();
    var engagementInsightReviewedAndCompletedRuns = engagementInsightLatestRuleRuns.Count(run => run.IsReviewedAndCompleted);
    var engagementInsightPendingAnalystRuns = engagementInsightLatestRuleRuns.Count(run => !run.HasDataAnalystSignoff);
    var engagementInsightAwaitingReviewRuns = engagementInsightLatestRuleRuns.Count(run => run.HasDataAnalystSignoff && !run.IsReviewedAndCompleted);
    var engagementInsightNeedsReviewRuns = engagementInsightLatestRuleRuns.Count(run => !run.IsReviewedAndCompleted);
    var engagementInsightPassedRuleRuns = engagementInsightLatestRuleRuns.Count(run => isPassedInsightRun(run));
    var engagementInsightFailedRuleRuns = engagementInsightLatestRuleRuns.Count(run => isFailedInsightRun(run));
    var engagementInsightPassedRuleRecords = engagementInsightLatestRuleRuns.Sum(run => Math.Max(run.PassCount, 0));
    var engagementInsightFailedRuleRecords = engagementInsightLatestRuleRuns.Sum(run => Math.Max(run.FailCount, 0));
    var engagementInsightTotalRuleRecords = engagementInsightLatestRuleRuns.Sum(run => Math.Max(run.TotalValidated, 0));
    var engagementInsightPassedRuleRecordRate = engagementInsightTotalRuleRecords > 0
        ? Math.Round(engagementInsightPassedRuleRecords * 100m / engagementInsightTotalRuleRecords, 2)
        : 0m;
    var engagementInsightFailedRuleRecordRate = engagementInsightTotalRuleRecords > 0
        ? Math.Round(engagementInsightFailedRuleRecords * 100m / engagementInsightTotalRuleRecords, 2)
        : 0m;
    var engagementInsightAnalystSignedRuns = engagementInsightLatestRuleRuns.Count(run => run.HasDataAnalystSignoff);
    var engagementInsightManagerSignedRuns = engagementInsightLatestRuleRuns.Count(run => run.HasManagerSignoff);
    var engagementInsightDirectorSignedRuns = engagementInsightLatestRuleRuns.Count(run => run.HasDirectorSignoff);
    var engagementInsightRecentRuns = Model.ValidationRuns
        .OrderByDescending(run => run.RunAt)
        .ThenByDescending(run => run.Id)
        .Take(6)
        .ToList();
    var engagementInsightRuleOutcomeBreakdown = RuleRouteHelper.GetSupportedRuleNumbers()
        .Select(ruleNumber =>
        {
            var run = engagementInsightLatestRuleRuns.FirstOrDefault(item => item.RuleNumber == ruleNumber);
            return new HemisAudit.ViewModels.DashboardRuleOutcomeMetric
            {
                RuleNumber = ruleNumber,
                RuleLabel = $"Rule {ruleNumber}",
                PassedCount = run != null && isPassedInsightRun(run) ? 1 : 0,
                FailedCount = run != null && isFailedInsightRun(run) ? 1 : 0
            };
        })
        .Where(metric => metric.PassedCount > 0 || metric.FailedCount > 0)
        .ToList();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
    <script>
        window.addEventListener('load', function () {
            window.showAppToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]?.ToString() ?? "")), 'success');
        }, { once: true });
    </script>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
    <script>
        window.addEventListener('load', function () {
            window.showAppToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]?.ToString() ?? "")), 'error');
        }, { once: true });
    </script>
}

<div class="page-header">
    <div>
        <h1>@Model.EngagementName</h1>
        <p>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            @Model.Industry
            <span style="padding:0 8px">|</span>
            <span class="badge @(Model.IsArchived ? "badge--warning" : Model.IsApproved ? "badge--pass" : "badge--neutral")">@Model.Status</span>
            <span style="padding:0 8px">|</span>
            Created @Model.CreatedAt.ToString("dd MMM yyyy")
        </p>
        <p style="margin-top:4px;color:#757575">
            Director: @Model.DirectorName (@Model.DirectorEmail)
            <span style="padding:0 8px">|</span>
            Manager: @Model.ManagerName (@Model.ManagerEmail)
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end">
        @if (showModulesWorkspaceUi && (canOpenModule || Model.IsArchived))
        {
            <a href="#modules-panel" class="btn btn-secondary">Modules</a>
        }
        else if (showModulesWorkspaceUi)
        {
            <span class="btn btn-secondary" style="pointer-events:none;opacity:.75">Modules Locked</span>
        }
        <a href="#engagement-insight-panel" class="btn btn-secondary">Engagement Insight</a>

        @if (User.IsInRole("Admin") && !Model.IsApproved && !isArchived)
        {
            <form asp-action="ApproveClient" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="/Admin/ClientDetail/@Model.Id" />
                <button type="submit" class="btn btn-primary">Approve</button>
            </form>
        }

        @if (User.IsInRole("Admin") && !isArchived)
        {
            <form asp-action="DeleteClient" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-warning"
                        onclick="return confirm('Delete this engagement and all related assignments and validation runs?')">
                    Delete
                </button>
            </form>
        }

        @if (User.IsInRole("Director") && !isArchived)
        {
            <form asp-action="ArchiveClient" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="/Admin/ClientDetail/@Model.Id" />
                @if (Model.CanArchive)
                {
                    <button type="submit" class="btn btn-success"
                            onclick="return confirm('Archive this engagement? The workspace will close and only saved results will remain available.')">
                        Archive
                    </button>
                }
                else
                {
                    <button type="button"
                            class="btn btn-secondary"
                            disabled
                            title="@Model.ArchiveEligibilityMessage"
                            style="opacity:.55;filter:saturate(.2);cursor:not-allowed">
                        Archive
                    </button>
                }
            </form>
        }

        <a asp-action="Clients" class="btn btn-secondary">Back to Engagements</a>
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The record is read-only for everyone, and only saved results remain available for review and download.
    </div>

    if (Model.CurrentRunId.HasValue)
    {
        <div class="card" style="margin-bottom:24px;padding:18px 20px">
            <h3 class="section-title" style="margin-top:0">Archived Results</h3>
            <p style="margin-bottom:12px;color:#757575">
                Open the latest signed-off validation run or download it directly. No edits are allowed on archived engagements.
            </p>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <a href="@RuleRouteHelper.GetRunUrl(Model.CurrentRunRuleNumber ?? 10, Model.CurrentRunId ?? 0)"
                   class="btn btn-primary">
                    Open Latest Results
                </a>
                <a asp-controller="@RuleRouteHelper.GetControllerName(Model.CurrentRunRuleNumber ?? 0)"
                   asp-action="DownloadSavedExcel"
                   asp-route-runId="@Model.CurrentRunId"
                   class="btn btn-success">
                    Download Excel
                </a>
            </div>
        </div>
    }
}

@if (User.IsInRole("Director"))
{
    <div class="alert alert--info" style="margin-bottom:24px">@Model.ArchiveEligibilityMessage</div>
}

@if (showModulesWorkspaceUi)
{
    <details class="collapsible-section" id="modules-panel" style="margin-bottom:24px">
        <summary class="collapsible-trigger">
            <div>
                <span class="collapsible-trigger__title">Modules</span>
                <span class="collapsible-trigger__subtitle">Open the validation workspaces or review module availability for this engagement.</span>
            </div>
            <span class="collapsible-trigger__meta">Rules 1–10, 11–32, 34–36, 37, 38, 39, 40, 41, 44, 45, 46, 47, 48, 51, 52, 53, 54, 55, 57, 58, 59, 60 and 61</span>
            <span class="collapsible-trigger__icon" aria-hidden="true"></span>
        </summary>
        <div class="collapsible-panel">
            <div class="card" style="padding:18px 20px">
                @if (canOpenModule)
                {
                    <div class="module-card-grid">
                        @foreach (var integrityRule in IntegrityRuleCatalog.GetRuleNumbers().Where(ruleNumber => ruleNumber >= 1 && ruleNumber <= 10).Select(IntegrityRuleCatalog.Get))
                        {
                            <article class="module-card">
                                <div class="module-card__eyebrow">@integrityRule.RuleLabel</div>
                                <h4 class="module-card__title">@integrityRule.RuleTitle</h4>
                                <p class="module-card__text">@integrityRule.DetailedDescription</p>
                                <div class="module-card__actions">
                                    <a href="@RuleRouteHelper.GetWorkspaceUrl(integrityRule.RuleNumber, Model.Id)" class="btn btn-success">Open @integrityRule.RuleLabel</a>
                                </div>
                            </article>
                        }

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 11</div>
                            <h4 class="module-card__title">QUAL vs CESM vs PQM Validation</h4>
                            <p class="module-card__text">Joins <code>dbo_QUAL</code> and <code>dbo_CESM</code> on <code>_001</code>, then validates each qualification name (<code>QUAL._003</code> vs PQM <code>Authorised_Qualification_Name</code>) and HEQF type (<code>QUAL._005</code> vs PQM <code>HEQF_Qual_Type</code>) on the same PQM row. PASS when both match. EL §5.1.2.</p>
                            <div class="module-card__actions">
                                <a href="/Rule11?clientId=@Model.Id" class="btn btn-success">Open Rule 11</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 12</div>
                            <h4 class="module-card__title">Course Selection from dbo_CREG</h4>
                            <p class="module-card__text">Test 100% of the course population selected from <code>dbo_CREG._030</code>, compare it to <code>dbo_CRSE._030</code>, and keep the saved result set available for review and signoff.</p>
                            <div class="module-card__actions">
                                <a href="/Rule12?clientId=@Model.Id" class="btn btn-success">Open Rule 12</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 13</div>
                            <h4 class="module-card__title">CESM Qualification Population Validation</h4>
                            <p class="module-card__text">Test 100% of the CESM population where <code>dbo_CESM._006 &lt;&gt; 'ZZZZZZ'</code>, verify the <code>dbo_CESM -&gt; dbo_QUAL -&gt; dbo_STUD</code> linkage on <code>_001</code>, and keep the saved result set available for review and signoff.</p>
                            <div class="module-card__actions">
                                <a href="/Rule13?clientId=@Model.Id" class="btn btn-success">Open Rule 13</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 14</div>
                            <h4 class="module-card__title">Course Registration Validation</h4>
                            <p class="module-card__text">Test 100% of approved courses through the dbo_CRSE -&gt; dbo_CREG path, classify course-registration exceptions, and keep the saved workspace available for engagement review.</p>
                            <div class="module-card__actions">
                                <a href="/Rule14?clientId=@Model.Id" class="btn btn-success">Open Rule 14</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 15</div>
                            <h4 class="module-card__title">Course Credentials Validation</h4>
                            <p class="module-card__text">Test 100% of approved credential courses through the dbo_QUAL -&gt; dbo_CRED -&gt; dbo_CREG path, classify every row for the credential-registration control, and keep the saved workspace available for engagement review.</p>
                            <div class="module-card__actions">
                                <a href="/Rule15?clientId=@Model.Id" class="btn btn-success">Open Rule 15</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 16</div>
                            <h4 class="module-card__title">Student Population Validation</h4>
                            <p class="module-card__text">Test 100% of the linked student population where <code>dbo_STUD._025 = 'N'</code> through <code>dbo_STUD -&gt; dbo_CREG -&gt; dbo_CRSE</code>, classify all rows across the three controls, and review saved PASS or FAIL results.</p>
                            <div class="module-card__actions">
                                <a href="/Rule16?clientId=@Model.Id" class="btn btn-success">Open Rule 16</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 17</div>
                            <h4 class="module-card__title">Graduate Students Fulfilled Qualification Validation</h4>
                            <p class="module-card__text">Validate 100% of the <code>dbo_STUD</code> population where <code>_025 = 'F'</code>, save the filtered result set, and let assigned reviewers inspect the signed results.</p>
                            <div class="module-card__actions">
                                <a href="/Rule17?clientId=@Model.Id" class="btn btn-success">Open Rule 17</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 18</div>
                            <h4 class="module-card__title">NSFAS Student Validation</h4>
                            <p class="module-card__text">Test 100% of the NSFAS student population through <code>dbo_STUD -&gt; dbo_CREG -&gt; dbo_CRSE</code>, classify all rows across the three controls, and review saved PASS or FAIL results.</p>
                            <div class="module-card__actions">
                                <a href="/Rule18?clientId=@Model.Id" class="btn btn-success">Open Rule 18</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 19</div>
                            <h4 class="module-card__title">Masters and PhD Population Validation</h4>
                            <p class="module-card__text">Test 100% of the linked Masters and PhD student population through <code>dbo_STUD -> dbo_QUAL</code> using the fulfilled indicator and qualification type list.</p>
                            <div class="module-card__actions">
                                <a href="/Rule19?clientId=@Model.Id" class="btn btn-success">Open Rule 19</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 20</div>
                            <h4 class="module-card__title">Foundation Validation</h4>
                            <p class="module-card__text">Apply the Rule 20 foundation logic across all students, keep CRSE rows where _091 = 'Y', and let reviewers inspect the saved PASS or FAIL results.</p>
                            <div class="module-card__actions">
                                <a href="/Rule20?clientId=@Model.Id" class="btn btn-success">Open Rule 20</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 21</div>
                            <h4 class="module-card__title">First Time Entering Students Validation</h4>
                            <p class="module-card__text">Validate 100% of <code>dbo_STUD</code> against the typed <code>_010</code> filter value, classify every row as PASS or FAIL, and save the signed review results for the engagement.</p>
                            <div class="module-card__actions">
                                <a href="/Rule21?clientId=@Model.Id" class="btn btn-success">Open Rule 21</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 22</div>
                            <h4 class="module-card__title">Staff Sampling (dbo_PROF)</h4>
                            <p class="module-card__text">Apply the three notebook staff controls to dbo_PROF, save the full classified result set, and let every reviewer filter rows by control and PASS or FAIL.</p>
                            <div class="module-card__actions">
                                <a href="/Rule22?clientId=@Model.Id" class="btn btn-success">Open Rule 22</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 23</div>
                            <h4 class="module-card__title">Reconcile Datasets</h4>
                            <p class="module-card__text">Reconcile student number, qualification code, and ID number across dbo_STUD, MT-audit-prod-std, and H16STUD and isolate missing or mismatched student rows for review.</p>
                            <div class="module-card__actions">
                                <a href="/Rule23?clientId=@Model.Id" class="btn btn-success">Open Rule 23</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 24</div>
                            <h4 class="module-card__title">Reconcile Qualification Datasets</h4>
                            <p class="module-card__text">Reconcile qualification codes across dbo_QUAL, MT-audit-prod-QUAL, and H16QUAL with separate missing-record and qualification-validation controls.</p>
                            <div class="module-card__actions">
                                <a href="/Rule24?clientId=@Model.Id" class="btn btn-success">Open Rule 24</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 25</div>
                            <h4 class="module-card__title">Reconcile Course Datasets</h4>
                            <p class="module-card__text">Reconcile course codes across dbo_CRSE, MT-audit-prod-CRSE, and H16CRSE and isolate missing or unmatched rows for analyst review.</p>
                            <div class="module-card__actions">
                                <a href="/Rule25?clientId=@Model.Id" class="btn btn-success">Open Rule 25</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 26</div>
                            <h4 class="module-card__title">dbo_PROF to Payroll_Sample 5-Control Validation</h4>
                            <p class="module-card__text">Check the dbo_PROF population against Payroll_Sample across personnel existence, employment type, gender, race/group, and birth date controls, flagging dbo_PROF rows that are missing or mismatched in Payroll_Sample.</p>
                            <div class="module-card__actions">
                                <a href="/Rule26?clientId=@Model.Id" class="btn btn-success">Open Rule 26</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 27</div>
                            <h4 class="module-card__title">Error Validation</h4>
                            <p class="module-card__text">Choose any validation table column, detect its values, and retrieve 100% of the records that match the selected value.</p>
                            <div class="module-card__actions">
                                <a href="/Rule27?clientId=@Model.Id" class="btn btn-success">Open Rule 27</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 28</div>
                            <h4 class="module-card__title">Fatal Errors with Exclusions (CESM)</h4>
                            <p class="module-card__text">Filter fatal CESM validation detail errors, remove approved exclusion codes, and escalate only the fatal errors that remain.</p>
                            <div class="module-card__actions">
                                <a href="/Rule28?clientId=@Model.Id" class="btn btn-success">Open Rule 28</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 29</div>
                            <h4 class="module-card__title">Single Column Filter</h4>
                            <p class="module-card__text">Filter records where one selected column equals one selected value, then review the matching set with an optional breakdown column.</p>
                            <div class="module-card__actions">
                                <a href="/Rule29?clientId=@Model.Id" class="btn btn-success">Open Rule 29</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 30</div>
                            <h4 class="module-card__title">Fatal Errors with Exclusions (PROF)</h4>
                            <p class="module-card__text">Filter fatal PROF validation detail errors, remove approved exclusion codes, and escalate only the fatal errors that remain.</p>
                            <div class="module-card__actions">
                                <a href="/Rule30?clientId=@Model.Id" class="btn btn-success">Open Rule 30</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 31</div>
                            <h4 class="module-card__title">Fatal Errors with Exclusions (QUAL)</h4>
                            <p class="module-card__text">Filter fatal QUAL validation detail errors, remove approved exclusion codes, and escalate only the fatal errors that remain.</p>
                            <div class="module-card__actions">
                                <a href="/Rule31?clientId=@Model.Id" class="btn btn-success">Open Rule 31</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 32</div>
                            <h4 class="module-card__title">Fatal Errors with Exclusions</h4>
                            <p class="module-card__text">Filter fatal STUD validation detail errors, remove approved exclusion codes, and escalate only the fatal errors that remain.</p>
                            <div class="module-card__actions">
                                <a href="/Rule32?clientId=@Model.Id" class="btn btn-success">Open Rule 32</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 34</div>
                            <h4 class="module-card__title">Census Date Validation</h4>
                            <p class="module-card__text">Calculate the midpoint between first and last class dates, compare it with the stored census date, and evaluate weekends and SA public holidays.</p>
                            <div class="module-card__actions">
                                <a href="/Rule34?clientId=@Model.Id" class="btn btn-success">Open Rule 34</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 35</div>
                            <h4 class="module-card__title">Duplicate Check on dbo_CRSE</h4>
                            <p class="module-card__text">Count duplicate occurrences in the selected dbo_CRSE field, isolate duplicate groups, and save the full duplicate analysis for review and signoff.</p>
                            <div class="module-card__actions">
                                <a href="/Rule35?clientId=@Model.Id" class="btn btn-success">Open Rule 35</a>
                            </div>
                        </article>
                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 36</div>
                            <h4 class="module-card__title">Deceased Students Validation</h4>
                            <p class="module-card__text">Match student records against the deceased students reference table and save exceptions for review and signoff.</p>
                            <div class="module-card__actions">
                                <a href="/Rule36?clientId=@Model.Id" class="btn btn-success">Open Rule 36</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 37</div>
                            <h4 class="module-card__title">CESM vs PQM Validation</h4>
                            <p class="module-card__text">Cross-validate HEMIS CESM codes and qualification names against the PQM reference table, flagging records where the code prefix or authorised qualification name does not match.</p>
                            <div class="module-card__actions">
                                <a href="/Rule37?clientId=@Model.Id" class="btn btn-success">Open Rule 37</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 38</div>
                            <h4 class="module-card__title">Enhanced QUAL -> CESM -> PQM Validation</h4>
                            <p class="module-card__text">Bridge approved qualifications through CESM using <code>QUAL._001 = CESM._001</code> and <code>CESM._006 = PQM.CESM_CODE1</code>, then validate controls 5.1.1-5.1.6 against the matched PQM row.</p>
                            <p class="module-card__text"><strong>Note:</strong> Procedure 5.1.1 checks approval status. Procedures 5.1.2-5.1.6 cover qualification type, minimum time total, WIL/experiential time, HEQF policy indicator, and total subsidy units.</p>
                            <div class="module-card__actions">
                                <a href="/Rule38?clientId=@Model.Id" class="btn btn-success">Open Rule 38</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 39</div>
                            <h4 class="module-card__title">First-Time Entering vs Non-Aligned Qualifications</h4>
                            <p class="module-card__text">Cross-match first-time entering students against the Non-Aligned Qualifications (NAL) register, flagging students enrolled in qualifications that are not aligned to a recognised HEQSF qualification.</p>
                            <div class="module-card__actions">
                                <a href="/Rule39?clientId=@Model.Id" class="btn btn-success">Open Rule 39</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 40</div>
                            <h4 class="module-card__title">PROF ASCII Staff Agreement</h4>
                            <p class="module-card__text">Reconcile common columns between the HEMIS ASCII PROF file and the VALPAC PROF and SFTE tables, identifying AGREE, DISAGREE, and MISSING staff records per Procedure 4.5.2.</p>
                            <div class="module-card__actions">
                                <a href="/Rule40?clientId=@Model.Id" class="btn btn-success">Open Rule 40</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 41</div>
                            <h4 class="module-card__title">Student ASCII Agreement</h4>
                            <p class="module-card__text">Full outer reconciliation of dbo_STUD against MT-Audit-prod-std on student number (_007 ? IAGSTNO), comparing birth date and qualification columns and flagging AGREE, DISAGREE, and MISSING records.</p>
                            <div class="module-card__actions">
                                <a href="/Rule41?clientId=@Model.Id" class="btn btn-success">Open Rule 41</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 44</div>
                            <h4 class="module-card__title">Masters &amp; PhD Research Time Validation</h4>
                            <p class="module-card__text">Validate Masters and PhD student research time compliance, flagging records where research registration exceeds the permitted duration thresholds for full-time and part-time students.</p>
                            <div class="module-card__actions">
                                <a href="/Rule44?clientId=@Model.Id" class="btn btn-success">Open Rule 44</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 45</div>
                            <h4 class="module-card__title">STU vs H16STU Agreement</h4>
                            <p class="module-card__text">Full outer reconciliation of the STU table against H16STU on student number (_007 ? _007), comparing birth date and qualification columns and flagging AGREE, DISAGREE, and MISSING records.</p>
                            <div class="module-card__actions">
                                <a href="/Rule45?clientId=@Model.Id" class="btn btn-success">Open Rule 45</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 46</div>
                            <h4 class="module-card__title">Foundation Student PQM Validation</h4>
                            <p class="module-card__text">Validate foundation students (dbo_STUD._106='Y') through two controls: full path via QUAL?CRED?CRSE?PQM and a short path via QUAL?PQM, flagging students whose qualifications do not appear in the PQM register.</p>
                            <div class="module-card__actions">
                                <a href="/Rule46?clientId=@Model.Id" class="btn btn-success">Open Rule 46</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 47</div>
                            <h4 class="module-card__title">QUAL vs H16QUAL Agreement</h4>
                            <p class="module-card__text">Full outer reconciliation of the QUAL table against H16QUAL on qualification code (_001 ? _001), comparing qualification fields and flagging AGREE, DISAGREE, and MISSING records.</p>
                            <div class="module-card__actions">
                                <a href="/Rule47?clientId=@Model.Id" class="btn btn-success">Open Rule 47</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 48</div>
                            <h4 class="module-card__title">CRED vs H16CRED Agreement</h4>
                            <p class="module-card__text">Full outer reconciliation of the CRED table against H16CRED on credential code (_001 ? _001), comparing credential fields (_001, _030, _036, _065) and flagging AGREE, DISAGREE, and MISSING records.</p>
                            <div class="module-card__actions">
                                <a href="/Rule48?clientId=@Model.Id" class="btn btn-success">Open Rule 48</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 51</div>
                            <h4 class="module-card__title">VALPAC Data in Production</h4>
                            <p class="module-card__text">Checks that every record in STUD VALPAC exists in STUD PRODUCTION using 4 mapped columns: _007?IAGSTNO, _008?IADIDNO, _001?IAGQUAL, ColYear?IAGCYR. PASS when all 4 columns match; FAIL when the record is missing from Production.</p>
                            <div class="module-card__actions">
                                <a href="/Rule51?clientId=@Model.Id" class="btn btn-success">Open Rule 51</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 52</div>
                            <h4 class="module-card__title">dbo_QUAL Qualification Code in MT-audit-prod-QUAL</h4>
                            <p class="module-card__text">Checks that every distinct <code>_001</code> (qualification code) in <code>dbo_QUAL</code> exists as <code>IAIQUAL</code> in <code>MT-audit-prod-QUAL</code>. PASS when the qualification code is found; FAIL when it is missing from the production table.</p>
                            <div class="module-card__actions">
                                <a href="/Rule52?clientId=@Model.Id" class="btn btn-success">Open Rule 52</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 53</div>
                            <h4 class="module-card__title">dbo_CRSE Subject Code in MT-audit-prod-CRSE</h4>
                            <p class="module-card__text">Checks that every distinct <code>_030</code> (subject code) value in <code>dbo_CRSE</code> exists as <code>IALSUBJ</code> in <code>MT-audit-prod-CRSE</code>. PASS when the subject code is found; FAIL when it is missing from the production table.</p>
                            <div class="module-card__actions">
                                <a href="/Rule53?clientId=@Model.Id" class="btn btn-success">Open Rule 53</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 54</div>
                            <h4 class="module-card__title">CRED vs QUAL vs PQM Validation</h4>
                            <p class="module-card__text">Joins <code>dbo_CRED</code> and <code>dbo_QUAL</code> on <code>_001</code>, then validates the qualification name (<code>QUAL._003</code> vs PQM <code>Authorised_Qualification_Name</code>) and Research_1 flag (<code>CRED._050</code> vs PQM <code>Research_1</code>). PASS when both fields match on the same PQM row; credit value (<code>_036</code>) is captured for manual prospectus verification.</p>
                            <div class="module-card__actions">
                                <a href="/Rule54?clientId=@Model.Id" class="btn btn-success">Open Rule 54</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 55</div>
                            <h4 class="module-card__title">Graduate W-Code Validation</h4>
                            <p class="module-card__text">Identifies all students where Element 025='W' (certificate withheld) in <code>dbo_STUD</code> and validates their qualification is approved in <code>dbo_QUAL</code> (<code>_004='A'</code>). Per DHET §1.5, W-coded students must be treated identically to 'F' graduates for Teaching and Research Output calculations. PASS when the qualification is found and approved; FAIL when missing or not approved for state funding.</p>
                            <div class="module-card__actions">
                                <a href="/Rule55?clientId=@Model.Id" class="btn btn-success">Open Rule 55</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 57</div>
                            <h4 class="module-card__title">Registration Documentation Agreement</h4>
                            <p class="module-card__text">Selects <code>dbo_CREG</code> records filtered by <code>_064</code>, joins to <code>dbo_STUD</code> on student ID (<code>_007</code>), and validates that <code>STUD._024</code> agrees with <code>CREG._064</code>. Agrees to the student's signed application and/or registration documentation.</p>
                            <div class="module-card__actions">
                                <a href="/Rule57?clientId=@Model.Id" class="btn btn-success">Open Rule 57</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 58</div>
                            <h4 class="module-card__title">STAFF VALPAC Data in STAFF PRODUCTION</h4>
                            <p class="module-card__text">Checks that every record in <code>STAFF VALPAC</code> exists in <code>STAFF PRODUCTION</code> using <code>_037 ? PERSONEL_NUMBER</code>. PASS when the staff record is found in Production; FAIL when it is missing.</p>
                            <div class="module-card__actions">
                                <a href="/Rule58?clientId=@Model.Id" class="btn btn-success">Open Rule 58</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 59</div>
                            <h4 class="module-card__title">SFTE VALPAC Data in STAFF PRODUCTION</h4>
                            <p class="module-card__text">Checks that every record in <code>SFTE VALPAC</code> exists in <code>STAFF PRODUCTION</code> using <code>_037 ? PERSONEL_NUMBER</code>. PASS when the SFTE record is found in Production; FAIL when it is missing.</p>
                            <div class="module-card__actions">
                                <a href="/Rule59?clientId=@Model.Id" class="btn btn-success">Open Rule 59</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 60</div>
                            <h4 class="module-card__title">CRSE vs H16CRSE Agreement</h4>
                            <p class="module-card__text">Checks that <code>CRSE</code> and <code>H16CRSE</code> align on the configured agreement fields and flags missing or mismatched records for review.</p>
                            <div class="module-card__actions">
                                <a href="/Rule60?clientId=@Model.Id" class="btn btn-success">Open Rule 60</a>
                            </div>
                        </article>

                        <article class="module-card">
                            <div class="module-card__eyebrow">Rule 61</div>
                            <h4 class="module-card__title">Masters / Doctoral Research Time Validation</h4>
                            <p class="module-card__text">Starts from <code>dbo_STUD</code>, bridges to <code>dbo_QUAL</code> on <code>_001</code>, filters the configured <code>QUAL._005</code> codes, then matches <code>QUAL._003</code> to <code>PQM.Authorised_Qualification_Name</code> and compares <code>STUD._073</code> to <code>PQM.Research_1</code>.</p>
                            <div class="module-card__actions">
                                <a href="/Rule61?clientId=@Model.Id" class="btn btn-success">Open Rule 61</a>
                            </div>
                        </article>
                    </div>
                }
                else
                {
                    <div class="empty-card" style="margin:0">
                        <p>This engagement must be approved before users can access modules.</p>
                    </div>
                }
            </div>
        </div>
    </details>
}

<details class="collapsible-section" style="margin-bottom:24px">
    <summary class="collapsible-trigger">
        <div>
            <span class="collapsible-trigger__title">Assigned Users (@Model.AssignedUsers.Count)</span>
            <span class="collapsible-trigger__subtitle">Show or hide the current engagement team and assignment actions.</span>
        </div>
        <span class="collapsible-trigger__icon" aria-hidden="true"></span>
    </summary>
    <div class="collapsible-panel">
        <div class="card">
    @if (User.IsInRole("Admin") && Model.IsArchived)
    {
        <div style="padding:12px 16px;color:#757575;font-size:13px;border-bottom:1px solid #E0E0E0">
            This engagement is archived. User assignments are now read-only.
        </div>
    }
    @if (canManageAssignments && !isArchived)
    {
        if (Model.AvailableUsers.Any())
        {
            <form asp-controller="Admin" asp-action="AssignUser" method="post"
                  style="display:flex;gap:10px;align-items:flex-end;padding:16px;border-bottom:1px solid #E0E0E0;flex-wrap:wrap">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ClientId" value="@Model.Id" />

                <div class="field-group" style="flex:1;min-width:220px">
                    <label>Add User</label>
                    <select name="UserId">
                        @foreach (var user in Model.AvailableUsers)
                        {
                            <option value="@user.Id">@user.FullName (@user.Email)</option>
                        }
                    </select>
                </div>

                <div class="field-group" style="min-width:180px">
                    <label>Engagement Role</label>
                    <select name="EngagementRole">
                        <option value="DataAnalyst">DataAnalyst</option>
                        <option value="Manager">Manager</option>
                        <option value="Director">Director</option>
                        <option value="Trainee">Trainee</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="margin-bottom:0">Assign</button>
            </form>
        }
        else
        {
            <div style="padding:12px 16px;color:#757575;font-size:13px;border-bottom:1px solid #E0E0E0">
                All active users are already assigned to this engagement.
            </div>
        }
    }

    @if (Model.AssignedUsers.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Assigned</th>
                        @if (canManageAssignments && !isArchived)
                        {
                            <th>Action</th>
                        }
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.AssignedUsers)
                {
                    <tr>
                        <td><strong>@user.FullName</strong></td>
                        <td>@user.Email</td>
                        <td><span class="badge badge--role">@user.EngagementRole</span></td>
                        <td>@user.AssignedAt.ToString("dd MMM yyyy")</td>
                        @if (canManageAssignments && !isArchived)
                        {
                            <td>
                                <form asp-controller="Admin" asp-action="RemoveUser" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="clientUserId" value="@user.ClientUserId" />
                                    <input type="hidden" name="clientId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning"
                                            onclick="return confirm('Remove @user.FullName from this engagement?')">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:16px;color:#757575;text-align:center">No users assigned yet.</div>
    }
        </div>
    </div>
</details>

<details class="collapsible-section" id="engagement-insight-panel" style="margin-bottom:24px">
    <summary class="collapsible-trigger">
        <div>
            <span class="collapsible-trigger__title">Engagement Insight</span>
            <span class="collapsible-trigger__subtitle">Insight for this engagement only, based on its current and historical validation runs.</span>
        </div>
        <span class="collapsible-trigger__icon" aria-hidden="true"></span>
    </summary>
    <div class="collapsible-panel">
        <div class="card" style="padding:18px 20px;margin-bottom:18px">
            <div style="display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap">
                <div>
                    <h3 class="section-title" style="margin:0">Insight for @Model.EngagementName</h3>
                    <p style="margin:6px 0 0;color:#64748b">@Model.MaconomyNumber | @Model.Industry | @Model.Status</p>
                </div>
                <div style="color:#64748b">Role: @(string.IsNullOrWhiteSpace(Model.CurrentUserEngagementRole) ? "-" : Model.CurrentUserEngagementRole)</div>
            </div>
        </div>

        <div class="dashboard-insight-grid" style="margin-bottom:18px">
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Current rule runs</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightLatestRuleRuns.Count</strong>
                    <span>latest current run per rule</span>
                </div>
            </div>
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Completed reviews</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightReviewedAndCompletedRuns</strong>
                    <span>all signoffs captured</span>
                </div>
            </div>
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Needs review</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightNeedsReviewRuns</strong>
                    <span>current runs waiting on review</span>
                </div>
            </div>
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Analyst pending</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightPendingAnalystRuns</strong>
                    <span>current runs not yet analyst-signed</span>
                </div>
            </div>
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Passed rules</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightPassedRuleRuns</strong>
                    <span>@engagementInsightPassedRuleRecords.ToString("N0") passing records | @engagementInsightPassedRuleRecordRate.ToString("0.##")%</span>
                </div>
            </div>
            <div class="dashboard-insight-card">
                <div class="dashboard-insight-card__label">Failed rules</div>
                <div class="dashboard-insight-card__value">
                    <strong>@engagementInsightFailedRuleRuns</strong>
                    <span>@engagementInsightFailedRuleRecords.ToString("N0") failing records | @engagementInsightFailedRuleRecordRate.ToString("0.##")%</span>
                </div>
            </div>
        </div>

        <div class="dashboard-insight-layout">
            <div class="dashboard-insight-rows">
                <div class="dashboard-insight-chart">
                    <h4>Review pipeline</h4>
                    <canvas id="engagementReviewPipelineChart"></canvas>
                </div>
                <div class="dashboard-insight-chart dashboard-insight-chart--rule-outcome">
                    <h4>Rule pass vs fail</h4>
                    <p class="dashboard-band__subtitle" style="margin:0 0 10px">Latest current run per rule for this engagement.</p>
                    @if (engagementInsightRuleOutcomeBreakdown.Any())
                    {
                        <div class="dashboard-insight-chart__scroll">
                            <canvas id="engagementRuleOutcomeChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="empty-card" style="padding:20px">
                            <p>No current rule runs are available for the insight chart yet.</p>
                        </div>
                    }
                </div>
                <div class="dashboard-insight-chart">
                    <h4>Signoff coverage</h4>
                    <canvas id="engagementSignoffChart"></canvas>
                </div>
            </div>

            <div class="dashboard-insight-feed">
                <h4>Latest activity</h4>
                @if (engagementInsightRecentRuns.Any())
                {
                    <div class="dashboard-activity-list">
                        @foreach (var run in engagementInsightRecentRuns)
                        {
                            var complete = run.IsReviewedAndCompleted;
                            var reviewed = run.HasDataAnalystSignoff && !complete;
                            var pending = !run.HasDataAnalystSignoff;
                            <div class="dashboard-activity-item">
                                <span class="dashboard-activity-item__dot @(complete ? "dashboard-activity-item__dot--complete" : reviewed ? "dashboard-activity-item__dot--review" : "dashboard-activity-item__dot--pending")"></span>
                                <div>
                                    <div class="dashboard-activity-item__title">Rule @run.RuleNumber - @run.RuleName</div>
                                    <div class="dashboard-activity-item__meta">@run.Status | @run.RunAt.ToString("dd MMM yyyy HH:mm")</div>
                                    <div class="dashboard-activity-item__meta">Run by @run.RunByUserName | @run.PassCount.ToString("N0") PASS | @run.FailCount.ToString("N0") FAIL</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="dashboard-activity-empty">No validation activity has been saved for this engagement yet.</div>
                }
            </div>
        </div>
    </div>
</details>


<details class="collapsible-section" id="validation-runs-panel">
    <summary class="collapsible-trigger">
        <div>
            <span class="collapsible-trigger__title">Validation Runs (@Model.ValidationRuns.Count)</span>
            <span class="collapsible-trigger__subtitle">Current results and history are separated for easier review.</span>
        </div>
        <span class="collapsible-trigger__icon" aria-hidden="true"></span>
    </summary>
    <div class="collapsible-panel">
@if (Model.ValidationRuns.Any())
{
    <div style="display:grid;gap:18px">
        <div class="card">
            <div style="padding:18px 20px 0">
                <h3 class="section-title" style="margin:0">Current Results (@currentValidationRuns.Count)</h3>
                <p style="margin:6px 0 0;color:#64748b">These are the current module results that have been reviewed and signed off by the data analyst.</p>
            </div>
            @if (currentValidationRuns.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Rule</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Exceptions</th>
                            <th>Rate</th>
                            <th>Signoffs</th>
                            <th>Run By</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in currentValidationRuns)
                        {
                            var runBadge = run.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || run.Status == "Pass"
                                ? "badge--pass"
                                : run.Status == "Fail" || run.Status == "Needs Review"
                                    ? "badge--fail"
                                    : "badge--role";
                            <tr>
                                <td>@run.Id</td>
                                <td>Rule @run.RuleNumber - @run.RuleName</td>
                                <td><span class="badge @runBadge">@run.Status</span></td>
                                <td>@run.TotalValidated.ToString("N0")</td>
                                <td class="@(run.FailCount > 0 ? "text-danger" : "text-success")">@run.FailCount.ToString("N0")</td>
                                <td>@run.ExceptionRate.ToString("F2")%</td>
                                <td>
                                    @run.SignoffCount
                                    @if (run.HasDataAnalystSignoff)
                                    {
                                        <br />
                                        <small style="color:#2e7d32">Data analyst signed</small>
                                    }
                                </td>
                                <td>@run.RunByUserName</td>
                                <td>@run.RunAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <a href="@RuleRouteHelper.GetWorkspaceUrl(run.RuleNumber, Model.Id)"
                                       class="btn btn-sm btn-secondary">Open Results</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:16px 20px;color:#757575">No current analyst-signed validation results are available yet.</div>
            }
        </div>

        <div class="card">
            <div style="padding:18px 20px 0">
                <h3 class="section-title" style="margin:0">Awaiting Analyst Signoff (@pendingAnalystSignoffRuns.Count)</h3>
                <p style="margin:6px 0 0;color:#64748b">These current runs were executed or validated, but they are not counted in Current Results until the data analyst signs off.</p>
            </div>
            @if (pendingAnalystSignoffRuns.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Rule</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Exceptions</th>
                            <th>Rate</th>
                            <th>Signoffs</th>
                            <th>Run By</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in pendingAnalystSignoffRuns)
                        {
                            var runBadge = run.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || run.Status == "Pass"
                                ? "badge--pass"
                                : run.Status == "Fail" || run.Status == "Needs Review"
                                    ? "badge--fail"
                                    : "badge--role";
                            <tr>
                                <td>@run.Id</td>
                                <td>Rule @run.RuleNumber - @run.RuleName</td>
                                <td><span class="badge @runBadge">@run.Status</span></td>
                                <td>@run.TotalValidated.ToString("N0")</td>
                                <td class="@(run.FailCount > 0 ? "text-danger" : "text-success")">@run.FailCount.ToString("N0")</td>
                                <td>@run.ExceptionRate.ToString("F2")%</td>
                                <td>
                                    @run.SignoffCount
                                    <br />
                                    <small style="color:#b45309">Analyst signoff pending</small>
                                </td>
                                <td>@run.RunByUserName</td>
                                <td>@run.RunAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <a href="@RuleRouteHelper.GetWorkspaceUrl(run.RuleNumber, Model.Id)"
                                       class="btn btn-sm btn-secondary">Open Results</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:16px 20px;color:#757575">No current runs are waiting for data analyst signoff.</div>
            }
        </div>

        <div class="card">
            <div style="padding:18px 20px 0">
                <h3 class="section-title" style="margin:0">History (@historicalValidationRuns.Count)</h3>
                <p style="margin:6px 0 0;color:#64748b">Previous saved runs remain available here for comparison and audit trail review.</p>
            </div>
            @if (historicalValidationRuns.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Rule</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Exceptions</th>
                            <th>Rate</th>
                            <th>Signoffs</th>
                            <th>Run By</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in historicalValidationRuns)
                        {
                            var runBadge = run.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || run.Status == "Pass"
                                ? "badge--pass"
                                : run.Status == "Fail" || run.Status == "Needs Review"
                                    ? "badge--fail"
                                    : "badge--role";
                            <tr>
                                <td>@run.Id</td>
                                <td>Rule @run.RuleNumber - @run.RuleName</td>
                                <td><span class="badge @runBadge">@run.Status</span></td>
                                <td>@run.TotalValidated.ToString("N0")</td>
                                <td class="@(run.FailCount > 0 ? "text-danger" : "text-success")">@run.FailCount.ToString("N0")</td>
                                <td>@run.ExceptionRate.ToString("F2")%</td>
                                <td>
                                    @run.SignoffCount
                                    @if (run.HasDataAnalystSignoff)
                                    {
                                        <br />
                                        <small style="color:#2e7d32">Data analyst signed</small>
                                    }
                                </td>
                                <td>@run.RunByUserName</td>
                                <td>@run.RunAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <a href="@RuleRouteHelper.GetRunUrl(run.RuleNumber, run.Id)"
                                       class="btn btn-sm btn-secondary">Review</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:16px 20px;color:#757575">No historical validation runs have been saved yet.</div>
            }
        </div>
    </div>
}
else
{
    <div class="empty-card">
        @if (canOpenModule)
        {
            <p>No validation runs yet. <a href="@RuleRouteHelper.GetWorkspaceUrl(1, Model.Id)">Open Rule 1</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(2, Model.Id)">Open Rule 2</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(3, Model.Id)">Open Rule 3</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(4, Model.Id)">Open Rule 4</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(5, Model.Id)">Open Rule 5</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(6, Model.Id)">Open Rule 6</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(7, Model.Id)">Open Rule 7</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(8, Model.Id)">Open Rule 8</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(9, Model.Id)">Open Rule 9</a>, <a href="@RuleRouteHelper.GetWorkspaceUrl(10, Model.Id)">Open Rule 10</a>, <a href="/Rule11?clientId=@Model.Id">Open Rule 11</a>, <a href="/Rule12?clientId=@Model.Id">Open Rule 12</a>, <a href="/Rule13?clientId=@Model.Id">Open Rule 13</a>, <a href="/Rule14?clientId=@Model.Id">Open Rule 14</a>, <a href="/Rule15?clientId=@Model.Id">Open Rule 15</a>, <a href="/Rule16?clientId=@Model.Id">Open Rule 16</a>, <a href="/Rule17?clientId=@Model.Id">Open Rule 17</a>, <a href="/Rule18?clientId=@Model.Id">Open Rule 18</a>, <a href="/Rule21?clientId=@Model.Id">Open Rule 21</a>, <a href="/Rule22?clientId=@Model.Id">Open Rule 22</a>, <a href="/Rule23?clientId=@Model.Id">Open Rule 23</a>, <a href="/Rule24?clientId=@Model.Id">Open Rule 24</a>, <a href="/Rule25?clientId=@Model.Id">Open Rule 25</a>, <a href="/Rule26?clientId=@Model.Id">Open Rule 26</a>, <a href="/Rule27?clientId=@Model.Id">Open Rule 27</a>, <a href="/Rule28?clientId=@Model.Id">Open Rule 28</a>, <a href="/Rule29?clientId=@Model.Id">Open Rule 29</a>, <a href="/Rule30?clientId=@Model.Id">Open Rule 30</a>, <a href="/Rule31?clientId=@Model.Id">Open Rule 31</a>, <a href="/Rule32?clientId=@Model.Id">Open Rule 32</a>, <a href="/Rule34?clientId=@Model.Id">Open Rule 34</a>, <a href="/Rule35?clientId=@Model.Id">Open Rule 35</a>, <a href="/Rule36?clientId=@Model.Id">Open Rule 36</a>, <a href="/Rule60?clientId=@Model.Id">Open Rule 60</a>, or <a href="/Rule61?clientId=@Model.Id">Open Rule 61</a></p>
        }
        else if (Model.IsArchived)
        {
            <p>This engagement is archived. Saved validation results remain available for review and download.</p>
        }
        else
        {
            <p>This engagement must be approved before users can access modules.</p>
        }
    </div>
}
    </div>
</details>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
(() => {
    const focusablePanelIds = ['engagement-insight-panel', 'validation-runs-panel'];
    const charts = [];
    let engagementInsightChartsReady = false;

    function focusPanelFromHash() {
        const panelId = window.location.hash.replace('#', '');
        if (!focusablePanelIds.includes(panelId)) {
            return;
        }

        const panel = document.getElementById(panelId);
        if (!panel) {
            return;
        }

        panel.open = true;
        if (panelId === 'engagement-insight-panel') {
            renderEngagementInsightCharts();
            window.setTimeout(() => {
                charts.forEach(chart => chart.resize());
            }, 0);
        }

        window.setTimeout(() => {
            panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
    }

    function getVar(name) {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    function renderEngagementInsightCharts() {
        if (engagementInsightChartsReady || typeof Chart === 'undefined') {
            return;
        }

        const green = '#34d399';
        const amber = '#fbbf24';
        const red = '#fb7185';
        const violet = '#8b5cf6';
        const teal = '#22d3ee';
        const blue = '#60a5fa';

        function isLightTheme() {
            return document.documentElement.classList.contains('light');
        }

        function getChartTextColor() {
            return isLightTheme()
                ? '#000000'
                : (getVar('--text') || '#f1f5f9');
        }

        function getChartLegendTextColor() {
            return isLightTheme()
                ? '#000000'
                : (getVar('--text-muted') || '#d5deea');
        }

        function getChartBorderColor() {
            return getVar('--border') || 'rgba(0,0,0,.08)';
        }

        function resetCharts() {
            while (charts.length) {
                const chart = charts.pop();
                chart.destroy();
            }

            engagementInsightChartsReady = false;
        }

        function makeDoughnut(id, labels, values, colors) {
            const el = document.getElementById(id);
            if (!el) return;
            const legendText = getChartLegendTextColor();
            const border = getChartBorderColor();

            charts.push(new Chart(el, {
                type: 'doughnut',
                data: {
                    labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors,
                        borderColor: border,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    aspectRatio: 1.35,
                    cutout: '68%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: legendText,
                                boxWidth: 10,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        }
                    }
                }
            }));
        }

        function makeStackedBar(id, labels, passedValues, failedValues) {
            const el = document.getElementById(id);
            if (!el) return;
            const axisText = getChartTextColor();
            const legendText = getChartLegendTextColor();
            const border = getChartBorderColor();

            const chartHeight = Math.max(labels.length * 30, 420);
            el.height = chartHeight;
            el.style.setProperty('height', `${chartHeight}px`, 'important');
            charts.push(new Chart(el, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [{
                        label: 'PASS',
                        data: passedValues,
                        backgroundColor: green,
                        borderColor: green,
                        borderWidth: 1,
                        borderRadius: 8
                    }, {
                        label: 'FAIL',
                        data: failedValues,
                        backgroundColor: red,
                        borderColor: red,
                        borderWidth: 1,
                        borderRadius: 8
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            stacked: true,
                            beginAtZero: true,
                            ticks: { color: axisText, precision: 0 },
                            grid: { color: border }
                        },
                        y: {
                            stacked: true,
                            ticks: {
                                color: axisText,
                                autoSkip: false,
                                font: {
                                    size: 13,
                                    weight: '600'
                                }
                            },
                            grid: { color: border }
                        }
                    },
                    layout: {
                        padding: {
                            left: 8,
                            right: 8
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: legendText,
                                boxWidth: 10,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        }
                    }
                }
            }));
        }

        makeDoughnut(
            'engagementReviewPipelineChart',
            ['Reviewed and completed', 'Awaiting review', 'Analyst signoff pending'],
            [@engagementInsightReviewedAndCompletedRuns, @engagementInsightAwaitingReviewRuns, @engagementInsightPendingAnalystRuns],
            [teal, amber, red]
        );

        makeDoughnut(
            'engagementSignoffChart',
            ['Analyst', 'Manager', 'Director'],
            [@engagementInsightAnalystSignedRuns, @engagementInsightManagerSignedRuns, @engagementInsightDirectorSignedRuns],
            [blue, amber, violet]
        );

        const engagementRuleLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(engagementInsightRuleOutcomeBreakdown.Select(metric => metric.RuleLabel).ToArray()));
        const engagementRulePassedValues = [@string.Join(",", engagementInsightRuleOutcomeBreakdown.Select(metric => metric.PassedCount))];
        const engagementRuleFailedValues = [@string.Join(",", engagementInsightRuleOutcomeBreakdown.Select(metric => metric.FailedCount))];
        if (engagementRuleLabels.length) {
            makeStackedBar('engagementRuleOutcomeChart', engagementRuleLabels, engagementRulePassedValues, engagementRuleFailedValues);
        }

        engagementInsightChartsReady = true;
    }

    const engagementInsightPanel = document.getElementById('engagement-insight-panel');
    if (engagementInsightPanel) {
        engagementInsightPanel.addEventListener('toggle', () => {
            if (!engagementInsightPanel.open) {
                return;
            }

            renderEngagementInsightCharts();
            window.setTimeout(() => {
                charts.forEach(chart => chart.resize());
            }, 0);
        });
    }

    const themeObserver = new MutationObserver(() => {
        resetCharts();

        if (engagementInsightPanel && engagementInsightPanel.open) {
            renderEngagementInsightCharts();
            window.setTimeout(() => {
                charts.forEach(chart => chart.resize());
            }, 0);
        }
    });

    themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
    });

    focusPanelFromHash();
    window.addEventListener('hashchange', focusPanelFromHash);
    window.addEventListener('beforeunload', () => {
        themeObserver.disconnect();
        resetCharts();
    });
})();
</script>

