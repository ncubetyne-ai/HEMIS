                            <th>Population</th>
                            <th>QUAL Code</th>
                            <th>QUAL Name</th>
                            <th>CESM Code</th>
                            <th>PQM?</th>
                            <th>Review</th>
                            <th title="5.1.2 Type Match">C2</th>
                            <th title="5.1.3 Min Time Total">C3</th>
                            <th title="5.1.4 WIL">C4</th>
                            <th title="5.1.5 HEQF Indicator">C5</th>
                            <th title="5.1.6 Total Subsidy">C6</th>
                            <th>Failed Controls</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${pageRows.map((row, i) => `
                        <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}" title="Population: ${escapeHtml(row.populationType||'Undergraduate')} | Population Rule: ${escapeHtml(row.populationClassificationNote||'')} | QUAL Type: ${escapeHtml(row.qualType||'')} | CESM: ${escapeHtml(row.cesmCode||'')} | PQM CESM1: ${escapeHtml(row.pqmCesmCode1||'')} | Match: ${escapeHtml(row.matchNote||'')}">
                            <td>${row.validationNumber}</td>
                            <td><span class="badge badge--${row.validationResult === 'PASS' ? 'pass' : 'fail'}">${escapeHtml(row.validationResult)}</span></td>
                            <td><span class="badge badge--${(row.populationType || 'Undergraduate') === 'Postgraduate' ? 'warning' : 'neutral'}">${escapeHtml(row.populationType || 'Undergraduate')}</span></td>
                            <td><strong>${escapeHtml(row.qualCode)}</strong></td>
                            <td style="max-width:220px;white-space:normal">${escapeHtml(row.qualName)}</td>
                            <td>${escapeHtml(row.cesmCode || '')}</td>
                            <td>${row.hasPqmMatch ? '<span class="badge badge--pass">YES</span>' : '<span class="badge badge--fail">NO</span>'}</td>
                            <td>${row.needsReview ? '<span class="badge badge--warning">YES</span>' : '<span class="badge badge--neutral">NO</span>'}</td>
                            <td>${ctrlBadge(row.c2_TypeMatch)}</td>
                            <td>${ctrlBadge(row.c3_MinTimeMatch)}</td>
                            <td>${ctrlBadge(row.c4_WILMatch)}</td>
                            <td title="Expected: ${escapeHtml(row.c5_ExpectedHeqf||'')} | Actual: ${escapeHtml(row.heqfIndicator||'')}">${ctrlBadge(row.c5_HeqfMatch)}</td>
                            <td>${ctrlBadge(row.c6_SubsidyMatch)}</td>
                            <td style="color:#C62828;font-size:0.78rem">${escapeHtml((row.failedControls||[]).join(', '))}</td>
