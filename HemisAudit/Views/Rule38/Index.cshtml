async function verifyTables() {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can verify tables.', 'error'); return;
    }
    if (isArchivedWorkspace()) {
        setWorkspaceInfo('Archived engagements are read-only. Verification is disabled.', 'error'); return;
    }
    syncStateFromSelects();
    if (!state.server || !state.database || !state.qualTable || !state.cesmTable || !state.pqmTable || !state.qualIdCol || !state.cesmIdCol) {
        setStatus('tableStatus', 'Select the server, database, all three tables, and the QUAL/CESM ID columns first.', 'warning'); return;
    }
    showSpinner('Verifying data...');
    try {
        const result = await post('/Rule38/VerifyTables', {
            server: state.server, database: state.database, driver: state.driver,
            qualTable: state.qualTable, cesmTable: state.cesmTable, pqmTable: state.pqmTable,
            qualIdCol: state.qualIdCol || '_001',
            cesmIdCol: state.cesmIdCol || '_001',
            qualApprovalCol: state.qualApprovalCol || '_004',
            qualApprovalValue: state.qualApprovalValue || 'A',
            useMPrefixPopulationSplit: state.useMPrefixPopulationSplit,
            excludeMPrefixPattern: state.useMPrefixPopulationSplit,
            postgraduateTypesCsv: state.postgraduateTypesCsv
        });
        if (!result.success) { setStatus('tableStatus', `Error: ${result.error}`, 'error'); return; }
        setStatus('tableStatus', `
            <strong>Verification Complete</strong><br>
            ${escapeHtml(state.qualTable)}: <strong>${result.qualTotal.toLocaleString()}</strong> total records<br>
            ${escapeHtml(state.cesmTable)}: <strong>${result.cesmTotal.toLocaleString()}</strong> total records<br>
            ${escapeHtml(state.qualTable)} (approved): <strong>${result.approvedCount.toLocaleString()}</strong> approved records<br>
            QUAL -> CESM bridge: <strong>${result.mergedTotal.toLocaleString()}</strong> records<br>
            ${escapeHtml(state.pqmTable)}: <strong>${result.pqmTotal.toLocaleString()}</strong> PQM rows<br>
            <em>Ready to run full validation.</em>
        `, 'success');
    } finally {
        hideSpinner();
    }
}

async function runValidation(options = {}) {
    if (currentSystemRole !== 'DataAnalyst') {
        setWorkspaceInfo('Only the assigned data analyst can run Rule 38.', 'error'); return null;
    }
    if (isArchivedWorkspace()) {
        setWorkspaceInfo('Archived engagements are read-only. Validation is disabled.', 'error'); return null;
    }
    syncStateFromSelects();
    if (!validateConfig()) return null;
    showSpinner(options.spinnerMessage || 'Running validation... this may take a moment for large datasets.');

    try {
        const result = await post('/Rule38/RunValidation', buildRequest());
        if (!result.success) {
            const el = document.getElementById('validationContent');
            el.classList.remove('empty-state');
            el.innerHTML = `<div class="alert alert--error">Error: ${escapeHtml(result.error)}</div>`;
            switchTab('validation');
            return null;
        }
        applyValidationResult(result, options);
        if (currentSystemRole === 'DataAnalyst') {
            state.editWarningAccepted = false;
            setWorkspaceInfo('Validation saved. Save the workspace and sign off again before others review this run.', 'warning');
            renderWorkspaceState();
        }
        return result;
    } finally {
        hideSpinner();
    }
}

function applyValidationResult(result, options = {}) {
    state.validationResult = result;
    state.validationView = { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    if (!options.fromWorkspace) state.currentRunId = result.savedRunId || state.currentRunId;
    state.currentUserHasSignedOff = options.fromWorkspace ? !!state.currentUserHasSignedOff : false;
    state.hasDataAnalystSignoff = options.fromWorkspace ? !!state.hasDataAnalystSignoff : false;
    if (!options.fromWorkspace) state.editWarningAccepted = false;
    state.isDirty = false;
    document.getElementById('downloadAllBtn').disabled = false;
    updateHeaderBadge(result.status);
    renderValidationResults(result);
    renderControlSummary(result);
    renderExceptions(result);
    renderDownloads(result);
    if (options.switchToValidation !== false) switchTab('validation');
    renderWorkspaceState();
}

function ctrlBadge(pass) {
    return pass
        ? '<span class="badge badge--pass" style="font-size:0.7rem">P</span>'
        : '<span class="badge badge--fail" style="font-size:0.7rem">F</span>';
}

function getRule38ResultReason(row) {
    const parts = [];
    if (row.validationResult === 'FAIL' && Array.isArray(row.failedControls) && row.failedControls.length) {
        parts.push('Failed: ' + row.failedControls.join(', '));
    }
    if (row.matchNote) {
        parts.push(row.matchNote);
    }
    return parts.join(' | ') || (row.validationResult === 'PASS'
        ? 'All Rule 38 checks matched on the selected PQM row.'
        : '');
}

function renderSectionHeader(title, subtitle, meta = '') {
    return `<div class="section-header">
        <div>
            <div class="section-header__title">${escapeHtml(title)}</div>
            <div class="section-header__subtitle">${escapeHtml(subtitle)}</div>
        </div>
        ${meta ? `<div class="section-header__meta">${meta}</div>` : ''}
    </div>`;
}

function renderValidationResults(r) {
    if (!state.validationView) state.validationView = { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    const rate = parseFloat(r.exceptionRate);
    const rateColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const allRows = r.validationRows || [];
    const resultFilter = state.validationView.resultFilter || 'ALL';
    const populationFilter = state.validationView.populationFilter || 'ALL';
    const filteredRows = allRows.filter(row => {
        const matchesResult = resultFilter === 'ALL' || row.validationResult === resultFilter;
        const matchesPopulation = populationFilter === 'ALL' || (row.populationType || 'Undergraduate') === populationFilter;
        return matchesResult && matchesPopulation;
    });
    const pageSize = uiPreviewRowLimit;
    const totalRows = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(totalRows / pageSize));
    const currentPage = Math.min(Math.max(state.validationView.page || 1, 1), totalPages);
    state.validationView.page = currentPage;
    const startIndex = (currentPage - 1) * pageSize;
    const pageRows = filteredRows.slice(startIndex, startIndex + pageSize);

    const previewBanner = r.isPreviewOnly
        ? `<div class="alert alert--warning" style="margin-bottom:8px">
            Preview mode: showing the first ${r.previewLimit} browser row(s). Save and download for the full result set.
           </div>`
        : '';

    const rowsHtml = pageRows.length === 0
        ? `<div class="alert alert--info">No rows match the selected filter.</div>`
        : `<div class="results-table-shell">
            <div class="table-wrapper">
                <table class="data-table" style="font-size:0.82rem">
                    <thead>
                        <tr>
                            <th>#</th>
