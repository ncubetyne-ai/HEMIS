        </div>
        <div class="overall-status ${r.status === 'PASS' ? 'status--pass' : 'status--fail'}">
            ${r.status === 'PASS'
                ? 'VALIDATION PASSED — All approved QUAL records passed controls 5.1.2–5.1.6'
                : `VALIDATION FAILED — ${(r.overallFailCount||0).toLocaleString()} record(s) failed one or more controls`}
        </div>
        <div class="results-table-panel">
            <div class="panel-title-row">
                <h4>Per-Qualification Results <small style="font-weight:normal;font-size:0.8rem">(hover row for QUAL/CESM/PQM match detail | C2=Type, C3=MinTime, C4=WIL, C5=HEQF, C6=Subsidy)</small></h4>
                <span class="panel-title-badge">${totalRows.toLocaleString()} filtered rows</span>
            </div>
            <div class="validation-toolbar">
                <div class="validation-toolbar__group">
                    <label for="validationResultFilter">Result</label>
                    <select id="validationResultFilter" onchange="setValidationResultFilter(this.value)">
