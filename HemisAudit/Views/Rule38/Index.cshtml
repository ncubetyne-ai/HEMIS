            `Database ${escapeHtml(r.database)} | QUAL: ${escapeHtml(r.qualTable||'')} | CESM: ${escapeHtml(r.cesmTable||'')} | PQM: ${escapeHtml(r.pqmTable||'')}`,
            `Scope: Approved QUAL records<br>Run: ${escapeHtml(r.timestamp)}`
        )}
        ${previewBanner}
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-card__label">Total QUAL Records</div><div class="stat-card__value">${(r.totalQualRecords||0).toLocaleString()}</div></div>
            <div class="stat-card"><div class="stat-card__label">Approved (tested)</div><div class="stat-card__value">${(r.approvedCount||0).toLocaleString()}</div></div>
