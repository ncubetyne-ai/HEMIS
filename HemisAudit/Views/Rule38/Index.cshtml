function renderCharts(r) {
    Object.values(state.chartInstances).forEach(c => c.destroy());
    state.chartInstances = {};
    const rate = parseFloat(r.exceptionRate);
    const rateBarColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const controls = r.controlSummaries || [];
    const cc = document.getElementById('chartsContent');
    cc.classList.remove('empty-state');
    cc.innerHTML = `
        ${renderSectionHeader('Rule 38 Visualisation', 'QUAL -> CESM -> PQM validation charts', `Status: ${escapeHtml(r.status)}`)}
        <div class="charts-grid">
            <div class="chart-card"><h4>Overall Pass/Fail</h4><canvas id="chartPassFail"></canvas></div>
            <div class="chart-card"><h4>Exception Rate: ${rate.toFixed(2)}%</h4><canvas id="chartRate"></canvas></div>
            <div class="chart-card chart-card--status ${r.status === 'PASS' ? 'chart-card--pass' : 'chart-card--fail'}">
                <h4>Validation Status</h4><div class="big-status">${r.status === 'PASS' ? 'PASS' : 'FAIL'}</div>
            </div>
            ${controls.length > 0 ? '<div class="chart-card"><h4>Per-Control Pass/Fail</h4><canvas id="chartControls"></canvas></div>' : ''}
        </div>`;

    state.chartInstances.passFail = new Chart(document.getElementById('chartPassFail'), {
        type: 'bar',
        data: {
            labels: ['PASS','FAIL'],
            datasets: [{ data: [r.overallPassCount||0, r.overallFailCount||0], backgroundColor: ['#4CAF50','#F44336'], borderWidth: 0 }]
        },
        options: { maintainAspectRatio: false, responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
    state.chartInstances.rate = new Chart(document.getElementById('chartRate'), {
        type: 'bar',
        data: {
            labels: ['Exception Rate'],
            datasets: [
                { data: [rate], backgroundColor: [rateBarColor], label: 'Exception %' },
                { data: [Math.max(0, 100 - rate)], backgroundColor: ['#E0E0E0'], label: 'Pass %' }
            ]
        },
        options: { indexAxis: 'y', maintainAspectRatio: false, responsive: true,
            plugins: { legend: { display: false } },
            scales: { x: { stacked: true, max: 100 }, y: { stacked: true } } }
    });

    if (controls.length > 0) {
        const ctrlCanvas = document.getElementById('chartControls');
        if (ctrlCanvas) {
            state.chartInstances.controls = new Chart(ctrlCanvas, {
                type: 'bar',
                data: {
                    labels: controls.map(c => c.controlId),
                    datasets: [
                        { label: 'PASS', data: controls.map(c => c.passCount||0), backgroundColor: '#4CAF50' },
                        { label: 'FAIL', data: controls.map(c => c.failCount||0), backgroundColor: '#F44336' }
                    ]
                },
                options: { maintainAspectRatio: false, responsive: true,
                    plugins: { legend: { display: true } },
                    scales: { x: { stacked: false }, y: { beginAtZero: true } } }
            });
        }
    }
}

function renderDownloads(r) {
    const el = document.getElementById('downloadsContent');
    const canUseSql = currentSystemRole === 'DataAnalyst' && !isArchivedWorkspace();
    el.classList.remove('empty-state');
    el.innerHTML = `
        <div class="downloads-panel">
            ${renderSectionHeader('Download Results',
                'Configuration and results are saved. Other assigned users only see this run after the data analyst signs off.',
                `Completed: ${escapeHtml(r.timestamp||'')}${r.savedRunId ? `<br>Saved Run: #${r.savedRunId}` : ''}${state.currentUserHasSignedOff ? '<br>Analyst signoff: saved' : ''}`
            )}
            <div class="download-buttons download-buttons--wide">
                <button class="btn btn-success" onclick="downloadExcel()">Excel</button>
                <button class="btn btn-info" onclick="downloadCsv()">Full CSV</button>
                <button class="btn btn-info" onclick="downloadExceptionsCsv()">Exceptions CSV</button>
                ${canUseSql ? '<button class="btn btn-primary" onclick="downloadSql()">SQL Script</button>' : ''}
                ${r.savedRunId ? `<a href="/Rule38/Run/${r.savedRunId}" class="btn btn-secondary">${canUseSql ? 'Open Saved Run and Sign Off' : 'Open Saved Run'}</a>` : ''}
            </div>
            <div class="download-summary-grid">
                <div class="download-summary-card"><span>QUAL Records</span><strong>${(r.totalQualRecords||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>Approved</span><strong>${(r.approvedCount||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>Undergraduate</span><strong>${(r.undergraduateCount||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>Postgraduate</span><strong>${(r.postgraduateCount||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>PASS</span><strong class="text-success">${(r.overallPassCount||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>FAIL</span><strong class="text-danger">${(r.overallFailCount||0).toLocaleString()}</strong></div>
                <div class="download-summary-card"><span>Exception Rate</span><strong>${parseFloat(r.exceptionRate||0).toFixed(2)}%</strong></div>
            </div>
        </div>`;
}

async function generateSql() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can generate SQL.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. SQL generation is disabled.', 'error'); return; }
    syncStateFromSelects();
    if (!validateConfig()) return;
    showSpinner('Generating SQL...');
    try {
        const result = await post('/Rule38/GenerateSql', buildRequest());
        if (!result.success) return;
        const el = document.getElementById('sqlContent');
        el.classList.remove('empty-state');
        el.innerHTML = `
            ${renderSectionHeader('Rule 38 SQL Code', 'Generated SQL matches the QUAL -> CESM -> PQM validation formula', `Database: ${escapeHtml(state.database || '')}`)}
            <div class="sql-toolbar">
                <button class="btn btn-sm btn-primary" onclick="copyToClipboard('sqlCode')">Copy</button>
                <button class="btn btn-sm btn-info" onclick="downloadSql()">Download SQL</button>
            </div>
            <div class="sql-panel"><pre id="sqlCode" class="sql-block">${escapeHtml(result.sql)}</pre></div>`;
        switchTab('sql');
    } finally {
        hideSpinner();
    }
}

function setValidationResultFilter(filter) {
    state.validationView = state.validationView || { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    state.validationView.resultFilter = filter;
    state.validationView.page = 1;
    if (state.validationResult) renderValidationResults(state.validationResult);
}

function setValidationPopulationFilter(filter) {
    state.validationView = state.validationView || { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    state.validationView.populationFilter = filter;
    state.validationView.page = 1;
    if (state.validationResult) renderValidationResults(state.validationResult);
}

function setValidationPage(delta) {
    if (!state.validationResult) return;
    state.validationView = state.validationView || { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit };
    state.validationView.page = Math.max(1, (state.validationView.page || 1) + delta);
    renderValidationResults(state.validationResult);
}

function escapeHtml(value) {
    return String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function updatePgCodesPreview() {
    const chk = document.getElementById('useMPrefixPopulationSplitChk');
    const pgCsv = document.getElementById('postgraduateTypesCsvInput');
    const preview = document.getElementById('pgCodesPreview');
    if (!preview) return;
    const pgList = (pgCsv?.value || '07,27,28,49,72,73,08,30,50,74,75').split(',').map(s => s.trim()).filter(Boolean).join(', ');
    const pgRule = chk?.checked
        ? `[_005] IN (${escapeHtml(pgList)}) OR [_001] LIKE 'M_____'`
        : `[_005] IN (${escapeHtml(pgList)})`;
    const ugRule = chk?.checked
        ? `[_005] NOT IN (${escapeHtml(pgList)}) AND [_001] NOT LIKE 'M_____'`
        : `[_005] NOT IN (${escapeHtml(pgList)})`;
    preview.innerHTML = `
        <strong>Undergraduate:</strong> <code>[_004] = '[approval value]' AND ${ugRule}</code><br/>
        <strong>Postgraduate:</strong> <code>[_004] = '[approval value]' AND (${pgRule})</code>
    `;
}

function validateConfig() {
    syncStateFromSelects();
    const missing = [];
    if (!state.clientId)          missing.push('engagement');
    if (!state.server)            missing.push('server');
    if (!state.database)          missing.push('database');
    if (!state.qualTable)         missing.push('QUAL table');
    if (!state.cesmTable)         missing.push('CESM table');
    if (!state.pqmTable)          missing.push('PQM table');
    if (!state.qualIdCol)         missing.push('QUAL ID column');
    if (!state.qualNameCol)       missing.push('QUAL Name column');
    if (!state.qualApprovalCol)   missing.push('QUAL Approval column');
    if (!state.qualApprovalValue) missing.push('Approval value');
    if (!state.cesmIdCol)         missing.push('CESM ID column');
    if (!state.cesmCodeCol)       missing.push('CESM Code column');
    if (!state.pqmNameCol)        missing.push('PQM Name column');
    if (!state.pqmQualTypeCol)    missing.push('PQM Qual Type column');
    if (!state.pqmCesmCodeCol)    missing.push('PQM CESM Code column');
    if (!state.pqmCesmCode1Col)   missing.push('PQM CESM Code 1 column');

    if (missing.length) {
        if (!state.clientId) setWorkspaceInfo('Select the approved engagement assigned to you before running this rule.', 'warning');
        setStatus('validationContent', `Please select/enter ${missing.join(', ')} first.`, 'warning');
        switchTab('validation');
        return false;
    }
    return true;
}

function buildRequest() {
    syncStateFromSelects();
    return {
        clientId: state.clientId, runId: state.currentRunId,
        server: state.server, database: state.database, driver: state.driver,
        qualTable: state.qualTable,
        qualIdCol: state.qualIdCol, qualNameCol: state.qualNameCol,
        qualApprovalCol: state.qualApprovalCol, qualApprovalValue: state.qualApprovalValue,
        qualTypeCol: state.qualTypeCol, qualMinTimeTotalCol: state.qualMinTimeTotalCol,
        qualMinTimeWilCol: state.qualMinTimeWilCol, qualHeqfCol: state.qualHeqfCol,
        qualTotalSubsidyCol: state.qualTotalSubsidyCol,
        cesmTable: state.cesmTable, cesmIdCol: state.cesmIdCol, cesmCodeCol: state.cesmCodeCol,
        pqmTable: state.pqmTable,
        pqmNameCol: state.pqmNameCol, pqmQualTypeCol: state.pqmQualTypeCol,
        pqmCesmCodeCol: state.pqmCesmCodeCol, pqmCesmCode1Col: state.pqmCesmCode1Col,
        pqmMinTimeTotalCol: state.pqmMinTimeTotalCol, pqmWilCol: state.pqmWilCol,
        pqmAccreditationCol: state.pqmAccreditationCol, pqmTotalSubsidyCol: state.pqmTotalSubsidyCol,
        heqfIndicatorCodesCsv: state.heqfIndicatorCodesCsv,
        useMPrefixPopulationSplit: state.useMPrefixPopulationSplit,
        excludeMPrefixPattern: state.useMPrefixPopulationSplit,
        postgraduateTypesCsv: state.postgraduateTypesCsv
    };
}

function fileStamp() {
    return new Date().toISOString().replace(/[:.]/g, '-').replace('T', '_').replace('Z', '');
}

async function downloadExcel() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule38/DownloadExcel', state.validationResult, `Rule38_QUAL_CESM_PQM_Validation_${fileStamp()}.xlsx`);
}
async function downloadCsv() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule38/DownloadCsv', state.validationResult, `Rule38_Validation_Results_${fileStamp()}.csv`);
}
async function downloadExceptionsCsv() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    await downloadPost('/Rule38/DownloadExceptionsCsv', state.validationResult, `Rule38_QUAL_CESM_PQM_Exceptions_${fileStamp()}.csv`);
}
async function downloadSql() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can download the SQL script.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. SQL download is disabled.', 'error'); return; }
    if (!validateConfig()) return;
    await downloadPost('/Rule38/DownloadSql', buildRequest(), `Rule38_QUAL_CESM_PQM_Validation_${fileStamp()}.sql`);
}

async function downloadAll() {
    if (!state.validationResult) { alert('Run validation first.'); return; }
    const tasks = [];
    if (document.getElementById('chkExcel')?.checked) tasks.push(() => downloadExcel());
    if (document.getElementById('chkCsv')?.checked) tasks.push(() => downloadCsv());
    if (document.getElementById('chkExceptionsCsv')?.checked) tasks.push(() => downloadExceptionsCsv());
    if (currentSystemRole === 'DataAnalyst' && document.getElementById('chkSql')?.checked) tasks.push(() => downloadSql());
    if (!tasks.length) { alert('Select at least one download format.'); return; }
    for (const task of tasks) await task();
}

function copyToClipboard(elId) {
    navigator.clipboard.writeText(document.getElementById(elId).textContent).then(() => alert('Copied to clipboard!'));
}

async function saveWorkspace() {
    if (currentSystemRole !== 'DataAnalyst') { setWorkspaceInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (isArchivedWorkspace()) { setWorkspaceInfo('Archived engagements are read-only. Saving is disabled.', 'error'); return; }
    if (!state.currentRunId) { setWorkspaceInfo('Run validation first so the workspace can be saved.', 'error'); return; }
    showSpinner('Saving workspace...');
    try {
        const result = await post('/Rule38/SaveWorkspace', buildRequest());
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save workspace.')}`, 'error'); return; }
        state.editWarningAccepted = true;
        state.isDirty = false;
        if (result.workspace) {
            state.currentRunId = result.workspace.runId || state.currentRunId;
            state.currentUserEngagementRole = result.workspace.currentUserEngagementRole || state.currentUserEngagementRole;
            state.currentUserHasSignedOff = !!result.workspace.currentUserHasSignedOff;
            state.hasDataAnalystSignoff = !!result.workspace.hasDataAnalystSignoff;
            state.isWorkspaceSaved = !!result.workspace.isWorkspaceSaved;
            document.getElementById('signoffComment').value = result.workspace.currentUserSignoffComment || document.getElementById('signoffComment').value;
            if (result.workspace.summary) applyValidationResult(result.workspace.summary, { switchToValidation: false, fromWorkspace: true });
        }
        setWorkspaceInfo(result.message || 'Workspace saved.', result.signoffsCleared ? 'warning' : 'success');
        renderWorkspaceState();
    } finally {
        hideSpinner();
    }
}

async function signOffWorkspace() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign) { setWorkspaceInfo('This workspace can only be signed off by the assigned analyst, manager, or director after the analyst review is available.', 'error'); return; }
    if (!state.isWorkspaceSaved) { setWorkspaceInfo('Save the workspace first before signing off.', 'warning'); return; }
    if (state.isDirty) { setWorkspaceInfo('Save the workspace first. Editing removes signoffs and requires a fresh review.', 'warning'); return; }
    showSpinner('Saving analyst signoff...');
    try {
        const result = await post('/Rule38/SignOffWorkspace', {
            clientId: state.clientId, runId: state.currentRunId,
            comment: document.getElementById('signoffComment').value.trim()
        });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to save signoff.')}`, 'error'); return; }
        const visible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = visible; await hydrateWorkspace(result.workspace); }
        state.isDirty = false;
        setWorkspaceInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
        renderWorkspaceState();
        switchTab('downloads');
    } finally {
        hideSpinner();
    }
}

async function removeWorkspaceSignoff() {
    const role = state.currentUserEngagementRole || currentSystemRole;
    const canSign = !isArchivedWorkspace() && state.currentRunId &&
        (currentSystemRole === 'DataAnalyst' || (state.resultsVisible && (role === 'Manager' || role === 'Director')));
    if (!canSign || !state.currentUserHasSignedOff) { setWorkspaceInfo('There is no signoff for your assigned engagement role to remove.', 'error'); return; }
    showSpinner('Removing signoff...');
    try {
        const result = await post('/Rule38/RemoveWorkspaceSignoff', { clientId: state.clientId, runId: state.currentRunId, comment: '' });
        if (!result.success) { setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to remove signoff.')}`, 'error'); return; }
        const visible = Object.prototype.hasOwnProperty.call(result, 'resultsVisible') ? !!result.resultsVisible : !!result.workspace?.resultsVisible;
        if (result.workspace) { result.workspace.resultsVisible = visible; await hydrateWorkspace(result.workspace); }
        setWorkspaceInfo('Signoff removed.', 'warning');
        renderWorkspaceState();
    } finally {
        hideSpinner();
    }
}

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('serverInput').addEventListener('input', async () => {
        state.server = document.getElementById('serverInput').value.trim();
        await markWorkspaceDirty();
    });
    document.getElementById('driverSelect').addEventListener('change', async () => {
        state.driver = document.getElementById('driverSelect').value;
        await markWorkspaceDirty();
    });
    document.getElementById('databaseSelect').addEventListener('change', async e => {
        state.database = e.target.value;
        await markWorkspaceDirty();
        await loadTables();
    });
    document.getElementById('qualApprovalValueInput').addEventListener('input', async () => {
        state.qualApprovalValue = document.getElementById('qualApprovalValueInput').value.trim();
        await markWorkspaceDirty();
    });
    document.getElementById('heqfCodesInput').addEventListener('input', async () => {
        state.heqfIndicatorCodesCsv = document.getElementById('heqfCodesInput').value.trim();
        await markWorkspaceDirty();
    });
    document.getElementById('useMPrefixPopulationSplitChk')?.addEventListener('change', async () => {
        state.useMPrefixPopulationSplit = document.getElementById('useMPrefixPopulationSplitChk').checked;
        updatePgCodesPreview();
        await markWorkspaceDirty();
    });
    document.getElementById('postgraduateTypesCsvInput')?.addEventListener('input', async () => {
        state.postgraduateTypesCsv = document.getElementById('postgraduateTypesCsvInput').value.trim();
        updatePgCodesPreview();
        await markWorkspaceDirty();
    });
    updatePgCodesPreview();

    const colSelects = [
        'qualIdColSelect','qualNameColSelect','qualApprovalColSelect','qualTypeColSelect',
        'qualMinTimeTotalColSelect','qualMinTimeWilColSelect','qualHeqfColSelect','qualTotalSubsidyColSelect',
        'cesmIdColSelect','cesmCodeColSelect',
        'pqmNameColSelect','pqmQualTypeColSelect','pqmCesmCodeColSelect','pqmCesmCode1ColSelect','pqmMinTimeTotalColSelect','pqmWilColSelect',
        'pqmAccreditationColSelect','pqmTotalSubsidyColSelect'
    ];
    colSelects.forEach(id => {
        document.getElementById(id).addEventListener('change', async () => {
            syncStateFromSelects();
            await markWorkspaceDirty();
        });
    });

    renderWorkspaceState();
    if (state.clientId > 0) await loadWorkspaceState();
});
</script>
