function renderExceptions(r) {
    const el = document.getElementById('exceptionsContent');
    el.classList.remove('empty-state');
    const failRows = (r.validationRows || []).filter(row => row.validationResult === 'FAIL');
    if (failRows.length === 0) {
        el.innerHTML = `${renderSectionHeader('Rule 38 Exceptions', 'QUAL -> CESM -> PQM mismatches', 'Exceptions: 0')}
            <div class="alert alert--success">No exceptions — all approved QUAL records passed controls 5.1.2–5.1.6.</div>`;
        return;
    }
    const rows = failRows.slice(0, 10).map((row, i) => `
        <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
            <td>${row.validationNumber}</td>
