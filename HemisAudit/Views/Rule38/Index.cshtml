    state.cesmCodeCol         = document.getElementById('cesmCodeColSelect').value;
    state.pqmNameCol          = document.getElementById('pqmNameColSelect').value;
    state.pqmQualTypeCol      = document.getElementById('pqmQualTypeColSelect').value;
    state.pqmCesmCodeCol      = document.getElementById('pqmCesmCodeColSelect').value;
    state.pqmCesmCode1Col     = document.getElementById('pqmCesmCode1ColSelect').value;
    state.pqmMinTimeTotalCol  = document.getElementById('pqmMinTimeTotalColSelect').value;
