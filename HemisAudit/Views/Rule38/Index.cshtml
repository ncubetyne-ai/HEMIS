@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 38 - Enhanced QUAL -> CESM -> PQM Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
    var selectedClientId = (int)(ViewBag.ClientId ?? 0);
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #app > .accordion-stack > .accordion-item:nth-child(-n+6),
        #app > .action-bar {
            display: none !important;
        }
    </style>
}

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <!-- Engagement selector -->
    <div class="engagement-selector">
        <label>Engagement</label>
        <select id="clientIdSelect" onchange="handleClientChange(this.value)">
            <option value="0">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name - @c.FiscalYear</option>
            }
        </select>
        <small id="workspaceSavedHint">Saved runs reload the last analyst configuration for this engagement.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R38</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 38: Enhanced QUAL -> CESM -> PQM Validation</h1>
            <p class="rule-header__sub">QUAL._001 = CESM._001, CESM._006 -> PQM.CESM_CODE1 or PQM.CESM_CODE | 5.1.1-5.1.6 | 100% population test</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    <div class="info-box info-box--dark" style="margin-bottom:16px">
        <strong>Procedure 5.1 reminder:</strong> Select a sample of approved qualifications from the Qualification file (<code>QUAL</code>) and perform the following procedures after downloading the results.<br />
        5.1.1 Obtain from The Registrar the approval documents from the Minister of Higher Education, Science and Innovation for state funding and inspect that <code>QUAL._004</code> Approval Status reflects <code>'A'</code>.<br />
        5.1.2 Inspect that the correct qualification type has been allocated to <code>QUAL._005</code> Qualification Type and agree that the university has allocated the correct qualification type according to the PQM.<br />
        5.1.3 Inspect <code>QUAL._053</code> Minimum Time: Total and agree to the Total Subsidy Units: Total as per the PQM.<br />
        5.1.4 Inspect <code>QUAL._054</code> Minimum Time: Experiential and agree to the Total Subsidy Units: Work Integrated Learning (<code>WIL/EL</code>), in years as per the PQM.<br />
        5.1.5 Obtain from The Registrar the policy under which the qualification has been approved and agree the coding as per <code>QUAL._084</code> Legacy Indicator/HEQF/HEQSF indicator to the policy.<br />
        5.1.6 Obtain the PQM document from The Registrar and agree <code>QUAL._090</code> Total subsidy units to the total subsidy units per the PQM document.
    </div>

    <div class="accordion-stack">

        <!-- 1. Database Connection -->
        <div class="accordion-item" id="acc-connection">
            <button class="accordion-toggle" onclick="toggleAccordion('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-connection">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Server Name</label>
                        <input type="text" id="serverInput" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label>Driver</label>
                        <select id="driverSelect">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group" id="dbFieldGroup" style="display:none">
                        <label>Database</label>
                        <select id="databaseSelect">
                            <option value="">Select database</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" id="connectBtn" onclick="connectServer()">Connect</button>
                <div class="status-output" id="connectionStatus"></div>
            </div>
        </div>

        <!-- 2. Table Configuration -->
        <div class="accordion-item" id="acc-tables">
            <button class="accordion-toggle" onclick="toggleAccordion('tables')">
                <span class="acc-icon">TB</span>
                <span>Table Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-tables" style="display:none">
                <div class="info-box info-box--red">
                    <strong>Rule 38 Requirement:</strong> Rule 38 follows the Rule 11 path:
                    <code>QUAL._001 = CESM._001</code>, then <code>CESM._006</code> must match <code>PQM.CESM_CODE1</code> or <code>PQM.CESM_CODE</code>.
                    Qualification name and qualification type must still align to the same PQM row before controls 5.1.2-5.1.6 are evaluated.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>QUAL Table <span class="auto-tag" id="qualAutoTag" style="display:none">auto-detected</span></label>
                        <select id="qualTableSelect" onchange="onTableChange('qual')">
                            <option value="">Select table (e.g. dbo_QUAL)</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>CESM Table <span class="auto-tag" id="cesmAutoTag" style="display:none">auto-detected</span></label>
                        <select id="cesmTableSelect" onchange="onTableChange('cesm')">
                            <option value="">Select table (e.g. dbo_CESM)</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>PQM Table <span class="auto-tag" id="pqmAutoTag" style="display:none">auto-detected</span></label>
                        <select id="pqmTableSelect" onchange="onTableChange('pqm')">
                            <option value="">Select PQM register table</option>
                        </select>
                    </div>
                </div>
                <div class="status-output" id="tableStatus"></div>
            </div>
        </div>

        <!-- 3. QUAL Column Mapping -->
        <div class="accordion-item" id="acc-qualcols">
            <button class="accordion-toggle" onclick="toggleAccordion('qualcols')">
                <span class="acc-icon">QC</span>
                <span>QUAL Column Mapping</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-qualcols" style="display:none">
                <div class="info-box info-box--dark">
                    Map the QUAL table columns used in validation. Defaults match the standard HEMIS QUAL structure.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>Record ID Column <small>(default: _001)</small> <span class="auto-tag" id="qualIdAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualIdColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Qualification Name Column <small>(default: _003, used for join)</small> <span class="auto-tag" id="qualNameAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualNameColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Approval Status Column <small>(default: _004)</small> <span class="auto-tag" id="qualApprovalAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualApprovalColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Approval Value <small>(only records with this value are tested)</small></label>
                        <input type="text" id="qualApprovalValueInput" value="A" placeholder="e.g. A" oninput="markWorkspaceDirty()" />
                    </div>
                    <div class="field-group">
                        <label>Qual Type Column <small>(default: _005, compared to PQM HEQF_Qual_Type)</small> <span class="auto-tag" id="qualTypeAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualTypeColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Min Time Total Column <small>(default: _053, compared to PQM Total2)</small> <span class="auto-tag" id="qualMinTimeTotalAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualMinTimeTotalColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Min Time WIL Column <small>(default: _054, compared to PQM WIL_EL2)</small> <span class="auto-tag" id="qualMinTimeWilAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualMinTimeWilColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>HEQF/HEQSF Indicator Column <small>(default: _084, expected Y or N)</small> <span class="auto-tag" id="qualHeqfAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualHeqfColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Total Subsidy Column <small>(default: _090, compared to PQM Total2)</small> <span class="auto-tag" id="qualTotalSubsidyAutoTag" style="display:none">auto-selected</span></label>
                        <select id="qualTotalSubsidyColSelect"><option value="">Select column</option></select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. CESM Column Mapping -->
        <div class="accordion-item" id="acc-cesmcols">
            <button class="accordion-toggle" onclick="toggleAccordion('cesmcols')">
                <span class="acc-icon">CC</span>
                <span>CESM Column Mapping</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-cesmcols" style="display:none">
                <div class="info-box info-box--dark" style="display:none">
                    Map the CESM bridge columns used to join QUAL to PQM. The standard bridge is
                    <code>QUAL._001 = CESM._001</code>, with <code>CESM._006</code> compared to <code>PQM.CESM_CODE1</code> or <code>PQM.CESM_CODE</code>.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>CESM Qualification Code <small>(default: _001)</small> <span class="auto-tag" id="cesmIdAutoTag" style="display:none">auto-selected</span></label>
                        <select id="cesmIdColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>CESM Code Column <small>(default: _006)</small> <span class="auto-tag" id="cesmCodeAutoTag" style="display:none">auto-selected</span></label>
                        <select id="cesmCodeColSelect"><option value="">Select column</option></select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. PQM Column Mapping -->
        <div class="accordion-item" id="acc-pqmcols">
            <button class="accordion-toggle" onclick="toggleAccordion('pqmcols')">
                <span class="acc-icon">PC</span>
                <span>PQM Column Mapping</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-pqmcols" style="display:none">
                <div class="info-box info-box--dark">
                    Map the PQM register columns used in validation. Rule 38 accepts <code>PQM.CESM_CODE1</code> or
                    <code>PQM.CESM_CODE</code> as the CESM match and keeps both values in the saved results.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>Authorised Qualification Name <small>(must match QUAL name)</small> <span class="auto-tag" id="pqmNameAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmNameColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>HEQF Qual Type Column <small>(compared to QUAL _005)</small> <span class="auto-tag" id="pqmQualTypeAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmQualTypeColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>CESM Code Column <small>(reference: CESM_CODE)</small> <span class="auto-tag" id="pqmCesmCodeAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmCesmCodeColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>CESM Code 1 Column <small>(matched to CESM._006)</small> <span class="auto-tag" id="pqmCesmCode1AutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmCesmCode1ColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Min Time Total Column <small>(compared to QUAL _053, e.g. Total2)</small> <span class="auto-tag" id="pqmMinTimeTotalAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmMinTimeTotalColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>WIL Column <small>(compared to QUAL _054, e.g. WIL_EL2)</small> <span class="auto-tag" id="pqmWilAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmWilColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Accreditation Reference Column <small>(used to determine expected HEQF indicator)</small> <span class="auto-tag" id="pqmAccreditationAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmAccreditationColSelect"><option value="">Select column</option></select>
                    </div>
                    <div class="field-group">
                        <label>Total Subsidy Column <small>(compared to QUAL _090, e.g. Total2)</small> <span class="auto-tag" id="pqmTotalSubsidyAutoTag" style="display:none">auto-selected</span></label>
                        <select id="pqmTotalSubsidyColSelect"><option value="">Select column</option></select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. Population Split & Postgraduate Type Codes -->
        <div class="accordion-item" id="acc-pgcodes">
            <button class="accordion-toggle" onclick="toggleAccordion('pgcodes')">
                <span class="acc-icon">PG</span>
                <span>Population Split</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-pgcodes" style="display:none">
                <div class="info-box info-box--dark">
                    <strong>M Prefix Exclusion:</strong> When checked, qualification codes matching <code>M_____</code> (e.g. M12345) are excluded from the validation population — identical to the Rule 11 behaviour.<br />
                    <strong>Postgraduate Type Codes:</strong> Comma-separated <code>_005</code> values that classify a qualification as postgraduate. Used to annotate and categorise results.
                </div>
                <div class="info-box info-box--dark">
                    <strong>M Prefix Population Split:</strong> When checked, qualification codes matching <code>M_____</code> (e.g. <code>M12345</code>) are tagged as <strong>Postgraduate</strong>. They remain included in the validation population.<br />
                    <strong>Postgraduate Type Codes:</strong> Comma-separated <code>_005</code> values that classify a qualification as postgraduate. Any approved row not matching these rules is labelled <strong>Undergraduate</strong>.
                </div>
                <div class="checkbox-row" style="margin-bottom:12px">
                    <label class="checkbox-label">
                        <input type="checkbox" id="useMPrefixPopulationSplitChk" onchange="markWorkspaceDirty()" />
                        Treat qualification codes matching <code>M_____</code> as postgraduate
                    </label>
                </div>
                <div class="field-group" style="max-width:600px">
                    <label>Postgraduate Type Codes <small>(<code>_005</code> values that classify a qualification as postgraduate)</small></label>
                    <textarea id="postgraduateTypesCsvInput" rows="3"
                              placeholder="e.g. 07,27,28,49,72,73,08,30,50,74,75"
                              oninput="markWorkspaceDirty()">07,27,28,49,72,73,08,30,50,74,75</textarea>
                </div>
                <div class="alert alert--info" style="margin-top:12px" id="pgCodesPreview">
                    Configure the fields above, then run validation. Each approved row will be labelled Undergraduate or Postgraduate in the results.
                </div>
            </div>
        </div>

        <!-- 6. HEQF Indicator Codes (Control 5.1.5) -->
        <div class="accordion-item" id="acc-heqf">
            <button class="accordion-toggle" onclick="toggleAccordion('heqf')">
                <span class="acc-icon">HQ</span>
                <span>HEQF/HEQSF Indicator Codes (5.1.5)</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-heqf" style="display:none">
                <div class="info-box info-box--dark">
                    <strong>Control 5.1.5:</strong> If <code>CHE_HEQC_Accreditation_Approval_Ref_Nr</code> contains any of these codes,
                    QUAL column <code>_084</code> is expected to be <strong>Y</strong>; otherwise <strong>N</strong>.
                    Enter codes as comma-separated values. You can update this list when new codes are issued.
                </div>
                <div class="field-group" style="max-width:600px">
                    <label>HEQF/HEQSF Indicator Codes <small>(comma-separated, case-insensitive substring match)</small></label>
                    <input type="text" id="heqfCodesInput" value="H/,HEQF,HEQSF"
                           placeholder="e.g. H/,HEQF,HEQSF"
                           oninput="markWorkspaceDirty()" />
                    <small style="color:#666;margin-top:4px;display:block">
                        Example: if the accreditation ref is <code>H/H16/E084CAN01</code>, it contains "H/" → expected _084 = <strong>Y</strong>
                    </small>
                </div>
            </div>
        </div>

        <!-- 6. Download Formats -->
        <div class="accordion-item" id="acc-downloads">
            <button class="accordion-toggle" onclick="toggleAccordion('downloads')">
                <span class="acc-icon">DL</span>
                <span>Download Formats</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-downloads" style="display:none">
                <div class="checkbox-row">
                    <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel (Validation Results, Exceptions, Control Summary, Stats)</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV (Full results)</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkExceptionsCsv" checked /> CSV (Exceptions only)</label>
                    <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL Script</label>
                </div>
            </div>
        </div>
    </div>

    <!-- Workspace Signoff Card -->
    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 38 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">
            Select an engagement to load the last saved Rule 38 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div class="field-group">
                <label id="workspaceSignoffLabel">Signoff Comment</label>
                <textarea id="signoffComment" placeholder="Add the final review note that confirms this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button class="btn btn-success" id="saveWorkspaceBtn" onclick="saveWorkspace()">Save Workspace</button>
            <button class="btn btn-primary" id="signOffBtn" onclick="signOffWorkspace()">Sign Off</button>
            <button class="btn btn-warning" id="removeWorkspaceSignoffBtn" onclick="removeWorkspaceSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="action-bar">
        <button class="btn btn-info" onclick="verifyTables()">Verify Tables</button>
        <button class="btn btn-success" id="runValidationBtn" onclick="runValidation()">Run Validation</button>
        <button class="btn btn-primary" id="generateSqlBtn" onclick="generateSql()">Generate SQL</button>
        <button class="btn btn-warning" id="downloadAllBtn" onclick="downloadAll()" disabled>Download All</button>
    </div>

    <!-- Results Panel -->
    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="validation" onclick="switchTab('validation')">Validation Results</button>
            <button class="tab-btn" type="button" data-tab="controls" onclick="switchTab('controls')">Control Summary</button>
            <button class="tab-btn" type="button" data-tab="exceptions" onclick="switchTab('exceptions')">Exceptions</button>
            <button class="tab-btn" type="button" data-tab="charts" onclick="switchTab('charts')">Charts</button>
            <button class="tab-btn" type="button" data-tab="sql" onclick="switchTab('sql')">SQL Code</button>
            <button class="tab-btn" type="button" data-tab="downloads" onclick="switchTab('downloads')">Downloads</button>
        </div>

        <div class="tab-pane active" id="tab-validation" data-tab-panel="validation">
            <div id="validationContent" class="empty-state"><p>Run validation to see results here.</p></div>
        </div>
        <div class="tab-pane" id="tab-controls" data-tab-panel="controls">
            <div id="controlsContent" class="empty-state"><p>Control summary will appear after running validation.</p></div>
        </div>
        <div class="tab-pane" id="tab-exceptions" data-tab-panel="exceptions">
            <div id="exceptionsContent" class="empty-state"><p>No exceptions data yet. Run validation first.</p></div>
        </div>
        <div class="tab-pane" id="tab-charts" data-tab-panel="charts">
            <div id="chartsContent" class="empty-state"><p>Charts will appear after running validation.</p></div>
        </div>
        <div class="tab-pane" id="tab-sql" data-tab-panel="sql">
            <div id="sqlContent" class="empty-state"><p>Click "Generate SQL" or run validation to generate the SQL script.</p></div>
        </div>
        <div class="tab-pane" id="tab-downloads" data-tab-panel="downloads">
            <div id="downloadsContent" class="empty-state"><p>Run validation first, then use "Download All" or individual download buttons.</p></div>
        </div>
    </div>

    <!-- Spinner overlay -->
    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="spinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const currentSystemRole = '@(ViewBag.CurrentSystemRole ?? "")';
const uiPreviewRowLimit = 10;
const state = {
    server: '', database: '', driver: 'ODBC Driver 17 for SQL Server',
    qualTable: '', cesmTable: '', pqmTable: '',
    qualIdCol: '_001', qualNameCol: '_003', qualApprovalCol: '_004', qualApprovalValue: 'A',
    qualTypeCol: '_005', qualMinTimeTotalCol: '_053', qualMinTimeWilCol: '_054',
    qualHeqfCol: '_084', qualTotalSubsidyCol: '_090',
    cesmIdCol: '_001', cesmCodeCol: '_006',
    pqmNameCol: 'Authorised_Qualification_Name', pqmQualTypeCol: 'HEQF_Qual_Type',
    pqmCesmCodeCol: 'CESM_CODE', pqmCesmCode1Col: 'CESM_CODE1',
    pqmMinTimeTotalCol: 'Total2', pqmWilCol: 'WIL_EL2',
    pqmAccreditationCol: 'CHE_HEQC_Accreditation_Approval_Ref_Nr', pqmTotalSubsidyCol: 'Total2',
    heqfIndicatorCodesCsv: 'H/,HEQF,HEQSF',
    useMPrefixPopulationSplit: false,
    postgraduateTypesCsv: '07,27,28,49,72,73,08,30,50,74,75',
    clientId: parseInt(document.getElementById('clientIdSelect')?.value || '0') || 0,
    currentRunId: null, validationResult: null,
    validationView: { resultFilter: 'ALL', populationFilter: 'ALL', page: 1, pageSize: uiPreviewRowLimit },
    currentUserEngagementRole: '', currentStatus: '',
    currentUserHasSignedOff: false, isWorkspaceSaved: false,
    hasDataAnalystSignoff: false, resultsVisible: false,
    editWarningAccepted: false, isBeginningWorkspaceEdit: false,
    isHydrating: false, isDirty: false, chartInstances: {}
};

function toggleAccordion(name) {
    const body = document.getElementById(`body-${name}`);
    const chevron = document.querySelector(`#acc-${name} .acc-chevron`);
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (chevron) chevron.textContent = open ? '^' : 'v';
}

function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelector(`[onclick="switchTab('${name}')"]`).classList.add('active');
    document.getElementById(`tab-${name}`).classList.add('active');
    if (name === 'charts' && state.validationResult) {
        const cc = document.getElementById('chartsContent');
        if (cc && cc.classList.contains('empty-state')) renderCharts(state.validationResult);
    }
}

function showSpinner(msg = 'Processing...') {
    document.getElementById('spinnerMsg').textContent = msg;
    document.getElementById('spinner').style.display = 'flex';
}
function hideSpinner() { document.getElementById('spinner').style.display = 'none'; }

function setStatus(elId, msg, type = 'info') {
    const el = document.getElementById(elId);
    if (el) el.innerHTML = `<div class="alert alert--${type}">${msg}</div>`;
}

function setWorkspaceInfo(msg, type = 'info') {
    const el = document.getElementById('workspaceInfo');
    if (!el) return;
    el.className = `alert alert--${type}`;
    el.innerHTML = msg;
    window.showWorkspaceActionToast?.(msg, type);
}

function setWorkspaceRunState(text, type = 'neutral') {
    const el = document.getElementById('workspaceRunState');
    if (el) { el.className = `badge badge--${type} badge--sm`; el.textContent = text; }
}

function isArchivedWorkspace() {
    return String(state.currentStatus || '').toLowerCase() === 'archived';
}

function updateHeaderBadge(status) {
    const badge = document.getElementById('statusBadge');
    if (!badge) return;
    if (!status) { badge.style.display = 'none'; badge.textContent = ''; return; }
    badge.style.display = 'inline-block';
    badge.className = `rule-header__badge ${String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    badge.textContent = String(status).toUpperCase();
}

async function post(url, data) {
    return await window.fetchJsonWithProgress(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
}

async function getJson(url) {
    return await window.fetchJsonWithProgress(url, { method: 'GET' });
}

async function downloadPost(url, data, filename) {
    await window.downloadFileWithProgress({
        url, method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        defaultFileName: filename,
        label: 'Downloading result'
    });
}

async function markWorkspaceDirty() {
    if (state.isHydrating) return;
    if (currentSystemRole === 'Admin') return;
    if (isArchivedWorkspace()) return;

    if (state.clientId && state.currentRunId && !state.editWarningAccepted) {
        if (state.isBeginningWorkspaceEdit) {
            state.isDirty = true;
            renderWorkspaceState();
            return;
        }

        const confirmEdit = window.confirm(
            'Are you sure you want to edit this saved workspace? Existing signoffs will be removed and the run will need to be reviewed again.'
        );

        if (!confirmEdit) {
            await loadWorkspaceState();
            return;
        }

        state.isBeginningWorkspaceEdit = true;
        state.editWarningAccepted = true;
        showSpinner('Clearing signoffs for the edited workspace...');

        try {
            const result = await post('/Rule38/BeginWorkspaceEdit', buildRequest());
            if (!result.success) {
                state.editWarningAccepted = false;
                setWorkspaceInfo(`Error: ${escapeHtml(result.error || 'Failed to begin editing.')}`, 'error');
                await loadWorkspaceState();
                return;
            }

            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;

            if (result.workspace) {
                state.currentRunId = result.workspace.runId || state.currentRunId;
                state.currentUserEngagementRole = result.workspace.currentUserEngagementRole || state.currentUserEngagementRole;
                state.currentStatus = result.workspace.currentStatus || state.currentStatus;
                state.resultsVisible = !!result.workspace.resultsVisible;
                document.getElementById('signoffComment').value = result.workspace.currentUserSignoffComment || '';
                if (result.workspace.summary) {
                    applyValidationResult(result.workspace.summary, { switchToValidation: false, fromWorkspace: true });
                }
            }

            setWorkspaceInfo(result.message || 'Editing has begun. Existing signoffs were removed.', 'warning');
        } catch (error) {
            state.editWarningAccepted = false;
            setWorkspaceInfo(`Error: ${escapeHtml(error?.message || 'Failed to begin editing.')}`, 'error');
            await loadWorkspaceState();
        } finally {
            state.isBeginningWorkspaceEdit = false;
            hideSpinner();
        }
    }

    state.isDirty = true;
    renderWorkspaceState();
}

