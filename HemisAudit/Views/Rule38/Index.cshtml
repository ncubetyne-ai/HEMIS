    const controls = r.controlSummaries || [];
    const cards = controls.map(cs => `
        <div class="stat-card ${cs.status === 'PASS' ? 'stat-card--pass' : 'stat-card--fail'}" style="min-width:160px">
            <div class="stat-card__label">${escapeHtml(cs.controlId)}: ${escapeHtml(cs.controlLabel)}</div>
            <div style="font-size:0.75rem;color:#666;margin:2px 0 6px">${escapeHtml(cs.criteriaText)}</div>
            <div style="display:flex;gap:12px;margin-top:4px">
                <div><span style="color:#2E7D32;font-weight:bold">${(cs.passCount||0).toLocaleString()}</span> PASS</div>
                <div><span style="color:#C62828;font-weight:bold">${(cs.failCount||0).toLocaleString()}</span> FAIL</div>
            </div>
