@model HemisAudit.ViewModels.Rule38RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 38 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = ViewBag.IsAdmin is bool admin && admin;
    var canDownload = ViewBag.CanDownloadSavedRun is bool allowed && allowed;
    var canManageEngagement = ViewBag.CanManageEngagement is bool manageEngagement && manageEngagement;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool openWorkspace && openWorkspace;
    var isArchived = ViewBag.IsArchived is bool archived && archived;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var failRows = Model.Summary.ValidationRows.Where(r => r.ValidationResult == "FAIL").ToList();
    var total = Model.Summary.ApprovedCount > 0 ? (decimal)Model.Summary.ApprovedCount : 1m;

    string BuildReason(HemisAudit.ViewModels.Rule38ValidationRow row)
    {
        var parts = new System.Collections.Generic.List<string>();
        if (row.ValidationResult == "FAIL" && row.FailedControls.Any())
            parts.Add($"Failed: {string.Join(", ", row.FailedControls)}");
        if (!string.IsNullOrWhiteSpace(row.MatchNote))
            parts.Add(row.MatchNote);
        return parts.Count > 0
            ? string.Join(" | ", parts)
            : row.ValidationResult == "PASS"
                ? "All Rule 38 checks matched on the selected PQM row."
                : "-";
    }

    string ResolvePqmName(HemisAudit.ViewModels.Rule38ValidationRow row)
    {
        if (!string.IsNullOrWhiteSpace(row.PqmName))
            return row.PqmName;
        return "Not found in PQM";
    }
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .viz-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); }
    .viz-card { background:#fff; border:1px solid #e5e7eb; border-radius:18px; padding:20px; box-shadow:0 18px 40px rgba(15, 23, 42, .06); }
    .viz-bar { background:#e5e7eb; border-radius:999px; height:14px; overflow:hidden; margin-top:10px; }
    .viz-bar > span { display:block; height:100%; }
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
    .filter-toolbar { align-items:center; display:flex; flex-wrap:wrap; gap:16px; justify-content:space-between; margin-bottom:16px; }
    .filter-toolbar__group { align-items:center; display:flex; gap:10px; }
    .filter-toolbar__group label { color:#64748b; font-size:12px; font-weight:700; text-transform:uppercase; }
    .filter-toolbar__meta { color:#64748b; font-size:14px; }
    .ctrl-badge-p { background:#dcfce7;color:#166534;font-size:0.7rem;padding:1px 6px;border-radius:4px;font-weight:700 }
    .ctrl-badge-f { background:#fee2e2;color:#991b1b;font-size:0.7rem;padding:1px 6px;border-radius:4px;font-weight:700 }
</style>

<div class="page-header">
    <div>
        <h1>Rule 38 Saved Run</h1>
        <p>
            @Model.EngagementName
            <span style="padding:0 8px">|</span>
            @Model.MaconomyNumber
            <span style="padding:0 8px">|</span>
            Run #@Model.RunId
            <span style="padding:0 8px">|</span>
            @Model.Summary.Timestamp
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Back to Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Back to Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This engagement is archived. The saved run is available for review and download only.
    </div>
}

@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">
        The data analyst signoff is still outstanding. Assigned users can still review and download this run.
    </div>
}

@if (Model.Summary.IsPreviewOnly)
{
    <div class="alert alert--info" style="margin-bottom:24px">
        This run was saved in browser preview mode. Download Excel or CSV for the full result set.
    </div>
}

<!-- Signoffs -->
<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>

    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review or completion notes">@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary">
                @(Model.CurrentUserHasSignedOff ? "Update My Signoff" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>

        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove the signoff for this validation run?')">
                    Remove Signoff
                </button>
            </form>
        }
    }
    else if (isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">Signoff controls are disabled for archived engagements.</div>
    }
    else if (!Model.IsCurrentRun)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff. Signoff is only available on the current run.</div>
    }

    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Reviewer</th>
                    <th>Comment</th>
                    <th>Signed At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var signoff in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@signoff.SignoffRole</span></td>
                        <td>
                            <strong>@signoff.ReviewerName</strong><br />
                            <small style="color:#757575">@signoff.ReviewerEmail</small>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(signoff.Comment) ? "-" : signoff.Comment)</td>
                        <td>@signoff.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<!-- Review Tabs -->
<div class="card" style="padding:0 0 24px">
    <div class="review-tabs" role="tablist" aria-label="Rule 38 review tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis Results</button>
        <button type="button" class="review-tab" data-review-tab="controls">Control Summary</button>
        <button type="button" class="review-tab" data-review-tab="details">Data Details</button>
        <button type="button" class="review-tab" data-review-tab="visuals">Visualizations</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL Code</button>
        <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
    </div>

    <!-- Analysis Results -->
    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">Total QUAL Records</div>
                <div class="stat-card__value">@Model.Summary.TotalQualRecords.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Approved (tested)</div>
                <div class="stat-card__value">@Model.Summary.ApprovedCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Undergraduate</div>
                <div class="stat-card__value">@Model.Summary.UndergraduateCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Postgraduate</div>
                <div class="stat-card__value">@Model.Summary.PostgraduateCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">PQM Match</div>
                <div class="stat-card__value">@Model.Summary.PqmMatchCount.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">PQM No Match</div>
                <div class="stat-card__value">@Model.Summary.PqmNoMatchCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Review Required</div>
                <div class="stat-card__value">@Model.Summary.ReviewRequiredCount.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--pass">
                <div class="stat-card__label">Overall PASS</div>
                <div class="stat-card__value">@Model.Summary.OverallPassCount.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">Overall FAIL</div>
                <div class="stat-card__value">@Model.Summary.OverallFailCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">Exception Rate</div>
                <div class="stat-card__value">@Model.Summary.ExceptionRate.ToString("F2")%</div>
            </div>
        </div>

        <div class="overall-status @(Model.Summary.Status == "PASS" ? "status--pass" : "status--fail")" style="border-radius:12px;padding:16px;margin-bottom:24px;text-align:center;font-weight:700;font-size:1.1rem">
            @if (Model.Summary.Status == "PASS")
            {
                <span>VALIDATION PASSED — All approved QUAL records passed controls 5.1.2–5.1.6</span>
            }
            else
            {
                <span>VALIDATION FAILED — @Model.Summary.OverallFailCount.ToString("N0") record(s) failed one or more controls</span>
            }
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Run Configuration</h3>
            <div class="form-grid">
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div>
                    <div>@Model.Summary.Database</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule</div>
                    <div>Rule 38 - Enhanced QUAL -> CESM -> PQM Validation (5.1.1-5.1.6)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">QUAL Table</div>
                    <div>@Model.Summary.QualTable (ID: @Model.Summary.QualIdCol, Name: @Model.Summary.QualNameCol)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">CESM Table</div>
                    <div>@Model.Summary.CesmTable (ID: @Model.Summary.CesmIdCol, Code: @Model.Summary.CesmCodeCol)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Approval Filter</div>
                    <div>@Model.Summary.QualApprovalCol = '@Model.Summary.QualApprovalValue'</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">QUAL Columns (C2–C6)</div>
                    <div>Type: @Model.Summary.QualTypeCol | MinTime: @Model.Summary.QualMinTimeTotalCol | WIL: @Model.Summary.QualMinTimeWilCol | HEQF: @Model.Summary.QualHeqfCol | Subsidy: @Model.Summary.QualTotalSubsidyCol</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">PQM Table</div>
                    <div>@Model.Summary.PqmTable (Name: @Model.Summary.PqmNameCol)</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">PQM Columns (C2–C6)</div>
                    <div>Type: @Model.Summary.PqmQualTypeCol | CESM: @Model.Summary.PqmCesmCodeCol | CESM1: @Model.Summary.PqmCesmCode1Col | MinTime: @Model.Summary.PqmMinTimeTotalCol | WIL: @Model.Summary.PqmWilCol | Accred: @Model.Summary.PqmAccreditationCol | Subsidy: @Model.Summary.PqmTotalSubsidyCol</div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">HEQF Indicator Codes</div>
                    <div><code>@Model.Summary.HeqfIndicatorCodesCsv</code></div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Population Split</div>
                    <div>
                        @(Model.Summary.UseMPrefixPopulationSplit
                            ? "Postgraduate = configured _005 codes or M_____ qualification codes"
                            : "Postgraduate = configured _005 codes only")
                    </div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Postgraduate Codes</div>
                    <div><code>@Model.Summary.PostgraduateTypesCsv</code></div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                    <div><span class="badge @(Model.Summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@Model.Summary.Status</span></div>
                </div>
                <div>
                    <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Engagement Role</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.CurrentUserEngagementRole) ? (isAdmin ? "Admin" : "Viewer") : Model.CurrentUserEngagementRole)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Control Summary -->
    <div class="review-panel" data-review-panel="controls" style="padding:24px">
        @if (Model.Summary.ControlSummaries.Any())
        {
            <div class="stats-grid" style="margin-bottom:24px">
                @foreach (var cs in Model.Summary.ControlSummaries)
                {
                    <div class="stat-card @(cs.Status == "PASS" ? "stat-card--pass" : "stat-card--fail")">
                        <div class="stat-card__label">@cs.ControlId: @cs.ControlLabel</div>
                        <div style="font-size:0.72rem;color:#555;margin:2px 0 6px">@cs.CriteriaText</div>
                        <div style="display:flex;gap:14px;margin-bottom:4px">
                            <div><span style="color:#166534;font-weight:700">@cs.PassCount.ToString("N0")</span> PASS</div>
                            <div><span style="color:#991b1b;font-weight:700">@cs.FailCount.ToString("N0")</span> FAIL</div>
                        </div>
                        <div class="stat-card__value" style="font-size:1rem">@cs.Status</div>
                    </div>
                }
            </div>

            <div class="card" style="padding:20px">
                <h3 class="section-title" style="margin-top:0">Control Detail Table</h3>
                <div style="overflow:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Control</th>
                                <th>Description</th>
                                <th>Criteria</th>
                                <th>Pass</th>
                                <th>Fail</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cs in Model.Summary.ControlSummaries)
                            {
                                <tr>
                                    <td><strong>@cs.ControlId</strong></td>
                                    <td>@cs.ControlLabel</td>
                                    <td style="font-size:0.8rem;color:#555">@cs.CriteriaText</td>
                                    <td style="color:#166534"><strong>@cs.PassCount.ToString("N0")</strong></td>
                                    <td style="color:#991b1b"><strong>@cs.FailCount.ToString("N0")</strong></td>
                                    <td><span class="badge @(cs.Status == "PASS" ? "badge--pass" : "badge--fail")">@cs.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert--info">No control summary data available for this saved run.</div>
        }
    </div>

    <!-- Data Details -->
    <div class="review-panel" data-review-panel="details" style="padding:24px">
        <div class="card" style="margin-bottom:24px;padding:20px">
            <h3 class="section-title" style="margin-top:0">Exceptions</h3>
            @if (failRows.Any())
            {
                <div style="overflow:auto">
                    <table class="data-table rule11-table" style="font-size:0.83rem">
                        <thead>
                            <tr>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">#</th>
                                <th colspan="9" style="background:#558B2F;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.QualTable</th>
                                <th colspan="2" style="background:#00838F;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.CesmTable</th>
                                <th colspan="8" style="background:#6A1B9A;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.PqmTable</th>
                                <th colspan="6" style="background:#374151;color:#fff;text-align:center;border-right:2px solid #fff">Rule 38 Controls</th>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">Result</th>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">Exception Reason</th>
                            </tr>
                            <tr>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualIdCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualNameCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualApprovalCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualTypeCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualMinTimeTotalCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualMinTimeWilCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualHeqfCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualTotalSubsidyCol</th>
                                <th style="background:#AED581;font-size:11px;border-right:2px solid #558B2F">Population Type</th>
                                <th style="background:#80DEEA;font-size:11px">@Model.Summary.CesmIdCol</th>
                                <th style="background:#80DEEA;font-size:11px;border-right:2px solid #00838F">@Model.Summary.CesmCodeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmNameCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmQualTypeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmCesmCodeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmCesmCode1Col</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmMinTimeTotalCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmWilCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmAccreditationCol</th>
                                <th style="background:#CE93D8;font-size:10px;border-right:2px solid #6A1B9A">@Model.Summary.PqmTotalSubsidyCol</th>
                                <th style="background:#D1D5DB;font-size:11px">Review</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.2 Qualification Type">C2</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.3 Minimum Time: Total">C3</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.4 Minimum Time: WIL">C4</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.5 HEQF Indicator">C5</th>
                                <th style="background:#D1D5DB;font-size:11px;border-right:2px solid #374151" title="5.1.6 Total Subsidy">C6</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in failRows.Take(10))
                            {
                                <tr style="background:#fff3f3" title="Population rule: @item.PopulationClassificationNote | Match: @item.MatchNote">
                                    <td style="text-align:center">@item.ValidationNumber</td>
                                    <td><strong>@item.QualCode</strong></td>
                                    <td>@item.QualName</td>
                                    <td>@item.ApprovalStatus</td>
                                    <td>@item.QualType</td>
                                    <td>@item.MinTimeTotal</td>
                                    <td>@item.MinTimeWIL</td>
                                    <td>@item.HeqfIndicator</td>
                                    <td>@item.TotalSubsidy</td>
                                    <td style="font-weight:700;color:@(item.PopulationType == "Postgraduate" ? "#1B5E20" : "#1565C0")">@item.PopulationType</td>
                                    <td>@item.QualCode</td>
                                    <td>@item.CesmCode</td>
                                    <td>@ResolvePqmName(item)</td>
                                    <td>@item.PqmQualType</td>
                                    <td>@item.PqmCesmCode</td>
                                    <td>@item.PqmCesmCode1</td>
                                    <td>@item.PqmMinTimeTotal</td>
                                    <td>@item.PqmWIL</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.PqmAccreditation) ? "N/A" : item.PqmAccreditation)</td>
                                    <td>@item.PqmTotalSubsidy</td>
                                    <td style="text-align:center"><span class="badge @(item.NeedsReview ? "badge--warning" : "badge--neutral")">@(item.NeedsReview ? "YES" : "NO")</span></td>
                                    <td style="text-align:center"><span class="@(item.C2_TypeMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C2_TypeMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C3_MinTimeMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C3_MinTimeMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C4_WILMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C4_WILMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C5_HeqfMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C5_HeqfMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C6_SubsidyMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C6_SubsidyMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="badge badge--fail">@item.ValidationResult</span></td>
                                    <td style="color:#991b1b;font-size:0.78rem">@BuildReason(item)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (failRows.Count > 10)
                {
                    <div style="color:#64748b;margin-top:8px">Showing first 10 exception rows in the browser. Download CSV for the full list.</div>
                }
            }
            else
            {
                <div class="alert alert--success" style="margin:0">No exceptions were found in this saved validation run.</div>
            }
        </div>

        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Validation Rows (preview)</h3>
            @if (Model.Summary.ValidationRows.Any())
            {
                <div class="filter-toolbar">
                    <div class="filter-toolbar__group">
                        <label for="rule38ValidationResultFilter">Result</label>
                        <select id="rule38ValidationResultFilter">
                            <option value="ALL">All</option>
                            <option value="PASS">Passed</option>
                            <option value="FAIL">Failed</option>
                        </select>
                    </div>
                    <div class="filter-toolbar__group">
                        <label for="rule38ValidationPopulationFilter">Population</label>
                        <select id="rule38ValidationPopulationFilter">
                            <option value="ALL">All</option>
                            <option value="Undergraduate">Undergraduate</option>
                            <option value="Postgraduate">Postgraduate</option>
                        </select>
                    </div>
                    <div class="filter-toolbar__meta">
                        <span id="rule38FilterCount">@Model.Summary.ValidationRows.Take(10).Count()</span> visible row(s)
                    </div>
                </div>
                <div style="overflow:auto">
                    <table class="data-table rule11-table" style="font-size:0.83rem">
                        <thead>
                            <tr>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">#</th>
                                <th colspan="9" style="background:#558B2F;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.QualTable</th>
                                <th colspan="2" style="background:#00838F;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.CesmTable</th>
                                <th colspan="8" style="background:#6A1B9A;color:#fff;text-align:center;border-right:2px solid #fff">@Model.Summary.PqmTable</th>
                                <th colspan="6" style="background:#374151;color:#fff;text-align:center;border-right:2px solid #fff">Rule 38 Controls</th>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">Result</th>
                                <th rowspan="2" style="vertical-align:middle;text-align:center">Reason</th>
                            </tr>
                            <tr>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualIdCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualNameCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualApprovalCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualTypeCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualMinTimeTotalCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualMinTimeWilCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualHeqfCol</th>
                                <th style="background:#AED581;font-size:11px">@Model.Summary.QualTotalSubsidyCol</th>
                                <th style="background:#AED581;font-size:11px;border-right:2px solid #558B2F">Population Type</th>
                                <th style="background:#80DEEA;font-size:11px">@Model.Summary.CesmIdCol</th>
                                <th style="background:#80DEEA;font-size:11px;border-right:2px solid #00838F">@Model.Summary.CesmCodeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmNameCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmQualTypeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmCesmCodeCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmCesmCode1Col</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmMinTimeTotalCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmWilCol</th>
                                <th style="background:#CE93D8;font-size:10px">@Model.Summary.PqmAccreditationCol</th>
                                <th style="background:#CE93D8;font-size:10px;border-right:2px solid #6A1B9A">@Model.Summary.PqmTotalSubsidyCol</th>
                                <th style="background:#D1D5DB;font-size:11px">Review</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.2">C2</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.3">C3</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.4">C4</th>
                                <th style="background:#D1D5DB;font-size:11px" title="5.1.5">C5</th>
                                <th style="background:#D1D5DB;font-size:11px;border-right:2px solid #374151" title="5.1.6">C6</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Summary.ValidationRows.Take(10))
                            {
                                <tr data-filter-result="@item.ValidationResult" data-filter-population="@item.PopulationType" style="background:@(item.NeedsReview ? "#fff8e1" : item.ValidationResult == "PASS" ? "#f3fff3" : "#fff3f3")" title="Population rule: @item.PopulationClassificationNote | Match: @item.MatchNote">
                                    <td style="text-align:center">@item.ValidationNumber</td>
                                    <td><strong>@item.QualCode</strong></td>
                                    <td>@item.QualName</td>
                                    <td>@item.ApprovalStatus</td>
                                    <td>@item.QualType</td>
                                    <td>@item.MinTimeTotal</td>
                                    <td>@item.MinTimeWIL</td>
                                    <td>@item.HeqfIndicator</td>
                                    <td>@item.TotalSubsidy</td>
                                    <td style="font-weight:700;color:@(item.PopulationType == "Postgraduate" ? "#1B5E20" : "#1565C0")">@item.PopulationType</td>
                                    <td>@item.QualCode</td>
                                    <td>@item.CesmCode</td>
                                    <td>@ResolvePqmName(item)</td>
                                    <td>@item.PqmQualType</td>
                                    <td>@item.PqmCesmCode</td>
                                    <td>@item.PqmCesmCode1</td>
                                    <td>@item.PqmMinTimeTotal</td>
                                    <td>@item.PqmWIL</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.PqmAccreditation) ? "N/A" : item.PqmAccreditation)</td>
                                    <td>@item.PqmTotalSubsidy</td>
                                    <td style="text-align:center"><span class="badge @(item.NeedsReview ? "badge--warning" : "badge--neutral")">@(item.NeedsReview ? "YES" : "NO")</span></td>
                                    <td style="text-align:center"><span class="@(item.C2_TypeMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C2_TypeMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C3_MinTimeMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C3_MinTimeMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C4_WILMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C4_WILMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C5_HeqfMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C5_HeqfMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="@(item.C6_SubsidyMatch ? "ctrl-badge-p" : "ctrl-badge-f")">@(item.C6_SubsidyMatch ? "P" : "F")</span></td>
                                    <td style="text-align:center"><span class="badge @(item.ValidationResult == "PASS" ? "badge--pass" : "badge--fail")">@item.ValidationResult</span></td>
                                    <td style="font-size:0.78rem;color:@(item.NeedsReview ? "#92400e" : item.ValidationResult == "PASS" ? "#166534" : "#991b1b")">@BuildReason(item)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="color:#64748b">No validation rows are available in this saved run.</div>
            }
        </div>
    </div>

    <!-- Visualizations -->
    <div class="review-panel" data-review-panel="visuals" style="padding:24px">
        <div class="viz-grid">
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Overall PASS</div>
                <div style="font-size:36px;font-weight:800;color:#166534">@Model.Summary.OverallPassCount.ToString("N0")</div>
                <div class="viz-bar">
                    <span style="width:@((Model.Summary.ApprovedCount == 0 ? 0m : Model.Summary.OverallPassCount * 100m / total).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#22c55e"></span>
                </div>
            </div>
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Overall FAIL</div>
                <div style="font-size:36px;font-weight:800;color:#dc2626">@Model.Summary.OverallFailCount.ToString("N0")</div>
                <div class="viz-bar">
                    <span style="width:@((Model.Summary.ApprovedCount == 0 ? 0m : Model.Summary.OverallFailCount * 100m / total).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;background:#ef4444"></span>
                </div>
            </div>
        </div>
        <div class="viz-grid" style="margin-top:20px">
            <div class="viz-card">
                <h4 style="margin-top:0">Run Composition</h4>
                    <div style="color:#475569;line-height:1.8">
                        <div><strong>Total QUAL:</strong> @Model.Summary.TotalQualRecords.ToString("N0")</div>
                        <div><strong>Approved:</strong> @Model.Summary.ApprovedCount.ToString("N0")</div>
                        <div><strong>Undergraduate:</strong> @Model.Summary.UndergraduateCount.ToString("N0")</div>
                        <div><strong>Postgraduate:</strong> @Model.Summary.PostgraduateCount.ToString("N0")</div>
                        <div><strong>PQM Match:</strong> @Model.Summary.PqmMatchCount.ToString("N0")</div>
                        <div><strong>PQM No Match:</strong> @Model.Summary.PqmNoMatchCount.ToString("N0")</div>
                    <div><strong>PASS:</strong> @Model.Summary.OverallPassCount.ToString("N0")</div>
                    <div><strong>FAIL:</strong> @Model.Summary.OverallFailCount.ToString("N0")</div>
                    <div><strong>Exception Rate:</strong> @Model.Summary.ExceptionRate.ToString("F2")%</div>
                    <div><strong>Status:</strong> @Model.Summary.Status</div>
                </div>
            </div>
            <div class="viz-card">
                <h4 style="margin-top:0">Per-Control Summary</h4>
                @foreach (var cs in Model.Summary.ControlSummaries)
                {
                    <div style="padding:6px 0;border-bottom:1px solid #e5e7eb">
                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <strong>@cs.ControlId</strong>
                            <span class="badge @(cs.Status == "PASS" ? "badge--pass" : "badge--fail")" style="font-size:0.7rem">@cs.Status</span>
                        </div>
                        <div style="font-size:0.78rem;color:#64748b">@cs.ControlLabel — Pass: @cs.PassCount.ToString("N0"), Fail: @cs.FailCount.ToString("N0")</div>
                    </div>
                }
            </div>
            @if (failRows.Any())
            {
                <div class="viz-card">
                    <h4 style="margin-top:0">Exception Feed</h4>
                    @foreach (var item in failRows.Take(5))
                    {
                        <div style="padding:8px 0;border-bottom:1px solid #e5e7eb">
                            <strong>@item.QualCode</strong> — @item.QualName
                            <div style="color:#64748b;font-size:0.78rem">Failed: @string.Join(", ", item.FailedControls)</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- SQL Code -->
    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="card" style="padding:20px;margin-bottom:20px">
            <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap">
                <div>
                    <h3 class="section-title" style="margin:0">Saved SQL Preview</h3>
                    <div style="color:#64748b;margin-top:4px">Review the SQL generated from the saved run configuration.</div>
                </div>
                @if (canDownload)
                {
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">Download SQL</a>
                }
            </div>
        </div>
        <div class="code-panel"><pre><code>@Model.GeneratedSql</code></pre></div>
    </div>

    <!-- Downloads -->
    <div class="review-panel" data-review-panel="downloads" style="padding:24px">
        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Downloads</h3>
            @if (canDownload)
            {
                <div style="display:flex;gap:10px;flex-wrap:wrap">
                    <a asp-action="DownloadSavedExcel" asp-route-runId="@Model.RunId" class="btn btn-success">Excel</a>
                    <a asp-action="DownloadSavedCsv" asp-route-runId="@Model.RunId" class="btn btn-info">Full CSV</a>
                    <a asp-action="DownloadSavedExceptionsCsv" asp-route-runId="@Model.RunId" class="btn btn-info">Exceptions CSV</a>
                    <a asp-action="DownloadSavedSql" asp-route-runId="@Model.RunId" class="btn btn-primary">SQL</a>
                </div>
            }
            else
            {
                <div class="alert alert--warning" style="margin:0">
                    Download is available to the assigned data analyst immediately, and to other assigned users after the data analyst signoff.
                </div>
            }
        </div>
    </div>
</div>

<script>
(() => {
    const tabs = Array.from(document.querySelectorAll('[data-review-tab]'));
    const panels = Array.from(document.querySelectorAll('[data-review-panel]'));

    function setActiveTab(name) {
        tabs.forEach(tab => tab.classList.toggle('is-active', tab.getAttribute('data-review-tab') === name));
        panels.forEach(panel => panel.classList.toggle('is-active', panel.getAttribute('data-review-panel') === name));
    }

    tabs.forEach(tab => tab.addEventListener('click', () => setActiveTab(tab.getAttribute('data-review-tab'))));

    const validationResultFilter = document.getElementById('rule38ValidationResultFilter');
    const validationPopulationFilter = document.getElementById('rule38ValidationPopulationFilter');
    const validationRows = Array.from(document.querySelectorAll('tr[data-filter-result]'));
    const validationCount = document.getElementById('rule38FilterCount');

    function applyValidationFilter() {
        if (!validationCount) return;
        const resultValue = validationResultFilter?.value || 'ALL';
        const populationValue = validationPopulationFilter?.value || 'ALL';
        let visibleCount = 0;
        validationRows.forEach(row => {
            const result = (row.getAttribute('data-filter-result') || '').toUpperCase();
            const population = row.getAttribute('data-filter-population') || 'Undergraduate';
            const matchesResult = resultValue === 'ALL' || result === resultValue;
            const matchesPopulation = populationValue === 'ALL' || population === populationValue;
            const visible = matchesResult && matchesPopulation;
            row.style.display = visible ? '' : 'none';
            if (visible) visibleCount++;
        });
        validationCount.textContent = visibleCount.toLocaleString();
    }

    validationResultFilter?.addEventListener('change', applyValidationFilter);
    validationPopulationFilter?.addEventListener('change', applyValidationFilter);
    applyValidationFilter();
})();
</script>

