        { datasetCode: '2024H16QUAL', datasetLabel: '2024H16QUAL', tableName: '2024H16QUAL', keyColumns: ['QUALCODE'], compositeKeyFields: [] },
        { datasetCode: 'Prod_CRSE', datasetLabel: 'Prod_CRSE', tableName: 'Prod_CRSE', keyColumns: ['IALSUBJ'], compositeKeyFields: [] },
        { datasetCode: '2024H16CRSE', datasetLabel: '2024H16CRSE', tableName: '2024H16CRSE', keyColumns: ['CRSECODE'], compositeKeyFields: [] },
        { datasetCode: 'Employee_file', datasetLabel: 'Employee_file', tableName: 'Employee_file', keyColumns: ['Personnel_Number'], compositeKeyFields: [] },
        { datasetCode: 'dbo_PROF', datasetLabel: 'dbo_PROF', tableName: 'dbo_PROF', keyColumns: ['_037'], compositeKeyFields: [] },
        { datasetCode: 'Deceased_Students', datasetLabel: 'Deceased_Students', tableName: 'Deceased_Students', keyColumns: ['STUDENT_NUMBER'], compositeKeyFields: [] }
    ];
    const resultColumnProfiles = {
