        chartInstances: {},
        detectedTables: [],
        tableColumnsCache: {},
        rule10ColumnLoads: {},
        rule10JoinConfig: rule10DatasetTemplates.map(item => ({ ...item })),
        pendingWorkspaceDatabase: '',
        pendingWorkspaceSelections: null
    };

    const els = {
        clientId: document.getElementById('clientId'),
        server: document.getElementById('server'),
        driver: document.getElementById('driver'),
        database: document.getElementById('database'),
        qualTable: document.getElementById('qualTable'),
        studTable: document.getElementById('studTable'),
        cregTable: document.getElementById('cregTable'),
        crseTable: document.getElementById('crseTable'),
        ruleColumn: document.getElementById('ruleColumn'),
        ruleValueInput: document.getElementById('ruleValueInput'),
        studContextColumn: document.getElementById('studContextColumn'),
        studLinkColumn: document.getElementById('studLinkColumn'),
        qualLinkColumn: document.getElementById('qualLinkColumn'),
        cregContextColumn: document.getElementById('cregContextColumn'),
        cregLinkColumn: document.getElementById('cregLinkColumn'),
        crseLinkColumn: document.getElementById('crseLinkColumn'),
        cregStudentLinkColumn: document.getElementById('cregStudentLinkColumn'),
