    function normalizeRule10TableToken(value) {
        return String(value || '')
            .toLowerCase()
            .replace(/[^a-z0-9]/g, '');
    }

    function findRule10DetectedTable(preferredName, detectedTables) {
        const candidates = Array.isArray(detectedTables) ? detectedTables.filter(Boolean) : [];
        if (!candidates.length) return '';

        const exact = candidates.find(table => String(table).toLowerCase() === String(preferredName || '').toLowerCase());
        if (exact) return exact;

        const normalizedPreferred = normalizeRule10TableToken(preferredName);
        if (!normalizedPreferred) return '';

        const aliasChecks = [];

        if (normalizedPreferred === 'cenusdates' || normalizedPreferred === 'censusdates') {
            aliasChecks.push(table => normalizeRule10TableToken(table) === 'censusdates');
        }

        if (normalizedPreferred === 'censusdatesdesign') {
            aliasChecks.push(table => normalizeRule10TableToken(table).includes('censusdatesdesign'));
        }

        if (normalizedPreferred === '2024h16stud' || normalizedPreferred === 'h16stud') {
            aliasChecks.push(table => normalizeRule10TableToken(table).endsWith('h16stud'));
        }

        if (normalizedPreferred === '2024h16qual' || normalizedPreferred === 'h16qual') {
            aliasChecks.push(table => normalizeRule10TableToken(table).endsWith('h16qual'));
        }

        if (normalizedPreferred === '2024h16crse' || normalizedPreferred === 'h16crse') {
            aliasChecks.push(table => normalizeRule10TableToken(table).endsWith('h16crse'));
        }

        if (normalizedPreferred === 'prodstud') {
            aliasChecks.push(table => {
                const token = normalizeRule10TableToken(table);
                return token.includes('prod') && (token.includes('std') || token.includes('stud'));
            });
        }

        if (normalizedPreferred === 'prodqual') {
            aliasChecks.push(table => {
                const token = normalizeRule10TableToken(table);
                return token.includes('prod') && token.includes('qual');
            });
        }

        if (normalizedPreferred === 'prodcrse') {
            aliasChecks.push(table => {
                const token = normalizeRule10TableToken(table);
                return token.includes('prod') && token.includes('crse');
            });
        }

        if (normalizedPreferred === 'deceasedstudents') {
            aliasChecks.push(table => normalizeRule10TableToken(table) === 'deceasedstudents');
        }

        if (normalizedPreferred === 'employeefile') {
            aliasChecks.push(table => normalizeRule10TableToken(table).includes('employee'));
        }

        for (const matcher of aliasChecks) {
            const match = candidates.find(matcher);
            if (match) return match;
        }

        const containsMatch = candidates.find(table => normalizeRule10TableToken(table).includes(normalizedPreferred) || normalizedPreferred.includes(normalizeRule10TableToken(table)));
        return containsMatch || '';
    }

    async function downloadBlob(url, payload, defaultName) {
