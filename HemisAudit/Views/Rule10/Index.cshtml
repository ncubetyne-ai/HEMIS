    function applyDetectedTables(data) {
        state.detectedTables = data.tables || [];
        state.tableColumnsCache = {};
        const pending = state.pendingWorkspaceSelections || {};
        const tables = {
            qual: pending.qualTable || data.autoQualTable || 'dbo_QUAL',
            stud: pending.studTable || data.autoStudTable || 'dbo_STUD',
            creg: pending.cregTable || data.autoCregTable || 'dbo_CREG',
            crse: pending.crseTable || data.autoCrseTable || 'dbo_CRSE'
        };
        if (ruleNumber === 10) {
            const pendingJoinConfig = Array.isArray(pending.rule10JoinConfig) ? pending.rule10JoinConfig : rule10DatasetTemplates;
            state.rule10JoinConfig = pendingJoinConfig.map(item => ({
                ...item,
                tableName: findRule10DetectedTable(item.tableName || item.datasetCode || item.datasetLabel, data.tables || [])
            }));
            void ensureRule10JoinColumnsLoaded()
                .then(() => {
                    renderRule10JoinConfig();
                    setAlert(els.configOutput, 'success', `Detected ${data.tables.length} table(s) and loaded available key-column options from the selected tables.`);
                })
                .catch(error => setAlert(els.configOutput, 'error', error.message || 'Could not load join dataset columns.'));
            state.pendingWorkspaceSelections = null;
            return;
        }

        populateSelect(els.qualTable, data.tables || [], tables.qual, 'dbo_QUAL');
        populateSelect(els.studTable, data.tables || [], tables.stud, 'dbo_STUD');
        populateSelect(els.cregTable, data.tables || [], tables.creg, 'dbo_CREG');
        populateSelect(els.crseTable, data.tables || [], tables.crse, 'dbo_CRSE');
        void refreshRuleColumns({
            qualColumn: pending.qualColumn,
            studColumn: pending.studColumn,
            cregColumn: pending.cregColumn,
            crseColumn: pending.crseColumn,
            studContextColumn: ruleNumber === 7 ? (parseRuleParameterJson(pending.ruleParameterJson).contextColumn || '_007') : '',
            cregContextColumn: ruleNumber === 8 ? (parseRuleParameterJson(pending.ruleParameterJson).contextColumn || '_007') : '',
            cregGhostContextColumn: ruleNumber === 9 ? (parseRuleParameterJson(pending.ruleParameterJson).contextColumn || '_001') : '',
            studGhostContextColumn: ruleNumber === 9 ? (parseRuleParameterJson(pending.ruleParameterJson).secondaryContextColumn || '_001') : ''
        });
        syncRuleNarrative();
        state.pendingWorkspaceSelections = null;
    }

    async function loadColumnsForTable(tableName) {
        if (!tableName || !els.server?.value?.trim() || !els.database?.value) return [];
        if (state.tableColumnsCache[tableName]) return state.tableColumnsCache[tableName];
        const data = await postJson(`${apiBasePath}/GetColumns`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value,
            tableName
        });
        if (!data.success) throw new Error(data.error || `Could not load columns for ${tableName}.`);
        const columns = data.columns || [];
        if (!columns.length) throw new Error(`No columns were detected for ${tableName}.`);
        state.tableColumnsCache[tableName] = columns;
        return columns;
    }

    async function ensureRule10JoinColumnsLoaded() {
        const datasets = state.rule10JoinConfig || [];
        for (const dataset of datasets) {
            const tableName = dataset?.tableName;
            if (!tableName) continue;

            const columns = await loadColumnsForTable(tableName);
            dataset.availableColumns = [...columns];
            const currentColumns = Array.isArray(dataset.keyColumns) ? dataset.keyColumns : [];
            dataset.keyColumns = currentColumns.map((selectedColumn, index) =>
                columns.includes(selectedColumn) ? selectedColumn : (columns[index] || columns[0] || selectedColumn));
        }
    }

    function getRule10ColumnOptions(tableName, selectedColumn) {
        const datasetColumns = (state.rule10JoinConfig || [])
            .find(item => String(item.tableName || '').toLowerCase() === String(tableName || '').toLowerCase())
            ?.availableColumns;
        const loadedColumns = Array.isArray(datasetColumns) && datasetColumns.length
            ? datasetColumns
            : (Array.isArray(state.tableColumnsCache[tableName]) ? state.tableColumnsCache[tableName] : []);
        const uniqueOptions = Array.from(new Set(loadedColumns.filter(Boolean)));
        const hasLoadedColumns = loadedColumns.length > 0;

        if (selectedColumn && !uniqueOptions.includes(selectedColumn)) {
            uniqueOptions.unshift(selectedColumn);
        }

        if (!hasLoadedColumns) {
            loadRule10ColumnsIfNeeded(tableName);
        }

        if (!uniqueOptions.length) {
            uniqueOptions.push(state.rule10ColumnLoads[tableName] ? 'Loading columns...' : 'Select database and table to load columns');
        }

        return {
            options: uniqueOptions,
            loaded: hasLoadedColumns
        };
    }

    function loadRule10ColumnsIfNeeded(tableName) {
        if (!tableName || !els.server?.value?.trim() || !els.database?.value) return;
        if (state.tableColumnsCache[tableName]) return;
        if (state.rule10ColumnLoads[tableName]) return;

        state.rule10ColumnLoads[tableName] = true;
        void loadColumnsForTable(tableName)
            .then(() => renderRule10JoinConfig())
            .catch(error => setAlert(els.configOutput, 'error', error.message || `Could not load columns for ${tableName}.`))
            .finally(() => {
                delete state.rule10ColumnLoads[tableName];
            });
    }

    function getDefaultColumns() {
        return ruleDefaultColumns[ruleNumber] || {};
    }

    async function refreshRuleColumns(preferredValues = {}) {
        const defaults = getDefaultColumns();
        if (ruleNumber >= 1 && ruleNumber <= 3) {
            populateSelect(els.ruleColumn, await loadColumnsForTable(els.qualTable?.value), preferredValues.qualColumn || defaults.qual, defaults.qual);
        } else if (ruleNumber === 4) {
            populateSelect(els.ruleColumn, await loadColumnsForTable(els.crseTable?.value), preferredValues.crseColumn || defaults.crse, defaults.crse);
        } else if (ruleNumber === 5 || ruleNumber === 6) {
            populateSelect(els.ruleColumn, await loadColumnsForTable(els.studTable?.value), preferredValues.studColumn || defaults.stud, defaults.stud);
        } else if (ruleNumber === 7) {
            const studColumns = await loadColumnsForTable(els.studTable?.value);
            populateSelect(els.studContextColumn, studColumns, preferredValues.studContextColumn || els.studContextColumn?.dataset.pendingValue || '_007', '_007');
            populateSelect(els.studLinkColumn, studColumns, preferredValues.studColumn || defaults.stud, defaults.stud);
            populateSelect(els.qualLinkColumn, await loadColumnsForTable(els.qualTable?.value), preferredValues.qualColumn || defaults.qual, defaults.qual);
        } else if (ruleNumber === 8) {
            const cregColumns = await loadColumnsForTable(els.cregTable?.value);
            populateSelect(els.cregContextColumn, cregColumns, preferredValues.cregContextColumn || els.cregContextColumn?.dataset.pendingValue || '_007', '_007');
            populateSelect(els.cregLinkColumn, cregColumns, preferredValues.cregColumn || defaults.creg, defaults.creg);
            populateSelect(els.crseLinkColumn, await loadColumnsForTable(els.crseTable?.value), preferredValues.crseColumn || defaults.crse, defaults.crse);
        } else if (ruleNumber === 9) {
            const cregColumns = await loadColumnsForTable(els.cregTable?.value);
            const studColumns = await loadColumnsForTable(els.studTable?.value);
            populateSelect(els.cregStudentLinkColumn, cregColumns, preferredValues.cregColumn || defaults.creg, defaults.creg);
            populateSelect(els.studStudentLinkColumn, studColumns, preferredValues.studColumn || defaults.stud, defaults.stud);
            populateSelect(els.cregGhostContextColumn, cregColumns, preferredValues.cregGhostContextColumn || els.cregGhostContextColumn?.dataset.pendingValue || '_001', '_001');
            populateSelect(els.studGhostContextColumn, studColumns, preferredValues.studGhostContextColumn || els.studGhostContextColumn?.dataset.pendingValue || '_001', '_001');
        }
        syncRuleNarrative();
    }

    function getSelectedColumns() {
        const defaults = getDefaultColumns();
        if (ruleNumber >= 1 && ruleNumber <= 3) {
            return { qualColumn: (els.ruleColumn?.value || defaults.qual || '').trim(), studColumn: '', cregColumn: '', crseColumn: '' };
        }
        if (ruleNumber === 4) {
            return { qualColumn: '', studColumn: '', cregColumn: '', crseColumn: (els.ruleColumn?.value || defaults.crse || '').trim() };
        }
        if (ruleNumber === 5 || ruleNumber === 6) {
            return { qualColumn: '', studColumn: (els.ruleColumn?.value || defaults.stud || '').trim(), cregColumn: '', crseColumn: '' };
        }
        if (ruleNumber === 7) {
            return { qualColumn: (els.qualLinkColumn?.value || defaults.qual || '').trim(), studColumn: (els.studLinkColumn?.value || defaults.stud || '').trim(), cregColumn: '', crseColumn: '' };
        }
        if (ruleNumber === 8) {
            return { qualColumn: '', studColumn: '', cregColumn: (els.cregLinkColumn?.value || defaults.creg || '').trim(), crseColumn: (els.crseLinkColumn?.value || defaults.crse || '').trim() };
        }
        if (ruleNumber === 9) {
            return { qualColumn: '', studColumn: (els.studStudentLinkColumn?.value || defaults.stud || '').trim(), cregColumn: (els.cregStudentLinkColumn?.value || defaults.creg || '').trim(), crseColumn: '' };
        }
        return { qualColumn: '', studColumn: '', cregColumn: '', crseColumn: '' };
    }

    function renderRule10JoinConfig() {
        if (!els.rule10JoinConfigGrid) return;

        const availableTables = Array.from(new Set(state.detectedTables || []));
        const rows = state.rule10JoinConfig.map((item, index) => `
            <tr>
                <td>${index + 1}</td>
                <td>${escapeHtml(item.datasetLabel)}</td>
                <td>
                    <select class="rule10-join-table" data-index="${index}">
                        <option value="">Select detected table</option>
                        ${availableTables.map(table => `
                            <option value="${escapeHtml(table)}" ${String(table).toLowerCase() === String(item.tableName).toLowerCase() ? 'selected' : ''}>${escapeHtml(table)}</option>`).join('')}
                    </select>
                </td>
                <td>
                    ${(item.keyColumns || []).map((selectedColumn, columnIndex) => {
                        const columnState = getRule10ColumnOptions(item.tableName, selectedColumn);
                        return `
                            <div style="margin-bottom:8px">
                                <label style="display:block;font-size:12px;margin-bottom:4px">Key Column ${columnIndex + 1}</label>
                                <select class="rule10-join-column" data-index="${index}" data-column-index="${columnIndex}" ${columnState.loaded ? '' : 'disabled'}>
                                    ${columnState.options.map(option => `
                                        <option value="${escapeHtml(option)}" ${String(option).toLowerCase() === String(selectedColumn).toLowerCase() ? 'selected' : ''}>${escapeHtml(option)}</option>`).join('')}
                                </select>
                            </div>`;
                    }).join('')}
                </td>
                <td>${escapeHtml((item.compositeKeyFields || []).join(', ') || '-')}</td>
            </tr>`).join('');

        els.rule10JoinConfigGrid.innerHTML = `
            <table class="data-table">
                <thead>
                    <tr><th>#</th><th>Dataset</th><th>Selected Table</th><th>Key Column Selection</th><th>Composite Keys</th></tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>`;

        document.querySelectorAll('.rule10-join-table').forEach(select => {
            select.addEventListener('change', async event => {
                const index = Number(event.target.dataset.index);
                if (!Number.isNaN(index) && state.rule10JoinConfig[index]) {
                    state.rule10JoinConfig[index].tableName = event.target.value;
                    try {
                        const columns = await loadColumnsForTable(event.target.value);
                        state.rule10JoinConfig[index].availableColumns = [...columns];
                        state.rule10JoinConfig[index].keyColumns = state.rule10JoinConfig[index].keyColumns.map((selected, keyIndex) =>
                            columns.includes(selected) ? selected : (columns[keyIndex] || columns[0] || selected));
                        setAlert(els.configOutput, 'success', `Loaded ${columns.length} available columns for ${event.target.value}. You can now choose any of them under Key Column.`);
                    } catch (error) {
                        setAlert(els.configOutput, 'error', error.message || `Could not load columns for ${event.target.value}.`);
                    }
                    renderRule10JoinConfig();
                }
            });
        });

        document.querySelectorAll('.rule10-join-column').forEach(select => {
            select.addEventListener('change', event => {
                const index = Number(event.target.dataset.index);
                const columnIndex = Number(event.target.dataset.columnIndex);
                if (!Number.isNaN(index) && !Number.isNaN(columnIndex) && state.rule10JoinConfig[index]?.keyColumns[columnIndex] !== undefined) {
                    state.rule10JoinConfig[index].keyColumns[columnIndex] = event.target.value;
                }
            });
        });
    }

    function getRequest() {
        const selectedColumns = getSelectedColumns();
        const joinTable = code => (state.rule10JoinConfig || []).find(item => item.datasetCode === code)?.tableName || '';
        return {
            clientId: parseInt(els.clientId?.value || '0', 10) || 0,
            runId: state.currentRunId,
            ruleNumber,
            server: els.server?.value.trim() || '',
            database: els.database?.value || '',
            driver: els.driver?.value || 'ODBC Driver 17 for SQL Server',
            qualTable: ruleNumber === 10 ? (joinTable('dbo_QUAL') || 'dbo_QUAL') : ((els.qualTable?.value || '').trim()),
            studTable: ruleNumber === 10 ? (joinTable('dbo_STUD') || 'dbo_STUD') : ((els.studTable?.value || '').trim()),
            cregTable: ruleNumber === 10 ? (joinTable('dbo_CREG') || 'dbo_CREG') : ((els.cregTable?.value || '').trim()),
            crseTable: ruleNumber === 10 ? (joinTable('dbo_CRSE') || 'dbo_CRSE') : ((els.crseTable?.value || '').trim()),
            qualColumn: selectedColumns.qualColumn,
            studColumn: selectedColumns.studColumn,
            cregColumn: selectedColumns.cregColumn,
            crseColumn: selectedColumns.crseColumn,
            ruleParameterJson: getRuleParameterJson(),
            rule10JoinConfigJson: ruleNumber === 10 ? JSON.stringify(state.rule10JoinConfig || []) : ''
        };
    }

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role);
        const normalizedSystemRole = normalizeRole(currentSystemRole);
        const hasUnsavedValidation = !!state.summary && (!!state.hasPendingValidation || (!state.currentRunId && !state.isWorkspaceSaved));
        const canEdit = !isResultsOnlyRole && (normalizedSystemRole === 'dataanalyst' || normalizedRole === 'dataanalyst' || hasUnsavedValidation);
        const canSign = !state.hasPendingValidation && !!state.currentRunId && !!state.isWorkspaceSaved &&
            (normalizedRole === 'dataanalyst' || (state.resultsVisible && (normalizedRole === 'manager' || normalizedRole === 'director')));
        const signoffLocked = !!state.currentUserHasSignedOff;

        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions', '.action-bar'], signoffLocked, {
            allow: ['#downloadAllBtn', '#downloadExcelBtn', '#downloadCsvBtn', '#downloadSqlBtn', '#removeSignoffBtn']
        });
        window.ruleWorkspaceUi.applyStates([
            { target: 'connectBtn', disabled: !canEdit || signoffLocked },
            { target: 'verifyBtn', disabled: !canEdit || signoffLocked },
            { target: 'runBtn', disabled: !canEdit || signoffLocked },
            { target: 'sqlBtn', disabled: !canEdit || signoffLocked },
            { target: 'rScriptBtn', disabled: !canEdit || signoffLocked },
            { target: els.beginEditBtn, disabled: signoffLocked || !canEdit || !state.currentRunId || state.hasPendingValidation },
            { target: els.saveWorkspaceBtn, disabled: signoffLocked || !canEdit || !hasUnsavedValidation },
            { target: els.signoffBtn, disabled: signoffLocked || !canSign, text: state.currentUserHasSignedOff ? `Signed Off as ${role || currentSystemRole}` : 'Save Signoff' },
            { target: els.removeSignoffBtn, show: state.currentUserHasSignedOff, display: '', disabled: !state.currentUserHasSignedOff },
            { target: els.workspaceSignoffComment, disabled: signoffLocked || !canSign },
            { target: els.downloadAllBtn, disabled: !state.summary }
        ]);
        applyWorkspaceAccessMode(canEdit);
    }

    function applyWorkspaceAccessMode(canEditWorkspace) {
        ['body-connection', 'body-config'].forEach(function(id) {
            var body = document.getElementById(id);
            if (!body) return;
            body.style.opacity = canEditWorkspace ? '' : '0.45';
            body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
            body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
                el.disabled = !canEditWorkspace;
            });
        });
    }

    function destroyCharts() {
        Object.values(state.chartInstances || {}).forEach(chart => {
            if (chart && typeof chart.destroy === 'function') chart.destroy();
        });
        state.chartInstances = {};
    }

    function renderAnalysis() {
        if (!state.summary) {
            els.analysisPane.innerHTML = '<div class="empty-card"><p>No integrity results loaded.</p></div>';
            return;
        }
        const s = state.summary;
        const statCards = [];
        if (ruleNumber === 10) {
            statCards.push(`<div class="stat-card"><div class="stat-card__label">Documented Datasets</div><div class="stat-card__value">${formatNumber(s.totalChecks)}</div></div>`);
        } else {
            if (requiredTables.qual) statCards.push(`<div class="stat-card"><div class="stat-card__label">QUAL Rows</div><div class="stat-card__value">${formatNumber(s.qualRecordCount)}</div></div>`);
            if (requiredTables.stud) statCards.push(`<div class="stat-card"><div class="stat-card__label">STUD Rows</div><div class="stat-card__value">${formatNumber(s.studRecordCount)}</div></div>`);
            if (requiredTables.creg) statCards.push(`<div class="stat-card"><div class="stat-card__label">CREG Rows</div><div class="stat-card__value">${formatNumber(s.cregRecordCount)}</div></div>`);
            if (requiredTables.crse) statCards.push(`<div class="stat-card"><div class="stat-card__label">CRSE Rows</div><div class="stat-card__value">${formatNumber(s.crseRecordCount)}</div></div>`);
        }
        statCards.push(`<div class="stat-card"><div class="stat-card__label">Passed Checks</div><div class="stat-card__value">${formatNumber(s.passedChecks)}</div></div>`);
        statCards.push(`<div class="stat-card stat-card--fail"><div class="stat-card__label">Failed Checks</div><div class="stat-card__value">${formatNumber(s.failedChecks)}</div></div>`);
        statCards.push(`<div class="stat-card stat-card--fail"><div class="stat-card__label">Total Issues</div><div class="stat-card__value">${formatNumber(s.totalIssues)}</div></div>`);
        statCards.push(`<div class="stat-card"><div class="stat-card__label">Overall Status</div><div class="stat-card__value">${escapeHtml(s.overallStatusText || s.status || '')}</div></div>`);
        const rows = (s.controlSummaries || []).map(item => `
            <tr>
                <td>${item.ruleId}</td>
                <td>${escapeHtml(item.controlLabel)}</td>
                <td>${escapeHtml(item.tableName || '')}</td>
                <td>${escapeHtml(item.criteriaText || '')}</td>
                <td>${formatNumber(item.errorCount)}</td>
                <td>${escapeHtml(item.severity || '')}</td>
                <td>${escapeHtml(item.status || '')}</td>
            </tr>`).join('');

        els.analysisPane.innerHTML = `
            <div class="stats-grid" style="margin-bottom:24px">
                ${statCards.join('')}
            </div>
            <div class="card" style="padding:20px">
                <h3 class="section-title" style="margin-top:0">Rule Summary</h3>
                <table class="data-table">
                    <thead>
                        <tr><th>Rule</th><th>Name</th><th>Table Scope</th><th>Criteria</th><th>Issues</th><th>Severity</th><th>Status</th></tr>
                    </thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
    }

    function renderResults() {
        if (!state.summary) {
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No integrity results loaded.</p></div>';
            return;
        }

        const rows = state.summary.reviewRows || [];
        const filtered = rows.filter(row =>
            state.resultFilter === 'ALL' || String(row.validationResult || '').toUpperCase() === state.resultFilter);
        const resultOptions = [
            `<option value="ALL" ${state.resultFilter === 'ALL' ? 'selected' : ''}>All results</option>`,
            `<option value="PASS" ${state.resultFilter === 'PASS' ? 'selected' : ''}>PASS</option>`,
            `<option value="FAIL" ${state.resultFilter === 'FAIL' ? 'selected' : ''}>FAIL</option>`
        ].join('');
        const previewNotice = state.summary.isPreviewOnly
            ? `The browser shows a 10-row pass/fail sample across the integrity checks. Excel and CSV include the full 100% result set. Loaded rows: ${formatNumber(state.summary.displayedCount || filtered.length)} of ${formatNumber(state.summary.totalValidated || filtered.length)}.`
            : 'The browser shows the saved result sample. Excel and CSV include the full 100% result set.';
        const sections = (state.summary.controlSummaries || [])
            .filter(shouldRenderIntegritySection)
            .sort((left, right) => Number(left.ruleId || 0) - Number(right.ruleId || 0))
            .map(summaryItem => renderIntegrityRuleSection(
                summaryItem,
                filtered.filter(row => Number(row.ruleId || 0) === Number(summaryItem.ruleId || 0))))
            .join('');

        els.resultsPane.innerHTML = `
            <div class="rule11-filterbar">
                <div class="field-group" style="margin:0;min-width:220px">
                    <label for="resultFilter">Result Filter</label>
                    <select id="resultFilter">${resultOptions}</select>
                </div>
            </div>
            <div class="alert alert--info" style="margin-bottom:16px">${escapeHtml(previewNotice)}</div>
            ${sections || '<div class="empty-card"><p>No integrity sections match the selected filter.</p></div>'}`;

        document.getElementById('resultFilter')?.addEventListener('change', event => {
            state.resultFilter = event.target.value;
            renderResults();
        });
    }

    function renderCharts() {
        destroyCharts();
        if (!state.summary) {
            els.chartsPane.innerHTML = `<div class="empty-card"><p>Charts will appear after running ${ruleLabel}.</p></div>`;
            return;
        }
        if (typeof Chart === 'undefined') {
            els.chartsPane.innerHTML = '<div class="empty-card"><p>Charts could not load because Chart.js is unavailable.</p></div>';
            return;
        }

        const labels = (state.summary.controlSummaries || []).map(item => `R${item.ruleId}`);
        const issueCounts = (state.summary.controlSummaries || []).map(item => Number(item.errorCount || 0));
        els.chartsPane.innerHTML = `
            <div class="card" style="padding:20px">
                <h3 class="section-title" style="margin-top:0">Integrity Visual Summary</h3>
                <div class="charts-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px">
                    <div class="chart-card"><h4>Issues by Rule</h4><canvas id="rule10IssuesChart"></canvas></div>
                    <div class="chart-card"><h4>Passed vs Failed Checks</h4><canvas id="rule10StatusChart"></canvas></div>
                </div>
            </div>`;

        state.chartInstances.issues = new Chart(document.getElementById('rule10IssuesChart'), {
            type: 'bar',
            data: {
                labels,
                datasets: [{ label: 'Issues', data: issueCounts, backgroundColor: issueCounts.map(x => x > 0 ? '#F44336' : '#4CAF50') }]
            },
            options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
        });

        state.chartInstances.status = new Chart(document.getElementById('rule10StatusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Passed', 'Failed'],
                datasets: [{ data: [Number(state.summary.passedChecks || 0), Number(state.summary.failedChecks || 0)], backgroundColor: ['#4CAF50', '#F44336'] }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    }

    function applySummary(summary, options = {}) {
        state.summary = summary;
        if (!options.fromWorkspace) state.currentRunId = summary?.savedRunId || state.currentRunId;
        state.currentStatus = summary?.status || state.currentStatus;
        state.resultsVisible = !!summary || state.resultsVisible;

        if (!summary) {
            els.analysisPane.innerHTML = '<div class="empty-card"><p>No integrity results loaded.</p></div>';
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No integrity results loaded.</p></div>';
            setStatusBadge('', 'pass');
            updateWorkspaceButtons();
            return;
        }

        if (state.hasPendingValidation) {
            els.workspaceRunState.textContent = `Pending save | ${summary.status || 'Completed'}`;
            els.workspaceRunLabel.textContent = `Unsaved ${ruleLabel} validation`;
            els.workspaceStatusLabel.textContent = 'Pending Save';
        } else {
            els.workspaceRunState.textContent = state.currentRunId ? `Run #${state.currentRunId} | ${state.currentStatus || 'Completed'}` : 'No saved run loaded';
            els.workspaceRunLabel.textContent = state.currentRunId ? `Run #${state.currentRunId}` : 'No saved run yet';
            els.workspaceStatusLabel.textContent = state.currentStatus || '-';
        }

        if (!els.workspaceRoleLabel.textContent?.trim()) els.workspaceRoleLabel.textContent = state.currentUserEngagementRole || currentSystemRole || '-';
        setStatusBadge(summary.status, summary.failedChecks > 0 ? 'fail' : 'pass');
        renderAnalysis();
        renderResults();
        renderCharts();
        updateWorkspaceButtons();
    }

    function applyWorkspace(workspace, resultsVisible, preserveExistingSummary = false) {
        if (!workspace) {
            state.currentRunId = null;
            state.currentStatus = '';
            state.currentUserEngagementRole = '';
            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;
            state.resultsVisible = false;
            state.hasPendingValidation = false;
            els.workspaceRunState.textContent = 'No saved run loaded';
            els.workspaceRunLabel.textContent = 'No saved run yet';
            els.workspaceStatusLabel.textContent = '-';
            els.workspaceEditedLabel.textContent = '-';
            applyRuleParameterUi('');
            setWorkspaceState(`No saved ${ruleLabel} workspace exists for this engagement yet.`, 'info');
            if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
            return;
        }

        state.clientId = workspace.clientId || state.clientId;
        state.currentRunId = workspace.runId || null;
        state.currentStatus = workspace.currentStatus || '';
        state.currentUserEngagementRole = workspace.currentUserEngagementRole || currentSystemRole || '';
        state.currentUserHasSignedOff = !!workspace.currentUserHasSignedOff;
        state.isWorkspaceSaved = !!workspace.isWorkspaceSaved;
        state.hasDataAnalystSignoff = !!workspace.hasDataAnalystSignoff;
        state.resultsVisible = !!resultsVisible;
        state.hasPendingValidation = false;
        state.detectedTables = [];
        state.tableColumnsCache = {};

        if (els.server) els.server.value = workspace.server || '';
        if (els.driver) els.driver.value = workspace.driver || 'ODBC Driver 17 for SQL Server';
        if (els.database) {
            els.database.innerHTML = workspace.database ? `<option value="${workspace.database}">${workspace.database}</option>` : '';
            els.database.value = workspace.database || '';
        }

        state.pendingWorkspaceDatabase = workspace.database || '';
        state.pendingWorkspaceSelections = {
            qualTable: workspace.qualTable || 'dbo_QUAL',
            studTable: workspace.studTable || 'dbo_STUD',
            cregTable: workspace.cregTable || 'dbo_CREG',
            crseTable: workspace.crseTable || 'dbo_CRSE',
            qualColumn: workspace.qualColumn,
            studColumn: workspace.studColumn,
            cregColumn: workspace.cregColumn,
            crseColumn: workspace.crseColumn,
            ruleParameterJson: workspace.ruleParameterJson || ''
        };
        applyRuleParameterUi(workspace.ruleParameterJson || '');

        if (ruleNumber === 10) {
            try {
                state.pendingWorkspaceSelections.rule10JoinConfig = workspace.rule10JoinConfigJson
                    ? JSON.parse(workspace.rule10JoinConfigJson)
                    : rule10DatasetTemplates.map(item => ({ ...item }));
            } catch {
                state.pendingWorkspaceSelections.rule10JoinConfig = rule10DatasetTemplates.map(item => ({ ...item }));
            }
            state.rule10JoinConfig = rule10DatasetTemplates.map(item => ({ ...item }));
            renderRule10JoinConfig();
        } else {
            clearRuleTableSelectors();
            clearRuleColumnSelectors();
        }

        els.workspaceRunState.textContent = workspace.runId ? `Run #${workspace.runId}` : 'No saved run loaded';
        els.workspaceRunLabel.textContent = workspace.runId ? `${ruleLabel} Run #${workspace.runId}` : 'No saved run yet';
        els.workspaceStatusLabel.textContent = workspace.currentStatus || '-';
        els.workspaceEditedLabel.textContent = workspace.lastEditedAt ? new Date(workspace.lastEditedAt).toLocaleString() : '-';
        els.workspaceRoleLabel.textContent = workspace.currentUserEngagementRole || currentSystemRole || '-';
        els.workspaceSignoffComment.value = workspace.currentUserSignoffComment || '';

        if (!resultsVisible) {
            setWorkspaceState(`Saved ${ruleLabel} results are not available for your engagement role.`, 'info');
            if (!preserveExistingSummary) applySummary(null); else updateWorkspaceButtons();
            return;
        }

        setWorkspaceState(
            workspace.summary
                ? 'Saved workspace loaded. The last analyst configuration and results are ready.'
                : `${ruleLabel} workspace loaded. Run the validation to generate results.`,
            'success');

        if (workspace.summary) applySummary(workspace.summary, { fromWorkspace: true });
        else if (!preserveExistingSummary) applySummary(null);
        else updateWorkspaceButtons();
    }

    async function loadWorkspace() {
        state.clientId = Number(els.clientId?.value || 0);
        if (!state.clientId) {
            applyWorkspace(null, false);
            return;
        }

        const data = await window.fetchJsonWithProgress(`${apiBasePath}/GetWorkspaceState?clientId=${state.clientId}`, { method: 'GET' });
        if (!data.success) throw new Error(data.error || 'Failed to load workspace.');
        applyWorkspace(data.workspace, data.resultsVisible);
    }

    async function connect() {
        const server = els.server?.value?.trim();
        if (!server) throw new Error('Enter the SQL Server name first.');

        showSpinner('Loading databases...');
        try {
            resetDetectedMetadata();
            const data = await postJson(`${apiBasePath}/GetDatabases`, { server, driver: els.driver.value });
            if (!data.success) throw new Error(data.error || 'Connection failed.');

            const preferredDatabase = state.pendingWorkspaceDatabase || els.database.value || '';
            els.database.innerHTML = '<option value="">Select database</option>';
            data.databases.forEach(db => {
                const option = document.createElement('option');
                option.value = db;
                option.textContent = db;
                els.database.appendChild(option);
            });
            if (preferredDatabase && (data.databases || []).includes(preferredDatabase)) {
                els.database.value = preferredDatabase;
            }

            setAlert(els.connectionOutput, 'success', `Connected. Found ${data.databases.length} database(s).`);
            if (preferredDatabase && els.database.value) await loadTables();
        } finally {
            hideSpinner();
        }
    }

    async function loadTables() {
        if (!els.database.value) {
            resetDetectedMetadata();
            setAlert(els.configOutput, 'info', 'Select a database to auto-detect tables and columns.');
            return;
        }

        resetDetectedMetadata('Loading tables from the selected database...');
        const data = await postJson(`${apiBasePath}/GetTables`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value
        });

        if (!data.success) throw new Error(data.error || 'Could not load tables.');
        applyDetectedTables(data);
        setAlert(els.configOutput, 'success', `Detected ${data.tables.length} table(s).`);
    }

    async function verifyTables() {
        showSpinner('Verifying integrity tables...');
        try {
            const data = await postJson(`${apiBasePath}/VerifyTables`, getRequest());
            if (!data.success) throw new Error(data.error || 'Verification failed.');

            if (ruleNumber === 10) {
                const rows = (data.joinDatasets || []).map(item => `
                    <tr>
                        <td>${escapeHtml(item.datasetLabel)}</td>
                        <td>${escapeHtml(item.tableName)}</td>
                        <td>${escapeHtml((item.requiredColumns || []).join(', '))}</td>
                        <td>${escapeHtml((item.missingColumns || []).join(', ') || '-')}</td>
                        <td>${escapeHtml(item.status || '')}</td>
                    </tr>`).join('');

                els.configOutput.innerHTML = `
                    <div class="alert alert--${(data.joinDatasets || []).some(item => (item.missingColumns || []).length > 0) ? 'warning' : 'success'}">
                        Documented join datasets verified against the selected tables.
                    </div>
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>Dataset</th><th>Selected Table</th><th>Required Key Columns</th><th>Missing Columns</th><th>Status</th></tr></thead>
                            <tbody>${rows}</tbody>
                        </table>
                    </div>`;
                return;
            }

            const pieces = [];
            if (requiredTables.qual) pieces.push(`QUAL rows: <strong>${formatNumber(data.qualRecordCount)}</strong>`);
            if (requiredTables.stud) pieces.push(`STUD rows: <strong>${formatNumber(data.studRecordCount)}</strong>`);
            if (requiredTables.creg) pieces.push(`CREG rows: <strong>${formatNumber(data.cregRecordCount)}</strong>`);
            if (requiredTables.crse) pieces.push(`CRSE rows: <strong>${formatNumber(data.crseRecordCount)}</strong>`);
            els.configOutput.innerHTML = `<div class="alert alert--success">${pieces.join(' | ')}</div>`;
        } finally {
            hideSpinner();
        }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) {
            setWorkspaceState('Select the approved engagement assigned to you before running this rule.', 'warning');
            return;
        }

        try {
            showSpinner(`Running ${ruleLabel} integrity check...`);
            const data = await postJson(`${apiBasePath}/RunValidation`, request);
            if (!data.success) throw new Error(data.error || `${ruleLabel} failed.`);

            state.hasPendingValidation = true;
            state.currentRunId = null;
            state.currentStatus = data.status || '';
            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;
            state.resultsVisible = true;
            state.currentUserEngagementRole = state.currentUserEngagementRole || currentSystemRole || 'DataAnalyst';
            applySummary(data);

            setWorkspaceState(`${ruleLabel} completed. Failed checks: ${formatNumber(data.failedChecks)} | Total issues: ${formatNumber(data.totalIssues)}. The current run is already in the system database. Click Save Workspace before signoff or visibility to other users.`, 'success');
        } finally {
            hideSpinner();
        }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try {
            const data = await postJson(`${apiBasePath}/GenerateSql`, getRequest());
            if (!data.success) throw new Error(data.error || 'SQL generation failed.');
            state.sql = data.sql || '';
            els.sqlText.value = state.sql;
            setActiveTab('sql');
        } finally {
            hideSpinner();
        }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try {
            const data = await postJson(`${apiBasePath}/BeginWorkspaceEdit`, getRequest());
            if (!data.success) throw new Error(data.error || 'Could not begin editing.');
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible') ? !!data.resultsVisible : !!data.workspace?.resultsVisible;
            applyWorkspace(data.workspace, workspaceResultsVisible, true);
            setWorkspaceState(data.message || 'Workspace ready for editing.', 'warning');
        } finally {
            hideSpinner();
        }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try {
            const data = await postJson(`${apiBasePath}/SaveWorkspace`, getRequest());
            if (!data.success) throw new Error(data.error || 'Could not save workspace.');
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible') ? !!data.resultsVisible : !!data.workspace?.resultsVisible || state.resultsVisible;
            state.hasPendingValidation = false;
            applyWorkspace(data.workspace, workspaceResultsVisible, true);
            setWorkspaceState(data.message || 'Workspace saved.', 'success');
        } finally {
            hideSpinner();
        }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try {
            const data = await postJson(`${apiBasePath}/SignOffWorkspace`, {
                clientId: Number(els.clientId?.value || 0),
                runId: state.currentRunId,
                comment: els.workspaceSignoffComment?.value || ''
            });
            if (!data.success) throw new Error(data.error || 'Could not save signoff.');
            applyWorkspace(data.workspace, !!data.resultsVisible, true);
            setWorkspaceState(data.message || 'Signoff saved.', 'success');
        } finally {
            hideSpinner();
        }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try {
            const data = await postJson(`${apiBasePath}/RemoveWorkspaceSignoff`, {
                clientId: Number(els.clientId?.value || 0),
                runId: state.currentRunId,
                comment: ''
            });
            if (!data.success) throw new Error(data.error || 'Could not remove signoff.');
            applyWorkspace(data.workspace, !!data.resultsVisible, true);
            setWorkspaceState(data.message || 'Signoff removed.', 'warning');
        } finally {
            hideSpinner();
        }
    }

    async function downloadAll() {
        if (!state.summary) return;
        if (document.getElementById('chkExcel')?.checked) await downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, `Rule${ruleNumber}_Integrity_Check.xlsx`);
        if (document.getElementById('chkCsv')?.checked) await downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, `Rule${ruleNumber}_Integrity_Check.csv`);
        if (document.getElementById('chkSql')?.checked) await downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), `Rule${ruleNumber}_Integrity_Check.sql`);
    }

    document.getElementById('connectBtn')?.addEventListener('click', () => connect().catch(err => setAlert(els.connectionOutput, 'error', err.message)));
    document.getElementById('verifyBtn')?.addEventListener('click', () => verifyTables().catch(err => setAlert(els.configOutput, 'error', err.message)));
    document.getElementById('runBtn')?.addEventListener('click', () => runValidation().catch(err => setWorkspaceState(err.message, 'error')));
    document.getElementById('sqlBtn')?.addEventListener('click', () => generateSql().catch(err => setWorkspaceState(err.message, 'error')));
    document.getElementById('rScriptBtn')?.addEventListener('click', () => generateRScript().catch(err => setWorkspaceState(err.message, 'error')));
        async function generateRScript() {
        showSpinner('Generating R script...');
        try {
            const data = await postJson(`${apiBasePath}/GenerateRScript`, getRequest());
            if (!data.success) throw new Error(data.error || 'R script generation failed.');
            const pane = document.getElementById('rscriptPane');
            pane.innerHTML = `<div style="padding:8px 0 8px"><button class="btn btn-sm btn-primary" onclick="(function(){const e=document.getElementById('rCode');if(e)navigator.clipboard.writeText(e.textContent)})()">Copy</button></div><pre id="rCode" style="white-space:pre-wrap;font-family:monospace;font-size:12px;padding:12px;overflow:auto;max-height:600px">${escapeHtml(data.sql)}</pre>`;
            setActiveTab('rscript');
        } finally {
            hideSpinner();
        }
    }
document.getElementById('downloadAllBtn')?.addEventListener('click', () => downloadAll().catch(err => setWorkspaceState(err.message, 'error')));
    document.getElementById('downloadExcelBtn')?.addEventListener('click', () => downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, `Rule${ruleNumber}_Integrity_Check.xlsx`));
    document.getElementById('downloadCsvBtn')?.addEventListener('click', () => downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, `Rule${ruleNumber}_Integrity_Check.csv`));
    document.getElementById('downloadSqlBtn')?.addEventListener('click', () => downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), `Rule${ruleNumber}_Integrity_Check.sql`));
    els.beginEditBtn?.addEventListener('click', () => beginEdit().catch(err => setWorkspaceState(err.message, 'error')));
    els.saveWorkspaceBtn?.addEventListener('click', () => saveWorkspace().catch(err => setWorkspaceState(err.message, 'error')));
    els.signoffBtn?.addEventListener('click', () => signoffWorkspace().catch(err => setWorkspaceState(err.message, 'error')));
    els.removeSignoffBtn?.addEventListener('click', () => removeWorkspaceSignoff().catch(err => setWorkspaceState(err.message, 'error')));
    els.clientId?.addEventListener('change', () => loadWorkspace().catch(err => setWorkspaceState(err.message, 'error')));
    els.server?.addEventListener('input', () => {
        els.database.innerHTML = '<option value="">Connect first to load databases</option>';
        resetDetectedMetadata();
        setAlert(els.connectionOutput, 'info', 'Server changed. Click Connect to load the databases for that server.');
        setAlert(els.configOutput, 'info', 'Select a database after connecting to auto-detect tables and columns.');
    });
    els.driver?.addEventListener('change', () => {
        els.database.innerHTML = '<option value="">Connect first to load databases</option>';
        resetDetectedMetadata();
        setAlert(els.connectionOutput, 'info', 'Driver changed. Click Connect to reload the databases for that connection.');
        setAlert(els.configOutput, 'info', 'Select a database after connecting to auto-detect tables and columns.');
    });
    els.database?.addEventListener('change', () => loadTables().catch(err => setAlert(els.configOutput, 'error', err.message)));
    [els.qualTable, els.studTable, els.cregTable, els.crseTable].filter(Boolean).forEach(select => {
        select.addEventListener('change', () => refreshRuleColumns().catch(err => setAlert(els.configOutput, 'error', err.message)));
    });
    [els.ruleColumn, els.studContextColumn, els.studLinkColumn, els.qualLinkColumn, els.cregContextColumn, els.cregLinkColumn, els.crseLinkColumn, els.cregStudentLinkColumn, els.studStudentLinkColumn, els.cregGhostContextColumn, els.studGhostContextColumn]
        .filter(Boolean)
        .forEach(select => select.addEventListener('change', () => syncRuleNarrative()));
    els.ruleValueInput?.addEventListener('input', () => syncRuleNarrative());

    if (els.database && !els.database.options.length) {
        els.database.innerHTML = '<option value="">Connect first to load databases</option>';
    }
    applyRuleParameterUi('');
    resetDetectedMetadata();
    syncRuleNarrative();
    loadWorkspace().catch(() => {});
    renderAnalysis();
    renderResults();
    renderCharts();
    updateWorkspaceButtons();
        const __ruleRApiBase = typeof apiBasePath !== 'undefined'
        ? apiBasePath
        : (typeof apiBase !== 'undefined'
            ? apiBase
            : (typeof API !== 'undefined'
                ? API
                : ((window.location.pathname.match(/^\/Rule\d+/i) || [null])[0])));
    const __ruleRRequestBuilder = typeof getRequest === 'function' ? getRequest : (typeof buildRequest === 'function' ? buildRequest : (typeof buildReq === 'function' ? buildReq : null));
    const __ruleRPost = typeof postJson === 'function' ? postJson : (typeof post === 'function' ? post : null);
    if (__ruleRApiBase && __ruleRRequestBuilder && __ruleRPost && window.ruleRScriptUi) {
        window.ruleRScriptUi.install({
            apiBase: __ruleRApiBase,
            requestBuilder: __ruleRRequestBuilder,
            postJson: __ruleRPost,
            showSpinner: typeof showSpinner === 'function' ? showSpinner : (typeof spin === 'function' ? spin : null),
            hideSpinner: typeof hideSpinner === 'function' ? hideSpinner : (typeof unspin === 'function' ? unspin : null)
        });
    }
})();
</script>
