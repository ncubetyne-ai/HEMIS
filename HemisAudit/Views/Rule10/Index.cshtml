@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    var ruleNumber = ViewBag.RuleNumber is int currentRuleNumber ? currentRuleNumber : 10;
    var ruleMetadata = ViewBag.RuleMetadata as HemisAudit.Helpers.IntegrityRuleMetadata;
    var ruleLabel = ruleMetadata?.RuleLabel ?? $"Rule {ruleNumber}";
    var ruleTitle = ruleMetadata?.RuleTitle ?? "Integrity Check";
    ViewData["Title"] = $"{ruleLabel} - {ruleTitle}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int currentClientId ? currentClientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
    var requiredTables = new HashSet<string>(ruleMetadata?.RequiredTables ?? Array.Empty<string>(), StringComparer.OrdinalIgnoreCase);
    var needsQualTable = requiredTables.Contains("QUAL");
    var needsStudTable = requiredTables.Contains("STUD");
    var needsCregTable = requiredTables.Contains("CREG");
    var needsCrseTable = requiredTables.Contains("CRSE");
}

<style>
.integrity-results-shell {
    border: 1px solid #d7e1ec;
    border-radius: 16px;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 18px 40px rgba(15, 23, 42, .08);
}

.integrity-results-shell .table-wrapper {
    overflow: auto;
    max-width: 100%;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
}

.integrity-results-table {
    width: max-content;
    min-width: 100%;
    table-layout: auto;
    border-collapse: collapse;
    font-size: 13px;
}

.integrity-results-table thead th {
    position: static;
    background: #e6edf5;
    color: #17324d;
    border-bottom: 1px solid #c7d4e2;
    border-right: 1px solid #d6e0ea;
    text-transform: none;
    letter-spacing: 0;
    white-space: nowrap;
}

.integrity-results-table td {
    border-bottom: 1px solid #e8eef5;
    border-right: 1px solid #eef3f8;
    white-space: nowrap;
    vertical-align: top;
    color: #18324a;
}

.integrity-results-table tbody tr:nth-child(even) td {
    background: #fbfdff;
}

.integrity-results-table tbody tr.integrity-row--pass td {
    background: #f3fbf5;
}

.integrity-results-table tbody tr.integrity-row--fail td {
    background: #fff8eb;
}

.integrity-cell--rule {
    font-weight: 800;
    min-width: 72px;
}

.integrity-cell--result {
    min-width: 120px;
    text-align: center;
}

.integrity-cell--medium {
    min-width: 150px;
}

.integrity-cell--code {
    font-family: Consolas, "Courier New", monospace;
}

.integrity-cell--wrap {
    white-space: normal !important;
    min-width: 220px;
    max-width: 360px;
}

.integrity-cell--empty {
    color: #7b8794;
    font-style: italic;
}

.integrity-result-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 70px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .02em;
}

.integrity-result-badge--pass {
    background: #e8f7ec;
    color: #19713e;
}

.integrity-result-badge--fail {
    background: #fdecec;
    color: #b42318;
}

.integrity-results-footer {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px;
    font-size: 12px;
    color: #667085;
    background: #f8fafc;
    border-top: 1px solid #e8eef5;
    flex-wrap: wrap;
}
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>
            @ruleLabel runs a 100% population integrity check using only the HEMIS tables required for this control.
            No sampling is used.
        </small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R@ruleNumber</div>
        <div>
            <h1 class="rule-header__title">HEMIS @ruleLabel: @ruleTitle</h1>
            <p class="rule-header__sub">@(ruleMetadata?.DetailedDescription ?? "Data quality and referential integrity verification.")</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                    <span class="acc-icon">DB</span>
                    <span>Database Connection</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-connection">
                    <div class="form-grid">
                        <div class="field-group">
                            <label for="server">Server Name</label>
                            <input id="server" type="text" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                        </div>
                        <div class="field-group">
                            <label for="driver">Driver</label>
                            <select id="driver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group">
                            <label for="database">Database</label>
                            <select id="database"></select>
                        </div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    </div>
                    <div id="connectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                    <span class="acc-icon">CF</span>
                    <span>Integrity Scope</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-config" style="display:none">
                    <div class="info-box info-box--red">
                        <strong>@ruleLabel logic:</strong><br />
                        <span id="ruleLogicText">@(ruleMetadata?.DetailedDescription ?? ruleMetadata?.ShortDescription ?? "This rule tests 100% of the population.")</span><br />
                        <span><strong>Audit criteria:</strong> <span id="ruleCriteriaText">@(ruleMetadata?.CriteriaText ?? "Integrity check")</span></span><br />
                        <span>The rule tests 100% of the population and captures all failing exceptions.</span>
                    </div>
                    @if (ruleNumber == 10)
                    {
                        <div class="card" style="padding:20px;margin-top:16px">
                            <h3 class="section-title" style="margin-top:0">Rule 10 Join Datasets</h3>
                            <div class="alert alert--info" style="margin-bottom:16px">
                                Select the source table for each documented dataset, then choose the key column values from that selected table. The module will confirm whether the selected key columns exist on the selected table.
                            </div>
                            <div id="rule10JoinConfigGrid" class="table-wrap"></div>
                        </div>
                    }
                    else
                    {
                        <div class="form-grid">
                            <div class="field-group" style="display:@(needsQualTable ? "" : "none")">
                                <label for="qualTable">QUAL Table</label>
                                <select id="qualTable"></select>
                            </div>
                            <div class="field-group" style="display:@(needsStudTable ? "" : "none")">
                                <label for="studTable">STUD Table</label>
                                <select id="studTable"></select>
                            </div>
                            <div class="field-group" style="display:@(needsCregTable ? "" : "none")">
                                <label for="cregTable">CREG Table</label>
                                <select id="cregTable"></select>
                            </div>
                            <div class="field-group" style="display:@(needsCrseTable ? "" : "none")">
                                <label for="crseTable">CRSE Table</label>
                                <select id="crseTable"></select>
                            </div>
                            @if (ruleNumber == 1 || ruleNumber == 2 || ruleNumber == 3 || ruleNumber == 4 || ruleNumber == 5 || ruleNumber == 6)
                            {
                                <div class="field-group">
                                    <label for="ruleColumn">Check Column</label>
                                    <select id="ruleColumn"></select>
                                </div>
                            }
                            @if (ruleNumber == 5)
                            {
                                <div class="field-group" id="ruleValueField">
                                    <label for="ruleValueInput" id="ruleValueLabel">Rule Value</label>
                                    <input id="ruleValueInput" type="text" />
                                </div>
                            }
                            @if (ruleNumber == 7)
                            {
                                <div class="field-group">
                                    <label for="studContextColumn">STUD Student Number Column</label>
                                    <select id="studContextColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="studLinkColumn">STUD Link Column</label>
                                    <select id="studLinkColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="qualLinkColumn">QUAL Link Column</label>
                                    <select id="qualLinkColumn"></select>
                                </div>
                            }
                            @if (ruleNumber == 8)
                            {
                                <div class="field-group">
                                    <label for="cregContextColumn">CREG Student Number Column</label>
                                    <select id="cregContextColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="cregLinkColumn">CREG Link Column</label>
                                    <select id="cregLinkColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="crseLinkColumn">CRSE Link Column</label>
                                    <select id="crseLinkColumn"></select>
                                </div>
                            }
                            @if (ruleNumber == 9)
                            {
                                <div class="field-group">
                                    <label for="cregStudentLinkColumn">CREG Student Number Column</label>
                                    <select id="cregStudentLinkColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="studStudentLinkColumn">STUD Student Number Column</label>
                                    <select id="studStudentLinkColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="cregGhostContextColumn">CREG Course Column</label>
                                    <select id="cregGhostContextColumn"></select>
                                </div>
                                <div class="field-group">
                                    <label for="studGhostContextColumn">STUD Course Column</label>
                                    <select id="studGhostContextColumn"></select>
                                </div>
                            }
                        </div>
                    }
                    <div class="alert alert--info" style="margin-top:16px">
                        The module auto-detects available tables and columns after connecting to the selected database.
                    </div>
                    <div id="configOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                    <span class="acc-icon">DL</span>
                    <span>Export Options</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-downloads" style="display:none">
                    <div class="checkbox-row">
                        <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The latest @ruleLabel connection, results, and signoffs reload automatically for this engagement.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">Select an engagement to load the saved @ruleLabel workspace.</div>
        <div class="workspace-signoff-grid">
            <div><div class="text-muted-caps">Current Run</div><div id="workspaceRunLabel">No saved run yet</div></div>
            <div><div class="text-muted-caps">Status</div><div id="workspaceStatusLabel">-</div></div>
            <div><div class="text-muted-caps">Last Edited</div><div id="workspaceEditedLabel">-</div></div>
            <div><div class="text-muted-caps">Your Role</div><div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div></div>
            <div class="field-group" style="grid-column:1 / -1">
                <label for="workspaceSignoffComment">Signoff Comment</label>
                <textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
                <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            }
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove Signoff</button>
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="runBtn">Run @ruleLabel</button>
            <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
                <button type="button" class="btn btn-primary" id="rScriptBtn">Generate R Script</button>
            <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="charts">Charts</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
                <button class="tab-btn" type="button" data-tab="rscript">R Code</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="analysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="resultsPane"></div>
        <div class="tab-pane" data-tab-panel="charts" id="chartsPane"></div>
        <div class="tab-pane" data-tab-panel="sql"><textarea id="sqlText" rows="18" readonly></textarea></div>
        <div class="tab-pane" data-tab-panel="rscript" id="rscriptPane">
            <div class="empty-state" style="padding:24px;text-align:center"><p>Click "Generate R Script" to generate the R script.</p></div>
        </div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">
                Excel includes the summary and full exception detail. CSV includes the current exception detail. SQL includes the query generated for @ruleLabel.
            </div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn">Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn">CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn">SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="spinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
window.toggleAccordion = function (section) {
    const body = document.getElementById(`body-${section}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

(() => {
    const ruleNumber = @ruleNumber;
    const ruleLabel = '@ruleLabel';
    const apiBasePath = `/Rule${ruleNumber}`;
    const requiredTables = {
        qual: @(needsQualTable.ToString().ToLowerInvariant()),
        stud: @(needsStudTable.ToString().ToLowerInvariant()),
        creg: @(needsCregTable.ToString().ToLowerInvariant()),
        crse: @(needsCrseTable.ToString().ToLowerInvariant())
    };
    const ruleDefaultColumns = {
        1: { qual: '_005' },
        2: { qual: '_004' },
        3: { qual: '_001' },
        4: { crse: '_030' },
        5: { stud: '_007' },
        6: { stud: '_106' },
        7: { stud: '_001', qual: '_001' },
        8: { creg: '_030', crse: '_030' },
        9: { creg: '_007', stud: '_007' }
    };
    const rule10DatasetTemplates = [
        { datasetCode: 'dbo_CREG', datasetLabel: 'dbo_CREG', tableName: 'dbo_CREG', keyColumns: ['_030', '_001'], compositeKeyFields: ['_001+_030'] },
        { datasetCode: 'dbo_CRSE', datasetLabel: 'dbo_CRSE', tableName: 'dbo_CRSE', keyColumns: ['_030'], compositeKeyFields: [] },
        { datasetCode: 'dbo_STUD', datasetLabel: 'dbo_STUD', tableName: 'dbo_STUD', keyColumns: ['_007', '_001'], compositeKeyFields: ['_007+_001'] },
        { datasetCode: 'dbo_QUAL', datasetLabel: 'dbo_QUAL', tableName: 'dbo_QUAL', keyColumns: ['_001'], compositeKeyFields: [] },
        { datasetCode: 'dbo_CESM', datasetLabel: 'dbo_CESM', tableName: 'dbo_CESM', keyColumns: ['_001'], compositeKeyFields: [] },
        { datasetCode: 'dbo_CRED', datasetLabel: 'dbo_CRED', tableName: 'dbo_CRED', keyColumns: ['_030', '_001'], compositeKeyFields: ['_001+_030'] },
