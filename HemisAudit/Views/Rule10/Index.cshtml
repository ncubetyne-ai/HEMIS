    };

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    tabButtons.forEach(btn => btn.addEventListener('click', () => setActiveTab(btn.dataset.tab)));

    function showSpinner(message) {
        document.getElementById('spinnerMsg').textContent = message || 'Processing...';
        document.getElementById('spinner').style.display = 'flex';
    }

    function hideSpinner() {
        document.getElementById('spinner').style.display = 'none';
    }

    function setActiveTab(tab) {
        tabButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.toggle('active', pane.dataset.tabPanel === tab));
        if (tab === 'results') renderResults();
        if (tab === 'charts') renderCharts();
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatNumber(value) {
        return Number(value || 0).toLocaleString();
    }

    function renderResultBadge(result) {
        const normalized = String(result || '').toUpperCase();
        if (normalized === 'PASS') {
            return '<span class="integrity-result-badge integrity-result-badge--pass">PASS</span>';
        }

        if (normalized === 'FAIL') {
            return '<span class="integrity-result-badge integrity-result-badge--fail">FAIL</span>';
        }

        return escapeHtml(result || '-');
    }

    function readDisplayValue(values, keys) {
        const source = values || {};
        for (const key of keys) {
            const value = source[key];
            if (value !== null && value !== undefined && String(value).trim() !== '') {
                return String(value);
            }
        }

        return '';
    }

    function renderReadableValue(value, fallback = '-') {
        if (value === null || value === undefined || String(value).trim() === '') {
            return `<span class="integrity-cell--empty">${escapeHtml(fallback)}</span>`;
        }

        return escapeHtml(String(value));
    }

    function buildMixedIntegrityRows(rows) {
        return rows.map(row => {
            const values = row.displayValues || {};
            return {
                ruleId: row.ruleId,
                controlLabel: row.controlLabel || values.RULE_LABEL || `Rule ${row.ruleId}`,
                tableName: readDisplayValue(values, ['TABLE_NAME', 'DATASET']),
                fieldName: readDisplayValue(values, ['COLUMN_NAME', 'REQUIRED_KEY_COLUMNS']),
                primaryValue: readDisplayValue(values, ['COLUMN_VALUE', 'DUPLICATE_VALUE', 'LEFT_COLUMN_VALUE', 'STUDENT_COLUMN_VALUE', 'LEFT_STUDENT_COLUMN_VALUE', 'DATASET']),
                secondaryValue: readDisplayValue(values, ['EXPECTED_VALUE', 'RIGHT_COLUMN_VALUE', 'RIGHT_STUDENT_COLUMN_VALUE', 'MISSING_COLUMNS', 'DUPLICATE_COUNT']),
                detail: readDisplayValue(values, ['FINAL_RESULT_MESSAGE', 'Exception_Type']) || row.validationExplanation || '',
                validationResult: row.validationResult || ''
            };
        });
    }

    function getIntegrityCellClass(key) {
        switch (String(key || '').toUpperCase()) {
            case 'RULE':
            case 'RESULT':
                return key === 'Result' ? 'integrity-cell--result' : 'integrity-cell--rule';
            case 'CONTROL':
            case 'DETAIL':
            case 'EXPLANATION':
            case 'RESULT DETAIL':
            case 'QUALIFICATION NAME':
                return 'integrity-cell--wrap';
            case 'TABLE':
            case 'COLUMN':
            case 'FIELD':
            case 'PRIMARY VALUE':
            case 'COMPARED / EXPECTED':
            case 'VALUE':
            case 'DUPLICATED VALUE':
            case 'MISSING COLUMNS':
            case 'REQUIRED COLUMNS':
                return 'integrity-cell--medium';
            default:
                return '';
        }
    }

    function renderIntegrityResultsShell(headers, bodyHtml, rowCount, emptyMessage) {
        return `
            <div class="integrity-results-shell">
                <div class="table-wrapper">
                    <table class="data-table integrity-results-table">
                        <thead>
                            <tr>${headers.map(header => `<th class="${header.className || ''}">${escapeHtml(header.label)}</th>`).join('')}</tr>
                        </thead>
                        <tbody>${bodyHtml || `<tr><td colspan="${headers.length}" class="integrity-cell--wrap">${escapeHtml(emptyMessage)}</td></tr>`}</tbody>
                    </table>
                </div>
                <div class="integrity-results-footer">
                    <span>${formatNumber(rowCount)} row(s) shown.</span>
                    <span>Scroll horizontally to view all columns.</span>
                </div>
            </div>`;
    }

    function shouldRenderIntegritySection(summaryItem) {
        if (!summaryItem) {
            return false;
        }

        if (state.resultFilter === 'PASS') {
            return Number(summaryItem.passCount || 0) > 0;
        }

        if (state.resultFilter === 'FAIL') {
            return Number(summaryItem.failCount || summaryItem.errorCount || 0) > 0;
        }

        return true;
    }

    function getIntegrityVisibleKeys(ruleId, rows) {
        const excludedKeys = new Set(['Validation_Result', 'Validation_Explanation', 'RULE_LABEL', 'RESULT_BADGE', 'FINAL_RESULT_MESSAGE']);
        const preferredProfile = resultColumnProfiles[ruleId] || [];
        const allKeys = Array.from(new Set((rows || []).flatMap(row =>
            Object.keys(row.displayValues || {}).filter(key => !excludedKeys.has(key)))));
        const preferredKeys = preferredProfile.filter(item => allKeys.includes(item.key));
        const visibleKeys = preferredKeys.length
            ? preferredKeys.map(item => item.key)
            : (allKeys.length ? allKeys : preferredProfile.map(item => item.key));
        const keyLabels = Object.fromEntries(preferredProfile.map(item => [item.key, item.label]));
        return { visibleKeys, keyLabels };
    }

    function buildIntegrityDuplicateTable(ruleRows, emptyMessage) {
        const duplicateGroups = new Map();
        (ruleRows || []).forEach(row => {
            const displayValues = row.displayValues || {};
            const duplicateValue = displayValues.DUPLICATE_VALUE || '';
            const groupKey = `${row.ruleId}|${displayValues.TABLE_NAME || ''}|${displayValues.COLUMN_NAME || ''}|${duplicateValue}`;
            const duplicateCount = Number(displayValues.DUPLICATE_COUNT || 0);
            const current = duplicateGroups.get(groupKey);
            if (!current) {
                duplicateGroups.set(groupKey, {
                    ruleId: row.ruleId,
                    tableName: displayValues.TABLE_NAME || '',
                    columnName: displayValues.COLUMN_NAME || '',
                    duplicateValue,
                    duplicateCount,
                    validationResult: row.validationResult || '',
                    validationExplanation: row.validationExplanation || ''
                });
                return;
            }

            if (duplicateCount > current.duplicateCount) {
                current.duplicateCount = duplicateCount;
            }
        });

        const duplicateRows = Array.from(duplicateGroups.values())
            .sort((left, right) =>
                right.duplicateCount - left.duplicateCount ||
                String(left.duplicateValue).localeCompare(String(right.duplicateValue)));
        const headers = [
            { label: 'Table', className: 'integrity-cell--medium' },
            { label: 'Column', className: 'integrity-cell--medium' },
            { label: 'Duplicated Value', className: 'integrity-cell--medium integrity-cell--code' },
            { label: 'Duplicate Count', className: 'integrity-cell--medium' },
            { label: 'Result', className: 'integrity-cell--result' },
            { label: 'Explanation', className: 'integrity-cell--wrap' }
        ];
        const bodyHtml = duplicateRows.map(row => `
            <tr class="integrity-row--${String(row.validationResult || '').toUpperCase() === 'PASS' ? 'pass' : 'fail'}">
                <td class="integrity-cell--medium">${renderReadableValue(row.tableName)}</td>
                <td class="integrity-cell--medium">${renderReadableValue(row.columnName)}</td>
                <td class="integrity-cell--medium integrity-cell--code">${renderReadableValue(formatDisplayValue(row.duplicateValue))}</td>
                <td class="integrity-cell--medium">${formatNumber(row.duplicateCount)}</td>
                <td class="integrity-cell--result">${renderResultBadge(row.validationResult)}</td>
                <td class="integrity-cell--wrap">${renderReadableValue(row.validationExplanation)}</td>
            </tr>`).join('');

        return renderIntegrityResultsShell(headers, bodyHtml, duplicateRows.length, emptyMessage);
    }

    function buildIntegrityRuleTable(ruleId, ruleRows, emptyMessage) {
        const { visibleKeys, keyLabels } = getIntegrityVisibleKeys(ruleId, ruleRows);
        const headers = [
            ...visibleKeys.map(key => ({
                label: keyLabels[key] || key,
                className: getIntegrityCellClass(keyLabels[key] || key)
            })),
            { label: 'Result', className: 'integrity-cell--result' },
            { label: 'Detail', className: 'integrity-cell--wrap' }
        ];
        const bodyHtml = (ruleRows || []).map(row => `
            <tr class="integrity-row--${String(row.validationResult || '').toUpperCase() === 'PASS' ? 'pass' : 'fail'}">
                ${visibleKeys.map(key => {
                    const label = keyLabels[key] || key;
                    const className = getIntegrityCellClass(label);
                    return `<td class="${className}">${renderReadableValue(formatDisplayValue((row.displayValues || {})[key]))}</td>`;
                }).join('')}
                <td class="integrity-cell--result">${renderResultBadge(row.validationResult)}</td>
                <td class="integrity-cell--wrap">${renderReadableValue(row.validationExplanation || readDisplayValue(row.displayValues, ['FINAL_RESULT_MESSAGE']))}</td>
            </tr>`).join('');

        return renderIntegrityResultsShell(headers, bodyHtml, (ruleRows || []).length, emptyMessage);
    }

    function renderIntegrityRuleSection(summaryItem, ruleRows) {
        const ruleId = Number(summaryItem.ruleId || 0);
        const ruleStatus = String(summaryItem.status || '').toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail';
        const emptyMessage = state.summary?.isPreviewOnly
            ? 'No browser sample rows were loaded for this rule. Download Excel or CSV for the full result set.'
            : 'No rows match the selected result filter for this rule.';
        const tableHtml = ruleId === 3 || ruleId === 4
            ? buildIntegrityDuplicateTable(ruleRows, emptyMessage)
            : buildIntegrityRuleTable(ruleId, ruleRows, emptyMessage);

        return `
            <div class="card" style="padding:20px;margin-top:18px">
                <div class="rule20-comparison-card__header">
                    <div>
                        <div class="rule20-comparison-card__title">Rule ${ruleId}</div>
                        <div class="rule20-comparison-card__subtitle">${escapeHtml(summaryItem.criteriaText || summaryItem.controlLabel || '')}</div>
                    </div>
                    <div class="rule20-comparison-card__meta">
                        <span class="badge ${ruleStatus}">${escapeHtml(summaryItem.status || '')}</span>
                        <span>Issues: ${formatNumber(summaryItem.errorCount)}</span>
                        <span>Tested: ${formatNumber(summaryItem.totalCount || summaryItem.requestedCount || 0)}</span>
                        <span>Sample rows: ${formatNumber((ruleRows || []).length)}</span>
                    </div>
                </div>
                ${tableHtml}
            </div>`;
    }

    function formatDisplayValue(value) {
        if (value === null || value === undefined) return '(null)';
        const text = String(value);
        return text.trim() === '' ? '(blank)' : text;
    }

    function getRuleParameterDefinition() {
        switch (ruleNumber) {
            case 5:
                return { label: 'Invalid Placeholder Value', defaultValue: '9999999', placeholder: 'e.g. 9999999' };
            default:
                return null;
        }
    }

    function parseRuleParameterJson(ruleParameterJson) {
        if (!ruleParameterJson) return {};
        try {
            const parsed = JSON.parse(ruleParameterJson);
            return parsed && typeof parsed === 'object' ? parsed : {};
        } catch {
            return {};
        }
    }

    function getRuleParameters() {
        if (ruleNumber === 5) {
            const definition = getRuleParameterDefinition();
            if (!definition) return {};
            return {
                matchValue: (els.ruleValueInput?.value || definition.defaultValue || '').trim() || definition.defaultValue || ''
            };
        }

        if (ruleNumber === 7) {
            return {
                contextColumn: (els.studContextColumn?.value || '').trim()
            };
        }

        if (ruleNumber === 8) {
            return {
                contextColumn: (els.cregContextColumn?.value || '').trim()
            };
        }

        if (ruleNumber === 9) {
            return {
                contextColumn: (els.cregGhostContextColumn?.value || '').trim(),
                secondaryContextColumn: (els.studGhostContextColumn?.value || '').trim()
            };
        }

        return {};
    }

    function getRuleParameterJson() {
        const parameters = getRuleParameters();
        return Object.keys(parameters).length ? JSON.stringify(parameters) : '';
    }

    function applyRuleParameterUi(ruleParameterJson) {
        const parsed = parseRuleParameterJson(ruleParameterJson);

        if (ruleNumber === 5) {
            const definition = getRuleParameterDefinition();
            if (!definition || !els.ruleValueInput) return;

            const selectedValue = parsed && typeof parsed.matchValue === 'string' && parsed.matchValue.trim()
                ? parsed.matchValue.trim()
                : (definition.defaultValue || '');

            const label = document.getElementById('ruleValueLabel');
            if (label) label.textContent = definition.label;
            els.ruleValueInput.placeholder = definition.placeholder || '';
            els.ruleValueInput.value = selectedValue;
            return;
        }

        if (ruleNumber === 7 && els.studContextColumn) {
            els.studContextColumn.dataset.pendingValue =
                parsed && typeof parsed.contextColumn === 'string' && parsed.contextColumn.trim()
                    ? parsed.contextColumn.trim()
                    : '_007';
        }

        if (ruleNumber === 8 && els.cregContextColumn) {
            els.cregContextColumn.dataset.pendingValue =
                parsed && typeof parsed.contextColumn === 'string' && parsed.contextColumn.trim()
                    ? parsed.contextColumn.trim()
                    : '_007';
        }

        if (ruleNumber === 9) {
            if (els.cregGhostContextColumn) {
                els.cregGhostContextColumn.dataset.pendingValue =
                    parsed && typeof parsed.contextColumn === 'string' && parsed.contextColumn.trim()
                        ? parsed.contextColumn.trim()
                        : '_001';
            }

            if (els.studGhostContextColumn) {
                els.studGhostContextColumn.dataset.pendingValue =
                    parsed && typeof parsed.secondaryContextColumn === 'string' && parsed.secondaryContextColumn.trim()
                        ? parsed.secondaryContextColumn.trim()
                        : '_001';
            }
        }
    }

    function getCurrentRuleTexts() {
        const qualTable = els.qualTable?.value || 'dbo_QUAL';
        const studTable = els.studTable?.value || 'dbo_STUD';
        const cregTable = els.cregTable?.value || 'dbo_CREG';
        const crseTable = els.crseTable?.value || 'dbo_CRSE';
        const defaults = getDefaultColumns();
        const ruleParameters = getRuleParameters();
        const configuredValue = ruleParameters.matchValue || '';
        const qualColumn = els.ruleColumn?.value || els.qualLinkColumn?.value || defaults.qual || '';
        const studColumn = els.ruleColumn?.value || els.studLinkColumn?.value || els.studStudentLinkColumn?.value || defaults.stud || '';
        const cregColumn = els.cregLinkColumn?.value || els.cregStudentLinkColumn?.value || defaults.creg || '';
        const crseColumn = els.ruleColumn?.value || els.crseLinkColumn?.value || defaults.crse || '';
        const rule7StudentContextColumn = (els.studContextColumn?.value || '').trim();
        const rule8StudentContextColumn = (els.cregContextColumn?.value || '').trim();
        const rule9CregCourseColumn = (els.cregGhostContextColumn?.value || '').trim();
        const rule9StudCourseColumn = (els.studGhostContextColumn?.value || '').trim();

        switch (ruleNumber) {
            case 1:
                return {
                    logic: `Verify whether any qualification in ${qualTable} has a blank value in ${qualColumn}.`,
                    criteria: `ISBLANK(${qualTable}.${qualColumn})`
                };
            case 2:
                return {
                    logic: `Verify whether any qualification in ${qualTable} has a blank approval-status value in ${qualColumn}.`,
                    criteria: `ISBLANK(${qualTable}.${qualColumn})`
                };
            case 3:
                return {
                    logic: `Check for duplicate values in ${qualTable} using the selected field ${qualColumn}.`,
                    criteria: `Checked for duplicates on ${qualTable} using the ${qualColumn} field.`
                };
            case 4:
                return {
                    logic: `Check for duplicate values in ${crseTable} using the selected field ${crseColumn}.`,
                    criteria: `Checked for duplicates on ${crseTable} using the ${crseColumn} field.`
                };
            case 5:
                return {
                    logic: `Check whether any rows in ${studTable} contain the configured invalid placeholder value ${configuredValue || '9999999'} in ${studColumn}.`,
                    criteria: `NOT MAP(${studTable}.${studColumn}, "${configuredValue || '9999999'}")`
                };
            case 6:
                return {
                    logic: `Check whether any rows in ${studTable} have a blank value in ${studColumn}.`,
                    criteria: `ISBLANK(${studTable}.${studColumn})`
                };
            case 7:
                return {
                    logic: `Check whether any rows in ${studTable} have a blank selected qualification value or do not match ${qualTable} on the selected qualification fields, while identifying the student from ${studTable}.${rule7StudentContextColumn || '...'}.`,
                    criteria: `ISBLANK(${studTable}.${studColumn}) OR ${studTable}.${studColumn} <> ${qualTable}.${qualColumn}`
                };
            case 8:
                return {
                    logic: `Check whether any rows in ${cregTable} have a blank selected course value or do not match ${crseTable} on the selected course fields, while identifying the student from ${cregTable}.${rule8StudentContextColumn || '...'}.`,
                    criteria: `ISBLANK(${cregTable}.${cregColumn}) OR ${cregTable}.${cregColumn} <> ${crseTable}.${crseColumn}`
                };
            case 9:
                return {
                    logic: `Check whether student number ${cregTable}.${cregColumn} is blank or does not exist in ${studTable}.${studColumn}. Flag each CREG row that points to a ghost student.`,
                    criteria: `ISBLANK(${cregTable}.${cregColumn}) OR ${cregTable}.${cregColumn} <> ${studTable}.${studColumn}`
                };
            default:
                return {
                    logic: '@(ruleMetadata?.DetailedDescription ?? ruleMetadata?.ShortDescription ?? "This rule tests 100% of the population.")',
                    criteria: '@(ruleMetadata?.CriteriaText ?? "Integrity check")'
                };
        }
    }

