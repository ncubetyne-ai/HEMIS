        cregGhostContextColumn: document.getElementById('cregGhostContextColumn'),
        studGhostContextColumn: document.getElementById('studGhostContextColumn'),
        rule10JoinConfigGrid: document.getElementById('rule10JoinConfigGrid'),
        ruleLogicText: document.getElementById('ruleLogicText'),
        ruleCriteriaText: document.getElementById('ruleCriteriaText'),
        connectionOutput: document.getElementById('connectionOutput'),
        configOutput: document.getElementById('configOutput'),
        analysisPane: document.getElementById('analysisPane'),
