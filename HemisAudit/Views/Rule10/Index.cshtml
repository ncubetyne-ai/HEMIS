        10: [
            { key: 'DATASET', label: 'Dataset' },
            { key: 'TABLE_NAME', label: 'Selected Table' },
            { key: 'REQUIRED_KEY_COLUMNS', label: 'Required Key Columns' },
            { key: 'MISSING_COLUMNS', label: 'Missing Columns' },
            { key: 'FINAL_RESULT_MESSAGE', label: 'Results' }
