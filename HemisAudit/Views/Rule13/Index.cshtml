    }

    function destroyCharts() {
        Object.values(state.chartInstances || {}).forEach(chart => {
            if (chart && typeof chart.destroy === 'function') {
                chart.destroy();
            }
        });
        state.chartInstances = {};
    }

    function renderCharts(summary) {
        destroyCharts();

        if (!els.chartsPane) {
            return;
        }

        if (!summary) {
            els.chartsPane.innerHTML = '<div class="empty-card"><p>Charts will appear after running Rule 13.</p></div>';
            return;
        }

        if (typeof Chart === 'undefined') {
            els.chartsPane.innerHTML = '<div class="empty-card"><p>Charts could not load because Chart.js is unavailable.</p></div>';
            return;
        }

        const partSummaries = summary.partSummaries || [];
        const labels = partSummaries.map(part => part.partCode || 'Scope');
        const passCounts = partSummaries.map(part => Number(part.passCount || 0));
        const failCounts = partSummaries.map(part => Number(part.failCount || 0));
        const failRates = partSummaries.map(part => {
            const total = Number(part.totalCount || 0);
            return total > 0 ? Number(((Number(part.failCount || 0) / total) * 100).toFixed(2)) : 0;
        });

        els.chartsPane.innerHTML = `
            <div class="card" style="padding:20px">
                <h3 class="section-title" style="margin-top:0">Rule 13 Visual Summary</h3>
                <div class="charts-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px">
                    <div class="chart-card">
                        <h4>Part PASS vs FAIL</h4>
                        <canvas id="rule20ChartParts"></canvas>
                    </div>
                    <div class="chart-card">
                        <h4>Overall PASS vs FAIL</h4>
                        <canvas id="rule20ChartOutcome"></canvas>
                    </div>
                    <div class="chart-card">
                        <h4>Part FAIL Rate</h4>
                        <canvas id="rule20ChartFailRates"></canvas>
                    </div>
                    <div class="chart-card chart-card--status ${String(summary.status).toUpperCase() === 'PASS' ? 'chart-card--pass' : 'chart-card--fail'}">
                        <h4>Run Status</h4>
                        <div class="big-status">${escapeHtml(summary.status || '')}</div>
                        <div class="summary-text" style="width:100%;margin-top:12px">
                            <div><span>Qualifying CESM Population</span><strong>${formatNumber(summary.foundationStudentCount)}</strong></div>
                            <div><span>Validated Rows</span><strong>${formatNumber(summary.totalValidated)}</strong></div>
                            <div><span>PASS</span><strong class="text-success">${formatNumber(summary.passCount)}</strong></div>
                            <div><span>FAIL</span><strong class="text-danger">${formatNumber(summary.failCount)}</strong></div>
                        </div>
                    </div>
                </div>
            </div>`;

        state.chartInstances.parts = new Chart(document.getElementById('rule20ChartParts'), {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'PASS', data: passCounts, backgroundColor: '#4CAF50' },
                    { label: 'FAIL', data: failCounts, backgroundColor: '#F44336' }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: { y: { beginAtZero: true } }
            }
        });

        state.chartInstances.outcome = new Chart(document.getElementById('rule20ChartOutcome'), {
            type: 'doughnut',
            data: {
                labels: ['PASS', 'FAIL'],
                datasets: [{
                    data: [Number(summary.passCount || 0), Number(summary.failCount || 0)],
                    backgroundColor: ['#4CAF50', '#F44336'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        state.chartInstances.failRates = new Chart(document.getElementById('rule20ChartFailRates'), {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'FAIL %',
                    data: failRates,
                    backgroundColor: '#F59E0B'
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, max: 100 } }
            }
        });
    }

    function getFilteredRows() {
        const rows = state.summary?.reviewRows || [];
        return rows.filter(row =>
            state.detailResult === 'ALL' || String(row.validationResult || '').toUpperCase() === state.detailResult);
    }

    function renderResults(force = false) {
        if (!state.summary) {
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No Rule 13 results loaded.</p></div>';
            return;
        }

        if (!force && getActiveTab() !== 'results') {
            els.resultsPane.innerHTML = `
                <div class="empty-card">
                    <p>Open the Results tab to load the browser preview.</p>
                </div>`;
            return;
        }

        const filteredRows = getFilteredRows();
        const visibleRows = filteredRows.slice(0, browserResultsRenderLimit);
        const isBrowserTrimmed = filteredRows.length > visibleRows.length;
        const linkageText = state.summary?.tableLinkageText || '';
        const previewNotice = state.summary.isPreviewOnly
            ? `Saved browser preview is already limited for performance. Loaded rows: ${formatNumber(state.summary.displayedCount || state.summary.reviewRows?.length || 0)} of ${formatNumber(state.summary.totalValidated)} validated row(s).`
            : isBrowserTrimmed
                ? `Browser rendering is capped at ${formatNumber(browserResultsRenderLimit)} row(s) per filter to keep the page responsive.`
                : '';

        els.resultsPane.innerHTML = `
            <div class="card" style="padding:20px">
                <div class="form-grid" style="margin-bottom:16px">
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Tables</div><div>CESM: ${escapeHtml(state.summary.studTable)} | QUAL: ${escapeHtml(state.summary.qualTable)} | STUD: ${escapeHtml(state.summary.cregTable)}</div></div>
                    <div style="grid-column:1 / -1"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Linkage Used</div><div>${escapeHtml(linkageText)}</div></div>
                    <div style="grid-column:1 / -1"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Population Rule</div><div>Rows are limited to the 100% CESM population where CESM._006 &lt;&gt; 'ZZZZZZ'.</div></div>
                    <div style="grid-column:1 / -1"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">PASS Rule</div><div>A qualifying CESM qualification passes only when it links to at least one STUD row through QUAL._001 = STUD._001.</div></div>
                </div>
                <div class="action-bar" style="justify-content:flex-start;margin:0 0 16px 0">
                    <label for="detailResultFilter" style="font-weight:600">Result</label>
                    <select id="detailResultFilter" style="max-width:220px">
                        <option value="ALL" ${state.detailResult === 'ALL' ? 'selected' : ''}>All Results</option>
                        <option value="PASS" ${state.detailResult === 'PASS' ? 'selected' : ''}>PASS</option>
                        <option value="FAIL" ${state.detailResult === 'FAIL' ? 'selected' : ''}>FAIL</option>
                    </select>
                </div>
                <div class="alert alert--info" style="margin-bottom:16px">
                    Showing ${formatNumber(visibleRows.length)} of ${formatNumber(filteredRows.length)} loaded result row(s) in the CESM -> QUAL -> STUD comparison layout.
                </div>
                ${previewNotice ? `<div class="alert alert--warning" style="margin-bottom:16px">${escapeHtml(previewNotice)}</div>` : ''}
            </div>
            ${renderComparisonSections(visibleRows)}`;

        document.getElementById('detailResultFilter')?.addEventListener('change', event => {
            state.detailResult = String(event.target.value || 'ALL').toUpperCase();
            renderResults(true);
        });
    }

    function applySummary(summary, options = {}) {
        state.summary = normalizeBrowserSummary(summary);
        if (!options.fromWorkspace) {
            state.currentRunId = summary?.savedRunId || state.currentRunId;
        }
        state.currentStatus = summary?.status || state.currentStatus;
        state.resultsVisible = !!summary || state.resultsVisible;
        if (!summary) {
            els.analysisPane.innerHTML = '<div class="empty-card"><p>No Rule 13 results loaded.</p></div>';
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No Rule 13 results loaded.</p></div>';
            setStatusBadge('');
            updateWorkspaceButtons();
            return;
        }

        if (state.hasPendingValidation) {
            els.workspaceRunState.textContent = `Pending save | ${summary.status || 'Completed'}`;
            els.workspaceRunLabel.textContent = 'Unsaved Rule 13 validation';
            els.workspaceStatusLabel.textContent = 'Pending Save';
        } else {
            els.workspaceRunState.textContent = state.currentRunId
                ? `Run #${state.currentRunId} | ${state.currentStatus || 'Completed'}`
                : 'No saved run loaded';
            els.workspaceRunLabel.textContent = state.currentRunId
                ? `Run #${state.currentRunId}`
                : 'No saved run yet';
            els.workspaceStatusLabel.textContent = state.currentStatus || '-';
        }

        if (!els.workspaceRoleLabel.textContent?.trim()) {
            els.workspaceRoleLabel.textContent = state.currentUserEngagementRole || currentSystemRole || '-';
        }
        setStatusBadge(summary?.status || '');
        renderAnalysis(summary);
        renderResults();
        renderCharts(summary);
        updateWorkspaceButtons();
    }

    function applyWorkspace(workspace, resultsVisible, preserveExistingSummary = false) {
        if (!workspace) {
            state.currentRunId = null;
            state.currentStatus = '';
            state.currentUserEngagementRole = '';
            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;
            state.resultsVisible = false;
            state.hasPendingValidation = false;
            setWorkspaceState('No saved Rule 13 workspace exists for this engagement yet.', 'info');
            els.workspaceRunState.textContent = 'No saved run loaded';
            els.workspaceRunLabel.textContent = 'No saved run yet';
            els.workspaceStatusLabel.textContent = '-';
            els.workspaceEditedLabel.textContent = '-';
            applySummary(null);
            updateWorkspaceButtons();
            return;
        }

        state.clientId = workspace.clientId || state.clientId;
        state.currentRunId = workspace.runId || null;
        state.currentStatus = workspace.currentStatus || state.currentStatus;
        state.currentUserEngagementRole = workspace.currentUserEngagementRole || currentSystemRole || '';
        state.currentUserHasSignedOff = !!workspace.currentUserHasSignedOff;
        state.isWorkspaceSaved = !!workspace.isWorkspaceSaved;
        state.hasDataAnalystSignoff = !!workspace.hasDataAnalystSignoff;
        state.resultsVisible = !!resultsVisible;
        state.hasPendingValidation = false;
        if (els.server) els.server.value = workspace.server || '';
        if (els.driver) els.driver.value = workspace.driver || 'ODBC Driver 17 for SQL Server';
        if (els.database) populateSelect(els.database, workspace.database ? [workspace.database] : [], workspace.database);
        if (els.studTable) populateSelect(els.studTable, workspace.studTable ? [workspace.studTable] : [], workspace.studTable);
        if (els.qualTable) populateSelect(els.qualTable, workspace.qualTable ? [workspace.qualTable] : [defaultQualTable], workspace.qualTable || defaultQualTable);
        if (els.cregTable) populateSelect(els.cregTable, workspace.cregTable ? [workspace.cregTable] : [], workspace.cregTable);
        if (els.crseTable) populateSelect(els.crseTable, workspace.crseTable ? [workspace.crseTable] : [], workspace.crseTable);
        if (els.pgTypesText) els.pgTypesText.value = workspace.pgTypesText || defaultPgTypesText;

        // Restore PQM config
        if (workspace.pqmTable !== undefined) {
            if (els.pqmTable) {
                // Ensure the saved value is in the list
                let found = Array.from(els.pqmTable.options).some(o => o.value === (workspace.pqmTable || ''));
                if (!found && workspace.pqmTable) {
                    const opt = document.createElement('option');
                    opt.value = workspace.pqmTable;
                    opt.textContent = workspace.pqmTable;
                    els.pqmTable.appendChild(opt);
                }
                els.pqmTable.value = workspace.pqmTable || '';
            }
            const setColSelect = (sel, val, def) => {
                if (!sel) return;
                let found = Array.from(sel.options).some(o => o.value === (val || def));
                if (!found && val) {
                    const opt = document.createElement('option');
                    opt.value = val;
                    opt.textContent = val;
                    sel.appendChild(opt);
                }
                sel.value = val || def;
            };
            setColSelect(els.cesmIdCol,   workspace.cesmIdCol,   '_001');
            setColSelect(els.cesmCodeCol, workspace.cesmCodeCol, '_006');
            setColSelect(els.qualIdCol,   workspace.qualIdCol,   '_001');
            setColSelect(els.qualNameCol, workspace.qualNameCol, '_003');
            setColSelect(els.studIdCol,   workspace.studIdCol,   '_001');
            setColSelect(els.pqmNameCol,  workspace.pqmNameCol,  'Authorised_Qualification_Name');
            setColSelect(els.pqmCode1Col, workspace.pqmCode1Col, 'CESM_Code');
            setColSelect(els.pqmCode2Col, workspace.pqmCode2Col, 'CESM_Code2');
        }
        updatePqmInfoBox();
        els.workspaceRunState.textContent = workspace.runId ? `Run #${workspace.runId}` : 'No saved run loaded';
        els.workspaceRunLabel.textContent = workspace.runId ? `Rule 13 Run #${workspace.runId}` : 'No saved run yet';
        els.workspaceStatusLabel.textContent = workspace.currentStatus || '-';
        els.workspaceEditedLabel.textContent = workspace.lastEditedAt ? new Date(workspace.lastEditedAt).toLocaleString() : '-';
        els.workspaceRoleLabel.textContent = workspace.currentUserEngagementRole || currentSystemRole || '-';
        els.workspaceSignoffComment.value = workspace.currentUserSignoffComment || '';

        if (!resultsVisible) {
            setWorkspaceState('Saved Rule 13 results are not available for your engagement role.', 'info');
            if (!preserveExistingSummary) {
                applySummary(null);
            } else {
                updateWorkspaceButtons();
            }
            return;
        }

        setWorkspaceState(workspace.summary
            ? 'Saved Rule 13 workspace loaded.'
            : 'Rule 13 workspace loaded. Run the validation to generate results.',
            'success');
        if (workspace.summary) {
            applySummary(workspace.summary, { fromWorkspace: true });
        } else if (!preserveExistingSummary) {
            applySummary(null);
        } else {
            updateWorkspaceButtons();
        }
    }

    async function loadWorkspace() {
        state.clientId = Number(els.clientId?.value || 0);
        if (!state.clientId) {
            applyWorkspace(null, false);
            return;
        }

        const data = await window.fetchJsonWithProgress(`${apiBasePath}/GetWorkspaceState?clientId=${state.clientId}`, { method: 'GET' });
        if (!data.success) throw new Error(data.error || 'Failed to load workspace.');
        applyWorkspace(data.workspace, data.resultsVisible);
    }

    async function connect() {
        const server = els.server?.value?.trim();
        if (!server) throw new Error('Enter the SQL Server name first.');

        showSpinner('Loading databases...');
        try {
            const data = await postJson(`${apiBasePath}/GetDatabases`, { server, driver: els.driver.value });
            if (!data.success) throw new Error(data.error || 'Failed to load databases.');
            populateSelect(els.database, data.databases || []);
            els.connectionOutput.innerHTML = `<div class="alert alert--success">Loaded ${(data.databases || []).length} database(s).</div>`;
            if ((data.databases || []).length) await loadTables();
        } finally {
            hideSpinner();
        }
    }

    async function loadTables() {
        if (!els.database?.value) return;
        const data = await postJson(`${apiBasePath}/GetTables`, {
            server: els.server.value.trim(),
            database: els.database.value,
            driver: els.driver.value
        });
        if (!data.success) throw new Error(data.error || 'Failed to load tables.');

        const tables = normalizeTableList(data.tables || []);
        populateSelect(els.studTable, tables, data.autoStudTable);
        if (els.qualTable) populateSelect(els.qualTable, tables, data.autoQualTable || defaultQualTable);
        populateSelect(els.cregTable, tables, data.autoCregTable);
        populateSelect(els.crseTable, tables, data.autoCrseTable || data.autoCregTable);

        // Populate PQM table dropdown — auto-detect and always select
        if (els.pqmTable) {
            els.pqmTable.innerHTML = '';
            let pqmAutoSelected = false;
            tables.forEach(t => {
                const opt = document.createElement('option');
                opt.value = t;
                opt.textContent = t;
                if (data.autoPqmTable && data.autoPqmTable === t) {
                    opt.selected = true;
                    pqmAutoSelected = true;
                }
                els.pqmTable.appendChild(opt);
            });
            // If no auto-detected PQM table, try to find one by name
            if (!pqmAutoSelected && els.pqmTable.options.length > 0) {
                const pqmOpt = Array.from(els.pqmTable.options).find(o =>
                    o.value.toUpperCase().includes('PQM'));
                if (pqmOpt) pqmOpt.selected = true;
                else els.pqmTable.selectedIndex = 0;
            }
        }

        // Load columns for CESM, QUAL, STUD, and PQM tables — PQM is always required
        await Promise.allSettled([
            loadColumnsForTable(els.studTable?.value,  ['cesm_id', 'cesm_code'], [els.cesmIdCol, els.cesmCodeCol]),
            loadColumnsForTable(els.qualTable?.value,  ['qual_id', 'qual_name'],  [els.qualIdCol, els.qualNameCol]),
            loadColumnsForTable(els.cregTable?.value,  ['stud_id'],               [els.studIdCol]),
            loadColumnsForTable(els.pqmTable?.value,   ['pqm_name', 'pqm_code1', 'pqm_code2'], [els.pqmNameCol, els.pqmCode1Col, els.pqmCode2Col])
        ]);

        updatePqmInfoBox();
        els.configOutput.innerHTML = `<div class="alert alert--success">Loaded ${tables.length} table(s).</div>`;
    }

    async function loadColumnsForTable(tableName, roles, selectEls) {
        if (!tableName || !els.server?.value || !els.database?.value) return;
        const conn = { server: els.server.value.trim(), database: els.database.value, driver: els.driver?.value || 'ODBC Driver 17 for SQL Server' };
        for (let i = 0; i < roles.length; i++) {
            const role = roles[i];
            const sel = selectEls[i];
            if (!sel) continue;
            try {
                const data = await postJson(`${apiBasePath}/GetColumns`, { ...conn, tableName, tableRole: role });
                if (data.success && Array.isArray(data.columns)) {
                    const currentVal = sel.value;
                    sel.innerHTML = '';
                    data.columns.forEach(col => {
                        const opt = document.createElement('option');
                        opt.value = col;
                        opt.textContent = col;
                        sel.appendChild(opt);
                    });
                    // Prefer current saved value, then auto-selected
                    const preferred = currentVal && data.columns.includes(currentVal) ? currentVal : (data.autoSelected || data.columns[0]);
                    if (preferred) sel.value = preferred;
                }
            } catch (e) { /* non-fatal */ }
        }
    }

    async function verifyTables() {
        showSpinner('Verifying Rule 13 tables...');
        try {
            const data = await postJson(`${apiBasePath}/VerifyTables`, getRequest());
            if (!data.success) throw new Error(data.error || 'Verification failed.');
            els.configOutput.innerHTML = `
                <div class="alert alert--success">
                    Qualifying CESM population where _006 &lt;&gt; 'ZZZZZZ': <strong>${formatNumber(data.foundationStudentCount)}</strong> |
                    CESM qualifications validated against STUD linkage: <strong>${formatNumber(data.validatedRowCount)}</strong>
                </div>`;
        } finally {
            hideSpinner();
        }
    }

    async function runValidation() {
        const request = getRequest();
        if (!request.clientId) {
            setWorkspaceState('Select the approved engagement assigned to you before running this rule.', 'warning');
            return;
        }
        if (!request.pqmTable) {
            setWorkspaceState('PQM table is required. Select the PQM table from the configuration above before running Rule 13.', 'warning');
            els.pqmTable?.focus();
            return;
        }

        showSpinner('Running Rule 13...');
        try {
            const data = await postJson(`${apiBasePath}/RunValidation`, request);
            if (!data.success) throw new Error(data.error || 'Rule 13 failed.');
            state.hasPendingValidation = true;
            state.currentRunId = null;
            state.currentStatus = data.status || '';
            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            state.hasDataAnalystSignoff = false;
            state.resultsVisible = true;
            state.currentUserEngagementRole = state.currentUserEngagementRole || currentSystemRole || 'DataAnalyst';
            applySummary(data);
            setWorkspaceState(`Rule 13 validation completed. Scope: ${data.governingPartCodesText || '100% population'}. PASS: ${formatNumber(data.passCount)} | FAIL: ${formatNumber(data.failCount)}. The current run is already in the system database. Click Save Workspace before signoff or visibility to other users.`, 'success');
        } finally {
            hideSpinner();
        }
    }

    async function generateSql() {
        showSpinner('Generating SQL...');
        try {
            const data = await postJson(`${apiBasePath}/GenerateSql`, getRequest());
            if (!data.success) throw new Error(data.error || 'SQL generation failed.');
            state.sql = data.sql || '';
            els.sqlText.value = state.sql;
            setActiveTab('sql');
        } finally {
            hideSpinner();
        }
    }

    async function saveWorkspace() {
        showSpinner('Saving workspace...');
        try {
            const data = await postJson(`${apiBasePath}/SaveWorkspace`, getRequest());
            if (!data.success) throw new Error(data.error || 'Workspace save failed.');
            state.hasPendingValidation = false;
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible')
                ? !!data.resultsVisible
                : !!data.workspace?.resultsVisible;
            applyWorkspace(data.workspace, workspaceResultsVisible, true);
            setWorkspaceState(data.message || 'Workspace saved.', data.signoffsCleared ? 'warning' : 'success');
        } finally {
            hideSpinner();
        }
    }

    async function beginEdit() {
        showSpinner('Preparing workspace edit...');
        try {
            const data = await postJson(`${apiBasePath}/BeginWorkspaceEdit`, getRequest());
            if (!data.success) throw new Error(data.error || 'Workspace edit could not start.');
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible')
                ? !!data.resultsVisible
                : !!data.workspace?.resultsVisible;
            applyWorkspace(data.workspace, workspaceResultsVisible, true);
            setWorkspaceState(data.message || 'Workspace ready for editing.', 'warning');
        } finally {
            hideSpinner();
        }
    }

    async function signoffWorkspace() {
        showSpinner('Saving signoff...');
        try {
            const data = await postJson(`${apiBasePath}/SignOffWorkspace`, {
                clientId: Number(els.clientId.value || 0),
                runId: state.currentRunId,
                comment: els.workspaceSignoffComment.value || ''
            });
            if (!data.success) throw new Error(data.error || 'Signoff failed.');
            state.currentUserHasSignedOff = true;
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible')
                ? !!data.resultsVisible
                : !!data.workspace?.resultsVisible;
            applyWorkspace(data.workspace, workspaceResultsVisible, true);
            setWorkspaceState(data.message || 'Signoff saved.', 'success');
        } finally {
            hideSpinner();
        }
    }

    async function removeWorkspaceSignoff() {
        showSpinner('Removing signoff...');
        try {
            const previousRunId = state.currentRunId;
            const data = await postJson(`${apiBasePath}/RemoveWorkspaceSignoff`, {
                clientId: Number(els.clientId.value || 0),
                runId: state.currentRunId,
                comment: ''
            });
            if (!data.success) throw new Error(data.error || 'Signoff removal failed.');
            state.currentUserHasSignedOff = false;
            state.isWorkspaceSaved = false;
            const workspaceResultsVisible = Object.prototype.hasOwnProperty.call(data, 'resultsVisible')
                ? !!data.resultsVisible
                : !!data.workspace?.resultsVisible;
            const preserveExistingSummary = !!(data.workspace && previousRunId && data.workspace.runId === previousRunId);
            applyWorkspace(data.workspace, workspaceResultsVisible, preserveExistingSummary);
            setWorkspaceState(data.message || 'Signoff removed.', 'warning');
        } finally {
            hideSpinner();
        }
    }

    document.getElementById('connectBtn')?.addEventListener('click', () => connect().catch(err => {
        hideSpinner();
        els.connectionOutput.innerHTML = `<div class="alert alert--error">${escapeHtml(err.message)}</div>`;
    }));
    els.database?.addEventListener('change', () => loadTables().catch(err => {
        els.configOutput.innerHTML = `<div class="alert alert--error">${escapeHtml(err.message)}</div>`;
    }));

    // When CESM table changes, reload CESM columns
    els.studTable?.addEventListener('change', () => {
        loadColumnsForTable(els.studTable.value, ['cesm_id', 'cesm_code'], [els.cesmIdCol, els.cesmCodeCol]).catch(() => {});
    });
    // When QUAL table changes, reload QUAL columns
    els.qualTable?.addEventListener('change', () => {
        loadColumnsForTable(els.qualTable.value, ['qual_id', 'qual_name'], [els.qualIdCol, els.qualNameCol]).catch(() => {});
    });
    // When STUD table changes, reload STUD link column
    els.cregTable?.addEventListener('change', () => {
        loadColumnsForTable(els.cregTable.value, ['stud_id'], [els.studIdCol]).catch(() => {});
    });
    // When PQM table changes, always reload PQM columns — PQM is required
    els.pqmTable?.addEventListener('change', () => {
        updatePqmInfoBox();
        loadColumnsForTable(els.pqmTable.value, ['pqm_name', 'pqm_code1', 'pqm_code2'], [els.pqmNameCol, els.pqmCode1Col, els.pqmCode2Col]).catch(() => {});
    });
    // Update info box labels when column selections change
    [els.cesmCodeCol, els.qualNameCol, els.pqmNameCol, els.pqmCode1Col, els.pqmCode2Col].forEach(sel => {
        sel?.addEventListener('change', () => updatePqmInfoBox());
    });
    document.getElementById('verifyBtn')?.addEventListener('click', () => verifyTables().catch(err => {
        hideSpinner();
        els.configOutput.innerHTML = `<div class="alert alert--error">${escapeHtml(err.message)}</div>`;
    }));
    document.getElementById('runBtn')?.addEventListener('click', () => runValidation().catch(err => {
        hideSpinner();
        setWorkspaceState(err.message, 'error');
    }));
    document.getElementById('sqlBtn')?.addEventListener('click', () => generateSql().catch(err => {
    document.getElementById('rScriptBtn')?.addEventListener('click', () => generateRScript().catch(err => setWorkspaceState(err.message, 'error')));
        hideSpinner();
        els.sqlText.value = err.message;
    }));
    document.getElementById('saveWorkspaceBtn')?.addEventListener('click', () => saveWorkspace().catch(err => {
        hideSpinner();
        setWorkspaceState(err.message, 'error');
    }));
    document.getElementById('beginEditBtn')?.addEventListener('click', () => beginEdit().catch(err => {
        hideSpinner();
        setWorkspaceState(err.message, 'error');
    }));
    document.getElementById('signoffBtn')?.addEventListener('click', () => signoffWorkspace().catch(err => {
        hideSpinner();
        setWorkspaceState(err.message, 'error');
    }));
    document.getElementById('removeSignoffBtn')?.addEventListener('click', () => removeWorkspaceSignoff().catch(err => {
        hideSpinner();
        setWorkspaceState(err.message, 'error');
    }));
    document.getElementById('downloadExcelBtn')?.addEventListener('click', () => state.summary && downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, 'Rule13_CESM_Qualification_Population.xlsx').catch(err => setWorkspaceState(err.message, 'error')));
    document.getElementById('downloadCsvBtn')?.addEventListener('click', () => state.summary && downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, 'Rule13_CESM_Qualification_Population.csv').catch(err => setWorkspaceState(err.message, 'error')));
    document.getElementById('downloadSqlBtn')?.addEventListener('click', () => downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), 'Rule13_CESM_Qualification_Population.sql').catch(err => setWorkspaceState(err.message, 'error')));
        async function generateRScript() {
        showSpinner('Generating R script...');
        try {
            const data = await postJson(`${apiBasePath}/GenerateRScript`, getRequest());
            if (!data.success) throw new Error(data.error || 'R script generation failed.');
            const pane = document.getElementById('rscriptPane');
            pane.innerHTML = `<div style="padding:8px 0 8px"><button class="btn btn-sm btn-primary" onclick="(function(){const e=document.getElementById('rCode');if(e)navigator.clipboard.writeText(e.textContent)})()">Copy</button></div><pre id="rCode" style="white-space:pre-wrap;font-family:monospace;font-size:12px;padding:12px;overflow:auto;max-height:600px">${escapeHtml(data.sql)}</pre>`;
            setActiveTab('rscript');
        } finally {
            hideSpinner();
        }
    }
document.getElementById('downloadAllBtn')?.addEventListener('click', async () => {
        try {
            if (!state.summary) throw new Error('Run Rule 13 first.');
            if (document.getElementById('chkExcel')?.checked) await downloadBlob(`${apiBasePath}/DownloadExcel`, state.summary, 'Rule13_CESM_Qualification_Population.xlsx');
            if (document.getElementById('chkCsv')?.checked) await downloadBlob(`${apiBasePath}/DownloadCsv`, state.summary, 'Rule13_CESM_Qualification_Population.csv');
            if (document.getElementById('chkSql')?.checked) await downloadBlob(`${apiBasePath}/DownloadSql`, getRequest(), 'Rule13_CESM_Qualification_Population.sql');
        } catch (err) {
            setWorkspaceState(err.message || 'Download failed.', 'error');
        }
    });
    els.clientId?.addEventListener('change', () => loadWorkspace().catch(err => setWorkspaceState(err.message, 'error')));

    renderAnalysis(null);
    renderResults();
    renderCharts(null);
    updateWorkspaceButtons();
    if (state.clientId) {
        loadWorkspace().catch(err => setWorkspaceState(err.message, 'error'));
    } else if (isResultsOnlyRole) {
        setWorkspaceState('Select an engagement to load the saved Rule 13 results.', 'info');
    }
        const __ruleRApiBase = typeof apiBasePath !== 'undefined'
        ? apiBasePath
        : (typeof apiBase !== 'undefined'
            ? apiBase
            : (typeof API !== 'undefined'
                ? API
                : ((window.location.pathname.match(/^\/Rule\d+/i) || [null])[0])));
    const __ruleRRequestBuilder = typeof getRequest === 'function' ? getRequest : (typeof buildRequest === 'function' ? buildRequest : (typeof buildReq === 'function' ? buildReq : null));
    const __ruleRPost = typeof postJson === 'function' ? postJson : (typeof post === 'function' ? post : null);
    if (__ruleRApiBase && __ruleRRequestBuilder && __ruleRPost && window.ruleRScriptUi) {
        window.ruleRScriptUi.install({
            apiBase: __ruleRApiBase,
            requestBuilder: __ruleRRequestBuilder,
            postJson: __ruleRPost,
            showSpinner: typeof showSpinner === 'function' ? showSpinner : (typeof spin === 'function' ? spin : null),
            hideSpinner: typeof hideSpinner === 'function' ? hideSpinner : (typeof unspin === 'function' ? unspin : null)
        });
    }
})();
</script>


