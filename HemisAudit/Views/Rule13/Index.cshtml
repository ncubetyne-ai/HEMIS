@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 13 - CESM Qualification Population Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int currentClientId ? currentClientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="clientId">Engagement</label>
        <select id="clientId">
            <option value="">Select engagement (results saved here)</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>Rule 13 validates 100% of the qualifying CESM population and saves the reviewable result set for the selected engagement.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R13</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 13: CESM Qualification Population Validation</h1>
            <p class="rule-header__sub">Rule 13 tests 100% of <code>dbo_CESM</code> where <code>_006 &lt;&gt; 'ZZZZZZ'</code>, then verifies the <code>dbo_CESM -> dbo_QUAL -> dbo_STUD</code> linkage on <code>_001</code>.</p>
        </div>
        <div class="rule-header__badge" id="statusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('connection')">
                    <span class="acc-icon">DB</span>
                    <span>Database Connection</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-connection">
                    <div class="form-grid">
                        <div class="field-group">
                            <label for="server">Server Name</label>
                            <input id="server" type="text" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                        </div>
                        <div class="field-group">
                            <label for="driver">Driver</label>
                            <select id="driver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group">
                            <label for="database">Database</label>
                            <select id="database"></select>
                        </div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start;margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="connectBtn">Connect</button>
                    </div>
                    <div id="connectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('config')">
                    <span class="acc-icon">CF</span>
                    <span>Rule Configuration</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-config" style="display:none">
                    <div class="info-box info-box--red">
                        <strong>Rule 13 Logic:</strong><br />
                        <span>Step 1: use 100% of <code>dbo_CESM</code> where <code>_006 &lt;&gt; 'ZZZZZZ'</code></span><br />
                        <span>Step 2: match <code>dbo_CESM._001</code> to <code>dbo_QUAL._001</code></span><br />
                        <span>Step 3: match <code>dbo_QUAL._001</code> to <code>dbo_STUD._001</code></span><br />
                        <span>Step 4: PASS when the qualifying CESM qualification links to at least one STUD row</span><br />
                        <span>Overall PASS is based on the full 100% qualifying CESM population.</span>
                    </div>
                    <div class="form-grid">
                        <div class="field-group">
                            <label for="studTable">CESM Table</label>
                            <select id="studTable"></select>
                        </div>
                        <div class="field-group">
                            <label for="qualTable">QUAL Table</label>
                            <select id="qualTable"></select>
                        </div>
                        <div class="field-group">
                            <label for="cregTable">STUD Table</label>
                            <select id="cregTable"></select>
                        </div>
                        <div class="field-group" style="display:none">
                            <label for="crseTable">Workspace Mirror</label>
                            <select id="crseTable"></select>
                        </div>
                        <input id="pgTypesText" type="hidden" value="" />
                    </div>

                    <div style="margin-top:20px;border-top:1px solid #e0e0e0;padding-top:16px">
                        <div style="font-weight:700;margin-bottom:8px;font-size:14px">Column Configuration <span style="font-weight:400;font-size:12px;color:#555">— map the key columns on each table used in Rule 13</span></div>
                        <div class="form-grid">
                            <div class="field-group">
                                <label for="cesmIdCol">CESM — Record ID Column (_001)</label>
                                <select id="cesmIdCol"><option value="_001">_001</option></select>
                            </div>
                            <div class="field-group">
                                <label for="cesmCodeCol">CESM — CESM Code Column (_006)</label>
                                <select id="cesmCodeCol"><option value="_006">_006</option></select>
                            </div>
                            <div class="field-group">
                                <label for="qualIdCol">QUAL — Record ID Column (_001)</label>
                                <select id="qualIdCol"><option value="_001">_001</option></select>
                            </div>
                            <div class="field-group">
                                <label for="qualNameCol">QUAL — Qualification Name Column (_003)</label>
                                <select id="qualNameCol"><option value="_003">_003</option></select>
                            </div>
                            <div class="field-group">
                                <label for="studIdCol">STUD — Qualification Link Column (_001)</label>
                                <select id="studIdCol"><option value="_001">_001</option></select>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top:20px;border-top:1px solid #e0e0e0;padding-top:16px">
                        <div style="font-weight:700;margin-bottom:8px;font-size:14px">PQM Table Configuration <span style="font-weight:400;font-size:12px;color:#1B5E20">— auto-detected and required for validation</span></div>
                        <div id="pqmMatchingInfo" class="info-box info-box--blue" style="display:none;margin-bottom:12px">
                            <strong>PQM Matching Logic:</strong> CESM [<span id="pqmCesmCodeColLabel">_006</span>] 4-digit prefix matches PQM <span id="pqmCode1ColLabel">CESM_Code</span> or <span id="pqmCode2ColLabel">CESM_Code2</span>,
                            AND QUAL [<span id="pqmQualNameColLabel">_003</span>] (case-insensitive, whitespace-normalised) matches PQM <span id="pqmNameColLabel">Authorised_Qualification_Name</span> — both on the same PQM row.
                        </div>
                        <div class="form-grid">
                            <div class="field-group">
                                <label for="pqmTable">PQM Table</label>
                                <select id="pqmTable"><option value="">-- Select PQM table --</option></select>
                            </div>
                            <div class="field-group">
                                <label for="pqmNameCol">PQM — Authorised Qualification Name</label>
                                <select id="pqmNameCol"><option value="Authorised_Qualification_Name">Authorised_Qualification_Name</option></select>
                            </div>
                            <div class="field-group">
                                <label for="pqmCode1Col">PQM — CESM Code (Primary)</label>
                                <select id="pqmCode1Col"><option value="CESM_Code">CESM_Code</option></select>
                            </div>
                            <div class="field-group">
                                <label for="pqmCode2Col">PQM — CESM Code 2 (Secondary)</label>
                                <select id="pqmCode2Col"><option value="CESM_Code2">CESM_Code2</option></select>
                            </div>
                        </div>
                    </div>

                    <div id="configOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="toggleAccordion('downloads')">
                    <span class="acc-icon">DL</span>
                    <span>Export Options</span>
                    <span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-downloads" style="display:none">
                    <div class="checkbox-row">
                        <label class="checkbox-label"><input type="checkbox" id="chkExcel" checked /> Excel</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkCsv" checked /> CSV</label>
                        <label class="checkbox-label"><input type="checkbox" id="chkSql" checked /> SQL</label>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The latest Rule 13 connection, configuration, results, and signoffs reload automatically for this engagement.</div>
            </div>
            <div id="workspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="workspaceInfo" class="alert alert--info">
            Select an engagement to load the saved Rule 13 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div>
                <div id="workspaceRunLabel">No saved run yet</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                <div id="workspaceStatusLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div>
                <div id="workspaceEditedLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div>
                <div id="workspaceRoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div>
            </div>
            <div class="field-group" style="grid-column:1 / -1">
                <label for="workspaceSignoffComment">Signoff Comment</label>
                <textarea id="workspaceSignoffComment" rows="3" placeholder="Add review or completion notes"></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-secondary" id="beginEditBtn">Begin Edit</button>
                <button type="button" class="btn btn-success" id="saveWorkspaceBtn">Save Workspace</button>
            }
            <button type="button" class="btn btn-primary" id="signoffBtn">Save Signoff</button>
            <button type="button" class="btn btn-warning" id="removeSignoffBtn">Remove Signoff</button>
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="verifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="runBtn">Run Rule 13</button>
            <button type="button" class="btn btn-primary" id="sqlBtn">Generate SQL</button>
                <button type="button" class="btn btn-primary" id="rScriptBtn">Generate R Script</button>
            <button type="button" class="btn btn-warning" id="downloadAllBtn" disabled>Download All</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="charts">Charts</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
                <button class="tab-btn" type="button" data-tab="rscript">R Code</button>
            <button class="tab-btn" type="button" data-tab="downloads">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis"></div>
        <div class="tab-pane" data-tab-panel="results"></div>
        <div class="tab-pane" data-tab-panel="charts"></div>
        <div class="tab-pane" data-tab-panel="sql">
            <textarea id="sqlText" rows="18" readonly></textarea>
        </div>
        <div class="tab-pane" data-tab-panel="rscript" id="rscriptPane">
            <div class="empty-state" style="padding:24px;text-align:center"><p>Click "Generate R Script" to generate the R script.</p></div>
        </div>
        <div class="tab-pane" data-tab-panel="downloads">
            <div class="alert alert--info" style="margin-bottom:16px">
                Excel includes summary, part breakdown, validated rows, and FAIL rows. CSV includes the validated row set. SQL includes the notebook-style query script.
            </div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info" id="downloadExcelBtn">Excel</button>
                <button type="button" class="btn btn-info" id="downloadCsvBtn">CSV</button>
                <button type="button" class="btn btn-secondary" id="downloadSqlBtn">SQL</button>
            </div>
        </div>
    </div>

    <div id="spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="spinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="antiForgeryForm" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
window.toggleAccordion = function (section) {
    const body = document.getElementById(`body-${section}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

(() => {
    const apiBasePath = '/Rule13';
    const currentSystemRole = '@currentSystemRole';
    const isResultsOnlyRole = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    const defaultQualTable = 'dbo_QUAL';
    const defaultPgTypesText = '';
    const defaultGoverningPartCodes = ['ALL'];
    const browserResultsRenderLimit = 10;
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
    const state = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        currentRunId: null,
        summary: null,
        sql: '',
        detailResult: 'ALL',
        currentStatus: '',
        currentUserEngagementRole: '',
        currentUserHasSignedOff: false,
        isWorkspaceSaved: false,
        hasDataAnalystSignoff: false,
        resultsVisible: false,
        hasPendingValidation: false,
        chartInstances: {}
    };

    const els = {
        clientId: document.getElementById('clientId'),
        server: document.getElementById('server'),
        driver: document.getElementById('driver'),
        database: document.getElementById('database'),
        studTable: document.getElementById('studTable'),
        qualTable: document.getElementById('qualTable'),
        cregTable: document.getElementById('cregTable'),
        crseTable: document.getElementById('crseTable'),
        pgTypesText: document.getElementById('pgTypesText'),
        pqmTable: document.getElementById('pqmTable'),
        cesmIdCol: document.getElementById('cesmIdCol'),
        cesmCodeCol: document.getElementById('cesmCodeCol'),
        qualIdCol: document.getElementById('qualIdCol'),
        qualNameCol: document.getElementById('qualNameCol'),
        studIdCol: document.getElementById('studIdCol'),
        pqmNameCol: document.getElementById('pqmNameCol'),
        pqmCode1Col: document.getElementById('pqmCode1Col'),
        pqmCode2Col: document.getElementById('pqmCode2Col'),
        connectionOutput: document.getElementById('connectionOutput'),
        configOutput: document.getElementById('configOutput'),
        analysisPane: document.querySelector('[data-tab-panel="analysis"]'),
        resultsPane: document.querySelector('[data-tab-panel="results"]'),
        chartsPane: document.querySelector('[data-tab-panel="charts"]'),
        sqlText: document.getElementById('sqlText'),
        downloadAllBtn: document.getElementById('downloadAllBtn'),
        workspaceInfo: document.getElementById('workspaceInfo'),
        workspaceRunState: document.getElementById('workspaceRunState'),
        workspaceRunLabel: document.getElementById('workspaceRunLabel'),
        workspaceStatusLabel: document.getElementById('workspaceStatusLabel'),
        workspaceEditedLabel: document.getElementById('workspaceEditedLabel'),
        workspaceRoleLabel: document.getElementById('workspaceRoleLabel'),
        workspaceSignoffComment: document.getElementById('workspaceSignoffComment'),
        beginEditBtn: document.getElementById('beginEditBtn'),
        saveWorkspaceBtn: document.getElementById('saveWorkspaceBtn'),
        signoffBtn: document.getElementById('signoffBtn'),
        removeSignoffBtn: document.getElementById('removeSignoffBtn'),
        statusBadge: document.getElementById('statusBadge'),
        spinner: document.getElementById('spinner'),
        spinnerMsg: document.getElementById('spinnerMsg')
    };

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    tabButtons.forEach(btn => btn.addEventListener('click', () => setActiveTab(btn.dataset.tab)));

    function getActiveTab() {
        return document.querySelector('.tab-btn.active')?.dataset.tab || 'analysis';
    }

    function setActiveTab(tab) {
        tabButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.tab-pane').forEach(pane => {
            pane.classList.toggle('active', pane.dataset.tabPanel === tab);
        });

        if (tab === 'results') {
            window.setTimeout(() => renderResults(true), 0);
        } else if (tab === 'charts') {
            window.setTimeout(() => renderCharts(state.summary), 0);
        }
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatNumber(value) {
        return Number(value || 0).toLocaleString();
    }

    function normalizeTableName(value) {
        return String(value || '').trim();
    }

    function normalizeTableList(items) {
        return [...new Set((items || [])
            .map(item => normalizeTableName(item))
            .filter(Boolean))];
    }

    function normalizeBrowserSummary(summary) {
        if (!summary) {
            return summary;
        }

        const rows = Array.isArray(summary.reviewRows) ? summary.reviewRows : [];
        if (rows.length <= browserResultsRenderLimit) {
            return summary;
        }

        return {
            ...summary,
            reviewRows: rows.slice(0, browserResultsRenderLimit),
            displayedCount: Math.min(Number(summary.displayedCount || rows.length), browserResultsRenderLimit),
            isPreviewOnly: true,
            previewLimit: Number(summary.previewLimit || browserResultsRenderLimit)
        };
    }

    function normalizeRole(value) {
        return String(value || '').replace(/[^a-z0-9]+/gi, '').toLowerCase();
    }

    function updateWorkspaceButtons() {
        const role = state.currentUserEngagementRole || currentSystemRole || '';
        const normalizedRole = normalizeRole(role);
        const normalizedSystemRole = normalizeRole(currentSystemRole);
        const hasUnsavedValidation = !!state.summary &&
            (!!state.hasPendingValidation || (!state.currentRunId && !state.isWorkspaceSaved));
        const canEdit = !isResultsOnlyRole &&
            (normalizedSystemRole === 'dataanalyst' || normalizedRole === 'dataanalyst' || hasUnsavedValidation);
        const canSignWorkspace = !state.hasPendingValidation && !!state.currentRunId &&
            !!state.isWorkspaceSaved &&
            (normalizedRole === 'dataanalyst' || (state.resultsVisible && (normalizedRole === 'manager' || normalizedRole === 'director')));
        const signoffLocked = !!state.currentUserHasSignedOff;
        const signoffButtonText = state.currentUserHasSignedOff
            ? `Signed Off as ${role || currentSystemRole || 'Reviewer'}`
            : 'Save Signoff';
        window.ruleWorkspaceUi.setReadonlyShell('app', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.setFormSectionReadonly('.accordion-stack', !canEdit || signoffLocked);
        window.ruleWorkspaceUi.applyStates([
            { target: 'connectBtn', disabled: !canEdit || signoffLocked },
            { target: 'verifyBtn', disabled: !canEdit || signoffLocked },
            { target: 'runBtn', disabled: !canEdit || signoffLocked },
            { target: 'sqlBtn', disabled: !canEdit || signoffLocked },
            { target: 'rScriptBtn', disabled: !canEdit || signoffLocked },
            { target: els.beginEditBtn, disabled: signoffLocked || !canEdit || !state.currentRunId || state.hasPendingValidation },
            { target: els.saveWorkspaceBtn, disabled: signoffLocked || !canEdit || !hasUnsavedValidation },
            {
                target: els.signoffBtn,
                show: canSignWorkspace,
                disabled: signoffLocked || !canSignWorkspace,
                text: signoffButtonText
            },
            { target: els.removeSignoffBtn, show: state.currentUserHasSignedOff, display: '', disabled: !state.currentUserHasSignedOff },
            { target: els.workspaceSignoffComment, disabled: signoffLocked || !canSignWorkspace },
            { target: els.downloadAllBtn, disabled: !state.summary }
        ]);
        window.ruleWorkspaceUi.setButtonGroupReadonly(['.workspace-signoff-actions', '.action-bar'], signoffLocked, {
            allow: ['#downloadAllBtn', '#downloadExcelBtn', '#downloadCsvBtn', '#downloadSqlBtn', '#removeSignoffBtn']
        });
        applyWorkspaceAccessMode(canEdit);
    }

    function applyWorkspaceAccessMode(canEditWorkspace) {
        ['body-connection', 'body-config'].forEach(function(id) {
            var body = document.getElementById(id);
            if (!body) return;
            body.style.opacity = canEditWorkspace ? '' : '0.45';
            body.style.filter = canEditWorkspace ? '' : 'grayscale(0.15)';
            body.querySelectorAll('input, select, textarea, button').forEach(function(el) {
                el.disabled = !canEditWorkspace;
            });
        });
    }

    function buildComparisonResultCell(row, hasPqm) {
        const isPass = String(row.validationResult || '').toUpperCase() === 'PASS';
        const pqmBadge = hasPqm && row.pqmResult
            ? `<span class="badge ${String(row.pqmResult).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}" title="${escapeHtml(row.pqmExceptionReason || '')}" style="margin-left:4px">PQM: ${escapeHtml(row.pqmResult)}</span>`
            : '';
        const reviewBadge = row.pqmNeedsReview
            ? `<span class="badge badge--warn" title="${escapeHtml(row.pqmExceptionReason || '')}" style="margin-left:4px">Review</span>`
            : '';
        return `
            <div class="rule20-comparison-result">
                <span class="badge ${isPass ? 'badge--pass' : 'badge--fail'}" title="${escapeHtml(row.validationExplanation || '')}">${escapeHtml(row.validationResult || 'FAIL')}</span>
                ${pqmBadge}${reviewBadge}
                ${row.pqmExceptionReason ? `<div style="font-size:11px;color:#555;margin-top:4px;max-width:300px">${escapeHtml(row.pqmExceptionReason)}</div>` : ''}
            </div>`;
    }

    function renderComparisonSections(rows) {
        const selectedParts = (state.summary?.partSummaries || [])
            .map(part => String(part.partCode || '').toUpperCase());
        const cesmTableName = escapeHtml(String(state.summary?.studTable || 'dbo_CESM').toUpperCase());
        const qualTableName = escapeHtml(String(state.summary?.qualTable || 'dbo_QUAL').toUpperCase());
        const studTableName = escapeHtml(String(state.summary?.cregTable || 'dbo_STUD').toUpperCase());
        const hasPqm = !!(state.summary?.pqmTable);
        const pqmTableName = hasPqm ? escapeHtml(String(state.summary.pqmTable).toUpperCase()) : '';

        const sections = selectedParts.map(partCode => {
            const partRows = rows.filter(row => String(row.partCode || '').toUpperCase() === partCode);
            if (!partRows.length) {
                return '';
            }

            const partSummary = (state.summary?.partSummaries || []).find(part =>
                String(part.partCode || '').toUpperCase() === partCode);

            const pqmHeaderCols = hasPqm
                ? `<th class="rule20-spacer" rowspan="3"></th><th colspan="3">PQM</th>`
                : '';
            const pqmSubHeaderCols = hasPqm
                ? `<th colspan="3">${pqmTableName}</th>`
                : '';
            const pqmColHeaders = hasPqm
                ? `<th>PQM Code</th><th>PQM Name</th><th>PQM Result</th>`
                : '';

            return `
                <div class="card rule20-comparison-card" style="padding:20px;margin-top:16px">
                    <div class="rule20-comparison-card__header">
                        <div>
                            <div class="rule20-comparison-card__title">${escapeHtml(partSummary?.partTitle || partCode)}</div>
                            ${partSummary?.partDescription ? `<div class="rule20-comparison-card__subtitle">${escapeHtml(partSummary.partDescription)}</div>` : ''}
                        </div>
                        <div class="rule20-comparison-card__meta">
                            <span class="badge ${String(partSummary?.status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}">${escapeHtml(partSummary?.status || '')}</span>
                            <span>${formatNumber(partRows.length)} row(s)</span>
                        </div>
                    </div>
                    <div class="rule20-grid-wrap">
                        <table class="data-table rule20-comparison-table rule20-grid-table">
                            <thead>
                                <tr>
                                    <th colspan="2"></th>
                                    <th class="rule20-spacer" rowspan="3"></th>
                                    <th colspan="2">LINK TABLE</th>
                                    <th class="rule20-spacer" rowspan="3"></th>
                                    <th colspan="2"></th>
                                    ${pqmHeaderCols}
                                    <th rowspan="3">Results</th>
                                </tr>
                                <tr>
                                    <th colspan="2">${cesmTableName}</th>
                                    <th colspan="2">${qualTableName}</th>
                                    <th colspan="2">${studTableName}</th>
                                    ${pqmSubHeaderCols}
                                </tr>
                                <tr>
                                    <th>_001</th>
                                    <th>_006</th>
                                    <th>_001</th>
                                    <th>_003</th>
                                    <th>_001</th>
                                    <th>Link Status</th>
                                    ${pqmColHeaders}
                                </tr>
                            </thead>
                            <tbody>
                                ${partRows.map(row => {
                                    const pqmCells = hasPqm
                                        ? `<td class="rule20-spacer"></td>
                                           <td class="rule20-align-center">${escapeHtml(row.pqmCode || '')}</td>
                                           <td style="font-size:12px">${escapeHtml(row.pqmName || '')}</td>
                                           <td class="rule20-align-center"><span class="badge ${String(row.pqmResult || '').toUpperCase() === 'PASS' ? 'badge--pass' : (row.pqmResult ? 'badge--fail' : 'badge--neutral')}" title="${escapeHtml(row.pqmExceptionReason || '')}">${escapeHtml(row.pqmResult || '-')}${row.pqmNeedsReview ? ' &#9873;' : ''}</span></td>`
                                        : '';
                                    return `
                                    <tr>
                                        <td class="rule20-align-center">${escapeHtml(row.qualificationCode001)}</td>
                                        <td class="rule20-align-center">${escapeHtml(row.courseCode030)}</td>
                                        <td class="rule20-spacer"></td>
                                        <td class="rule20-align-center">${escapeHtml(row.bridgeQualificationCode001)}</td>
                                        <td>${escapeHtml(row.qualificationDescription003)}</td>
                                        <td class="rule20-spacer"></td>
                                        <td class="rule20-align-center">${escapeHtml(row.foundationCourse091)}</td>
                                        <td class="rule20-align-center">${escapeHtml(row.notebookStatus)}</td>
                                        ${pqmCells}
                                        <td class="rule20-align-center">${buildComparisonResultCell(row, hasPqm)}</td>
                                    </tr>`;
                                }).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>`;
        }).filter(Boolean);

        return sections.length
            ? sections.join('')
            : '<div class="empty-card" style="padding:20px;margin-top:16px"><p>No rows match the selected filters.</p></div>';
    }

    function showSpinner(message) {
        if (els.spinnerMsg) els.spinnerMsg.textContent = message;
        if (els.spinner) els.spinner.style.display = 'flex';
    }

    function hideSpinner() {
        if (els.spinner) els.spinner.style.display = 'none';
    }

    async function postJson(url, payload) {
        return await window.fetchJsonWithProgress(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload)
        });
    }

    async function downloadBlob(url, payload, fileName) {
        await window.downloadFileWithProgress({
            url,
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload),
            defaultFileName: fileName,
            label: 'Downloading result'
        });
    }

    function setStatusBadge(status) {
        if (!els.statusBadge) return;
        if (!status) {
            els.statusBadge.style.display = 'none';
            els.statusBadge.textContent = '';
            els.statusBadge.className = 'rule-header__badge';
            return;
        }

        els.statusBadge.style.display = '';
        els.statusBadge.textContent = status;
        els.statusBadge.className = `rule-header__badge ${String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    }

    function setWorkspaceState(message, type) {
        els.workspaceInfo.className = `alert alert--${type}`;
        els.workspaceInfo.textContent = message;
        window.showWorkspaceActionToast?.(message, type);
    }

    function getRequest() {
        return {
            clientId: Number(els.clientId?.value || state.clientId || 0),
            runId: state.currentRunId,
            server: els.server?.value?.trim() || '',
            database: els.database?.value || '',
            driver: els.driver?.value || 'ODBC Driver 17 for SQL Server',
            studTable: normalizeTableName(els.studTable?.value || ''),
            qualTable: normalizeTableName(els.qualTable?.value || defaultQualTable),
            cregTable: normalizeTableName(els.cregTable?.value || ''),
            crseTable: normalizeTableName(els.crseTable?.value || els.cregTable?.value || ''),
            pgTypesText: els.pgTypesText?.value || defaultPgTypesText,
            governingPartCodes: [...defaultGoverningPartCodes],
            pqmTable: normalizeTableName(els.pqmTable?.value || ''),
            cesmIdCol: els.cesmIdCol?.value || '_001',
            cesmCodeCol: els.cesmCodeCol?.value || '_006',
            qualIdCol: els.qualIdCol?.value || '_001',
            qualNameCol: els.qualNameCol?.value || '_003',
            studIdCol: els.studIdCol?.value || '_001',
            pqmNameCol: els.pqmNameCol?.value || 'Authorised_Qualification_Name',
            pqmCode1Col: els.pqmCode1Col?.value || 'CESM_Code',
            pqmCode2Col: els.pqmCode2Col?.value || 'CESM_Code2'
        };
    }

    function updatePqmInfoBox() {
        const hasPqm = !!(els.pqmTable?.value?.trim());
        const infoBox = document.getElementById('pqmMatchingInfo');
        if (infoBox) infoBox.style.display = ''; // always visible — PQM is required
        if (hasPqm) {
            const cesmCodeColLabel = document.getElementById('pqmCesmCodeColLabel');
            const qualNameColLabel = document.getElementById('pqmQualNameColLabel');
            const pqmCode1Label = document.getElementById('pqmCode1ColLabel');
            const pqmCode2Label = document.getElementById('pqmCode2ColLabel');
            const pqmNameLabel = document.getElementById('pqmNameColLabel');
            if (cesmCodeColLabel) cesmCodeColLabel.textContent = els.cesmCodeCol?.value || '_006';
            if (qualNameColLabel) qualNameColLabel.textContent = els.qualNameCol?.value || '_003';
            if (pqmCode1Label) pqmCode1Label.textContent = els.pqmCode1Col?.value || 'CESM_Code';
            if (pqmCode2Label) pqmCode2Label.textContent = els.pqmCode2Col?.value || 'CESM_Code2';
            if (pqmNameLabel) pqmNameLabel.textContent = els.pqmNameCol?.value || 'Authorised_Qualification_Name';
        }
    }

    function populateSelect(select, items, selectedValue) {
        if (!select) return;
        const normalizedItems = normalizeTableList(items);
        const normalizedSelectedValue = normalizeTableName(selectedValue || '');
        select.innerHTML = '';
        normalizedItems.forEach(item => {
            const opt = document.createElement('option');
            opt.value = item;
            opt.textContent = item;
            if (normalizedSelectedValue && normalizedSelectedValue === item) opt.selected = true;
            select.appendChild(opt);
        });
    }

    function renderAnalysis(summary) {
        if (!summary) {
            els.analysisPane.innerHTML = '<div class="empty-card"><p>No Rule 13 results loaded.</p></div>';
            return;
        }

        const partsHtml = (summary.partSummaries || []).map(part => `
            <tr>
                <td><strong>${escapeHtml(part.partCode)}</strong></td>
                <td>${escapeHtml(part.partTitle)}</td>
                <td>${formatNumber(part.totalCount)}</td>
                <td>${formatNumber(part.passCount)}</td>
                <td>${formatNumber(part.failCount)}</td>
                <td><span class="badge ${String(part.status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}">${escapeHtml(part.status)}</span></td>
            </tr>`).join('');

        const procedureSteps = (summary.procedureSteps || [])
            .map(step => `<li>${escapeHtml(step)}</li>`)
            .join('');

        const hasPqm = !!(summary.pqmTable);
        const reviewCountCard = hasPqm && Number(summary.reviewCount || 0) > 0
            ? `<div class="stat-card stat-card--warn">
                    <div class="stat-card__label">PQM Review Required</div>
                    <div class="stat-card__value">${formatNumber(summary.reviewCount)}</div>
               </div>`
            : '';
        els.analysisPane.innerHTML = `
            <div class="stats-grid" style="margin-bottom:24px">
                <div class="stat-card">
                    <div class="stat-card__label">Qualifying CESM Population</div>
                    <div class="stat-card__value">${formatNumber(summary.foundationStudentCount)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__label">Validated Rows</div>
                    <div class="stat-card__value">${formatNumber(summary.totalValidated)}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__label">PASS Rows</div>
                    <div class="stat-card__value">${formatNumber(summary.passCount)}</div>
                </div>
                <div class="stat-card stat-card--fail">
                    <div class="stat-card__label">FAIL Rows</div>
                    <div class="stat-card__value">${formatNumber(summary.failCount)}</div>
                </div>
                ${reviewCountCard}
            </div>
            <div class="card" style="padding:20px">
                <div class="form-grid" style="margin-bottom:16px">
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>${escapeHtml(summary.database)}</div></div>
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Tables</div><div>CESM: ${escapeHtml(summary.studTable)} | QUAL: ${escapeHtml(summary.qualTable)} | STUD: ${escapeHtml(summary.cregTable)}</div></div>
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><span class="badge ${String(summary.status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail'}">${escapeHtml(summary.status)}</span></div></div>
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Rule Scope</div><div>${escapeHtml(summary.governingPartCodesText || '100% population')}</div></div>
                    <div style="grid-column:1 / -1"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Linkage Used</div><div>${escapeHtml(summary.tableLinkageText || '')}</div></div>
                    <div style="grid-column:1 / -1"><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Overall PASS Rule</div><div>${escapeHtml(summary.overallStatusRuleText || '')}</div></div>
                </div>
                ${procedureSteps ? `
                    <div style="margin:0 0 16px 0">
                        <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700;margin-bottom:8px">Procedure Performed</div>
                        <ol style="margin:0;padding-left:20px">${procedureSteps}</ol>
                    </div>` : ''}
                <table class="data-table">
