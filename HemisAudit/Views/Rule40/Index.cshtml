@using HemisAudit.Models
@{
    ViewData["Title"] = "Rule 40 – PROF VALPAC vs 2025H16PROF";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients           = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId  = ViewBag.ClientId is int cid ? cid : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole = string.Equals(currentSystemRole, "Manager",  StringComparison.OrdinalIgnoreCase)
                         || string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(currentSystemRole, "Trainee",  StringComparison.OrdinalIgnoreCase);
    var moduleNavigation  = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
}

<style>
.r40-pair-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:6px; background:#f9f9f9; padding:6px 8px; border-radius:6px; border:1px solid #e8e8e8; }
.r40-pair-row input[type=text] { font-size:.82rem; border:1px solid #ccc; border-radius:4px; padding:3px 7px; min-width:100px; max-width:170px; }
.r40-pair-del { background:#C0392B; color:#fff; border:none; border-radius:4px; padding:2px 8px; cursor:pointer; font-size:.8rem; flex-shrink:0; }
.r40-tbl { border-collapse:collapse; width:100%; font-size:.81rem; }
.r40-tbl th { background:#1565A6; color:#fff; padding:5px 7px; text-align:center; border:1px solid #bbb; white-space:nowrap; }
.r40-tbl td { padding:4px 6px; border:1px solid #ddd; text-align:center; vertical-align:middle; }
.r40-tbl tr.agree    { background:#F1F8E9; }
.r40-tbl tr.disagree { background:#FFEBEE; }
.r40-tbl tr.missing  { background:#FFF3E0; }
.r40-tbl td.ac { background:#DDEEFF; }
.r40-agree { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#E8F5E9; color:#1E8449; }
.r40-exc   { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#FFEBEE; color:#C0392B; }
.r40-miss  { display:inline-block; padding:2px 7px; border-radius:4px; font-size:.75rem; font-weight:700; background:#FFF3E0; color:#E67E22; }
.workspace-signoff-actions { display:flex; gap:10px; flex-wrap:wrap; padding-top:4px; }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="r40ClientId">Engagement</label>
        <select id="r40ClientId" onchange="r40OnClientChange(this.value)">
            <option value="">Select engagement</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">R40</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 40: PROF VALPAC vs 2025H16PROF Staff Agreement</h1>
            <p class="rule-header__sub">
                Full outer reconciliation — <code>VALPAC PROF</code> vs <code>2025H16PROF</code>.
                Configurable join key and field-by-field comparison columns.
            </p>
        </div>
        <div class="rule-header__badge" id="r40StatusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
    <div class="accordion-stack">
        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r40-conn')">
                <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r40-conn">
                <div class="form-grid">
                    <div class="field-group">
                        <label for="r40Server">Server Name</label>
                        <input id="r40Server" type="text" placeholder="SERVER\INSTANCE or (localdb)\MSSQLLocalDB" />
                    </div>
                    <div class="field-group">
                        <label for="r40Driver">Driver</label>
                        <select id="r40Driver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="r40Db">Database</label>
                        <select id="r40Db" onchange="r40LoadTables()"></select>
                    </div>
                </div>
                <div class="action-bar" style="justify-content:flex-start;margin:10px 0 0">
                    <button type="button" class="btn btn-primary" onclick="r40Connect()">Connect</button>
                </div>
                <div id="r40ConnOut" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r40-tables')">
                <span class="acc-icon">TB</span><span>Table Configuration &amp; Join Key</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r40-tables" style="display:none">
                <div class="info-box info-box--red" style="margin-bottom:12px">
                    Tables auto-detected on connect. Set join key columns for both tables and configure comparison fields below.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>VALPAC Table (Staff PROF)</label>
                        <select id="r40ValpacTable" onchange="r40OnValpacTableChange()"></select>
                    </div>
                    <div class="field-group">
                        <label>ASCII Table (2025H16PROF)</label>
                        <select id="r40AsciiTable" onchange="r40OnAsciiTableChange()"></select>
                    </div>
                    <div class="field-group">
                        <label>VALPAC Join Key Column</label>
                        <select id="r40ValpacKey" onchange="r40OnValpacKeyChange()"></select>
                    </div>
                    <div class="field-group">
                        <label>ASCII Join Key Column</label>
                        <select id="r40AsciiKey" onchange="r40OnAsciiKeyChange()"></select>
                    </div>
                </div>
                <div id="r40TableOut" class="status-output"></div>
            </div>
        </div>

        <div class="accordion-item">
            <button class="accordion-toggle" type="button" onclick="toggleAccordion('r40-colmap')">
                <span class="acc-icon">CM</span><span>Column Mapping</span><span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="body-r40-colmap" style="display:none">
                <div class="alert alert--info" style="margin-bottom:12px">
                    Map VALPAC columns to ASCII columns for field-by-field comparison. The join key is set in Table Configuration above.
                </div>
                <div id="r40ColPairs"></div>
                <button type="button" class="btn btn-secondary" style="margin-top:8px;font-size:.82rem" onclick="r40AddPair()">&#65291; Add pair</button>
            </div>
        </div>
    </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 40 configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="r40RunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="r40WorkspaceInfo" class="alert alert--info">Select an engagement to load the saved Rule 40 workspace.</div>
        <div class="workspace-signoff-grid">
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div>
                <div id="r40RunLabel">No saved run yet</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                <div id="r40StatusLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Last Edited</div>
                <div id="r40EditedLabel">-</div>
            </div>
            <div>
                <div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Your Role</div>
                <div id="r40RoleLabel">@(string.IsNullOrWhiteSpace(currentSystemRole) ? "-" : currentSystemRole)</div>
            </div>
            <div class="field-group" style="grid-column:1/-1">
                <label for="r40SignoffComment">Signoff Comment</label>
                <textarea id="r40SignoffComment" rows="2" placeholder="Add the final review note confirming this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button class="btn btn-success" id="r40SaveBtn" onclick="r40SaveWorkspace()">Save Workspace</button>
            }
            <button class="btn btn-primary" id="r40SignoffBtn" onclick="r40SignOff()">Sign Off</button>
            <button class="btn btn-warning" id="r40RemoveSignoffBtn" onclick="r40RemoveSignoff()" style="display:none">Remove Signoff</button>
        </div>
    </div>

    <div class="action-bar">
        @if (!isResultsOnlyRole)
        {
            <button class="btn btn-info"    onclick="r40Verify()">Verify Tables</button>
            <button class="btn btn-success" onclick="r40Run()">&#9654; Run Rule 40</button>
            <button class="btn btn-primary" onclick="r40GenerateSql()">Generate SQL</button>
        }
        <button class="btn btn-warning" id="r40DlAllBtn" onclick="r40DlAll()" disabled>Download All</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="r40-analysis"  onclick="r40Tab('r40-analysis')">Analysis</button>
            <button class="tab-btn"        type="button" data-tab="r40-flagged"   onclick="r40Tab('r40-flagged')">EXCEPTIONS</button>
            <button class="tab-btn"        type="button" data-tab="r40-clear"     onclick="r40Tab('r40-clear')">AGREE</button>
            <button class="tab-btn"        type="button" data-tab="r40-sql"       onclick="r40Tab('r40-sql')">SQL Code</button>
            <button class="tab-btn"        type="button" data-tab="r40-downloads" onclick="r40Tab('r40-downloads')">Downloads</button>
        </div>
        <div class="tab-pane active" data-tab-panel="r40-analysis">
            <div id="r40AnalysisPane"><div class="empty-state"><p>Run Rule 40 validation to see results here.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r40-flagged">
            <div id="r40FlaggedPane"><div class="empty-state"><p>No exception rows yet — run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r40-clear">
            <div id="r40ClearPane"><div class="empty-state"><p>No agree rows yet — run validation first.</p></div></div>
        </div>
        <div class="tab-pane" data-tab-panel="r40-sql">
            <textarea id="r40SqlText" rows="20" readonly style="width:100%;font-family:monospace;font-size:12px"></textarea>
        </div>
        <div class="tab-pane" data-tab-panel="r40-downloads">
            <div class="alert alert--info" style="margin-bottom:12px">Download the full Rule 40 result set after running and saving validation.</div>
            <div class="action-bar" style="justify-content:flex-start;margin:0">
                <button type="button" class="btn btn-info"      id="r40DlExcel">Excel</button>
                <button type="button" class="btn btn-info"      id="r40DlCsv">CSV</button>
                <button type="button" class="btn btn-secondary" id="r40DlSql">SQL</button>
            </div>
        </div>
    </div>

    <div id="r40Spinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="r40SpinMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="r40AntiForgery" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = window.toggleAccordion || function(s) {
    var b = document.getElementById('body-' + s);
    if (b) b.style.display = b.style.display === 'none' ? '' : 'none';
};

window.r40Tab = function(tab) {
    document.querySelectorAll('#app .results-panel .tab-btn').forEach(function(b) { b.classList.toggle('active', b.dataset.tab === tab); });
    document.querySelectorAll('#app .results-panel .tab-pane').forEach(function(p) { p.classList.toggle('active', p.dataset.tabPanel === tab); });
};

(function () {
    var API = '/Rule40';
    var ROLE = '@currentSystemRole';
    var IS_RESULTS_ONLY = @(isResultsOnlyRole.ToString().ToLowerInvariant());
    var TOKEN = (document.querySelector('#r40AntiForgery input[name="__RequestVerificationToken"]') || {}).value || '';

    var DEF_PAIRS = [
        { valpacCol:'_011', asciiCol:'_011', label:'Date of Birth' },
        { valpacCol:'_012', asciiCol:'_012', label:'Gender' },
        { valpacCol:'_013', asciiCol:'_013', label:'Race' },
        { valpacCol:'_014', asciiCol:'_014', label:'Nationality' },
        { valpacCol:'_038', asciiCol:'_038', label:'Empl. Commencement' },
        { valpacCol:'_042', asciiCol:'_042', label:'Full/Part-time' }
    ];

    var st = {
        clientId: @(selectedClientId > 0 ? selectedClientId : 0),
        runId: null, summary: null, pairs: [],
        valpacCols: [], asciiCols: [],
        valpacKey: '_037', asciiKey: '_037',
        isWorkspaceSaved: false, currentUserHasSignedOff: false, resultsVisible: false,
        currentUserEngagementRole: ''
    };

    function g(id)             { return document.getElementById(id); }
    function gv(id)            { var e = g(id); return e ? e.value : ''; }
    function esc(v)            { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function fmt(n)            { return Number(n || 0).toLocaleString(); }
    function show(id, v)       { var e = g(id); if (e) e.style.display = v ? '' : 'none'; }
    function setHtml(id, html) { var e = g(id); if (e) e.innerHTML = html; }
    function spin(msg)         { var e = g('r40SpinMsg'); if (e) e.textContent = msg || 'Processing...'; show('r40Spinner', true); }
    function unspin()          { show('r40Spinner', false); }
    function setWs(msg, type)  { var e = g('r40WorkspaceInfo'); if (e) { e.className = 'alert alert--' + (type || 'info'); e.textContent = msg; } }
    function setOut(id, msg, type) { var e = g(id); if (e) { e.className = 'status-output alert alert--' + (type || 'info'); e.textContent = msg; } }

    function fillSel(id, items, selected) {
        var sel = g(id); if (!sel) return;
        sel.innerHTML = '';
        (items || []).forEach(function(item) {
            var o = document.createElement('option');
            o.value = o.textContent = item;
            if (selected && selected === item) o.selected = true;
            sel.appendChild(o);
        });
    }

    function post(url, body) {
        return fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify(body)
        }).then(function(r) { return r.json(); });
    }

    function setStatusBadge(status) {
        var b = g('r40StatusBadge'); if (!b) return;
        if (!status) { b.style.display = 'none'; return; }
        b.style.display = ''; b.textContent = status;
        b.className = 'rule-header__badge ' + (String(status).toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail');
    }

    /* ── Key column helpers ── */
    function fillKeySel(id, cols, currentVal) {
        var sel = g(id); if (!sel) return;
        var prev = currentVal || '_037';
        sel.innerHTML = '<option value="">-- select key --</option>' +
            (cols || []).map(function(c) {
                return '<option value="' + esc(c) + '"' + (c === prev ? ' selected' : '') + '>' + esc(c) + '</option>';
            }).join('');
    }
    window.r40OnValpacKeyChange = function() { st.valpacKey = gv('r40ValpacKey') || '_037'; };
    window.r40OnAsciiKeyChange  = function() { st.asciiKey  = gv('r40AsciiKey')  || '_037'; };

    /* ── Column loading ── */
    function loadOneCols(tableName, side) {
        if (!tableName) return;
        post(API + '/GetTableColumns', {
            server: gv('r40Server').trim(), database: gv('r40Db'), driver: gv('r40Driver'),
            tableName: tableName
        }).then(function(d) {
            if (!d.success || !d.columns) return;
            if (side === 'valpac') {
                st.valpacCols = d.columns;
                fillKeySel('r40ValpacKey', d.columns, st.valpacKey);
            } else {
                st.asciiCols = d.columns;
                fillKeySel('r40AsciiKey', d.columns, st.asciiKey);
            }
            renderPairs();
        }).catch(function() {});
    }

    window.r40OnValpacTableChange = function() { loadOneCols(gv('r40ValpacTable'), 'valpac'); };
    window.r40OnAsciiTableChange  = function() { loadOneCols(gv('r40AsciiTable'),  'ascii');  };

    function r40LoadColumns() {
        loadOneCols(gv('r40ValpacTable'), 'valpac');
        loadOneCols(gv('r40AsciiTable'),  'ascii');
    }

    /* ── Pair Management ── */
    function makeColSel(idx, side, val, cols) {
        var key = side === 'valpac' ? 'valpacCol' : 'asciiCol';
        var ph  = side === 'valpac' ? 'VALPAC col' : 'ASCII col';
        var opts = (cols || []).map(function(c) {
            return '<option value="' + esc(c) + '"' + (c === val ? ' selected' : '') + '>' + esc(c) + '</option>';
        }).join('');
        var hasCols = cols && cols.length > 0;
        if (hasCols) {
            return '<select onchange="r40PairSet(' + idx + ',\'' + key + '\',this.value)" ' +
                'style="font-size:.82rem;border:1px solid #ccc;border-radius:4px;padding:3px 6px;min-width:110px;max-width:175px">' +
                '<option value="">-- ' + ph + ' --</option>' + opts + '</select>';
        }
        return '<input type="text" placeholder="' + ph + '" value="' + esc(val) + '" ' +
            'oninput="r40PairSet(' + idx + ',\'' + key + '\',this.value)" ' +
            'style="font-size:.82rem;border:1px solid #ccc;border-radius:4px;padding:3px 7px;min-width:100px;max-width:170px">';
    }

    function renderPairs() {
        var box = g('r40ColPairs'); if (!box) return;
        box.innerHTML = '';
        if (!st.pairs || !st.pairs.length) st.pairs = DEF_PAIRS.slice();
        st.pairs.forEach(function(p, i) {
            var row = document.createElement('div'); row.className = 'r40-pair-row';
            row.innerHTML = '<span style="color:#888;font-size:.8rem">#' + (i + 1) + '</span>' +
                makeColSel(i, 'valpac', p.valpacCol, st.valpacCols) +
                '<span style="color:#999">&harr;</span>' +
                makeColSel(i, 'ascii',  p.asciiCol,  st.asciiCols) +
                '<input type="text" placeholder="Label" value="' + esc(p.label) + '" ' +
                'oninput="r40PairSet(' + i + ',\'label\',this.value)" style="font-size:.82rem;border:1px solid #ccc;border-radius:4px;padding:3px 7px;max-width:200px">' +
                '<button class="r40-pair-del" onclick="r40RemovePair(' + i + ')">&#x2715;</button>';
            box.appendChild(row);
        });
    }

    window.r40PairSet    = function(i, key, val) { if (st.pairs[i]) st.pairs[i][key] = val; };
    window.r40RemovePair = function(i) { st.pairs.splice(i, 1); renderPairs(); };
    window.r40AddPair    = function() { st.pairs.push({ valpacCol: '', asciiCol: '', label: '' }); renderPairs(); };

    /* ── Connection ── */
    window.r40Connect = function() {
        var server = gv('r40Server').trim();
        if (!server) { setWs('Enter a server name first.', 'warning'); return; }
        spin('Connecting to server...');
        post(API + '/GetDatabases', { server: server, driver: gv('r40Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setOut('r40ConnOut', d.error || 'Connection failed.', 'error'); return; }
            fillSel('r40Db', d.databases || []);
            setOut('r40ConnOut', 'Connected — ' + (d.databases || []).length + ' database(s) found.', 'success');
            if ((d.databases || []).length) r40LoadTables();
        }).catch(function(e) { unspin(); setOut('r40ConnOut', e.message, 'error'); });
    };

    window.r40LoadTables = function() {
        var db = gv('r40Db'); if (!db) return;
        spin('Loading tables...');
        post(API + '/GetTables', { server: gv('r40Server').trim(), database: db, driver: gv('r40Driver') })
        .then(function(d) {
            unspin();
            if (!d.success) { setOut('r40TableOut', d.error || 'Failed to load tables.', 'error'); return; }
            var tables = d.tables || [];
            fillSel('r40ValpacTable', tables, d.autoValpacTable);
            fillSel('r40AsciiTable',  tables, d.autoAsciiTable);
            show('body-r40-tables', true);
            show('body-r40-colmap', true);
            setOut('r40TableOut', 'Loaded ' + tables.length + ' tables — VALPAC and ASCII auto-detected.', 'success');
            st.pairs = DEF_PAIRS.slice();
            renderPairs();
            r40LoadColumns();
        }).catch(function(e) { unspin(); setOut('r40TableOut', e.message, 'error'); });
    };

    window.r40Verify = function() {
        var vt = gv('r40ValpacTable'), at = gv('r40AsciiTable');
        if (!vt || !at) { setOut('r40TableOut', 'Select both tables first.', 'error'); return; }
        spin('Verifying tables...');
        post(API + '/VerifyTables', {
            server: gv('r40Server').trim(), database: gv('r40Db'), driver: gv('r40Driver'),
            valpacTable: vt, asciiTable: at
        }).then(function(d) {
            unspin();
            if (!d.success) { setOut('r40TableOut', d.error || 'Verification failed.', 'error'); return; }
            setOut('r40TableOut', 'VALPAC: ' + fmt(d.valpacCount) + ' rows | ASCII: ' + fmt(d.asciiCount) + ' rows', 'success');
        }).catch(function(e) { unspin(); setOut('r40TableOut', e.message, 'error'); });
    };

    function buildReq() {
        var activePairs = (st.pairs || DEF_PAIRS).filter(function(p) { return p.valpacCol && p.asciiCol; });
        return {
            clientId: st.clientId, runId: st.runId,
            server: gv('r40Server').trim(), database: gv('r40Db'), driver: gv('r40Driver') || 'ODBC Driver 17 for SQL Server',
            valpacTable: gv('r40ValpacTable'), asciiTable: gv('r40AsciiTable'),
            valpacKeyCol: gv('r40ValpacKey') || st.valpacKey || '_037',
            asciiKeyCol:  gv('r40AsciiKey')  || st.asciiKey  || '_037',
            pairs: activePairs
        };
    }

    /* ── Run ── */
    window.r40Run = function() {
        if (!st.clientId) { setWs('Select an engagement before running.', 'warning'); return; }
        spin('Running Rule 40 validation...');
        post(API + '/RunValidation', buildReq())
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Validation failed.', 'error'); return; }
            st.runId = d.savedRunId || st.runId;
            st.currentUserHasSignedOff = false; st.isWorkspaceSaved = false; st.resultsVisible = true;
            applySummary(d, false);
            setWs('Rule 40 complete. Total: ' + fmt(d.totalCount) + ' | Agree: ' + fmt(d.agreeCount) + ' | Exceptions: ' +
                fmt((d.disagreeCount || 0) + (d.missingInAsciiCount || 0) + (d.missingInValpacCount || 0)) + '. Overall: ' + d.status,
                d.status === 'PASS' ? 'success' : 'warning');
            var dlBtn = g('r40DlAllBtn'); if (dlBtn) dlBtn.disabled = false;
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    /* ── SQL ── */
    window.r40GenerateSql = function() {
        spin('Generating SQL...');
        post(API + '/GenerateSql', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { alert('Error: ' + (d.error || 'Failed.')); return; }
            var t = g('r40SqlText'); if (t) t.value = d.sql || '';
            r40Tab('r40-sql');
        }).catch(function(e) { unspin(); alert(e.message); });
    };

    window.r40DlAll = function() { if (st.runId) window.open(API + '/DownloadExcel?runId=' + st.runId, '_blank'); };

    /* ── Workspace ── */
    window.r40SaveWorkspace = function() {
        spin('Saving workspace...');
        post(API + '/SaveWorkspace', buildReq()).then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || d.message || 'Save failed.', 'error'); return; }
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Workspace saved.', 'success');
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r40SignOff = function() {
        spin('Saving signoff...');
        post(API + '/SignOffWorkspace', { clientId: st.clientId, runId: st.runId, comment: gv('r40SignoffComment') })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Signoff failed.', 'error'); return; }
            st.currentUserHasSignedOff = true;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff saved.', 'success'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    window.r40RemoveSignoff = function() {
        spin('Removing signoff...');
        post(API + '/RemoveWorkspaceSignoff', { clientId: st.clientId, runId: st.runId, comment: '' })
        .then(function(d) {
            unspin();
            if (!d.success) { setWs(d.error || 'Failed.', 'error'); return; }
            st.currentUserHasSignedOff = false;
            if (d.workspace) applyWsMeta(d.workspace);
            setWs(d.message || 'Signoff removed.', 'warning'); updateButtons();
        }).catch(function(e) { unspin(); setWs(e.message, 'error'); });
    };

    function applyWsMeta(ws) {
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        if (ws.currentUserEngagementRole) st.currentUserEngagementRole = ws.currentUserEngagementRole;
        var b   = g('r40RunState');    if (b)   b.textContent   = ws.runId ? 'Run #' + ws.runId : 'No saved run loaded';
        var rl  = g('r40RunLabel');    if (rl)  rl.textContent  = ws.runId ? 'Rule 40 Run #' + ws.runId : 'No saved run yet';
        var sl  = g('r40StatusLabel'); if (sl)  sl.textContent  = ws.currentStatus || '-';
        var el  = g('r40EditedLabel'); if (el)  el.textContent  = ws.lastEditedAt ? new Date(ws.lastEditedAt).toLocaleString() : '-';
        var rl2 = g('r40RoleLabel');   if (rl2) rl2.textContent = ws.currentUserEngagementRole || ROLE || '-';
        var sc  = g('r40SignoffComment'); if (sc && ws.currentUserSignoffComment) sc.value = ws.currentUserSignoffComment;
        updateButtons();
    }

    function updateButtons() {
        var engRole = (st.currentUserEngagementRole || ROLE || '').toLowerCase();
        var canEdit = !IS_RESULTS_ONLY && (engRole === 'dataanalyst' || ROLE.toLowerCase() === 'dataanalyst');
        var canSign = !!st.runId && !!st.isWorkspaceSaved &&
            (engRole === 'dataanalyst' || (st.resultsVisible && (engRole === 'manager' || engRole === 'director')));
        var signed  = st.currentUserHasSignedOff;
        var sw = g('r40SaveBtn');   if (sw) sw.disabled = signed || !canEdit || !st.runId;
        var so = g('r40SignoffBtn');if (so) { so.disabled = signed || !canSign; so.textContent = signed ? 'Signed Off' : 'Sign Off'; }
        show('r40RemoveSignoffBtn', signed);
        // Lock the whole configuration shell after signoff
        window.ruleWorkspaceUi?.setReadonlyShell('app', signed);
        window.ruleWorkspaceUi?.setFormSectionReadonly('.accordion-stack', signed);
        window.ruleWorkspaceUi?.setButtonGroupReadonly(['.action-bar'], signed, {
            except: ['r40SignoffBtn', 'r40RemoveSignoffBtn', 'r40SaveBtn', 'r40DlAllBtn']
        });
    }

    /* ── Client change ── */
    window.r40OnClientChange = function(val) {
        st.clientId = parseInt(val) || 0;
        if (!st.clientId) { setWs('Select an engagement to load the saved Rule 40 workspace.', 'info'); return; }
        loadWorkspace();
    };

    function loadWorkspace() {
        if (!st.clientId) return;
        setWs('Loading saved workspace...', 'info');
        fetch(API + '/GetWorkspaceState?clientId=' + st.clientId)
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d.success) { setWs(d.error || 'Failed to load workspace.', 'error'); return; }
            applyWorkspace(d.workspace, d.resultsVisible);
        }).catch(function(e) { setWs(e.message, 'error'); });
    }

    function applyWorkspace(ws, resultsVisible) {
        if (!ws) {
            st.runId = null; st.summary = null; st.isWorkspaceSaved = false;
            st.currentUserHasSignedOff = false; st.resultsVisible = false; st.currentUserEngagementRole = '';
            setWs('No saved Rule 40 workspace for this engagement yet.', 'info');
            var b  = g('r40RunState');    if (b)  b.textContent  = 'No saved run loaded';
            var rl = g('r40RunLabel');    if (rl) rl.textContent = 'No saved run yet';
            var sl = g('r40StatusLabel'); if (sl) sl.textContent = '-';
            var el = g('r40EditedLabel'); if (el) el.textContent = '-';
            st.pairs = DEF_PAIRS.slice(); renderPairs();
            applySummary(null, false); updateButtons(); return;
        }
        st.runId = ws.runId || null;
        st.isWorkspaceSaved = !!ws.isWorkspaceSaved;
        st.currentUserHasSignedOff = !!ws.currentUserHasSignedOff;
        st.resultsVisible = !!resultsVisible;
        st.currentUserEngagementRole = ws.currentUserEngagementRole || '';

        if (!IS_RESULTS_ONLY) {
            var sv = g('r40Server'); if (sv && ws.server) sv.value = ws.server;
            var dv = g('r40Driver'); if (dv && ws.driver) dv.value = ws.driver;
            if (ws.database)    fillSel('r40Db',         [ws.database],    ws.database);
            if (ws.valpacTable) fillSel('r40ValpacTable',[ws.valpacTable], ws.valpacTable);
            if (ws.asciiTable)  fillSel('r40AsciiTable', [ws.asciiTable],  ws.asciiTable);
        }
        // restore key cols from saved summary
        var savedValpacKey = (ws.summary && ws.summary.valpacKeyCol) || (ws.valpacKeyCol) || '_037';
        var savedAsciiKey  = (ws.summary && ws.summary.asciiKeyCol)  || (ws.asciiKeyCol)  || '_037';
        st.valpacKey = savedValpacKey; st.asciiKey = savedAsciiKey;
        fillKeySel('r40ValpacKey', st.valpacCols.length ? st.valpacCols : [savedValpacKey], savedValpacKey);
        fillKeySel('r40AsciiKey',  st.asciiCols.length  ? st.asciiCols  : [savedAsciiKey],  savedAsciiKey);

        applyWsMeta(ws);
        var sc = g('r40SignoffComment'); if (sc && ws.currentUserSignoffComment) sc.value = ws.currentUserSignoffComment;

        // restore column pairs from saved summary
        var savedPairs = ws.summary && ws.summary.pairs && ws.summary.pairs.length ? ws.summary.pairs : null;
        st.pairs = savedPairs ? savedPairs.map(function(p) { return { valpacCol: p.valpacCol||p.ValpacCol||'', asciiCol: p.asciiCol||p.AsciiCol||'', label: p.label||p.Label||'' }; }) : DEF_PAIRS.slice();
        if (!IS_RESULTS_ONLY) renderPairs();

        if (!resultsVisible) { setWs('Saved Rule 40 results are not available for your role.', 'info'); applySummary(null, false); updateButtons(); return; }
        setWs(ws.summary ? 'Saved Rule 40 workspace loaded.' : 'Rule 40 workspace loaded. Run validation to generate results.', 'success');
        if (ws.summary) applySummary(ws.summary, true);
        else { applySummary(null, false); updateButtons(); }
        var dlBtn = g('r40DlAllBtn'); if (dlBtn) dlBtn.disabled = !ws.runId;
    }

    /* ── Rendering ── */
    function applySummary(summary, fromWs) {
        st.summary = summary;
        if (summary && !fromWs) st.runId = summary.savedRunId || st.runId;
        setStatusBadge(summary ? summary.status : '');
        renderAnalysis(summary);
        renderExceptions(summary);
        renderAgree(summary);
        if (summary && st.runId) {
            var dlE = g('r40DlExcel'); if (dlE) dlE.onclick = function() { window.open(API + '/DownloadExcel?runId=' + st.runId, '_blank'); };
            var dlC = g('r40DlCsv');   if (dlC) dlC.onclick = function() { window.open(API + '/DownloadCsv?runId='   + st.runId, '_blank'); };
            var dlS = g('r40DlSql');   if (dlS) dlS.onclick = function() { window.open(API + '/DownloadSql?runId='   + st.runId, '_blank'); };
        }
        updateButtons();
    }

    function renderAnalysis(s) {
        var pane = g('r40AnalysisPane'); if (!pane) return;
        if (!s) { pane.innerHTML = '<div class="empty-state"><p>Run Rule 40 validation to see results here.</p></div>'; return; }
        var sc = String(s.status || '').toUpperCase() === 'PASS' ? 'badge--pass' : 'badge--fail';
        pane.innerHTML =
            '<div class="stats-grid" style="margin-bottom:20px">' +
            statCard('Total', fmt(s.totalCount || 0), '') +
            statCard('Agree', fmt(s.agreeCount || 0), 'pass') +
            statCard('Disagree', fmt(s.disagreeCount || 0), s.disagreeCount > 0 ? 'fail' : '') +
            statCard('Missing in ASCII', fmt(s.missingInAsciiCount || 0), s.missingInAsciiCount > 0 ? 'fail' : '') +
            statCard('Missing in VALPAC', fmt(s.missingInValpacCount || 0), s.missingInValpacCount > 0 ? 'fail' : '') +
            statCard('Exception Rate', Number(s.exceptionRate || 0).toFixed(2) + '%', s.exceptionRate > 0 ? 'fail' : 'pass') +
            statCard('Overall', '<span class="badge ' + sc + '">' + esc(s.status) + '</span>', '') +
            '</div>' +
            '<div class="card" style="padding:16px"><div class="form-grid">' +
            '<div><div class="stat-label">Database</div><div>' + esc(s.database || '') + '</div></div>' +
            '<div><div class="stat-label">VALPAC Table</div><div>' + esc(s.valpacTable || '') + '</div></div>' +
            '<div><div class="stat-label">ASCII Table</div><div>' + esc(s.asciiTable || '') + '</div></div>' +
            '<div><div class="stat-label">Timestamp</div><div>' + esc(s.timestamp || '') + '</div></div>' +
            '</div></div>';
    }

    function statCard(label, value, mod) {
        var cls = mod === 'pass' ? ' stat-card--pass' : mod === 'fail' ? ' stat-card--fail' : '';
        return '<div class="stat-card' + cls + '"><div class="stat-card__label">' + label + '</div><div class="stat-card__value">' + value + '</div></div>';
    }

    function getPairs(s) {
        if (s && s.pairs && s.pairs.length) return s.pairs;
        return st.pairs && st.pairs.length ? st.pairs : DEF_PAIRS;
    }

    function renderExceptions(s) {
        var pane = g('r40FlaggedPane'); if (!pane) return;
        if (!s) { pane.innerHTML = '<div class="empty-state"><p>Run validation first.</p></div>'; return; }
        var rows = s.reviewRows || [];
        pane.innerHTML =
            '<div class="card" style="padding:12px;margin-bottom:10px;border-left:4px solid #C0392B">' +
            '<strong>EXCEPTIONS</strong>: ' + fmt(s.disagreeCount || 0) + ' DISAGREE + ' +
            fmt((s.missingInAsciiCount || 0) + (s.missingInValpacCount || 0)) + ' MISSING rows.' +
            (rows.length < ((s.disagreeCount||0)+(s.missingInAsciiCount||0)+(s.missingInValpacCount||0)) ? ' (Preview: ' + rows.length + ' shown — download for full set)' : '') +
            '</div>' + buildStaffTable(rows, getPairs(s), 'No exceptions — all staff records agree.');
    }

    function renderAgree(s) {
        var pane = g('r40ClearPane'); if (!pane) return;
        if (!s) { pane.innerHTML = '<div class="empty-state"><p>Run validation first.</p></div>'; return; }
        var rows = s.agreeSample || [];
        pane.innerHTML =
            '<div class="card" style="padding:12px;margin-bottom:10px;border-left:4px solid #1E8449">' +
            '<strong>AGREE</strong>: ' + fmt(s.agreeCount || 0) + ' staff records agree' +
            (rows.length < (s.agreeCount || 0) ? ' (sample of ' + rows.length + ' shown)' : '') + '.' +
            '</div>' + buildStaffTable(rows, getPairs(s), 'No agree rows in this run.');
    }

    function buildStaffTable(rows, pairs, emptyMsg) {
        if (!rows || !rows.length) return '<div class="empty-state"><p>' + emptyMsg + '</p></div>';
        var hdrs = pairs.map(function(p) {
            var vc = p.valpacCol || p.ValpacCol || '';
            var ac = p.asciiCol  || p.AsciiCol  || '';
            var lb = p.label     || p.Label      || vc;
            return '<th>VALPAC ' + esc(vc) + '</th><th style="background:#0D6E2E">ASCII ' + esc(ac) + '</th><th>' + esc(lb) + '</th>';
        }).join('');
        var body = rows.map(function(r) {
            var ov  = r.overallResult || '';
            var cls = ov === 'AGREE' ? 'agree' : ov === 'DISAGREE' ? 'disagree' : 'missing';
            var badge = ov === 'AGREE' ? '<span class="r40-agree">&#10003; AGREE</span>'
                : (ov === 'DISAGREE' ? '<span class="r40-exc">&#x2717; DISAGREE</span>'
                : '<span class="r40-miss">? ' + esc(ov) + '</span>');
            var cells = pairs.map(function(p) {
                var lb  = p.label || p.Label || p.valpacCol || '';
                var fMap = r.fields || {};
                var f    = fMap[lb] || {};
                // try case-insensitive lookup
                if (!f || Object.keys(f).length === 0) {
                    var lbl_lc = lb.toLowerCase();
                    Object.keys(fMap).forEach(function(k) { if (k.toLowerCase() === lbl_lc) f = fMap[k]; });
                }
                var vv = f.valpacValue != null ? f.valpacValue : (f.ValpacValue != null ? f.ValpacValue : '—');
                var av = f.asciiValue  != null ? f.asciiValue  : (f.AsciiValue  != null ? f.AsciiValue  : '—');
                var m  = f.match || f.Match || 'MISSING';
                var mi = m === 'AGREE' ? '<span style="color:#1E8449">&#10003;</span>' : m === 'DISAGREE' ? '<span style="color:#C0392B">&#x2717;</span>' : '<span style="color:#E67E22">?</span>';
                return '<td>' + esc(vv) + '</td><td class="ac">' + esc(av) + '</td><td>' + mi + '</td>';
            }).join('');
            return '<tr class="' + cls + '"><td style="font-size:.73rem;color:#777">' + (r.rowNumber || '') + '</td>' +
                '<td style="font-weight:600;font-family:monospace">' + esc(r.staffNumber || '') + '</td>' +
                cells + '<td>' + badge + '</td>' +
                '<td style="font-size:.71rem;text-align:left;max-width:200px">' + esc(r.disagreeDetail || '') + '</td></tr>';
        }).join('');
        return '<div style="overflow-x:auto"><table class="r40-tbl"><thead><tr>' +
            '<th>#</th><th>Staff No (_037)</th>' + hdrs +
            '<th>Result</th><th>Detail</th></tr></thead><tbody>' + body + '</tbody></table></div>';
    }

    /* ── Init ── */
    st.pairs = DEF_PAIRS.slice();
    renderPairs();
    applySummary(null, false);
    updateButtons();
    if (st.clientId) loadWorkspace();
})();
</script>
