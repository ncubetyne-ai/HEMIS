    function populateColumnSelect(selectEl, columns, currentValue, defaultValue) {
        if (!selectEl) return;
        const val = currentValue || selectEl.value || defaultValue;
        const allCols = [...new Set([defaultValue, ...(columns || [])])].filter(Boolean);
        selectEl.innerHTML = '';
        allCols.forEach(col => {
            const opt = document.createElement('option');
            opt.value = col;
            opt.textContent = col;
            if (col === val) opt.selected = true;
            selectEl.appendChild(opt);
        });
        if (!allCols.includes(val)) {
            const opt = document.createElement('option');
            opt.value = val;
            opt.textContent = val;
            opt.selected = true;
            selectEl.insertBefore(opt, selectEl.firstChild);
        }
    }

    async function loadColumnsForTable(tableName, selectGroups) {
        if (!tableName || !els.server?.value?.trim() || !els.database?.value) return;
        try {
            const data = await postJson(`${apiBasePath}/GetColumns`, {
                server: els.server.value.trim(),
                database: els.database.value,
                driver: els.driver?.value || 'ODBC Driver 17 for SQL Server',
                tableName
            });
            if (!data || !data.success || !Array.isArray(data.columns)) return;
            selectGroups.forEach(({ selectEl, defaultValue }) =>
                populateColumnSelect(selectEl, data.columns, null, defaultValue));
        } catch {}
    }

