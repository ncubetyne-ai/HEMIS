    function renderResults(force = false) {
        if (!state.summary) {
            els.resultsPane.innerHTML = '<div class="empty-card"><p>No Rule 20 results loaded.</p></div>';
            return;
        }

        if (!force && getActiveTab() !== 'results') {
            els.resultsPane.innerHTML = `
                <div class="empty-card">
                    <p>Open the Results tab to load the browser preview.</p>
                </div>`;
            return;
        }

        const filteredRows = getFilteredRows();
        const visibleRows = filteredRows.slice(0, browserResultsRenderLimit);
        const isBrowserTrimmed = filteredRows.length > visibleRows.length;
        const linkageText = state.summary?.tableLinkageText || '';
        const previewNotice = state.summary.isPreviewOnly
            ? `Saved browser preview is already limited for performance. Loaded rows: ${formatNumber(state.summary.displayedCount || state.summary.reviewRows?.length || 0)} of ${formatNumber(state.summary.totalValidated)} validated row(s).`
            : isBrowserTrimmed
                ? `Browser rendering is capped at ${formatNumber(browserResultsRenderLimit)} row(s) per filter to keep the page responsive.`
                : '';

        els.resultsPane.innerHTML = `
            <div class="card" style="padding:20px">
                <div class="form-grid" style="margin-bottom:16px">
                    <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Tables</div><div>STUD: ${escapeHtml(state.summary.studTable)} | CRED: ${escapeHtml(state.summary.cregTable)} | CRSE: ${escapeHtml(state.summary.crseTable)}</div></div>
